<!-- PRIVACY OVERLAY -->
<div class="priv-overlay" id="priv-overlay">
  <div class="priv-page">
    <div class="priv-back" onclick="closePrivacy()">← <span id="priv-back">Tilbake</span></div>
    <h1 id="priv-h1">Personvernerklæring</h1>
    <div class="priv-updated" id="priv-updated">Sist oppdatert: mars 2026</div>
    <div class="priv-intro" id="priv-intro">Hverdagsverktøy er en gratis finanskalkulator som kjører helt og holdent i nettleseren din. Vi tar personvernet ditt på alvor — og den enkleste måten å beskytte det på er å aldri samle inn data i utgangspunktet.</div>

    <div class="priv-section">
      <h2 id="priv-h-nodata">Ingen datainnsamling</h2>
      <p id="priv-p-nodata">Vi samler ikke inn, lagrer eller sender noen form for personopplysninger. Alle beregninger skjer lokalt i nettleseren din. Ingen data forlater enheten din.</p>
    </div>
    <div class="priv-section">
      <h2 id="priv-h-cookies">Ingen informasjonskapsler (cookies)</h2>
      <p id="priv-p-cookies">Denne nettsiden bruker ingen cookies — verken til analyse, sporing eller reklame. Det finnes ingen cookie-banner fordi det ikke finnes noen cookies.</p>
    </div>
    <div class="priv-section">
      <h2 id="priv-h-thirdparty">Ingen tredjepartstjenester</h2>
      <p id="priv-p-thirdparty">Vi bruker ingen analysetjenester (Google Analytics, Facebook Pixel e.l.), ingen annonseringsnettverk og ingen sporing av noe slag. Eneste eksterne ressurs er Bunny Fonts for skrifttyper.</p>
    </div>
    <div class="priv-section">
      <h2 id="priv-h-storage">Ingen lokal lagring</h2>
      <p id="priv-p-storage">Kalkulatoren bruker ikke localStorage, sessionStorage eller andre mekanismer for å lagre data på enheten din. Når du lukker fanen, er alt borte.</p>
    </div>
    <div class="priv-section">
      <h2 id="priv-h-children">Barn</h2>
      <p id="priv-p-children">Siden vi ikke samler inn noen data, er tjenesten trygg å bruke for alle aldersgrupper.</p>
    </div>
    <div class="priv-section">
      <h2 id="priv-h-changes">Endringer</h2>
      <p id="priv-p-changes">Dersom vi endrer denne erklæringen, oppdaterer vi datoen øverst. Siden vi ikke samler inn data, forventer vi ingen vesentlige endringer.</p>
    </div>
    <div class="priv-contact">
      <h2 id="priv-h-contact">Kontakt</h2>
      <p id="priv-p-contact">Har du spørsmål om personvern? Send en e-post til kontakt@hverdagsverktoy.com.</p>
    </div>
  </div>
</div>

<!-- CONTACT OVERLAY -->
<div class="contact-overlay" id="contact-overlay">
  <div class="contact-page">
    <div class="priv-back" onclick="closeContact()">← <span id="con-back">Tilbake</span></div>
    <h1 id="con-h1">Kontakt oss</h1>
    <div class="contact-sub" id="con-sub">Har du spørsmål, tilbakemeldinger eller forslag? Vi hører gjerne fra deg.</div>

    <form class="contact-form" id="contact-form" onsubmit="submitContact(event)">
      <div class="contact-fg">
        <label id="con-l-name">Navn</label>
        <input type="text" id="con-name" required>
      </div>
      <div class="contact-fg">
        <label id="con-l-email">E-post</label>
        <input type="email" id="con-email" required>
      </div>
      <div class="contact-fg">
        <label id="con-l-subject">Emne</label>
        <select id="con-subject">
          <option value="general" id="con-opt-general">Generell henvendelse</option>
          <option value="bug" id="con-opt-bug">Feilrapport</option>
          <option value="feature" id="con-opt-feature">Forslag til forbedring</option>
          <option value="other" id="con-opt-other">Annet</option>
        </select>
      </div>
      <div class="contact-fg">
        <label id="con-l-message">Melding</label>
        <textarea id="con-message" required></textarea>
      </div>
      <button type="submit" class="contact-btn" id="con-btn">Send melding →</button>
    </form>

    <div class="contact-success" id="con-success">
      <div class="check">✓</div>
      <h2 id="con-success-h">Takk for meldingen!</h2>
      <p id="con-success-p">E-postklienten din åpnes med meldingen ferdig utfylt. Trykk «Send» i e-postklienten for å fullføre.</p>
    </div>

    <div class="contact-alt">
      <h2 id="con-alt-h">Direkte kontakt</h2>
      <p id="con-alt-p">Du kan også sende e-post direkte til <a href="mailto:kontakt@hverdagsverktoy.com">kontakt@hverdagsverktoy.com</a></p>
    </div>
  </div>
</div>

<script>
// ═══════════════════════════════════════════════════════
// REGION DATA (simplified — no accounting standards)
// ═══════════════════════════════════════════════════════
const REGIONS = {
  en: {
    flag:'🇬🇧', name:'English',
    lang:'en',    currency:'kr', currencyCode:'NOK',
    salDefaults: { gross: 800000 },
    salClasses: [['1','Class 1 (Standard)'],['2','Class 2 (Married w/low income)'],['self','Self-employed']],
    salRegions: [['0.22','Standard (nationwide)'],['0.185','Finnmark / Northern Troms (incentive zone)']],
    salInfoRows: [['Personal allowance (Personfradrag)','114 540 kr'],['Minimum deduction (Minstefradrag, max)','95 700 kr'],['Bracket tax 1 (226k+)','1.7%'],['Bracket tax 2 (318k+)','4.0%'],['Bracket tax 3 (725k+)','13.7%'],['Bracket tax 4 (980k+)','16.8%'],['Bracket tax 5 (1 467k+)','17.8%'],['National insurance contribution (Trygdeavgift)','7.6%'],['Ordinary tax (Alminnelig skatt)','22%']],
    salLawRows: [['— MAIN RULE (§ 5-1) —',''],['Taxable income','Any benefit derived from employment, capital or business activity','Everything you earn from work, investments or business is taxable'],['Also taxable','Pensions, annuities, life annuities'],['Gain on disposal (§ 5-1(2))','Taxable (see ch. 9)','If you sell something at a profit you must pay tax on the gain'],['Withdrawal for personal use (§ 5-2)','Taxable at market value','Taking goods from your own business for personal use counts as income'],['— EMPLOYMENT INCOME (§ 5-10) —',''],['Salary, fees, holiday pay','Taxable'],['Board fees, bonuses, tips','Taxable'],['Unemployment benefits, sick pay, parental benefits','Taxable','Public benefits replacing salary are taxed as salary'],['Severance / termination pay (§ 5-10 d)','Taxable'],['Benefits in kind (§ 5-12)','Taxable at market value','Non-cash benefits from your employer — e.g. phone, newspaper, insurance'],['Low-interest employee loans (§ 5-12(4))','Benefit = benchmark rate − actual rate','If you get a loan from your employer below market rate, the difference is taxed'],['Company car (§ 5-13)','30% of list price (20% above threshold)','If you have a company car you are taxed on a share of its original list price'],['Car >3 years','75% of list price'],['Employee stock options (§ 5-14)','Taxable on exercise/sale','Taxed when you exercise or sell the option, not when you receive it'],['Start-up options (§ 5-14(2))','Not employment income (special rules)','More favourable rules for employees in small companies under 6 years old'],['— CAPITAL INCOME (§ 5-20) —',''],['Returns from real property/chattels','Taxable','Rental income from letting property, cabins or chattels'],['Returns from financial assets','Taxable','Interest, dividends and gains from shares, funds, bank deposits'],['Free use of others\' property','Taxable','Using a free residence or similar counts as income'],['Loans from own company (§ 5-22)','Extra tax, grossed up ×1.72','Loans from your own limited company are treated as dividends and taxed accordingly'],['— TAX-EXEMPT (§ 5-15/5-43) —',''],['Child benefit (Barnetrygd)','Tax-exempt'],['Cash-for-care benefit (Kontantstøtte)','Tax-exempt'],['Social assistance','Tax-exempt'],['Basic/attendance allowance','Tax-exempt'],['Funeral grant','Tax-exempt'],['Compensation for injury/suffering','Tax-exempt'],['Child maintenance (Barnebidrag)','Tax-exempt'],['Gambling winnings (Norsk Tipping etc.)','Tax-exempt','Winnings from Norsk Tipping, Rikstoto and similar are tax-exempt'],['Casual prizes (§ 5-50)','Taxable above 10 000 kr','Prizes from private competitions, lotteries etc.'],['Consumer goods (§ 5-21)','Tax-exempt on own-use sale','Selling used personal items (furniture, clothes, car) is tax-free']],
    salDedRows: [['— MAIN RULE (§ 6-1) —',''],['Right to deduction','Expenses incurred to earn, maintain or secure taxable income','You can deduct costs that are necessary to earn income'],['No deduction','Private costs (housing, food, personal expenses)','Personal living costs can never be deducted'],['Loss on disposal (§ 6-2)','Deductible under ch. 9 rules','If you sell something at a loss you can deduct it from your taxes'],['Loss on receivables (§ 6-2(2))','Deductible when finally confirmed lost in business','Someone owes your business money and cannot pay'],['Deficit (§ 6-3)','Offset against other income, carried forward (§ 14-6)','If the business runs at a loss you can use it against other income — or carry it forward to future years'],['— MINIMUM DEDUCTION (§ 6-30/32) —',''],['Employment income','46% of salary, max 95 700 kr','All employees receive this automatically — covers commuting, clothing, tools etc.'],['Pension income','40% of pension'],['Replaces','Most work-related expense deductions','You do not need to document individual expenses when using the minimum deduction'],['Not included','Union dues, commuter expenses','These can be deducted in addition to the minimum deduction'],['— STANDARD DEDUCTIONS —',''],['Union dues (§ 6-20)','Max 8 700 kr','Membership in unions such as LO, YS, Unio, Akademikerne'],['Home–work travel (§ 6-44)','Above 12 000 kr, max 120 000 kr','Deduction for commuting distance over 37 km one way (after threshold)'],['Childcare deduction (§ 6-48)','Children under 12, amount set by Parliament','Covers expenses for kindergarten, after-school care and childminding'],['Charitable donations (§ 6-50)','Min 500 kr, max 25 000 kr','Donations to approved organisations such as Red Cross, Doctors Without Borders'],['Child pension deduction (§ 6-49)','Up to 32 600 kr'],['— INTEREST ON DEBT (§ 6-40) —',''],['Interest on debt','Full deduction (22% tax effect)','All interest you pay — mortgage, student loan, car loan — gives 22% back on tax'],['Interest limitation for groups (§ 6-41)','25% of EBITDA, threshold 25M (group) / 5M (outside)','Limits interest deductions on loans between companies in the same group'],['Carried forward denied interest','10 years','Interest not allowed this year can be used over the next 10 years'],['— BUSINESS DEDUCTIONS —',''],['Depreciation (§ 6-10)','Wear/age of business assets, goodwill on purchase','Spreads the cost of machinery, vehicles etc. over several years'],['Maintenance/insurance (§ 6-11)','Deductible for business assets'],['Research and development (§ 6-25)','Part of cost price for business asset','Development costs can be capitalised and depreciated over time'],['Start-up company investment (§ 6-53)','Up to 1M kr, company ≤6 years, ≥3 years holding','Individuals investing in small newly established companies receive a deduction'],['— NO DEDUCTION —',''],['Entertainment (§ 6-21)','Never deductible','Client dinners, gifts to business associates etc.'],['Bribery (§ 6-22)','Never deductible'],['Association dues (§ 6-18)','Generally not deductible (exceptions § 6-19/20)','Exceptions for industry and professional associations'],['— PAYMENT VIA BANK (§ 6-51) —',''],['Requirement','Payments ≥10 000 kr must go through bank for deduction','Cash payments over 10 000 kr do not qualify for deduction'],['— OCCUPATIONAL DEDUCTIONS —',''],['Fisher\'s deduction (§ 6-60)','30%, max 160 000 kr, ≥130 days','Requires at least 130 days of fishing in the income year'],['Seafarer\'s deduction (§ 6-61)','30%, max 86 300 kr, ≥130 days','Requires at least 130 days at sea in the income year']],
    salRealRows: [['— WHEN HAVE YOU REALISED A GAIN? —','Main rule in § 9-1 and § 9-2'],['What triggers capital gains tax?','Sale, exchange, redemption of shares, expropriation, destruction — any transfer of ownership for consideration','§ 9-2(1)'],['Giving away something?','Gift is not a realisation — no tax for the giver','§ 9-2(3)'],['Inheritance?','Not a realisation — no capital gains tax on inheritance','§ 9-2(3)'],['Transfer between spouses?','Not a realisation — also not in separation/divorce','§ 9-2(3)'],['What about compulsory redemption?','Counts as realisation — tax liability is triggered','§ 9-2(1)'],['— TAX EXEMPTION ON HOUSING —','§ 9-3: When do you avoid capital gains tax?'],['Sold own home?','Tax-free if you have owned it for at least 1 year and lived there in at least 1 of the last 2 years','§ 9-3(2)'],['Sold holiday home?','Tax-free if you have owned it for at least 5 years and used it in at least 5 of the last 8 years','§ 9-3(4)'],['Sold household goods and chattels?','Tax-free — personal belongings','§ 9-3(1)a'],['Gain on land?','Tax-free only if the land is insignificant — otherwise taxed as land sale even though the house is exempt','§ 9-3(8): Land exemption'],['Loss on housing that would have been exempt?','No deduction — symmetry principle: exempt gain = no deduction for loss','§ 9-4'],['— LOSSES GIVE DEDUCTIONS —','§ 9-4: Symmetry principle'],['Sold something at a loss?','Deduction to the same extent that a corresponding gain would have been taxable','§ 9-4(1)'],['Sold shares at a loss?','Full deduction — grossed up ×1.72 like gain','§ 9-4, § 10-31'],['— COST BASIS ON INHERITANCE AND GIFTS —','§ 9-7: Continuity principle'],['Did you inherit something?','You step into the decedent\'s cost basis — not market value at time of inheritance','§ 9-7(1)'],['Received a gift?','Same principle — donor\'s cost basis is taken over','§ 9-7(1)'],['Exception if decedent could have sold tax-free?','If the decedent could have sold it tax-free (home), cost basis is set to market value','§ 9-7(2)'],['— TRANSFER OUT OF NORWAY —','§ 9-14: Exit tax on assets'],['Moving assets out of Norway?','Latent gain is taxed as if the asset had been sold at market value','§ 9-14(1)'],['Does it apply to intangible rights?','Yes — patents, licenses, trademarks etc.','§ 9-14(2)'],['Can the tax be deferred?','Yes, within the EEA — but security may be required','§ 9-14(4)']],
    salCorpRows: [['— GROUP CONTRIBUTIONS (§ 10-2 to 10-5) —',''],['Group contribution (§ 10-2)','Deductible for giver, taxable for recipient','Transfer between companies in the same group — used to even out results'],['Ownership requirement (§ 10-4)','Parent must own >90% of shares and votes','Applies to limited companies and equivalent foreign companies in EEA'],['— DIVIDENDS AND SHIELDING (§ 10-10 to 10-13) —',''],['Dividends (§ 10-11)','Taxable for individual shareholders','Grossed up by factor 1.72 before taxation at 22%'],['Shielding deduction (§ 10-12)','Deducted from dividend before tax','You are not taxed on the portion of the dividend corresponding to the risk-free return'],['Shielding rate','Treasury bills after tax','Set annually by the Tax Directorate'],['Participation exemption (§ 2-38)','Tax-exempt for companies','A limited company owning shares in another is exempt from tax on dividends and gains'],['3% rule (§ 2-38(6))','3% of the income is recognised','Companies still pay 0.66% (3% × 22%) on exempt dividends'],['— SHARE GAINS AND LOSSES (§ 10-30 to 10-37) —',''],['Gain on sale (§ 10-31)','Taxable for individual shareholders','Grossed up by factor 1.72, i.e. effective tax approx. 37.84%'],['Loss on sale (§ 10-31(2))','Deductible','Grossed up correspondingly by factor 1.72'],['Cost price (§ 10-32)','Purchase price + unused shielding','What you paid for the share plus any accumulated shielding deduction'],['FIFO principle (§ 10-36)','First bought = first sold','When selling part of a shareholding the oldest shares are deemed sold first'],['— SECURITIES FUNDS AND ASK (§ 10-20/10-21) —',''],['Securities funds (§ 10-20)','Equity and interest portions taxed differently','Equity portion = shareholder model, interest portion = ordinary income'],['Share savings account / ASK (§ 10-21)','Tax deferred until withdrawal','You can buy and sell shares/funds within the account without triggering tax'],['Taxable withdrawal (§ 10-21(4))','Withdrawals exceeding deposits are taxable','You pay tax only when you withdraw more than you have deposited'],['— PARTNER TAXATION ANS/KS (§ 10-40 to 10-49) —',''],['Net method (§ 10-41)','Profit taxed at partner level','Each partner is taxed on their share of the partnership\'s result'],['Distribution (§ 10-42)','Taxable for individual partners','Grossed up by factor 1.72 like dividends'],['Gain on sale of interest (§ 10-44)','Taxable','Calculated from cost price with adjustments for over-/under-pricing'],['— COOPERATIVE ENTERPRISES (§ 10-50) —',''],['Patronage refunds (§ 10-50)','Deductible for the cooperative','Repayment to members based on turnover with the enterprise'],['— CFC / LOW-TAX COUNTRIES (§ 10-60 to 10-68) —',''],['CFC rules (§ 10-60)','Norwegian owner taxed on current basis','Applies to companies in low-tax countries controlled by Norwegian owners'],['Low-tax country (§ 10-63)','Tax below 2/3 of Norwegian tax','The country is deemed low-tax if effective tax is below approx. 14.67%'],['Control requirement (§ 10-62)','Norwegian owners hold at least 50%','Control is assessed collectively for all Norwegian taxpayers'],['Credit deduction (§ 10-65)','Deduction for foreign tax paid','Avoids double taxation by deducting tax paid abroad'],['— EXIT TAX (§ 10-70/10-71) —',''],['Latent gains (§ 10-70)','Taxable upon emigration from Norway','Applies to shares, interests and certain other assets'],['Deferral (§ 10-70(7))','Can be deferred within EEA','Payment is deferred, but security may be required'],['Lapse (§ 10-70(9))','Tax lapses after 5 years','If you have not disposed of the asset within 5 years the tax is cancelled'],['— WITHHOLDING TAX (§ 10-80 to 10-82) —',''],['Withholding tax on dividends','15–25% for foreign shareholders','Rate depends on tax treaty with shareholder\'s home country'],['Withholding tax on interest/royalties (§ 10-80)','Per rules set by law','Applies to payments to related parties in low-tax countries']],
    salReorgRows: [['— MERGER (§ 11-2/11-3) —',''],['Limited companies (§ 11-2)','Tax-free when the merger follows the Companies Act ch. 13','Two or more limited companies merge without anyone paying tax'],['Cooperative enterprises (§ 11-2(2))','Tax-free under the Cooperatives Act ch. 8'],['Partnerships (§ 11-3)','Tax-free if same company type and liability form','Partners must receive interests as consideration (max 20% additional cash)'],['— DEMERGER (§ 11-4/11-5) —',''],['Limited companies (§ 11-4)','Tax-free when the demerger follows the Companies Act ch. 14','A company is split into two or more without tax'],['Partnerships (§ 11-5)','Tax-free if same company type and liability form','Max 20% of the consideration may be other than interests'],['— CONDITIONS AND PRINCIPLES —',''],['Other consideration (§ 11-6)','Cash consideration to shareholder is taxable','Only shares/interests in the merging companies are tax-free'],['Continuity (§ 11-7)','Tax values and acquisition dates are continued','The receiving company takes over all tax positions unchanged'],['Allocation on demerger (§ 11-8)','Tax positions allocated by net values'],['Dissolution (§ 11-9)','Transferring company must be dissolved after transfer'],['Effective date (§ 11-10)','From corporate-law effective date'],['— CROSS-BORDER (§ 11-11) —',''],['Cross-border merger/demerger','Tax-free within EEA with continuity','A Norwegian limited company can merge with a company in another EEA state'],['Share exchange (§ 11-11(4))','Tax-free on transfer of at least 90% of shares','Max 20% cash consideration'],['Low-tax country (§ 11-11(7))','Tax exemption does not apply to low-tax countries','Exception if genuinely established in an EEA state'],['— CONVERSION (§ 11-20) —',''],['To limited company','Sole proprietorships, partnerships etc. can be converted tax-free','Tax values and positions are continued'],['Intra-group transfer (§ 11-21)','Tax-free transfer between companies in the same group','Parent must own more than 90% of shares'],['Rationalisation (§ 11-22)','Ministry may grant tax exemption on reorganisation','Applies to sale of property, business or shares']],
    salSubjRows: [['— INDIVIDUAL TAXPAYER (§ 2-1) —',''],['Resident in Norway (§ 2-1(1))','Taxable on all income/wealth, in Norway and abroad','If you live in Norway you are taxed on everything — regardless of where the income originates'],['Residence established (§ 2-1(2))','Stay >183 days in 12 months, or >270 days in 36 months','If you stay in Norway long enough you become a tax resident'],['Residence ceases (§ 2-1(3))','Requires permanent residence abroad + giving up dwelling in Norway','You must live permanently abroad and no longer have a dwelling in Norway'],['Temporary absence (§ 2-1(4))','Does not interrupt tax residence','Holidays or short stays abroad do not change your residence'],['Svalbard (§ 2-1(5))','Separate rules (Svalbard Tax Act)'],['— ESTATE (§ 2-2) —',''],['Estate (§ 2-2)','Separate tax subject in the year of death and onwards','The estate is taxed as a separate entity until it is settled'],['Distribution in year of death (§ 2-15)','Heirs take over from 1 January','If the estate is distributed in the year of death, the heirs are taxed for the whole year'],['— COMPANIES (§ 2-2) —',''],['Limited company (§ 2-2(1)a)','Separate tax subject','A limited company is an independent taxpayer — taxed at 22% on profit'],['Public limited company (§ 2-2(1)b)','Separate tax subject'],['Savings bank, mutual insurance (§ 2-2(1)c-d)','Separate tax subject'],['Cooperative enterprise (§ 2-2(1)e)','Separate tax subject'],['State enterprise, health enterprise (§ 2-2(1)g-h)','Separate tax subject'],['Foundations (§ 2-2(1)f)','Separate tax subject'],['Municipal enterprise (§ 2-2(1)i)','Separate tax subject'],['— LIMITED TAX LIABILITY (§ 2-3) —',''],['Income from real property in Norway (§ 2-3(1)a)','Taxable','Foreigners owning property in Norway are taxed on the income from it'],['Business in Norway (§ 2-3(1)b)','Taxable','If you carry on business from Norway you are taxed here'],['Work in Norway (§ 2-3(1)d)','Taxable','If you work in Norway you are taxed on your salary — foreigners too'],['Dividend from Norwegian company (§ 2-3(1)c)','Withholding tax','Foreign shareholders pay withholding tax on dividends from Norwegian companies'],['Board remuneration (§ 2-3(1)e)','Taxable','If you sit on the board of a Norwegian company you are taxed on the fee'],['Pension from Norway (§ 2-3(4))','Taxable (withholding tax)','Also for persons resident abroad'],['Artist tax (§ 2-3(1)h)','Taxable for foreign artists','Special rules for taxation of concerts, performances, etc.'],['— EXEMPTION METHOD (§ 2-38) —',''],['Tax-free for companies (§ 2-38(1))','Dividends and gains between companies are tax-free','A limited company owning shares in another normally pays no tax on dividends and gains'],['3% rule (§ 2-38(6))','3% of the income is nevertheless taxed','The company effectively pays 0.66% (3% × 22%) on exempt dividends'],['Low-tax country exception (§ 2-38(3))','Exemption does not apply to companies in low-tax countries','Companies in countries with very low tax fall outside the exemption method'],['EEA portfolio exception (§ 2-38(3)b)','Exemption does not apply below 10% ownership outside the EEA','If you own less than 10% of a company outside the EEA the exemption method does not apply'],['— SPOUSES (§ 2-10 to 2-16) —',''],['Joint or separate (§ 2-10)','Spouses may be taxed jointly or separately','You can choose whether income is combined or taxed separately'],['Allocation (§ 2-11)','Income/deductions are attributed to the spouse to whom they belong'],['Class 2 (§ 2-14)','Supporting spouse with low income','Gives lower tax if one spouse has little or no income'],['Joint dwelling (§ 2-12)','Shared taxation of joint dwelling'],['— CHILDREN (§ 2-14) —',''],['Children under 17 (§ 2-14(1))','Children\'s income is taxed on the parents','Capital income of children under 17 is taxed on the parents'],['Children\'s employment income (§ 2-14(3))','Taxed on the child','Wages earned by the child are taxed separately'],['Children\'s wealth (§ 2-14(5))','Divided equally between the parents'],['— TAX-EXEMPT INSTITUTIONS (§ 2-30 to 2-32) —',''],['The State (§ 2-30(1)a)','Tax-exempt'],['Counties/municipalities (§ 2-30(1)b-c)','Tax-exempt'],['Religious communities (§ 2-30(1)d)','Tax-exempt'],['Non-commercial institutions (§ 2-32)','Tax-exempt as long as income is not commercial','Associations, clubs and foundations not operating for profit are tax-exempt'],['Commercial activity (§ 2-32(2))','Taxable above 140 000 kr / 70 000 kr','If income from sales, rental, etc. exceeds the threshold, tax must be paid'],['— COMPANY RESIDENCE RULES (§ 2-2(6)) —',''],['Registered in Norway','Always a Norwegian tax subject','Companies registered in the Norwegian business register are taxable in Norway'],['Incorporated in Norway (§ 2-2(7))','Always a Norwegian tax subject'],['Management in Norway (§ 2-2(6))','May become a Norwegian tax subject','A foreign company effectively managed from Norway may be taxed here'],['— COMPANY IMMIGRATION/EMIGRATION (§ 2-2(8)) —',''],['Immigration (§ 2-2(8))','Full tax liability from establishment in Norway'],['Emigration (§ 2-2(8))','Settlement of latent gains','The company must settle tax positions when emigrating from Norway'],['— INTERNATIONAL (§ 2-37/2-38) —',''],['Tax credit (§ 2-37)','Deduction for tax paid abroad','Avoids double taxation — foreign tax is deducted from the Norwegian return'],['Tax treaties','May limit Norway\'s right to tax','Norway has treaties with many countries allocating taxing rights']],
    morReqRows: [['Max loan','Total debt max 5× gross annual income','All debt counts — mortgage, student loan, car loan, credit card'],['Equity','At least 10%','You must have saved at least 10% of the property price yourself'],['Stress test','Higher of 7% and rate + 3 pp','The bank checks that you can afford payments even if rates rise'],['Repayment','Min. 2.5% per year above 60% LTV','If you have borrowed more than 60% of the property value you must repay principal'],['Flexibility quota','Bank can deviate for 10% of loans','In Oslo: max 8% — means the bank can say yes even if you don\'t meet all requirements']],
    morCostRows: [['Interest rate now','Approx. 5.1% variable (Jan 2026)'],['Tax deduction on interest','22% of interest costs','You get back 22% of the interest you pay on your tax return'],['Document duty','2.5% of market value','Paid when purchasing real property — exceptions for new builds and housing co-ops']],
    morBsuRows: [['Max savings per year','27 500 kr'],['Max total amount','300 000 kr'],['Tax deduction','10% of amount saved — up to 2 750 kr/year'],['Age limit','Up to and including the year you turn 33'],['Requirement for tax deduction','You must have taxable employment income and not own a home'],['What can the money be used for?','Purchase, repayment, improvement or maintenance of own home'],['Breach of terms?','If you use the money for something other than housing you must repay all tax deductions']],
    morBsuTitle:'BSU — Home Savings for Youth', morBsuDesc:'Tax deduction, savings limits, age limit, usage terms',
    morReqTitle:'Mortgage Requirements', morReqDesc:'Equity, debt ratio, stress test, repayment',
    morCostTitle:'Costs of Buying a Home', morCostDesc:'Interest, tax deduction, document duty',
    npvInfoRows: [['— GLOSSARY —',''],['NPV (Net Present Value)','Present value of future cash flows minus investment'],['IRR (Internal Rate of Return)','The rate that gives NPV = 0'],['WACC','Weighted average cost of capital'],['— INTERPRETATION —',''],['NPV > 0','Profitable – accept investment'],['NPV < 0','Unprofitable – reject'],['IRR > WACC','Value-creating project'],['IRR < WACC','Value-destroying project'],['— REFERENCE —',''],['Discount rate','Usually WACC (pre-tax)'],['Typical WACC','8–12%'],['Payback period','Shorter is better']],
    vatSubjRows: [['— BASIC CONDITIONS —','Three things must be met for VAT liability'],['1. Business activity','You must carry on a business — not a hobby or employment','§ 2-1(1)'],['2. Supply of goods/services','There must be a transaction — delivery for consideration (payment)','§ 1-3(1)a'],['3. Turnover threshold','Turnover exceeding 50 000 kr within 12 months','§ 2-1(1)'],['— WHO MUST REGISTER? —',''],['Businesses above 50 000 kr','Must register in the VAT Register','§ 2-1(1)'],['Charities','Higher threshold: 140 000 kr','§ 2-1(1)'],['Sports events','Separate threshold: 3 000 000 kr','§ 2-1(1)'],['— KEY CONCEPTS —',''],['What is "business activity"?','Independent, lasting activity of an economic character and capable of generating profit. Hobbies and one-off assignments are normally not business.'],['What is "turnover"?','Supply of goods or services for consideration. Gifts, compensation and grants are normally not turnover.','§ 1-3(1)a'],['What is a "taxable person"?','An entity registered (or required to register) in the VAT Register, obliged to calculate and pay VAT.','§ 1-3(1)d'],['Voluntary registration?','Landlords of commercial property may register voluntarily to obtain input VAT deductions.','§ 2-3']],
    vatSubjTitle:'Who is liable for VAT?', vatSubjDesc:'Business activity, turnover threshold, registration',
    vatRates: [['25','25% Standard – goods and services (§ 5-1)'],['15','15% Foodstuffs (§ 5-2)'],['12','12% Transport, hotels, cinema (§ 5-3/5-5/5-6)'],['0','0% Exempt – newspapers, books, exports (ch. 6)']],
    vatInfoRows: [['— RATES —',''],['Standard rate (§ 5-1)','25%'],['Foodstuffs (§ 5-2)','15%'],['Passenger transport (§ 5-3)','12%'],['Hotel accommodation (§ 5-5)','12%'],['Cinema (§ 5-6)','12%'],['Museums/galleries (§ 5-9)','12%'],['Amusement parks (§ 5-10)','12%'],['Sports events (§ 5-11)','12%'],['Water/sewage (§ 5-12)','12%'],['Catering (§ 5-2)','25% (not 15%)'],['— REGISTRATION —',''],['Businesses (§ 2-1)','50 000 kr / 12 months'],['Charities (§ 2-1)','140 000 kr / 12 months'],['Sports events (§ 2-1)','3 000 000 kr'],['— TERRITORY —',''],['Geographic (§ 1-2)','Norwegian mainland + territorial border'],['Not VAT territory','Svalbard, Jan Mayen, dependencies']],
    vatLawRows: [['— EXEMPT (ch. 3) —','Outside the Act, no right to deduct input VAT'],['Health services (§ 3-2)','Exempt','Doctor, dentist, physiotherapy etc. — no VAT and no input deduction'],['Social services (§ 3-4)','Exempt','Child welfare, elderly care, substance abuse care etc.'],['Education (§ 3-5)','Exempt','Schools, courses, training — both public and private'],['Financial services (§ 3-6)','Exempt','Banking, insurance, securities trading — no VAT'],['Arts/culture – performance (§ 3-7)','Exempt','Concerts, theatre, dance — tickets are VAT-free'],['Sports – right to participate (§ 3-8)','Exempt','Gym, football pitch, swimming pool etc.'],['Public authority exercise (§ 3-9)','Exempt'],['Real property/letting (§ 3-11)','Exempt (exception in (2))','Letting of residential and commercial property is exempt — but voluntary registration is possible for commercial'],['Charities (§ 3-12)','Exempt (certain sales)','Flea markets, bazaars etc. from charitable organisations'],['Non-profit membership fees (§ 3-13)','Exempt'],['Gambling (§ 3-14)','Exempt'],['Funeral – ceremony (§ 3-15)','Exempt'],['Board fees (§ 3-17)','Exempt (subject to employer NI)','Board fees are exempt from VAT but employer national insurance contributions apply'],['Privately used goods (§ 3-19)','Exempt','Private individuals selling used items do not need to charge VAT'],['— ZERO-RATED (ch. 6) —','Covered by the Act, 0% output VAT, right to deduct input VAT'],['Newspapers (§ 6-1)','Zero-rated'],['Periodicals (§ 6-3)','Zero-rated (final paragraph)'],['Books (§ 6-4)','Zero-rated (final paragraph)'],['Household electricity Northern Norway (§ 6-6)','Zero-rated'],['Electric vehicles ≤300 000 kr (§ 6-8)','Zero-rated','Applies only to purchase amount up to 300 000 kr — above this 25% VAT is charged'],['Vessels ≥15m (§ 6-9)','Zero-rated'],['Aircraft for business (§ 6-10)','Zero-rated'],['Transfer of business (§ 6-14)','Zero-rated','When an entire business is sold as a going concern, VAT history transfers — no VAT on the sale'],['Export of goods (§ 6-21)','Zero-rated','Export abroad — 0% VAT but full input deduction'],['Export of services (§ 6-22)','Zero-rated'],['Transport to/from abroad (§ 6-28)','Zero-rated'],['— DEEMED SUPPLY (ch. 3 part II) —',''],['Withdrawal of goods (§ 3-21)','VAT applies','Taking goods from the business for personal use requires VAT calculation'],['Withdrawal of services for personal use (§ 3-22)','VAT applies'],['Meals/produce/entertainment (§ 3-23)','VAT applies'],['— IMPORTS (ch. 3 part III) —',''],['Imported goods (§ 3-29)','VAT applies','Import of goods — VAT is calculated at customs clearance'],['Remotely deliverable services (§ 3-30)','Reverse charge','If you buy digital services from abroad you calculate the VAT yourself']],
    vatDefRows: [['Turnover (a)','Supply of goods/services for consideration','If you exchange something for money it is turnover'],['Goods (b)','Physical objects, real property, electricity, water, gas, heating, cooling'],['Services (c)','Anything that can be traded and is not goods','Consulting, hairdressing, transport, repairs etc.'],['Taxable person (d)','Registered/required to register in the VAT Register','Businesses with turnover above 50 000 kr in 12 months'],['Output VAT (e)','Calculated and paid on turnover and withdrawals','VAT you add to the price and collect from the customer'],['Input VAT (f)','Incurred on purchases or imports','VAT you pay when you buy goods/services for the business'],['Exemption from the Act (g)','Turnover not covered by the Act → no input deduction','The business cannot deduct VAT on purchases related to exempt turnover'],['Zero-rating (h)','Covered by the Act, but 0% output VAT → full input deduction','Exports are zero-rated — you do not add VAT but can deduct input VAT'],['Remotely deliverable services (i)','Not tied to a specific physical location','IT services, online consulting, streaming etc.'],['Electronic services (j)','Remotely deliverable, provided over the internet, automated','Apps, e-books, streaming services, online courses']],
    vatDedRows: [['Main rule (§ 8-1)','Deduction for input VAT used in registered business','You get back VAT on everything you buy for use in the business'],['Mixed use (§ 8-2)','Proportional deduction based on estimated use','If something is used 60% for business and 40% privately, you get 60% deduction'],['No deduction: catering (§ 8-3 a)','','Food and drink for employees, clients etc.'],['No deduction: entertainment (§ 8-3 e)','','Client dinners, events for business associates'],['No deduction: gifts (§ 8-3 f)','Not of trivial value','Gifts above the trivial threshold do not qualify for deduction'],['No deduction: housing/welfare (§ 8-3 g)','Exception: staff canteens'],['Passenger vehicles (§ 8-4)','No deduction (exceptions: leasing, taxi, resale)','Company car does not give VAT deduction unless used for leasing or passenger transport'],['Payment via bank (§ 8-8)','Required for ≥10 000 kr','Cash payments over 10 000 kr do not give VAT deduction']],
    vatAdjRows: [['Capital asset – business assets (§ 9-1 a)','Input VAT ≥50 000 kr','Machinery, vehicles etc. with VAT above 50 000 kr'],['Capital asset – real property (§ 9-1 b)','Input VAT ≥100 000 kr','Buildings, structures etc. with VAT above 100 000 kr'],['Adjustment period – business assets (§ 9-4)','5 years','If use changes over the next 5 years the VAT deduction must be adjusted'],['Adjustment period – real property (§ 9-4)','10 years','If use changes over the next 10 years the VAT deduction must be adjusted']],
    vatCalcRows: [['Main rule (§ 4-1)','Consideration excluding VAT'],['Barter (§ 4-3)','Fair market value','In barter transactions, market price is used as the basis for VAT'],['Related parties (§ 4-4)','Not lower than fair market value','If you sell cheaply to your own company, VAT is calculated on market price'],['Loss on receivables (§ 4-7)','May correct finally lost receivable','The customer never pays — then you can reverse VAT you have remitted']],
    vatRegRows: [['Joint registration (§ 2-2)','≥85% ownership, joint liability','Group companies can be registered as one VAT entity'],['Voluntary registration – letting (§ 2-3)','Buildings/structures to VAT-registered tenant','Landlord gets VAT deduction on renovation/construction when tenant is VAT-registered'],['Pre-registration (§ 2-4)','Significant acquisitions before turnover','Newly started businesses can register before reaching 50 000 kr in turnover']],
