  },
  pl: {
    flag:'🇵🇱', name:'Polski', lang:'pl', currency:'kr', currencyCode:'NOK',
    salDefaults: { gross: 800000 },
    salClasses: [['1','Klasa 1 (Standardowa)'],['2','Klasa 2 (Małżonek z niskim dochodem)'],['self','Osoba samozatrudniona']],
    salRegions: [['0.22','Standardowa (cały kraj)'],['0.185','Finnmark / Troms Północny (strefa ulg)']],
    salInfoRows: [['Odliczenie osobiste','114 540 kr'],['Odliczenie minimalne (maks)','95 700 kr'],['Podatek progresywny 1 (226 tys.+)','1,7%'],['Podatek progresywny 2 (318 tys.+)','4,0%'],['Podatek progresywny 3 (725 tys.+)','13,7%'],['Podatek progresywny 4 (980 tys.+)','16,8%'],['Podatek progresywny 5 (1 467 tys.+)','17,8%'],['Składka na ubezpieczenie społ.','7,6%'],['Podatek dochodowy zwykły','22%']],
    salLawRows: [['— ZASADA GŁÓWNA (§ 5-1) —',''],['Dochód podlegający opodatkowaniu','Każda korzyść uzyskana z pracy, kapitału lub działalności gospodarczej','Wszystko, co zarabiasz na pracy, inwestycjach lub działalności gospodarczej, podlega opodatkowaniu'],['Również opodatkowane','Emerytury, renty, dożywotnie świadczenia'],['Zysk ze zbycia (§ 5-1(2))','Opodatkowany (zob. rozdz. 9)','Jeśli sprzedajesz coś z zyskiem, musisz zapłacić podatek od tego zysku'],['Pobranie na własny użytek (§ 5-2)','Opodatkowane wg wartości rynkowej','Jeśli bierzesz towary z własnej firmy do użytku prywatnego, liczy się to jako dochód'],['— DOCHODY Z PRACY (§ 5-10) —',''],['Wynagrodzenie, honoraria, urlop','Opodatkowane'],['Wynagrodzenie zarządu, napiwki','Opodatkowane'],['Zasiłek dla bezrobotnych, chorobowy, rodzicielski','Opodatkowane','Świadczenia publiczne zastępujące wynagrodzenie są opodatkowane jak wynagrodzenie'],['Odprawa/zwolnienie (§ 5-10 d)','Opodatkowane'],['Świadczenia rzeczowe (§ 5-12)','Opodatkowane wg wartości rynkowej','Korzyści od pracodawcy zamiast pieniędzy — np. telefon, gazeta, ubezpieczenie'],['Pożyczka na korzystnych warunkach (§ 5-12(4))','Korzyść = stopa referencyjna − faktyczna stopa','Jeśli dostajesz pożyczkę od pracodawcy poniżej rynkowej stopy, opodatkowana jest różnica'],['Samochód służbowy (§ 5-13)','30% ceny katalogowej (20% powyżej progu)','Jeśli masz samochód służbowy, jesteś opodatkowany od części ceny nowego auta'],['Samochód >3 lata','75% ceny katalogowej'],['Opcje pracownicze (§ 5-14)','Opodatkowane przy realizacji/sprzedaży','Opodatkowanie następuje, gdy korzystasz z opcji lub ją sprzedajesz, nie gdy ją otrzymujesz'],['Opcje w startupach (§ 5-14(2))','Nie stanowią dochodu z pracy (specjalne warunki)','Korzystniejsze zasady dla pracowników małych firm poniżej 6 lat'],['— DOCHODY Z KAPITAŁU (§ 5-20) —',''],['Zwrot z nieruchomości/ruchomości','Opodatkowany','Dochody z wynajmu mieszkania, domku letniskowego lub ruchomości'],['Zwrot z instrumentów finansowych','Opodatkowany','Odsetki, dywidendy i zyski z akcji, funduszy, depozytów bankowych'],['Nieodpłatne korzystanie z cudzych rzeczy','Opodatkowane','Jeśli korzystasz z darmowego mieszkania lub podobnych, liczy się to jako dochód'],['Pożyczka dla spółki (§ 5-22)','Dodatkowy podatek, mnożnik ×1,72','Pożyczka z własnej spółki AS traktowana jest jak dywidenda i odpowiednio opodatkowana'],['— ZWOLNIONE Z PODATKU (§ 5-15/5-43) —',''],['Zasiłek na dziecko','Zwolniony z podatku'],['Świadczenie opiekuńcze','Zwolnione z podatku'],['Pomoc społeczna','Zwolniona z podatku'],['Zasiłek pielęgnacyjny','Zwolniony z podatku'],['Zasiłek pogrzebowy','Zwolniony z podatku'],['Odszkodowanie za uszczerbek na zdrowiu','Zwolnione z podatku'],['Alimenty na dziecko','Zwolnione z podatku'],['Gry losowe (Norsk Tipping itp.)','Zwolnione z podatku','Wygrane z Norsk Tipping, Rikstoto i podobnych są zwolnione z podatku'],['Przypadkowe wygrane (§ 5-50)','Opodatkowane powyżej 10 000 kr','Wygrane z prywatnych konkursów, loterii itp.'],['Rzeczy użytku osobistego (§ 5-21)','Zwolnione przy użytku własnym','Sprzedaż używanych rzeczy prywatnych (meble, ubrania, samochód) jest zwolniona z podatku']],
    salDedRows: [['— ZASADA GŁÓWNA (§ 6-1) —',''],['Prawo do odliczenia','Koszty poniesione w celu uzyskania, utrzymania lub zabezpieczenia dochodu podlegającego opodatkowaniu','Możesz odliczyć wydatki niezbędne do zarabiania pieniędzy'],['Brak odliczenia','Koszty prywatne (mieszkanie, jedzenie, utrzymanie)','Osobistych kosztów utrzymania nigdy nie można odliczyć'],['Strata ze zbycia (§ 6-2)','Odliczenie wg zasad z rozdz. 9','Jeśli sprzedajesz coś ze stratą, możesz odliczyć ją od podatku'],['Strata z wierzytelności (§ 6-2(2))','Odliczenie przy ostatecznie stwierdzonej stracie w działalności','Ktoś jest winien Twojej firmie pieniądze i nie może zapłacić'],['Strata netto (§ 6-3)','Potrącenie z innego dochodu, przeniesienie (§ 14-6)','Jeśli firma ma stratę, możesz ją wykorzystać przeciw innemu dochodowi — lub zachować na przyszłe lata'],['— ODLICZENIE MINIMALNE (§ 6-30/32) —',''],['Dochód z pracy','46% wynagrodzenia, maks 95 700 kr','Wszyscy pracownicy otrzymują to automatycznie — pokrywa dojazdy, ubrania, narzędzia itp.'],['Dochód z emerytury','40% emerytury'],['Zastępuje','Większość odliczeń za koszty pracy','Nie musisz dokumentować poszczególnych wydatków, korzystając z odliczenia minimalnego'],['Nie obejmuje','Składki związkowe, koszty dojazdów','Te możesz odliczyć dodatkowo oprócz odliczenia minimalnego'],['— ODLICZENIA STANDARDOWE —',''],['Składka związkowa (§ 6-20)','Maks 8 700 kr','Członkostwo w związku zawodowym jak LO, YS, Unio, Akademikerne'],['Dojazd dom–praca (§ 6-44)','Powyżej 12 000 kr, maks 120 000 kr','Odliczenie za dojazd powyżej 37 km w jedną stronę (po odliczeniu podstawowym)'],['Odliczenie na dziecko (§ 6-48)','Dziecko do 12 lat, kwota ustalana przez Storting','Pokrywa wydatki na przedszkole, świetlicę i opiekę dzienną'],['Darowizny na organizacje (§ 6-50)','Min 500 kr, maks 25 000 kr','Darowizny na zatwierdzone organizacje jak Czerwony Krzyż, Lekarze bez Granic'],['Odliczenie renty sierocej (§ 6-49)','Do 32 600 kr'],['— ODSETKI OD DŁUGU (§ 6-40) —',''],['Odsetki od długu','Pełne odliczenie (22% efektu podatkowego)','Wszystkie odsetki, które płacisz — kredyt hipoteczny, studencki, samochodowy — dają 22% zwrotu z podatku'],['Ograniczenie odsetek w koncernie (§ 6-41)','25% EBITDA, próg 25M (koncern) / 5M (poza)','Ogranicza odliczenie odsetek od pożyczek między spółkami w tym samym koncernie'],['Przeniesienie odciętych odsetek','10 lat','Odsetki, które nie zostały uznane w tym roku, mogą być wykorzystane w ciągu następnych 10 lat'],['— ODLICZENIA DZIAŁALNOŚCI —',''],['Amortyzacja (§ 6-10)','Zużycie środków trwałych, wartość firmy przy zakupie','Rozkłada koszt maszyn, pojazdów itp. na kilka lat'],['Konserwacja/ubezpieczenie (§ 6-11)','Odliczenie za środki trwałe'],['Badania i rozwój (§ 6-25)','Część kosztu wytworzenia środka trwałego','Koszty rozwoju mogą być aktywowane i amortyzowane w czasie'],['Startup (§ 6-53)','Do 1M kr, spółka ≤6 lat, ≥3 lata posiadania','Osoby prywatne inwestujące w małe nowe firmy otrzymują odliczenie'],['— BRAK ODLICZENIA —',''],['Reprezentacja (§ 6-21)','Nigdy nie podlega odliczeniu','Kolacje z klientami, prezenty dla partnerów biznesowych itp.'],['Łapówki (§ 6-22)','Nigdy nie podlegają odliczeniu'],['Składki stowarzyszeniowe (§ 6-18)','Zasadniczo bez odliczenia (wyjątek § 6-19/20)','Wyjątek dla stowarzyszeń branżowych i zawodowych'],['— PŁATNOŚĆ PRZEZ BANK (§ 6-51) —',''],['Wymóg','Płatność ≥10 000 kr musi być przez bank, aby uzyskać odliczenie','Płatności gotówkowe powyżej 10 000 kr nie dają prawa do odliczenia'],['— ODLICZENIA ZAWODOWE —',''],['Odliczenie rybackie (§ 6-60)','30%, maks 160 000 kr, ≥130 dni','Wymaga co najmniej 130 dni połowów w roku podatkowym'],['Odliczenie marynarskie (§ 6-61)','30%, maks 86 300 kr, ≥130 dni','Wymaga co najmniej 130 dni na morzu w roku podatkowym']],
    salCorpRows: [['— DOTACJA KONCERNOWA (§ 10-2 do 10-5) —',''],['Dotacja koncernowa (§ 10-2)','Odliczenie dla dawcy, opodatkowane dla odbiorcy','Transfer między spółkami w tym samym koncernie — służy do wyrównywania wyników'],['Wymóg własności (§ 10-4)','Spółka macierzysta posiada >90% akcji i głosów','Dotyczy spółek akcyjnych i odpowiednich zagranicznych spółek w EOG'],['— DYWIDENDA I EKRANOWANIE (§ 10-10 do 10-13) —',''],['Dywidenda (§ 10-11)','Opodatkowana dla osobistych akcjonariuszy','Powiększana o mnożnik 1,72 przed opodatkowaniem stawką 22%'],['Odliczenie ekranujące (§ 10-12)','Odejmowane od dywidendy przed podatkiem','Nie płacisz podatku od części dywidendy odpowiadającej stopie wolnej od ryzyka'],['Stopa ekranowania','Obligacje skarbowe po opodatkowaniu','Ustalana co roku przez Urząd Skarbowy'],['Metoda zwolnienia (§ 2-38)','Zwolnione z podatku dla spółek','Spółki AS posiadające akcje w innych AS nie płacą podatku od dywidend i zysków'],['Zasada 3% (§ 2-38(6))','3% dochodu jest ujmowane','Spółki płacą mimo to 0,66% (3% × 22%) od zwolnionej dywidendy'],['— ZYSK I STRATA Z AKCJI (§ 10-30 do 10-37) —',''],['Zysk ze sprzedaży (§ 10-31)','Opodatkowany dla osobistych akcjonariuszy','Powiększany o mnożnik 1,72, tj. efektywny podatek ok. 37,84%'],['Strata ze sprzedaży (§ 10-31(2))','Podlega odliczeniu','Powiększana analogicznie o mnożnik 1,72'],['Wartość wejściowa (§ 10-32)','Cena nabycia + niewykorzystane ekranowanie','To, co zapłaciłeś za akcję, plus ewentualne naliczone odliczenie ekranujące'],['Zasada FIFO (§ 10-36)','Pierwsze kupione = pierwsze sprzedane','Przy sprzedaży części pakietu akcji, najstarsze akcje uznaje się za sprzedane pierwsze'],['— FUNDUSZE INWESTYCYJNE I ASK (§ 10-20/10-21) —',''],['Fundusze inwestycyjne (§ 10-20)','Część akcyjna i odsetkowa opodatkowane różnie','Część akcyjna = model akcjonariusza, część odsetkowa = zwykły dochód'],['Konto oszczędnościowe akcji (§ 10-21)','Podatek odroczony do wypłaty','Możesz kupować i sprzedawać akcje/fundusze na koncie bez wyzwalania podatku'],['Wypłata opodatkowana (§ 10-21(4))','Wypłata powyżej wpłaty podlega opodatkowaniu','Płacisz podatek dopiero gdy wypłacasz więcej niż wpłaciłeś'],['— OPODATKOWANIE UCZESTNIKÓW ANS/KS (§ 10-40 do 10-49) —',''],['Metoda netto (§ 10-41)','Zysk opodatkowany u uczestników','Każdy uczestnik płaci podatek od swojego udziału w wyniku spółki'],['Wypłata (§ 10-42)','Opodatkowana dla osobistego uczestnika','Powiększana o mnożnik 1,72 jak dywidenda'],['Zysk ze sprzedaży udziału (§ 10-44)','Opodatkowany','Obliczany na podstawie wartości wejściowej z korektami o nad-/niedopłatę'],['— SPÓŁDZIELNIA (§ 10-50) —',''],['Zwroty (§ 10-50)','Odliczenie dla spółdzielni','Zwrot dla członków na podstawie obrotów ze spółdzielnią'],['— NOKUS / KRAJE NISKOOPODATKOWANE (§ 10-60 do 10-68) —',''],['Zasady NOKUS (§ 10-60)','Norweski właściciel opodatkowany na bieżąco','Dotyczy spółek w krajach niskoopodatkowanych kontrolowanych przez norweskich właścicieli'],['Kraj niskoopodatkowany (§ 10-63)','Podatek poniżej 2/3 norweskiego podatku','Kraj uznaje się za niskoopodatkowany, jeśli efektywny podatek wynosi poniżej ok. 14,67%'],['Wymóg kontroli (§ 10-62)','Norwescy właściciele mają co najmniej 50%','Kontrola oceniana łącznie dla wszystkich norweskich podatników'],['Odliczenie kredytowe (§ 10-65)','Odliczenie za zapłacony zagraniczny podatek','Unikanie podwójnego opodatkowania przez odliczenie podatku zapłaconego za granicą'],['— PODATEK OD EMIGRACJI (§ 10-70/10-71) —',''],['Ukryte zyski (§ 10-70)','Opodatkowane przy wyprowadzce z Norwegii','Dotyczy akcji, udziałów i niektórych innych aktywów'],['Odroczenie (§ 10-70(7))','Możliwe w ramach EOG','Płatność odroczona, ale może być wymagane zabezpieczenie'],['Wygaśnięcie (§ 10-70(9))','Podatek wygasa po 5 latach','Jeśli nie zrealizowałeś w ciągu 5 lat, podatek odpada'],['— PODATEK U ŹRÓDŁA (§ 10-80 do 10-82) —',''],['Podatek u źródła od dywidendy','15–25% dla zagranicznych akcjonariuszy','Stawka zależy od umowy podatkowej z krajem akcjonariusza'],['Podatek u źródła od odsetek/tantiem (§ 10-80)','Wg zasad określonych w ustawie','Dotyczy płatności na rzecz podmiotów powiązanych w krajach niskoopodatkowanych']],
    salRealRows: [['— KIEDY NASTĘPUJE REALIZACJA? —','Zasada główna §§ 9-1 i 9-2'],['Co powoduje opodatkowanie zysków?','Sprzedaż, zamiana, wykup akcji, wywłaszczenie, zniszczenie — każde przeniesienie własności za wynagrodzeniem','§ 9-2(1)'],['Darowizna?','Darowizna nie jest realizacją — brak podatku dla darczyńcy','§ 9-2(3)'],['Spadek?','Nie jest realizacją — brak podatku od zysków przy dziedziczeniu','§ 9-2(3)'],['Podział między małżonkami?','Nie jest realizacją — także przy separacji/rozwodzie','§ 9-2(3)'],['Przymusowy wykup?','Uznawany za realizację — obowiązek podatkowy powstaje','§ 9-2(1)'],['— ZWOLNIENIE DLA NIERUCHOMOŚCI —','§ 9-3: Kiedy nie płacisz podatku od zysków?'],['Sprzedaż własnego mieszkania?','Zwolnione jeśli posiadane min. 1 rok i zamieszkiwane min. 1 z ostatnich 2 lat','§ 9-3(2)'],['Sprzedaż domku letniskowego?','Zwolnione jeśli posiadane min. 5 lat i używane min. 5 z ostatnich 8 lat','§ 9-3(4)'],['Sprzedaż rzeczy osobistych?','Zwolnione — mienie osobiste','§ 9-3(1)a'],['Zysk z działki?','Zwolnione tylko gdy działka jest nieznaczna — inaczej opodatkowane jako sprzedaż gruntu nawet jeśli dom jest zwolniony','§ 9-3(8)'],['Strata na zwolnionej nieruchomości?','Brak odliczenia — zasada symetrii: zwolniony zysk = brak odliczenia straty','§ 9-4'],['— STRATY DO ODLICZENIA —','§ 9-4: Zasada symetrii'],['Sprzedaż ze stratą?','Odliczenie w takim samym stopniu, w jakim odpowiedni zysk byłby opodatkowany','§ 9-4(1)'],['Strata na akcjach?','Pełne odliczenie — podwyższona ×1,72 jak zysk','§ 9-4, § 10-31'],['— WARTOŚĆ POCZĄTKOWA PRZY SPADKU/DAROWIŹNIE —','§ 9-7: Zasada ciągłości'],['Odziedziczyłeś coś?','Przejmujesz wartość początkową spadkodawcy — nie wartość rynkową w momencie dziedziczenia','§ 9-7(1)'],['Otrzymałeś darowiznę?','Ta sama zasada — przejmujesz wartość początkową darczyńcy','§ 9-7(1)'],['Wyjątek — spadkodawca mógł sprzedać bez podatku?','Wartość początkowa ustalana na wartość rynkową w dniu śmierci','§ 9-7(2)'],['— WYPROWADZENIE Z NORWESKIEJ JURYSDYKCJI —','§ 9-14: Podatek wyjściowy od aktywów'],['Przeniesienie aktywów z Norwegii?','Ukryty zysk opodatkowany jakby aktywo zostało sprzedane po wartości rynkowej','§ 9-14(1)'],['Dotyczy też wartości niematerialnych?','Tak — patenty, licencje, znaki towarowe itp.','§ 9-14(2)'],['Można odroczyć podatek?','Tak, w EOG — ale może być wymagane zabezpieczenie','§ 9-14(4)']],
    salReorgRows: [['— FUZJA (§ 11-2/11-3) —',''],['Spółki akcyjne (§ 11-2)','Zwolniona z podatku, gdy fuzja odbywa się wg ustawy o spółkach akcyjnych rozdz. 13','Dwie lub więcej spółek AS łączy się bez płacenia podatku'],['Spółdzielnie (§ 11-2(2))','Zwolniona z podatku wg ustawy o spółdzielniach rozdz. 8'],['Spółki z opodatkowaniem uczestników (§ 11-3)','Zwolniona z podatku przy tej samej formie spółki i odpowiedzialności','Uczestnicy muszą otrzymać udziały jako wynagrodzenie (maks 20% dopłaty gotówkowej)'],['— PODZIAŁ (§ 11-4/11-5) —',''],['Spółki akcyjne (§ 11-4)','Zwolniony z podatku, gdy podział odbywa się wg ustawy o spółkach akcyjnych rozdz. 14','Spółka dzieli się na dwie lub więcej bez podatku'],['Spółki z opodatkowaniem uczestników (§ 11-5)','Zwolniony z podatku przy tej samej formie spółki i odpowiedzialności','Maks 20% wynagrodzenia może być inne niż udziały'],['— WARUNKI I ZASADY —',''],['Inne wynagrodzenie (§ 11-6)','Wynagrodzenie gotówkowe dla akcjonariusza podlega opodatkowaniu','Tylko akcje/udziały w łączących się spółkach są zwolnione z podatku'],['Kontynuacja (§ 11-7)','Wartości podatkowe i daty nabycia są kontynuowane','Spółka przejmująca przejmuje wszystkie pozycje podatkowe bez zmian'],['Podział przy podziale spółki (§ 11-8)','Pozycje podatkowe dzielone wg wartości netto'],['Likwidacja (§ 11-9)','Spółka przekazująca musi zostać rozwiązana po przekazaniu'],['Data wejścia w życie (§ 11-10)','Od daty wejścia w życie wg prawa spółek'],['— TRANSAKCJE TRANSGRANICZNE (§ 11-11) —',''],['Fuzja/podział międzynarodowy','Zwolnione z podatku w ramach EOG z kontynuacją','Norweska spółka AS może łączyć się ze spółką z innego państwa EOG'],['Wymiana akcji (§ 11-11(4))','Zwolniona z podatku przy przekazaniu co najmniej 90% akcji','Maks 20% wynagrodzenia gotówkowego'],['Kraje niskoopodatkowane (§ 11-11(7))','Zwolnienie nie dotyczy krajów niskoopodatkowanych','Wyjątek, jeśli rzeczywiście prowadzona działalność w państwie EOG'],['— PRZEKSZTAŁCENIE (§ 11-20) —',''],['Na spółkę akcyjną','Jednoosobowa działalność, ANS, DA itp. mogą być przekształcone bez podatku','Wartości podatkowe i pozycje są kontynuowane'],['Transfer koncernowy (§ 11-21)','Zwolniony z podatku transfer między spółkami w tym samym koncernie','Spółka macierzysta musi posiadać ponad 90% akcji'],['Racjonalizacja (§ 11-22)','Ministerstwo może przyznać zwolnienie podatkowe przy reorganizacji','Dotyczy sprzedaży nieruchomości, działalności lub akcji']],
    salSubjRows: [['— OSOBISTY PODATNIK (§ 2-1) —',''],['Zamieszkały w Norwegii (§ 2-1(1))','Obowiązek podatkowy od wszystkich dochodów/majątku, w Norwegii i za granicą','Jeśli mieszkasz w Norwegii, płacisz podatek od wszystkiego — niezależnie od źródła dochodu'],['Nabycie rezydencji (§ 2-1(2))','Pobyt >183 dni w ciągu 12 mies. lub >270 dni w ciągu 36 mies.','Jeśli przebywasz w Norwegii wystarczająco długo, stajesz się rezydentem podatkowym'],['Ustanie rezydencji (§ 2-1(3))','Wymaga stałego pobytu za granicą + rezygnacji z mieszkania w Norwegii','Musisz mieszkać na stałe za granicą i nie dysponować mieszkaniem w Norwegii'],['Tymczasowa nieobecność (§ 2-1(4))','Nie przerywa rezydencji podatkowej','Urlop czy krótkie pobyty za granicą nie zmieniają twojej rezydencji'],['Svalbard (§ 2-1(5))','Odrębne przepisy (ustawa o opodatkowaniu na Svalbardzie)'],['— MASA SPADKOWA (§ 2-2) —',''],['Masa spadkowa (§ 2-2)','Odrębny podmiot podatkowy w roku śmierci i dalej','Masa spadkowa jest opodatkowana jako odrębna jednostka do czasu rozliczenia'],['Podział w roku śmierci (§ 2-15)','Spadkobiercy przejmują od 1 stycznia','Jeśli spadek został rozdzielony w roku śmierci, spadkobiercy są opodatkowani za cały rok'],['— SPÓŁKI (§ 2-2) —',''],['Spółka akcyjna (§ 2-2(1)a)','Odrębny podmiot podatkowy','Spółka z o.o. jest samodzielnym podatnikiem — płaci 22% podatku od zysku'],['Publiczna spółka akcyjna (§ 2-2(1)b)','Odrębny podmiot podatkowy'],['Kasa oszczędnościowa, ubezpieczenie wzajemne (§ 2-2(1)c-d)','Odrębny podmiot podatkowy'],['Spółdzielnia (§ 2-2(1)e)','Odrębny podmiot podatkowy'],['Przedsiębiorstwo państwowe, szpital (§ 2-2(1)g-h)','Odrębny podmiot podatkowy'],['Fundacje (§ 2-2(1)f)','Odrębny podmiot podatkowy'],['Przedsiębiorstwo komunalne (§ 2-2(1)i)','Odrębny podmiot podatkowy'],['— OGRANICZONY OBOWIĄZEK PODATKOWY (§ 2-3) —',''],['Dochód z nieruchomości w Norwegii (§ 2-3(1)a)','Opodatkowany','Cudzoziemcy posiadający nieruchomość w Norwegii płacą podatek od dochodu z niej'],['Działalność w Norwegii (§ 2-3(1)b)','Opodatkowana','Jeśli prowadzisz działalność z Norwegii, płacisz tu podatek'],['Praca w Norwegii (§ 2-3(1)d)','Opodatkowana','Jeśli pracujesz w Norwegii, płacisz podatek od wynagrodzenia — także cudzoziemcy'],['Dywidenda od norweskiej spółki (§ 2-3(1)c)','Podatek u źródła','Zagraniczni akcjonariusze płacą podatek u źródła od dywidend z norweskich spółek'],['Wynagrodzenie członka zarządu (§ 2-3(1)e)','Opodatkowane','Jeśli zasiadasz w zarządzie norweskiej spółki, płacisz podatek od honorarium'],['Emerytura z Norwegii (§ 2-3(4))','Opodatkowana (podatek u źródła)','Także dla osób mieszkających za granicą'],['Podatek artystów (§ 2-3(1)h)','Opodatkowany dla zagranicznych artystów','Odrębne zasady opodatkowania koncertów, występów itp.'],['— METODA ZWOLNIENIA (§ 2-38) —',''],['Zwolnienie dla spółek (§ 2-38(1))','Dywidendy i zyski między spółkami są zwolnione z podatku','Spółka z o.o. posiadająca akcje innej spółki zwykle nie płaci podatku od dywidend i zysków'],['Reguła 3% (§ 2-38(6))','3% dochodu jest mimo to opodatkowane','Spółka faktycznie płaci 0,66% (3% × 22%) od zwolnionych dywidend'],['Wyjątek kraje niskoopodatkowane (§ 2-38(3))','Zwolnienie nie dotyczy spółek w krajach niskoopodatkowanych','Spółki w krajach o bardzo niskim opodatkowaniu nie korzystają z metody zwolnienia'],['Wyjątek portfelowy EOG (§ 2-38(3)b)','Zwolnienie nie dotyczy udziału poniżej 10% poza EOG','Jeśli posiadasz mniej niż 10% spółki poza EOG, metoda zwolnienia nie ma zastosowania'],['— MAŁŻONKOWIE (§ 2-10 do 2-16) —',''],['Wspólne lub odrębne (§ 2-10)','Małżonkowie mogą być opodatkowani wspólnie lub odrębnie','Możecie wybrać, czy dochody mają być łączone, czy opodatkowane osobno'],['Podział (§ 2-11)','Dochody/odliczenia przypisywane są do tego małżonka, do którego należą'],['Klasa 2 (§ 2-14)','Utrzymanie małżonka z niskim dochodem','Daje niższy podatek, jeśli jeden z małżonków ma mały lub zerowy dochód'],['Wspólne mieszkanie (§ 2-12)','Wspólne opodatkowanie wspólnego mieszkania'],['— DZIECI (§ 2-14) —',''],['Dzieci poniżej 17 lat (§ 2-14(1))','Dochody dzieci opodatkowane u rodziców','Dochody kapitałowe dzieci poniżej 17 lat są opodatkowane u rodziców'],['Dochód z pracy dzieci (§ 2-14(3))','Opodatkowany u samego dziecka','Wynagrodzenie zarobione przez dziecko jest opodatkowane odrębnie'],['Majątek dzieci (§ 2-14(5))','Dzielony równo między rodziców'],['— INSTYTUCJE ZWOLNIONE Z PODATKU (§ 2-30 do 2-32) —',''],['Państwo (§ 2-30(1)a)','Zwolnione z podatku'],['Województwa/gminy (§ 2-30(1)b-c)','Zwolnione z podatku'],['Wspólnoty religijne (§ 2-30(1)d)','Zwolnione z podatku'],['Instytucje niezarobkowe (§ 2-32)','Zwolnione z podatku, jeśli dochód nie jest zarobkowy','Stowarzyszenia, kluby i fundacje niedziałające dla zysku są zwolnione z podatku'],['Działalność zarobkowa (§ 2-32(2))','Opodatkowana powyżej 140 000 kr / 70 000 kr','Jeśli dochód ze sprzedaży, najmu itp. przekracza próg, trzeba płacić podatek'],['— REGUŁY REZYDENCJI SPÓŁEK (§ 2-2(6)) —',''],['Zarejestrowana w Norwegii','Zawsze norweski podmiot podatkowy','Spółki zarejestrowane w norweskim rejestrze przedsiębiorstw są opodatkowane w Norwegii'],['Założona w Norwegii (§ 2-2(7))','Zawsze norweski podmiot podatkowy'],['Zarząd w Norwegii (§ 2-2(6))','Może stać się norweskim podmiotem podatkowym','Zagraniczna spółka faktycznie zarządzana z Norwegii może być tu opodatkowana'],['— PRZENIESIENIE SPÓŁKI DO/Z NORWEGII (§ 2-2(8)) —',''],['Przeniesienie do Norwegii (§ 2-2(8))','Pełny obowiązek podatkowy od momentu ustanowienia w Norwegii'],['Przeniesienie z Norwegii (§ 2-2(8))','Rozliczenie ukrytych zysków','Spółka musi rozliczyć pozycje podatkowe przy przeniesieniu z Norwegii'],['— MIĘDZYNARODOWE (§ 2-37/2-38) —',''],['Kredyt podatkowy (§ 2-37)','Odliczenie za podatek zapłacony za granicą','Unikanie podwójnego opodatkowania — odliczenie zagranicznego podatku od norweskiego zeznania'],['Umowy podatkowe','Mogą ograniczać prawo Norwegii do opodatkowania','Norwegia ma umowy z wieloma krajami o podziale prawa do opodatkowania']],
    salKeyRows: [['— PRACA, KAPITAŁ CZY DZIAŁALNOŚĆ? —','§ 5-1: Dlaczego granica między nimi decyduje o Twoim podatku'],['Dochód z pracy','Osobiste świadczenie dla innych. Wynagrodzenie, honoraria, świadczenia rzeczowe. Daje dochód osobisty → podatek progresywny + składki (7,6%).','§ 5-10'],['Dochód z kapitału','Zwrot z tego co posiadasz — odsetki, dywidendy, czynsz, zyski z akcji. Tylko 22% zwykłego podatku.','§ 5-20'],['Dochód z działalności','Prawo podatkowe nie definiuje „działalności" bezpośrednio. Cztery kryteria:'],['1. Trwałość','Działalność musi mieć pewną trwałość — nie tylko pojedyncza sprzedaż.'],['2. Zakres','Musi mieć pewien zakres. Jeden lokal na wynajem = kapitał. Dziesięć z aktywnym zarządzaniem = działalność.'],['3. Zdolność do zysku','Działalność musi obiektywnie móc przynosić zysk. Hobby to nie działalność.'],['4. Na własne ryzyko','Sam ponosisz ryzyko finansowe. Odróżnia działalność od zatrudnienia.'],['Dlaczego to ważne?','Działalność jednoosobowa daje dochód osobisty → podatek progresywny + składki. Kapitał daje tylko 22%.'],['Typowa szara strefa?','Wynajem nieruchomości. Mało lokali, mało pracy = kapitał. Dużo lokali, aktywne zarządzanie = działalność.'],['— POJĘCIE REALIZACJI —','§ 9-2: Co uruchamia podatek — a co nie?'],['Czym jest realizacja?','Przeniesienie własności za wynagrodzeniem: sprzedaż, zamiana, wykup, wywłaszczenie, zniszczenie.','§ 9-2(1)'],['Co NIE jest realizacją?','Darowizna, spadek, podział przy rozstaniu, przeniesienie między małżonkami.','§ 9-2(3)'],['Zasada mieszkaniowa?','Sprzedaż własnego mieszkania zwolniona jeśli posiadane min. 1 rok i zamieszkiwane 1 z 2 lat. Letniskowy: 5 lat, używany 5/8.','§ 9-3(2)/(4)'],['Zasada symetrii?','Strata odliczana dokładnie w takim stopniu jak odpowiedni zysk byłby opodatkowany.','§ 9-4'],['Spadek i darowizna — ciągłość?','Odbiorca przejmuje wartość początkową spadkodawcy/darczyńcy. Brak podatku przy odbiorze, ale przyszły zysk liczony od oryginalnej ceny zakupu.','§ 9-7'],['Wyjątek: spadkodawca mógł sprzedać bez podatku?','Wartość początkowa ustalana na wartość rynkową w dniu śmierci — korzystniejsze dla spadkobiercy.','§ 9-7(2)'],['— WARTOŚĆ POCZĄTKOWA —','Co „zapłaciłeś" w sensie podatkowym'],['Czym jest wartość początkowa?','Kwota od której mierzy się zysk lub stratę przy sprzedaży. Zwykle: cena zakupu + koszty. Dla akcji: też niewykorzystana ulga.','§ 9-7, § 10-32'],['Dlaczego to ważne?','Zysk = cena sprzedaży minus wartość początkowa. Błędna wartość = błędny podatek.'],['Spadek/darowizna?','Przejmujesz wartość początkową (ciągłość). Brak „zerowania" do wartości rynkowej. Wyjątek: jeśli spadkodawca mógł sprzedać bez podatku.','§ 9-7'],['Akcje?','Cena zakupu + koszty transakcji + niewykorzystana ulga. FIFO określa kolejność sprzedaży.','§ 10-32, § 10-36'],['Nieruchomość?','Cena zakupu + opłata skarbowa + ulepszenia (nie konserwacja).','§ 9-3'],['Amortyzacja?','Dla środków trwałych w działalności wartość początkowa jest zmniejszana o odpisy amortyzacyjne.','§ 6-10, § 14-40'],['— MODEL AKCJONARIUSZA —','§ 10-11 do 10-12'],['Jak opodatkowane są dywidendy?','Dywidendy mnożone przez 1,72 i opodatkowane 22%. Efektywny podatek: ok. 37,84%.','§ 10-11'],['Czym jest ulga skjermingowa?','Część dywidendy odpowiadająca stopie wolnej od ryzyka jest zwolniona.','§ 10-12'],['Dlaczego 1,72?','Aby łączny podatek (spółka + akcjonariusz) był na poziomie podatku od wynagrodzeń.'],['— METODA ZWOLNIEŃ —','§ 2-38'],['Co to jest?','Spółki nie płacą podatku od dywidend i zysków z innych spółek.','§ 2-38'],['Zasada 3%?','Spółka musi jednak rozpoznać 3% zwolnionej dywidendy. Efektywny podatek: 0,66%.','§ 2-38(6)'],['Wyjątki?','Nie dotyczy krajów o niskim opodatkowaniu ani udziałów poniżej 10% poza EOG.','§ 2-38(3)'],['— KONTRYBUCJE GRUPOWE —','§ 10-2 do 10-5'],['Co to jest?','Transfer pieniędzy między spółkami w grupie. Odliczenie dla dającego, opodatkowanie dla odbierającego.','§ 10-2'],['Jaki cel?','Wyrównanie zysków i strat w grupie dla prawidłowego łącznego podatku.'],['Wymóg?','Spółka matka musi posiadać ponad 90% akcji i głosów.','§ 10-4'],['— ZWOLNIONA FUZJA I PODZIAŁ —','§ 11-2, § 11-4, § 11-7'],['Kiedy jest zwolnione?','Gdy przeprowadzone zgodnie z prawem spółek z ciągłością podatkową.','§ 11-2/11-4'],['Czym jest ciągłość?','Spółka przejmująca dziedziczy wszystkie wartości podatkowe bez zmian.','§ 11-7'],['Co może pójść nie tak?','Wynagrodzenie gotówkowe = opodatkowanie. Straty mogą przepaść (§ 13-3).'],['— NORMA ANTYUNIKOWA —','§ 13-2'],['Kiedy się stosuje?','Gdy głównym celem jest korzyść podatkowa i transakcja nie wytrzymuje oceny całościowej.','§ 13-2(2)'],['Co się ocenia?','Substancja biznesowa, wielkość korzyści podatkowej, nieodpowiednia droga, wykorzystanie sprzeczne z celem przepisów.','§ 13-2(3)'],['Konsekwencja?','Transakcja opodatkowana według rzeczywistej treści — nie formy.','§ 13-2(4)'],['Przykład?','Zakup pustej spółki dla wykorzystania straty. Strata przepada wg § 13-3.','§ 13-3'],['— WYMÓG LEGALNOŚCI —','§ 11-1(2)'],['Co to jest?','Fuzja i podział muszą być legalne na trzech poziomach, aby być zwolnione.','§ 11-1(2)'],['Prawo spółek','Musi spełniać prawo spółek: plan fuzji, zawiadomienie wierzycieli, uchwała WZ, rejestracja.','Prawo spółek rozdz. 13/14'],['Prawo podatkowe (rozdz. 11)','Ciągłość podatkowa, maks 20% gotówki, rozwiązanie spółki cedującej.','§ 11-7, § 11-6, § 11-9'],['Prawo VAT','Fuzja/podział zwolnione (§ 6-14, 0% VAT). Ale obowiązki korekt przejmowane przez nowego właściciela.','Ustawa VAT § 6-14, rozdz. 9'],['W praktyce?','Wszystkie trzy poziomy muszą się zgadzać. Błąd w prawie spółek wpływa na podatek i VAT.']],
    morReqRows: [['Maksymalny kredyt','Łączne zadłużenie maksymalnie 5× dochód roczny','Liczy się całe zadłużenie — kredyt hipoteczny, studencki, samochodowy, karty kredytowe'],['Wkład własny','Co najmniej 10%','Musisz mieć zaoszczędzone co najmniej 10% wartości nieruchomości'],['Test obciążeniowy','Wyższe z 7% i oprocentowania + 3 pp','Bank sprawdza, czy stać cię nawet gdy odsetki wzrosną'],['Spłata kapitału','Wymagana powyżej 60% LTV','Jeśli pożyczyłeś więcej niż 60% wartości nieruchomości, musisz spłacać kapitał'],['Kwota elastyczności','Bank może odejść dla 10% kredytów','W Warszawie: maksymalnie 8% — oznacza, że bank może powiedzieć tak, nawet jeśli nie spełniasz wszystkich wymagań']],
    morCostRows: [['Oprocentowanie teraz','Ok. 5,1% zmienne (sty 2026)'],['Odliczenie podatku','22% kosztów odsetek','Odzyskujesz 22% odsetek, które płacisz, z podatku'],['Podatek od dokumentacji','Zwykle 2,5% wartości rynkowej','Płacony przy zakupie nieruchomości — mogą obowiązywać wyjątki']],
    morBsuRows: [['Maksymalna roczna oszczędność','27 500 kr'],['Maksymalna kwota całkowita','300 000 kr'],['Odliczenie podatku','10% wpłaconej kwoty — do 2 750 kr/rok'],['Limit wieku','Do i włącznie z rokiem, w którym skończysz 33 lata'],['Warunek na odliczenie podatku','Musisz mieć opodatkowany dochód z zatrudnienia i nie być właścicielem domu'],['Na co można wydać pieniądze?','Zakup, spłata, remonty lub utrzymanie własnego domu'],['Naruszenie warunków?','Jeśli wydasz pieniądze na coś innego niż mieszkanie, musisz zwrócić wszystkie odliczenia podatkowe']],
    morBsuTitle:'BSU — Oszczędzanie na mieszkanie dla młodzieży', morBsuDesc:'Odliczenie podatku, limity oszczędności, limit wieku, warunki użytkowania',
    morReqTitle:'Wymagania kredytu hipotecznego', morReqDesc:'Wkład własny, stosunek zadłużenia, test obciążeniowy, spłata',
    morCostTitle:'Koszty zakupu nieruchomości', morCostDesc:'Oprocentowanie, odliczenie podatku, podatek od dokumentacji',
    npvInfoRows: [['— SŁOWNICZEK —',''],['NPV (wartość bieżąca netto)','Wartość bieżąca przyszłych przepływów pieniężnych minus inwestycja'],['IRR (wewnętrzna stopa zwrotu)','Stopa procentowa, przy której NPV = 0'],['WACC','Średni ważony koszt kapitału'],['— INTERPRETACJA —',''],['NPV > 0','Opłacalna — zaakceptuj inwestycję'],['NPV < 0','Nieopłacalna — odrzuć'],['IRR > WACC','Projekt tworzący wartość'],['IRR < WACC','Projekt niszczący wartość'],['— DANE REFERENCYJNE —',''],['Stopa dyskontowa','Zwykle WACC (przed opodatkowaniem)'],['Typowy WACC','8–12%'],['Okres zwrotu','Krótszy jest lepszy']],
    vatSubjRows: [['— WARUNKI PODSTAWOWE —','Trzy rzeczy muszą być spełnione dla odpowiedzialności VAT'],['1. Działalność gospodarcza','Musisz prowadzić działalność gospodarczą — nie hobby lub pracę najemną','§ 2-1(1)'],['2. Dostawa towarów/usług','Musi być transakcja — dostawa za wynagrodzenie (płatność)','§ 1-3(1)a'],['3. Próg obrotu','Obrót przekraczający 50 000 kr w ciągu 12 miesięcy','§ 2-1(1)'],['— KTO MUSI SIĘ ZAREJESTROWAĆ? —',''],['Przedsiębiorcy powyżej 50 000 kr','Muszą się zarejestrować w Rejestrze VAT','§ 2-1(1)'],['Organizacje charytatywne','Wyższy próg: 140 000 kr','§ 2-1(1)'],['Imprezy sportowe','Oddzielny próg: 3 000 000 kr','§ 2-1(1)'],['— GŁÓWNE POJĘCIA —',''],['Czym jest « działalność gospodarcza »?','Niezależna, trwała działalność o charakterze gospodarczym i zdolna do generowania zysku. Hobby i zlecenia jednorazowe to zwykle nie działalność gospodarcza.'],['Czym jest « obrót »?','Dostawa towarów lub usług za wynagrodzenie. Prezenty, odszkodowanie i dotacje to zwykle nie obrót.','§ 1-3(1)a'],['Czym jest « podatnik »?','Podmiot zarejestrowany (lub powinien być zarejestrowany) w Rejestrze VAT, zobowiązany do obliczenia i zapłaty VAT.','§ 1-3(1)d'],['Rejestracja dobrowolna?','Właściciele nieruchomości handlowych mogą się zarejestrować dobrowolnie, aby uzyskać prawo do odliczenia VAT na wejściu.','§ 2-3']],
    vatSubjTitle:'Kto jest podatnikiem VAT?', vatSubjDesc:'Działalność gospodarcza · Próg obrotu · Obowiązek rejestracji',
    vatRates: [['25','25% Standardowa — towary i usługi (§ 5-1)'],['15','15% Artykuły spożywcze (§ 5-2)'],['12','12% Transport, hotel, kino (§ 5-3/5-5/5-6)'],['0','0% Zwolnione — gazety, książki, eksport (rozdz. 6)']],
    vatInfoRows: [['— STAWKI —',''],['Stawka podstawowa (§ 5-1)','25%'],['Artykuły spożywcze (§ 5-2)','15%'],['Transport osobowy (§ 5-3)','12%'],['Wynajem pokoi hotelowych (§ 5-5)','12%'],['Kino (§ 5-6)','12%'],['Muzea/galerie (§ 5-9)','12%'],['Parki rozrywki (§ 5-10)','12%'],['Imprezy sportowe (§ 5-11)','12%'],['Woda/kanalizacja (§ 5-12)','12%'],['Gastronomia (§ 5-2)','25% (nie 15%)'],['— REJESTRACJA —',''],['Przedsiębiorcy (§ 2-1)','50 000 kr / 12 mies.'],['Organizacje dobroczynne (§ 2-1)','140 000 kr / 12 mies.'],['Imprezy sportowe (§ 2-1)','3 000 000 kr'],['— OBSZAR —',''],['Geograficzny (§ 1-2)','Stały ląd Norwegii + granica terytorialna'],['Poza obszarem VAT','Svalbard, Jan Mayen, terytoria zależne']],
    vatLawRows: [['— WYŁĄCZONE (rozdz. 3) —','Poza ustawą, brak prawa do odliczenia'],['Usługi zdrowotne (§ 3-2)','Wyłączone','Lekarz, dentysta, fizjoterapeuta itp. — brak VAT i brak prawa do odliczenia'],['Usługi socjalne (§ 3-4)','Wyłączone','Ochrona dzieci, opieka nad osobami starszymi, leczenie uzależnień itp.'],['Edukacja (§ 3-5)','Wyłączona','Szkoły, kursy, szkolenia — zarówno publiczne, jak i prywatne'],['Usługi finansowe (§ 3-6)','Wyłączone','Bankowość, ubezpieczenia, obrót papierami wartościowymi — brak VAT'],['Sztuka/kultura — wykonanie (§ 3-7)','Wyłączone','Koncerty, teatr, taniec — bilety są bez VAT'],['Sport — prawo do uprawiania (§ 3-8)','Wyłączone','Siłownia, boisko piłkarskie, basen itp.'],['Wykonywanie władzy publicznej (§ 3-9)','Wyłączone'],['Nieruchomość/wynajem (§ 3-11)','Wyłączone (wyjątek w (2))','Wynajem mieszkań i nieruchomości komercyjnych jest wyłączony — ale dobrowolna rejestracja możliwa dla działalności'],['Organizacje dobroczynne (§ 3-12)','Wyłączone (niektóre sprzedaże)','Pchlce targi, kiermasze itp. organizacji charytatywnych'],['Org. ideowe — składki (§ 3-13)','Wyłączone'],['Gry hazardowe (§ 3-14)','Wyłączone'],['Pogrzeb — ceremonia (§ 3-15)','Wyłączone'],['Wynagrodzenie zarządu (§ 3-17)','Wyłączone (z AGA)','Wynagrodzenie zarządu jest wyłączone z VAT, ale należy zapłacić składkę pracodawcy'],['Używane rzeczy prywatne (§ 3-19)','Wyłączone','Osoby prywatne sprzedające używane rzeczy nie muszą naliczać VAT'],['— STAWKA ZEROWA (rozdz. 6) —','Objęte ustawą, 0% VAT naliczonego, prawo do odliczenia'],['Gazety (§ 6-1)','Stawka zerowa'],['Czasopisma (§ 6-3)','Stawka zerowa (ostatni ustęp)'],['Książki (§ 6-4)','Stawka zerowa (ostatni ustęp)'],['Energia elektryczna gosp. domowe Płn. Norwegia (§ 6-6)','Stawka zerowa'],['Samochód elektryczny ≤300 000 kr (§ 6-8)','Stawka zerowa','Dotyczy tylko kwoty zakupu do 300 000 kr — powyżej naliczany jest 25% VAT'],['Statki ≥15m (§ 6-9)','Stawka zerowa'],['Statki powietrzne do celów zawodowych (§ 6-10)','Stawka zerowa'],['Przeniesienie działalności (§ 6-14)','Stawka zerowa','Gdy cała działalność jest sprzedawana łącznie, historia VAT jest przenoszona — brak VAT od sprzedaży'],['Eksport towarów (§ 6-21)','Stawka zerowa','Eksport za granicę — 0% VAT, ale pełne prawo do odliczenia naliczonego'],['Eksport usług (§ 6-22)','Stawka zerowa'],['Transport do/z zagranicy (§ 6-28)','Stawka zerowa'],['— POBRANIE (rozdz. 3 część II) —',''],['Pobranie towarów (§ 3-21)','Podlega VAT','Jeśli bierzesz towary z firmy do użytku własnego, musisz naliczyć VAT'],['Pobranie usług prywatnych (§ 3-22)','Podlega VAT'],['Wyżywienie/naturalia/repr. (§ 3-23)','Podlega VAT'],['— IMPORT (rozdz. 3 część III) —',''],['Towary importowane (§ 3-29)','Podlega VAT','Import towarów — VAT naliczany przy odprawie celnej'],['Usługi zdalnie dostarczalne (§ 3-30)','Odwrotne obciążenie','Kupujesz usługi cyfrowe z zagranicy — sam naliczasz VAT']],
    vatDefRows: [['Obrót (a)','Dostawa towarów/usług za wynagrodzeniem','Jeśli wymieniasz coś za pieniądze, to jest obrót'],['Towary (b)','Przedmioty fizyczne, nieruchomości, energia elektryczna, woda, gaz, ciepło, chłód'],['Usługi (c)','Wszystko, co można sprzedać, a nie jest towarem','Doradztwo, fryzjer, transport, naprawa itp.'],['Podmiot podatkowy (d)','Zarejestrowany/zobowiązany do rejestracji w rejestrze VAT','Firmy z obrotem powyżej 50 000 kr w ciągu 12 miesięcy'],['VAT naliczony (e)','Obliczany i płacony przy obrocie i pobraniu','VAT, który doliczasz do ceny i pobierasz od klienta'],['VAT naliczony do odliczenia (f)','Naliczony przy zakupie lub imporcie','VAT, który płacisz kupując towary/usługi dla firmy'],['Wyłączenie z ustawy (g)','Obrót nieobjęty ustawą → brak prawa do odliczenia','Firma nie może odliczyć VAT od zakupów związanych z wyłączonym obrotem'],['Zwolnienie z VAT (h)','Objęte ustawą, ale 0% VAT naliczonego → pełne prawo do odliczenia','Eksport jest zwolniony — nie doliczasz VAT, ale możesz odliczyć naliczony'],['Usługi zdalnie dostarczalne (i)','Niezwiązane z konkretnym miejscem fizycznym','Usługi IT, doradztwo online, streaming itp.'],['Usługi elektroniczne (j)','Zdalnie dostarczalne, przez internet, zautomatyzowane','Aplikacje, e-booki, usługi streamingowe, kursy online']],
    vatDedRows: [['Zasada główna (§ 8-1)','Odliczenie VAT naliczonego do użytku w zarejestrowanej działalności','Odzyskujesz VAT od wszystkiego, co kupujesz do użytku w firmie'],['Użytek mieszany (§ 8-2)','Proporcjonalne odliczenie wg szacowanego użytku','Jeśli coś jest używane w 60% w firmie i 40% prywatnie, dostajesz 60% odliczenia'],['Brak odliczenia: gastronomia (§ 8-3 a)','','Jedzenie i napoje dla pracowników, klientów itp.'],['Brak odliczenia: reprezentacja (§ 8-3 e)','','Kolacje z klientami, imprezy dla partnerów biznesowych'],['Brak odliczenia: prezenty (§ 8-3 f)','Nie bagatelnej wartości','Prezenty powyżej progu bagatelnego nie dają odliczenia'],['Brak odliczenia: mieszkanie/socjal (§ 8-3 g)','Wyjątek: stołówki zakładowe'],['Samochód osobowy (§ 8-4)','Brak odliczenia (wyjątek: wynajem, taksówka, sprzedaż)','Samochód służbowy nie daje odliczenia VAT, chyba że jest używany do wynajmu lub transportu osób'],['Płatność przez bank (§ 8-8)','Wymagana przy ≥10 000 kr','Płatności gotówkowe powyżej 10 000 kr nie dają odliczenia VAT']],
    vatAdjRows: [['Środki trwałe — ruchomości (§ 9-1 a)','VAT naliczony ≥50 000 kr','Maszyny, pojazdy itp. z VAT powyżej 50 000 kr'],['Środki trwałe — nieruchomości (§ 9-1 b)','VAT naliczony ≥100 000 kr','Budynki, obiekty itp. z VAT powyżej 100 000 kr'],['Okres korekty — ruchomości (§ 9-4)','5 lat','Jeśli zmienisz sposób użytkowania w ciągu 5 lat, odliczenie VAT musi być skorygowane'],['Okres korekty — nieruchomości (§ 9-4)','10 lat','Jeśli zmienisz sposób użytkowania w ciągu 10 lat, odliczenie VAT musi być skorygowane']],
    vatCalcRows: [['Zasada główna (§ 4-1)','Wynagrodzenie bez VAT'],['Wymiana barterowa (§ 4-3)','Zwykła wartość rynkowa','Przy wymianie barterowej jako podstawę VAT przyjmuje się cenę rynkową'],['Powiązania osobowe (§ 4-4)','Nie niższa niż zwykła wartość rynkowa','Sprzedajesz tanio własnej spółce — VAT naliczany od ceny rynkowej'],['Strata z wierzytelności (§ 4-7)','Można skorygować ostatecznie utraconą wierzytelność','Klient nigdy nie zapłaci — wtedy możesz odzyskać wpłacony VAT']],
    vatRegRows: [['Wspólna rejestracja (§ 2-2)','≥85% własności, odpowiedzialność solidarna','Spółki koncernowe mogą być zarejestrowane jako jedna jednostka VAT'],['Dobrowolna rej. wynajmu (§ 2-3)','Budynki/obiekty dla zarejestrowanego najemcy VAT','Wynajmujący uzyskuje odliczenie VAT od remontu/budowy, gdy najemca jest zarejestrowany w VAT'],['Rejestracja wstępna (§ 2-4)','Znaczące nabycia przed obrotem','Nowo założona firma może się zarejestrować zanim osiągnie 50 000 kr obrotu']],
