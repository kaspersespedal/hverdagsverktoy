    <!-- ══════════════ NPV ══════════════ -->
    <div id="calc-npv" class="calc-grid hidden">
      <div class="card">
        <div class="card-hdr"><div class="card-ico">📈</div><div><div class="card-title" id="npv-title">NPV / IRR Calculator</div><div class="card-desc" id="npv-desc">Net present value and internal rate of return.</div></div></div>
        <div id="npv-help" style="font-style:italic;font-size:11.5px;padding:0 24px 0;margin-top:-4px;"><a href="javascript:void(0)" onclick="document.querySelectorAll('#npv-info-card,#npv-howto-card,#npv-examples-card,#npv-tips-card').forEach(c=>{c.classList.remove('collapsed');c.scrollIntoView({behavior:'smooth',block:'nearest'})})" style="color:var(--accent);text-decoration:none;opacity:.7;">Trenger du hjelp med kalkulatoren? →</a></div>
        <div class="card-body">
          <div class="form-row">
            <div class="fg"><label class="flbl" id="npv-l-inv">Initial Investment</label><input class="fc" type="text" id="n-inv" value="1,000,000" inputmode="numeric"></div>
            <div class="fg"><label class="flbl" id="npv-l-rate">Discount Rate (%)</label><input class="fc" type="number" id="n-r" value="10" step="0.5"></div>
          </div>
          <div class="form-row">
            <div class="fg"><label class="flbl" id="npv-l-cf1">Cash Flow Year 1</label><input class="fc" type="text" id="n-c1" value="300,000" inputmode="numeric"></div>
            <div class="fg"><label class="flbl" id="npv-l-cf2">Cash Flow Year 2</label><input class="fc" type="text" id="n-c2" value="350,000" inputmode="numeric"></div>
          </div>
          <div class="form-row">
            <div class="fg"><label class="flbl" id="npv-l-cf3">Cash Flow Year 3</label><input class="fc" type="text" id="n-c3" value="400,000" inputmode="numeric"></div>
            <div class="fg"><label class="flbl" id="npv-l-cf4">Cash Flow Year 4</label><input class="fc" type="text" id="n-c4" value="400,000" inputmode="numeric"></div>
          </div>
          <div class="fg"><label class="flbl" id="npv-l-cf5">Cash Flow Year 5</label><input class="fc" type="text" id="n-c5" value="500,000" inputmode="numeric"></div>
          <button class="btn-calc" onclick="calcNpv()"><span id="btn-calc-n">Calculate →</span></button>
          <div id="n-res" class="result-sec hidden">
            <div class="rh"><div class="rh-lbl" id="npv-r-lbl">Net Present Value (NPV)</div><div class="rh-val" id="n-npv">–</div><div class="rh-sub" id="n-verd">–</div></div>
            <div class="rgrid">
              <div class="rt"><div class="rt-lbl">IRR</div><div class="rt-val gld" id="n-irr">–</div></div>
              <div class="rt"><div class="rt-lbl" id="npv-r-pay">Payback Period</div><div class="rt-val" id="n-pay">–</div></div>
              <div class="rt"><div class="rt-lbl" id="npv-r-sum">Total Cash Flows</div><div class="rt-val" id="n-sum">–</div></div>
              <div class="rt"><div class="rt-lbl" id="npv-r-pi">Profitability Index</div><div class="rt-val" id="n-pi">–</div></div>
            </div>
          </div>
        </div>
      </div>
      <div class="right-col">
        <div class="info-card">
          <div class="card-hdr"><div class="card-ico gold">📋</div><div><div class="card-title" id="npv-info-title">Interpretation Guide</div><div class="card-desc" id="npv-info-desc">How to read NPV and IRR</div></div></div>
          <div id="npv-info-rows"></div>
        </div>
      </div>
    </div>

    <!-- ══════════════ VAT ══════════════ -->
    <div id="calc-vat" class="calc-grid hidden">
      <div class="card">
        <div class="card-hdr"><div class="card-ico">🧾</div><div><div class="card-title" id="vat-title">VAT / Tax Calculator</div><div class="card-desc" id="vat-desc">Calculate tax amounts and prices incl/excl.</div></div></div>
        <div class="card-body">
          <div class="fg"><label class="flbl" id="vat-l-amount">Amount</label><input class="fc" type="text" id="v-a" value="10,000" inputmode="numeric"></div>
          <div class="form-row">
            <div class="fg"><label class="flbl" id="vat-l-rate">Tax Rate</label><select class="fc" id="v-r"></select></div>
            <div class="fg"><label class="flbl" id="vat-l-type">Amount is</label><select class="fc" id="v-t"><option value="ex" id="vat-opt-ex">Excl. tax (add tax)</option><option value="inc" id="vat-opt-inc">Incl. tax (extract tax)</option></select></div>
          </div>
          <button class="btn-calc" onclick="calcVat()"><span id="btn-calc-v">Calculate →</span></button>
          <div id="v-res" class="result-sec hidden">
            <div class="rh"><div class="rh-lbl" id="vat-r-incl">Price Incl. Tax</div><div class="rh-val" id="v-inc">–</div></div>
            <div class="rgrid" style="grid-template-columns:1fr 1fr 1fr">
              <div class="rt"><div class="rt-lbl" id="vat-r-excl">Excl. Tax</div><div class="rt-val" id="v-exc">–</div></div>
              <div class="rt"><div class="rt-lbl" id="vat-r-tax">Tax Amount</div><div class="rt-val" id="v-vat">–</div></div>
              <div class="rt"><div class="rt-lbl" id="vat-r-pct">Rate %</div><div class="rt-val" id="v-pct">–</div></div>
            </div>
          </div>
          <!-- Adjustment calculator -->
          <div id="vat-adj-card" class="hidden" style="margin-top:20px;border-top:1.5px solid var(--border);padding-top:20px;">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
              <div class="card-ico" style="width:36px;height:36px;font-size:16px;display:flex;align-items:center;justify-content:center;border-radius:10px;">🔧</div>
              <div>
                <div style="font-weight:700;font-size:15px;color:var(--ink);" id="vat-adj-title">Justeringskalkulator</div>
                <div style="font-size:12px;color:var(--ink3);" id="vat-adj-desc">Mval. kap. 9 — justering av inngående MVA ved bruksendring</div>
                <div id="vat-adj-help" style="font-style:italic;font-size:11.5px;margin-top:2px;"><a href="javascript:void(0)" onclick="const c=document.getElementById('vat-adj-info-card');if(c){c.classList.remove('hidden','collapsed');c.scrollIntoView({behavior:'smooth',block:'center'})}" style="color:var(--accent);text-decoration:none;opacity:.7;">Trenger du hjelp med kalkulatoren? →</a></div>
              </div>
            </div>
            <div class="fg"><label class="flbl" id="adj-l-type">Type kapitalvare</label>
              <select class="fc" id="adj-type" onchange="document.getElementById('adj-period').value=this.value==='eiendom'?'10':'5'">
                <option value="eiendom" id="adj-opt-prop">Fast eiendom (§ 9-1 b) — 10 år</option>
                <option value="maskin" id="adj-opt-mach">Maskiner & inventar (§ 9-1 a) — 5 år</option>
              </select>
            </div>
            <div class="fg"><label class="flbl" id="adj-l-mva">Total inngående MVA (kr)</label>
              <input class="fc" type="text" id="adj-mva" value="2,500,000" inputmode="numeric">
            </div>
            <div class="form-row">
              <div class="fg"><label class="flbl" id="adj-l-period">Periode (år)</label>
                <input class="fc" type="text" id="adj-period" value="10" readonly style="opacity:.6;cursor:not-allowed">
              </div>
              <div class="fg"><label class="flbl" id="adj-l-years">År brukt</label>
                <input class="fc" type="text" id="adj-years" value="4" inputmode="numeric">
              </div>
            </div>
            <div class="form-row">
              <div class="fg"><label class="flbl" id="adj-l-old">Gammel andel (%)</label>
                <input class="fc" type="text" id="adj-old" value="100" inputmode="numeric">
              </div>
              <div class="fg"><label class="flbl" id="adj-l-new">Ny andel (%)</label>
                <input class="fc" type="text" id="adj-new" value="60" inputmode="numeric">
              </div>
            </div>
            <button class="btn-calc" onclick="calcAdj()"><span id="btn-calc-adj">Beregn justering →</span></button>
            <div id="adj-res" class="result-sec hidden">
              <div class="rh" id="adj-rh">
                <div class="rh-lbl" id="adj-r-lbl">Justeringsbeløp</div>
                <div class="rh-val" id="adj-r-val">–</div>
                <div class="rh-sub" id="adj-r-sub">–</div>
              </div>
              <div class="rgrid">
                <div class="rt"><div class="rt-lbl" id="adj-rl-base">Årlig grunnbeløp (MVA/periode)</div><div class="rt-val" id="adj-r-base">–</div></div>
                <div class="rt"><div class="rt-lbl" id="adj-rl-annual">Årlig justering</div><div class="rt-val" id="adj-r-annual">–</div></div>
                <div class="rt"><div class="rt-lbl" id="adj-rl-remain">Gjenværende år</div><div class="rt-val" id="adj-r-remain">–</div></div>
                <div class="rt"><div class="rt-lbl" id="adj-rl-change">Endring i andel</div><div class="rt-val" id="adj-r-change">–</div></div>
              </div>
            </div>
            <!-- Collapsible explanation -->
            <div style="margin-top:16px;" id="adj-explain-wrap">
              <div style="cursor:pointer;display:flex;align-items:center;gap:8px;padding:10px 0;" onclick="const b=this.nextElementSibling;b.style.display=b.style.display==='none'?'block':'none';this.querySelector('.adj-arrow').textContent=b.style.display==='none'?'▶':'▼'">
                <span class="adj-arrow" style="font-size:10px;color:var(--ink3);">▶</span>
                <span id="adj-ex-title" style="font-size:12px;font-weight:700;color:var(--ink2);letter-spacing:.5px;text-transform:uppercase;">Forklaring av justeringsreglene (mval. kap. 9)</span>
              </div>
              <div style="display:none;border-top:1px solid var(--border);padding-top:12px;">
                <div style="font-size:13px;color:var(--ink2);line-height:1.7;">
                  <div id="adj-ex-what" style="font-weight:700;color:var(--ink);margin-bottom:8px;">Hva er justering?</div>
                  <div id="adj-ex-whatdesc" style="font-style:italic;color:var(--ink3);margin-bottom:12px;">Når du har fradragsført inngående MVA på en kapitalvare, og bruken endres i justeringsperioden (mer eller mindre avgiftspliktig), må du justere fradraget — enten tilbakebetale til staten eller kreve mer fradrag.</div>

                  <div id="adj-ex-cap" style="font-weight:700;color:var(--ink);margin-bottom:6px;">Kapitalvarer (§ 9-1)</div>
                  <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px;">
                    <div style="background:var(--surface2);border-radius:8px;padding:10px 14px;border:1px solid var(--border);">
                      <div id="adj-ex-mach" style="font-size:11px;font-weight:700;color:var(--ink3);text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px;">Maskiner & inventar (a)</div>
                      <div id="adj-ex-machthres" style="font-size:13px;">Terskel: <b>50 000 kr</b> MVA</div>
                      <div id="adj-ex-machper" style="font-size:13px;">Periode: <b>5 år</b></div>
                      <div id="adj-ex-machfoot" style="font-style:italic;font-size:11px;color:var(--ink3);margin-top:4px;">Inkl. driftsmidler — ikke fritatte kjøretøy (§ 6-7)</div>
                    </div>
                    <div style="background:var(--surface2);border-radius:8px;padding:10px 14px;border:1px solid var(--border);">
                      <div id="adj-ex-prop" style="font-size:11px;font-weight:700;color:var(--ink3);text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px;">Fast eiendom (b)</div>
                      <div id="adj-ex-propthres" style="font-size:13px;">Terskel: <b>100 000 kr</b> MVA</div>
                      <div id="adj-ex-propper" style="font-size:13px;">Periode: <b>10 år</b></div>
                      <div id="adj-ex-propfoot" style="font-style:italic;font-size:11px;color:var(--ink3);margin-top:4px;">Ny-, på- eller ombygging av fast eiendom</div>
                    </div>
                  </div>

                  <div id="adj-ex-when" style="font-weight:700;color:var(--ink);margin-bottom:6px;">Når skal du justere? (§ 9-2)</div>
                  <div id="adj-ex-whendesc" style="font-style:italic;color:var(--ink3);margin-bottom:4px;">Justering utløses når bruken endres fra fradragsberettiget til ikke-fradragsberettiget formål, eller motsatt.</div>
                  <ul style="margin:6px 0 12px 18px;padding:0;color:var(--ink2);font-size:12px;line-height:1.8;">
                    <li id="adj-ex-when1"><b>Bruksendring</b> — f.eks. lokale går fra avgiftspliktig utleie til bolig</li>
                    <li id="adj-ex-when2"><b>Salg av driftsmidler</b> (§ 9-2(2)) — justering ved mva-pliktig omsetning uten fullt fradrag</li>
                    <li id="adj-ex-when3"><b>Overdragelse av eiendom</b> (§ 9-2(3)) — alltid justering ved salg</li>
                    <li id="adj-ex-when4"><b>Virksomhetsoverdragelse</b> (§ 9-2(4)) — fritatt etter § 6-14, men justering</li>
                    <li id="adj-ex-when5"><b>Unntak:</b> Uttak etter § 3-21 utløser <i>ikke</i> justering (§ 9-2(5))</li>
                  </ul>

                  <div id="adj-ex-transfer" style="font-weight:700;color:var(--ink);margin-bottom:6px;">Overføring av justeringsplikt (§ 9-3)</div>
                  <div id="adj-ex-transferdesc" style="font-style:italic;color:var(--ink3);margin-bottom:12px;">Ved overdragelse kan kjøper overta selgers justeringsplikt. Selger justerer samlet for endringer i sin eiertid, kjøper overtar for resten av perioden.</div>

                  <div id="adj-ex-calc" style="font-weight:700;color:var(--ink);margin-bottom:6px;">Beregning (§ 9-5)</div>
                  <div style="background:var(--surface2);border-radius:8px;padding:12px 16px;border:1px solid var(--border);margin-bottom:12px;">
                    <div id="adj-ex-calcformula" style="font-size:12px;color:var(--ink3);margin-bottom:6px;font-style:italic;">Formel:</div>
                    <div id="adj-ex-calcf1" style="font-size:13px;font-weight:600;color:var(--ink);font-family:'Inter',sans-serif;">Årlig justering = (Inngående MVA ÷ periode) × (ny andel − gammel andel)</div>
                    <div id="adj-ex-calcf2" style="font-size:13px;font-weight:600;color:var(--ink);margin-top:4px;font-family:'Inter',sans-serif;">Total justering = Årlig justering × gjenværende år</div>
                    <div id="adj-ex-calcfoot" style="font-size:11px;color:var(--ink3);margin-top:8px;font-style:italic;">Negativt = tilbakebetaling · Positivt = økt fradrag · Ingen justering ved endring &lt; 10 prosentpoeng (§ 9-5(3))</div>
                  </div>

                  <div id="adj-ex-rev" style="font-weight:700;color:var(--ink);margin-bottom:6px;">Tilbakeføring (§ 9-6 og § 9-7)</div>
                  <div id="adj-ex-revdesc" style="font-style:italic;color:var(--ink3);margin-bottom:4px;">Tilbakeføring er noe annet enn justering — det er full reversering av fradrag.</div>
                  <ul style="margin:6px 0 12px 18px;padding:0;color:var(--ink2);font-size:12px;line-height:1.8;">
                    <li id="adj-ex-rev1"><b>Personkjøretøy (§ 9-6)</b> — 8 års tilbakeføringsperiode for utleie-/transportkjøretøy</li>
                    <li id="adj-ex-rev2"><b>Eiendom før fullføring (§ 9-7)</b> — fullt fradrag tilbakeføres hvis solgt/omdisponert før ferdigstilt</li>
                    <li id="adj-ex-rev3"><b>Unntak:</b> Kondemnering, konkurs og dødsfall (§ 9-6(4))</li>
                  </ul>

                  <div id="adj-ex-source" style="font-size:11px;color:var(--ink3);font-style:italic;border-top:1px solid var(--border);padding-top:8px;">Kilde: Merverdiavgiftsloven kap. 9 (lov-2009-06-19-58). Kalkulatoren er veiledende — kontakt revisor for konkrete vurderinger.</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="right-col">
        <div class="info-card collapsed" id="vat-subj-card">
          <div class="card-hdr" style="cursor:pointer" onclick="toggleCard(this.parentElement)"><div class="card-ico gold">👤</div><div><div class="card-title" id="vat-subj-title">Hvem er avgiftspliktig? <span style="font-size:11px;opacity:.5">▼</span></div><div class="card-desc" id="vat-subj-desc">Næring, omsetningsgrense, registreringsplikt</div></div></div>
          <div id="vat-subj-rows" class="law-body"></div>
        </div>
