  uk: {
    flag:'🇺🇦', name:'Українська', lang:'uk', currency:'kr', currencyCode:'NOK',
    salDefaults: { gross: 800000 },
    salClasses: [['1','Клас 1 (Стандартний)'],['2','Клас 2 (Подружжя з низьким доходом)'],['self','Самозайнята особа']],
    salRegions: [['0.22','Стандартна (вся країна)'],['0.185','Фіннмарк / Північний Тромс (зона пільг)']],
    salInfoRows: [['Особиста знижка','114 540 kr'],['Мінімальне вирахування (макс.)','95 700 kr'],['Ступінь 1 (226 тис.+)','1.7%'],['Ступінь 2 (318 тис.+)','4.0%'],['Ступінь 3 (725 тис.+)','13.7%'],['Ступінь 4 (980 тис.+)','16.8%'],['Ступінь 5 (1 467 тис.+)','17.8%'],['Внесок на соцстрах','7.6%'],['Загальний податок','22%']],
    salLawRows: [['— ОСНОВНЕ ПРАВИЛО (§ 5-1) —',''],['Оподатковуваний дохід','Будь-яка вигода від роботи, капіталу або підприємництва','Усе, що ви заробляєте на роботі, інвестиціях або бізнесі, оподатковується'],['Також оподатковується','Пенсія, довічна рента, ануїтет'],['Прибуток від реалізації (§ 5-1(2))','Оподатковується (див. розд. 9)','Якщо ви продаєте щось із прибутком, потрібно сплатити податок на приріст'],['Вилучення для власного використання (§ 5-2)','Оподатковується за ринковою вартістю','Якщо ви берете товари з бізнесу для особистого використання, це вважається доходом'],['— ТРУДОВИЙ ДОХІД (§ 5-10) —',''],['Зарплата, гонорар, відпускні','Оподатковується'],['Винагорода правління, тантьєма, чайові','Оподатковується'],['Допомога з безробіття, лікарняні, батьківські','Оподатковується','Державні виплати, що замінюють зарплату, оподатковуються як зарплата'],['Вихідна допомога/звільнення (§ 5-10 d)','Оподатковується'],['Натуральні виплати (§ 5-12)','Оподатковуються за ринковою вартістю','Блага від роботодавця замість грошей — наприклад, телефон, газета, страховка'],['Пільговий кредит від роботодавця (§ 5-12(4))','Вигода = нормативна ставка − фактична ставка','Якщо роботодавець дає кредит нижче ринкової ставки, різниця оподатковується'],['Службовий автомобіль (§ 5-13)','30% від прейскурантної ціни (20% понад поріг)','Якщо маєте службове авто, оподатковується частка від ціни нового автомобіля'],['Авто >3 роки','75% від прейскурантної ціни'],['Опціони на роботі (§ 5-14)','Оподатковуються при реалізації/продажу','Оподатковуються, коли ви використовуєте або продаєте опціон, а не коли отримуєте'],['Опціони стартапів (§ 5-14(2))','Не трудовий дохід (особливі умови)','Пільгові правила для працівників малих компаній віком до 6 років'],['— ДОХІД ВІД КАПІТАЛУ (§ 5-20) —',''],['Дохід від нерухомості/майна','Оподатковується','Орендний дохід від здачі житла, дачі або майна'],['Дохід від фінансових інструментів','Оподатковується','Відсотки, дивіденди та прибуток від акцій, фондів, банківських вкладів'],['Безоплатне користування чужим майном','Оподатковується','Якщо ви безкоштовно користуєтесь житлом тощо, це вважається доходом'],['Позика компанії (§ 5-22)','Додатковий податок, множник ×1.72','Позика від власного ТОВ розглядається як дивіденди і оподатковується відповідно'],['— НЕОПОДАТКОВУВАНЕ (§ 5-15/5-43) —',''],['Допомога на дітей','Не оподатковується'],['Грошова допомога на дитину','Не оподатковується'],['Соціальна допомога','Не оподатковується'],['Базова/додаткова допомога','Не оподатковується'],['Допомога на поховання','Не оподатковується'],['Компенсація шкоди/моральна шкода','Не оподатковується'],['Аліменти на дитину','Не оподатковуються'],['Азартні ігри (Norsk Tipping тощо)','Не оподатковуються','Виграші в Norsk Tipping, Rikstoto та подібних є неоподатковуваними'],['Випадкові виграші (§ 5-50)','Оподатковуються понад 10 000 kr','Виграші в приватних конкурсах, лотереях тощо'],['Споживчі товари (§ 5-21)','Не оподатковуються при особистому використанні','Продаж вживаних особистих речей (меблі, одяг, авто) не оподатковується']],
    salDedRows: [['— ОСНОВНЕ ПРАВИЛО (§ 6-1) —',''],['Право на вирахування','Витрати, понесені для отримання, збереження або забезпечення оподатковуваного доходу','Можна вирахувати витрати, необхідні для заробітку'],['Без вирахування','Приватні витрати (житло, їжа, утримання)','Особисті витрати на проживання ніколи не вираховуються'],['Збиток від реалізації (§ 6-2)','Вирахування за правилами розд. 9','Якщо ви продаєте щось зі збитком, можна вирахувати це з податку'],['Збиток за вимогами (§ 6-2(2))','Вирахування при остаточно підтвердженому збитку в бізнесі','Хтось винен вашому бізнесу гроші і не може заплатити'],['Дефіцит (§ 6-3)','Зараховується проти іншого доходу, переноситься (§ 14-6)','Якщо бізнес у мінусі, можна використати збиток проти іншого доходу або зберегти на майбутнє'],['— МІНІМАЛЬНЕ ВИРАХУВАННЯ (§ 6-30/32) —',''],['Зарплатний дохід','46% від зарплати, макс. 95 700 kr','Усі наймані працівники отримують це автоматично — покриває проїзд, одяг, інструменти тощо'],['Пенсійний дохід','40% від пенсії'],['Замінює','Більшість вирахувань на робочі витрати','Не потрібно документувати окремі витрати при використанні мінімального вирахування'],['Не включає','Профспілковий внесок, витрати маятникової міграції','Ці витрати можна вирахувати додатково до мінімального вирахування'],['— СТАНДАРТНІ ВИРАХУВАННЯ —',''],['Профспілковий внесок (§ 6-20)','Макс. 8 700 kr','Членство в профспілці — LO, YS, Unio, Akademikerne'],['Проїзд дім–робота (§ 6-44)','Понад 12 000 kr, макс. 120 000 kr','Вирахування на відстань понад 37 км в одну сторону (після базового вирахування)'],['Вирахування на дітей (§ 6-48)','Діти до 12 років, ліміт встановлений Стортингом','Покриває витрати на дитячий садок, продовжений день та няню'],['Пожертви організаціям (§ 6-50)','Мін. 500 kr, макс. 25 000 kr','Пожертви затвердженим організаціям — Червоний Хрест, Лікарі без кордонів'],['Вирахування дитячої пенсії (§ 6-49)','До 32 600 kr'],['— ВІДСОТКИ ЗА БОРГОМ (§ 6-40) —',''],['Відсотки за боргом','Повне вирахування (22% податковий ефект)','Усі відсотки — іпотека, студентська позика, автокредит — повертають 22% на податку'],['Обмеження відсотків у концерні (§ 6-41)','25% від EBITDA, поріг 25 млн (концерн) / 5 млн (зовнішній)','Обмежує вирахування відсотків за позиками між компаніями одного концерну'],['Перенесення обмежених відсотків','10 років','Відсотки, не прийняті цього року, можна використати протягом наступних 10 років'],['— ВИРАХУВАННЯ ДЛЯ БІЗНЕСУ —',''],['Амортизація (§ 6-10)','Знос основних засобів, гудвіл при покупці','Розподіляє вартість машин, транспорту тощо на кілька років'],['Обслуговування/страхування (§ 6-11)','Вирахування на основні засоби'],['Дослідження та розробки (§ 6-25)','Частина собівартості основного засобу','Витрати на розробку можна активувати та амортизувати з часом'],['Стартап-компанія (§ 6-53)','До 1 млн kr, компанія ≤6 років, ≥3 роки володіння','Фізичні особи, що інвестують у малі нові компанії, отримують вирахування'],['— БЕЗ ВИРАХУВАННЯ —',''],['Представницькі витрати (§ 6-21)','Ніколи не вираховуються','Обіди з клієнтами, подарунки діловим партнерам тощо'],['Хабарництво (§ 6-22)','Ніколи не вираховується'],['Членський внесок (§ 6-18)','Загалом без вирахування (виняток § 6-19/20)','Виняток для галузевих та професійних організацій'],['— ОПЛАТА ЧЕРЕЗ БАНК (§ 6-51) —',''],['Вимога','Оплата ≥10 000 kr має бути через банк для права на вирахування','Готівкові платежі понад 10 000 kr не дають права на вирахування'],['— ПРОФЕСІЙНІ ВИРАХУВАННЯ —',''],['Вирахування для рибалок (§ 6-60)','30%, макс. 160 000 kr, ≥130 днів','Потрібно щонайменше 130 днів риболовлі на рік'],['Вирахування для моряків (§ 6-61)','30%, макс. 86 300 kr, ≥130 днів','Потрібно щонайменше 130 днів у морі на рік']],
    salRealRows: [['— КОЛИ ВІДБУВАЄТЬСЯ РЕАЛІЗАЦІЯ? —','Основне правило §§ 9-1 та 9-2'],['Що спричиняє оподаткування приросту?','Продаж, обмін, викуп акцій, експропріація, знищення — будь-яке передання за винагороду','§ 9-2(1)'],['Подарунок?','Подарунок не є реалізацією — немає податку для дарувальника','§ 9-2(3)'],['Спадщина?','Не є реалізацією — немає податку на приріст при спадкуванні','§ 9-2(3)'],['Поділ між подружжям?','Не є реалізацією — також при розлученні','§ 9-2(3)'],['Примусовий викуп?','Вважається реалізацією — податковий обов\'язок виникає','§ 9-2(1)'],['— ЗВІЛЬНЕННЯ ДЛЯ ЖИТЛА —','§ 9-3: Коли не платите податок?'],['Продаж власного житла?','Звільнено якщо володіли мін. 1 рік і проживали мін. 1 з останніх 2 років','§ 9-3(2)'],['Продаж дачі?','Звільнено якщо володіли мін. 5 років і використовували мін. 5 з останніх 8 років','§ 9-3(4)'],['Продаж особистих речей?','Звільнено — особисте майно','§ 9-3(1)a'],['Прибуток від ділянки?','Звільнено лише якщо ділянка незначна — інакше оподатковується навіть якщо будинок звільнений','§ 9-3(8)'],['Збиток на звільненому житлі?','Немає відрахування — принцип симетрії','§ 9-4'],['— ЗБИТКИ ПІДЛЯГАЮТЬ ВІДРАХУВАННЮ —','§ 9-4: Принцип симетрії'],['Продаж зі збитком?','Відрахування в тій же мірі, що й відповідний прибуток оподатковувався б','§ 9-4(1)'],['Збиток на акціях?','Повне відрахування — збільшене ×1,72 як прибуток','§ 9-4, § 10-31'],['— ПОЧАТКОВА ВАРТІСТЬ ПРИ СПАДЩИНІ/ДАРУНКУ —','§ 9-7: Принцип безперервності'],['Успадкували щось?','Ви приймаєте початкову вартість спадкодавця — не ринкову вартість','§ 9-7(1)'],['Отримали подарунок?','Той же принцип — приймаєте початкову вартість дарувальника','§ 9-7(1)'],['Виняток — спадкодавець міг продати без податку?','Початкова вартість встановлюється за ринковою вартістю на дату смерті','§ 9-7(2)'],['— ВИВЕДЕННЯ З НОРВЕЗЬКОЇ ЮРИСДИКЦІЇ —','§ 9-14: Податок при виїзді'],['Переміщення активів з Норвегії?','Прихований прибуток оподатковується як при продажу за ринковою вартістю','§ 9-14(1)'],['Включає нематеріальні активи?','Так — патенти, ліцензії, торгові марки тощо','§ 9-14(2)'],['Можна відстрочити?','Так, в ЄЕП — але може вимагатися забезпечення','§ 9-14(4)']],
    salCorpRows: [['— КОНЦЕРННИЙ ВНЕСОК (§ 10-2 до 10-5) —',''],['Концернний внесок (§ 10-2)','Вирахування для донора, оподатковується для одержувача','Переказ між компаніями одного концерну — використовується для вирівнювання результатів'],['Вимога до власності (§ 10-4)','Материнська компанія володіє >90% акцій та голосів','Стосується акціонерних товариств та аналогічних іноземних компаній у ЄЕП'],['— ДИВІДЕНДИ ТА ЗАХИСТ (§ 10-10 до 10-13) —',''],['Дивіденди (§ 10-11)','Оподатковуються для фізичних осіб-акціонерів','Коригуються з множником 1.72 перед оподаткуванням за ставкою 22%'],['Захисне вирахування (§ 10-12)','Вираховується з дивідендів перед оподаткуванням','Не оподатковується частина дивідендів, що відповідає безризиковій ставці'],['Захисна ставка','Державні казначейські векселі після оподаткування','Встановлюється Податковим управлінням щорічно'],['Метод звільнення (§ 2-38)','Неоподатковуване для компаній','ТОВ, що володіє акціями інших ТОВ, звільняється від податку на дивіденди та прибуток'],['Правило 3% (§ 2-38(6))','3% доходу зараховується','Компанії все ж сплачують 0.66% (3% × 22%) від звільнених дивідендів'],['— ПРИБУТОК ТА ЗБИТОК ВІД АКЦІЙ (§ 10-30 до 10-37) —',''],['Прибуток від продажу (§ 10-31)','Оподатковується для фізичних осіб-акціонерів','Коригується з множником 1.72, тобто ефективний податок ~37.84%'],['Збиток від продажу (§ 10-31(2))','Підлягає вирахуванню','Коригується аналогічно з множником 1.72'],['Початкова вартість (§ 10-32)','Собівартість + невикористаний захист','Ціна покупки акції плюс накопичене захисне вирахування'],['Принцип FIFO (§ 10-36)','Першим куплено = першим продано','При продажу частини пакету акцій вважається, що найстаріші акції продані першими'],['— ІНВЕСТИЦІЙНІ ФОНДИ ТА ASK (§ 10-20/10-21) —',''],['Інвестиційний фонд (§ 10-20)','Акціонерна та відсоткова частини оподатковуються по-різному','Акціонерна частина = акціонерна модель, відсоткова = загальний дохід'],['Рахунок заощаджень в акціях (§ 10-21)','Податок відкладається до зняття','Можна купувати та продавати акції/фонди в межах рахунку без сплати податку'],['Оподатковуване зняття (§ 10-21(4))','Зняття понад внесок оподатковується','Податок сплачується лише коли знімаєте більше, ніж внесли'],['— ОПОДАТКУВАННЯ УЧАСНИКІВ ANS/KS (§ 10-40 до 10-49) —',''],['Нетто-метод (§ 10-41)','Прибуток оподатковується у учасників','Кожен учасник сплачує податок зі своєї частки результату компанії'],['Розподіл (§ 10-42)','Оподатковується для фізичної особи-учасника','Коригується з множником 1.72 як дивіденди'],['Прибуток від продажу частки (§ 10-44)','Оподатковується','Розраховується на основі початкової вартості з коригуванням на пере-/недооцінку'],['— КООПЕРАТИВИ (§ 10-50) —',''],['Зворотні виплати (§ 10-50)','Вирахування для кооперативу','Повернення членам на основі обороту з кооперативом'],['— NOKUS / НИЗЬКОПОДАТКОВІ КРАЇНИ (§ 10-60 до 10-68) —',''],['Правила NOKUS (§ 10-60)','Норвезький власник оподатковується поточно','Стосується компаній у низькоподаткових країнах, контрольованих норвезькими власниками'],['Низькоподаткова країна (§ 10-63)','Податок менше 2/3 норвезького','Країна вважається низькоподатковою, якщо ефективний податок нижче ~14.67%'],['Вимога контролю (§ 10-62)','Норвезькі власники мають щонайменше 50%','Контроль оцінюється сукупно для всіх норвезьких платників'],['Кредит на податок (§ 10-65)','Вирахування за сплачений іноземний податок','Запобігає подвійному оподаткуванню шляхом вирахування податку, сплаченого за кордоном'],['— ПОДАТОК ПРИ ЕМІГРАЦІЇ (§ 10-70/10-71) —',''],['Латентний прибуток (§ 10-70)','Оподатковується при виїзді з Норвегії','Стосується акцій, часток та деяких інших активів'],['Відстрочка (§ 10-70(7))','Може бути відстрочена в межах ЄЕП','Платіж відстрочується, але може вимагатися забезпечення'],['Анулювання (§ 10-70(9))','Податок анулюється через 5 років','Якщо ви не реалізували протягом 5 років, податок скасовується'],['— ПОДАТОК У ДЖЕРЕЛА (§ 10-80 до 10-82) —',''],['Податок у джерела на дивіденди','15–25% для іноземних акціонерів','Ставка залежить від податкової угоди з країною акціонера'],['Податок у джерела на відсотки/роялті (§ 10-80)','За правилами, встановленими законом','Стосується платежів пов\'язаним особам у низькоподаткових країнах']],
    salReorgRows: [['— ЗЛИТТЯ (§ 11-2/11-3) —',''],['Акціонерні товариства (§ 11-2)','Неоподатковуване, якщо злиття відповідає Закону про АТ розд. 13','Два або більше ТОВ об\'єднуються без сплати податку'],['Кооперативи (§ 11-2(2))','Неоподатковуване за Законом про кооперативи розд. 8'],['Товариства з оподаткуванням учасників (§ 11-3)','Неоподатковуване при однаковій формі товариства та відповідальності','Учасники повинні отримати частки як винагороду (макс. 20% доплата готівкою)'],['— ПОДІЛ (§ 11-4/11-5) —',''],['Акціонерні товариства (§ 11-4)','Неоподатковуване, якщо поділ відповідає Закону про АТ розд. 14','Компанія ділиться на дві або більше без оподаткування'],['Товариства з оподаткуванням учасників (§ 11-5)','Неоподатковуване при однаковій формі товариства та відповідальності','Макс. 20% винагороди може бути не у формі часток'],['— УМОВИ ТА ПРИНЦИПИ —',''],['Інша винагорода (§ 11-6)','Грошова винагорода акціонеру оподатковується','Лише акції/частки в компаніях, що зливаються, є неоподатковуваними'],['Безперервність (§ 11-7)','Податкові вартості та дати придбання зберігаються','Компанія-правонаступник переймає всі податкові позиції без змін'],['Розподіл при поділі (§ 11-8)','Податкові позиції розподіляються за чистою вартістю'],['Ліквідація (§ 11-9)','Компанія-передавач повинна бути ліквідована після передачі'],['Дата набрання чинності (§ 11-10)','З дати набрання чинності корпоративного права'],['— ТРАНСКОРДОННІ (§ 11-11) —',''],['Злиття/поділ через кордони','Неоподатковуване в межах ЄЕП з безперервністю','Норвезьке ТОВ може зливатися з компанією в іншій державі ЄЕП'],['Обмін акціями (§ 11-11(4))','Неоподатковуване при передачі щонайменше 90% акцій','Макс. 20% грошова винагорода'],['Низькоподаткова країна (§ 11-11(7))','Звільнення не діє щодо низькоподаткових країн','Виняток, якщо реально зареєстровано в державі ЄЕП'],['— ПЕРЕТВОРЕННЯ (§ 11-20) —',''],['В акціонерне товариство','ФОП, ANS, DA тощо можуть бути перетворені без оподаткування','Податкові вартості та позиції зберігаються'],['Передача в концерні (§ 11-21)','Неоподатковувана передача між компаніями одного концерну','Материнська компанія повинна володіти понад 90% акцій'],['Раціоналізація (§ 11-22)','Міністерство може надати звільнення при реорганізації','Стосується продажу нерухомості, бізнесу або акцій']],
    salSubjRows: [['— ФІЗИЧНА ОСОБА-ПЛАТНИК ПОДАТКІВ (§ 2-1) —',''],['Резидент Норвегії (§ 2-1(1))','Оподаткування всіх доходів/активів, у Норвегії та за кордоном','Якщо ви проживаєте в Норвегії, оподатковується все — незалежно від джерела доходу'],['Набуття резидентства (§ 2-1(2))','Перебування >183 днів за 12 міс. або >270 днів за 36 міс.','Якщо ви перебуваєте в Норвегії достатньо довго, ви стаєте податковим резидентом'],['Припинення резидентства (§ 2-1(3))','Потрібне постійне проживання за кордоном + відмова від житла в Норвегії','Ви повинні постійно проживати за кордоном і не мати житла в Норвегії'],['Тимчасова відсутність (§ 2-1(4))','Не перериває податкове резидентство','Відпустка чи короткі перебування за кордоном не змінюють ваше резидентство'],['Шпіцберген (§ 2-1(5))','Окреме законодавство (закон про оподаткування на Шпіцбергені)'],['— СПАДКОВА МАСА (§ 2-2) —',''],['Спадкова маса (§ 2-2)','Окремий суб\'єкт оподаткування у рік смерті та далі','Спадкова маса оподатковується як окрема одиниця до повного розрахунку'],['Розподіл у рік смерті (§ 2-15)','Спадкоємці оподатковуються з 1 січня','Якщо спадщину розподілено у рік смерті, спадкоємці оподатковуються за весь рік'],['— КОМПАНІЇ (§ 2-2) —',''],['Акціонерне товариство (§ 2-2(1)a)','Окремий суб\'єкт оподаткування','ТОВ є самостійним платником податків — оподатковується 22% прибутку'],['Публічне акціонерне товариство (§ 2-2(1)b)','Окремий суб\'єкт оподаткування'],['Ощадний банк, взаємне страхування (§ 2-2(1)c-d)','Окремий суб\'єкт оподаткування'],['Кооперативне підприємство (§ 2-2(1)e)','Окремий суб\'єкт оподаткування'],['Державне підприємство, медичний заклад (§ 2-2(1)g-h)','Окремий суб\'єкт оподаткування'],['Фонди (§ 2-2(1)f)','Окремий суб\'єкт оподаткування'],['Комунальне підприємство (§ 2-2(1)i)','Окремий суб\'єкт оподаткування'],['— ОБМЕЖЕНИЙ ОБОВ\'ЯЗОК ОПОДАТКУВАННЯ (§ 2-3) —',''],['Дохід від нерухомості в Норвегії (§ 2-3(1)a)','Оподатковується','Іноземці, які володіють нерухомістю в Норвегії, оподатковуються за дохід від неї'],['Підприємницька діяльність у Норвегії (§ 2-3(1)b)','Оподатковується','Якщо ви ведете бізнес з Норвегії, ви оподатковуєтесь тут'],['Робота в Норвегії (§ 2-3(1)d)','Оподатковується','Якщо ви працюєте в Норвегії, ви оподатковуєтесь із заробітної плати — також іноземці'],['Дивіденди від норвезької компанії (§ 2-3(1)c)','Податок біля джерела','Іноземні акціонери сплачують податок біля джерела на дивіденди від норвезьких компаній'],['Винагорода директора (§ 2-3(1)e)','Оподатковується','Якщо ви є членом правління норвезької компанії, ви оподатковуєтесь за гонорар'],['Пенсія з Норвегії (§ 2-3(4))','Оподатковується (податок біля джерела)','Також для осіб, які проживають за кордоном'],['Податок на артистів (§ 2-3(1)h)','Оподатковується для іноземних артистів','Окремі правила для оподаткування концертів, виступів тощо'],['— МЕТОД ЗВІЛЬНЕННЯ (§ 2-38) —',''],['Звільнення для компаній (§ 2-38(1))','Дивіденди та прибутки між компаніями звільнені від податку','ТОВ, що володіє акціями іншого ТОВ, зазвичай не оподатковується за дивіденди та прибутки'],['Правило 3% (§ 2-38(6))','3% доходу все одно оподатковується','Компанія фактично оподатковується 0,66% (3% × 22%) звільнених дивідендів'],['Виняток для низькоподаткових країн (§ 2-38(3))','Звільнення не діє для компаній у низькоподаткових країнах','Компанії в країнах з дуже низьким оподаткуванням не підпадають під метод звільнення'],['Портфельний виняток ЄЕП (§ 2-38(3)b)','Звільнення не діє при частці менше 10% за межами ЄЕП','Якщо ви володієте менше 10% компанії за межами ЄЕП, метод звільнення не застосовується'],['— ПОДРУЖЖЯ (§ 2-10 до 2-16) —',''],['Спільне або окреме (§ 2-10)','Подружжя може оподатковуватись спільно або окремо','Ви можете обрати, чи оподатковувати дохід разом чи окремо'],['Розподіл (§ 2-11)','Дохід/відрахування відносяться до того з подружжя, кому вони належать'],['Клас 2 (§ 2-14)','Утримання подружжя з низьким доходом','Дає нижчий податок, якщо один з подружжя має малий або нульовий дохід'],['Спільне житло (§ 2-12)','Спільне оподаткування спільного житла'],['— ДІТИ (§ 2-14) —',''],['Діти до 17 років (§ 2-14(1))','Дохід дітей оподатковується у батьків','Дохід від капіталу дітей до 17 років оподатковується у батьків'],['Трудовий дохід дітей (§ 2-14(3))','Оподатковується у самої дитини','Заробітна плата, зароблена дитиною, оподатковується окремо'],['Майно дітей (§ 2-14(5))','Розподіляється порівну між батьками'],['— ЗВІЛЬНЕНІ УСТАНОВИ (§ 2-30 до 2-32) —',''],['Держава (§ 2-30(1)a)','Звільнена від оподаткування'],['Обласні/муніципальні органи (§ 2-30(1)b-c)','Звільнені від оподаткування'],['Релігійні організації (§ 2-30(1)d)','Звільнені від оподаткування'],['Некомерційні установи (§ 2-32)','Звільнені від оподаткування, якщо дохід не є комерційним','Асоціації, клуби та фонди, що не працюють на прибуток, звільнені від податку'],['Комерційна діяльність (§ 2-32(2))','Оподатковується понад 140 000 kr / 70 000 kr','Якщо дохід від продажу, оренди тощо перевищує порогову суму, необхідно сплачувати податок'],['— ПРАВИЛА РЕЗИДЕНТСТВА КОМПАНІЙ (§ 2-2(6)) —',''],['Зареєстрована в Норвегії','Завжди норвезький суб\'єкт оподаткування','Компанії, зареєстровані в норвезькому реєстрі підприємств, оподатковуються в Норвегії'],['Заснована в Норвегії (§ 2-2(7))','Завжди норвезький суб\'єкт оподаткування'],['Управління в Норвегії (§ 2-2(6))','Може стати норвезьким суб\'єктом оподаткування','Іноземна компанія, яка фактично управляється з Норвегії, може бути оподаткована тут'],['— В\'ЇЗД/ВИЇЗД КОМПАНІЇ (§ 2-2(8)) —',''],['В\'їзд (§ 2-2(8))','Повний податковий обов\'язок з моменту заснування в Норвегії'],['Виїзд (§ 2-2(8))','Розрахунок прихованих прибутків','Компанія повинна розрахувати податкові позиції при виїзді з Норвегії'],['— МІЖНАРОДНЕ (§ 2-37/2-38) —',''],['Кредит на сплачений податок (§ 2-37)','Відрахування за податок, сплачений за кордоном','Уникнення подвійного оподаткування — вираховується іноземний податок з норвезької декларації'],['Податкові угоди','Можуть обмежувати право Норвегії на оподаткування','Норвегія має угоди з багатьма країнами про розподіл права оподаткування']],
    morReqRows: [['Макс. позика','Загальний борг максимум 5× річний дохід','Враховується весь борг — іпотека, студентська позика, автокредит, кредитні картки'],['Власний капітал','Мінімум 10%','Потрібно накопичити щонайменше 10% від вартості житла самостійно'],['Стрес-тест','Найвище з 7% та ставка + 3 в.п.','Банк перевіряє, чи зможете ви платити, навіть якщо ставка зросте'],['Погашення','Вимога при LTV понад 60%','Якщо позика перевищує 60% вартості житла, потрібно платити основну суму'],['Квота гнучкості','Банк може відхилитися для 10% позик','У Києві: максимум 8% — означає, що банк може сказати так, навіть якщо не всі умови виконані']],
    morCostRows: [['Ставка зараз','Прибл. 5,1% плаваюча (січ. 2026)'],['Податкове вирахування','22% від витрат на відсотки','Повертається 22% від сплачених відсотків через податок'],['Гербовий збір','Зазвичай 2,5% від ринкової вартості','Сплачується при купівлі нерухомості — можливі винятки']],
    morBsuRows: [['Макс. річна економія','27 500 kr'],['Макс. загальна сума','300 000 kr'],['Податкове вирахування','10% від внесеної суми — до 2 750 kr/рік'],['Вікова межа','До включно року, коли вам виповниться 33 років'],['Умова для податкового вирахування','Ви повинні мати оподатковуваний трудовий дохід і не бути власником житла'],['На що можна витратити гроші?','Купівля, погашення, поліпшення або утримання власного житла'],['Порушення умов?','Якщо ви витратите гроші на щось інше, крім житла, ви повинні повернути все податкове вирахування']],
    morBsuTitle:'BSU — Житлові заощадження для молоді', morBsuDesc:'Податкове вирахування, ліміти заощаджень, вікова межа, умови використання',
    morReqTitle:'Вимоги до іпотеки', morReqDesc:'Власний капітал, коефіцієнт боргу, стрес-тест, погашення',
    morCostTitle:'Витрати на придбання житла', morCostDesc:'Ставка, податкове вирахування, гербовий збір',
    npvInfoRows: [['— ПОЯСНЕННЯ ТЕРМІНІВ —',''],['NPV (чиста теперішня вартість)','Теперішня вартість майбутніх грошових потоків мінус інвестиція'],['IRR (внутрішня норма прибутку)','Ставка, при якій NPV = 0'],['WACC','Середньозважена вартість капіталу'],['— ІНТЕРПРЕТАЦІЯ —',''],['NPV > 0','Прибутковий — прийняти інвестицію'],['NPV < 0','Збитковий — відхилити'],['IRR > WACC','Проєкт створює вартість'],['IRR < WACC','Проєкт знищує вартість'],['— ДОВІДКА —',''],['Ставка дисконтування','Зазвичай WACC (до оподаткування)'],['Типовий WACC','8–12%'],['Термін окупності','Коротший — краще']],
    vatSubjRows: [['— БАЗОВІ УМОВИ —','Три речі повинні бути виконані для податкової відповідальності'],['1. Комерційна діяльність','Ви повинні здійснювати комерційну діяльність — не хобі або роботу найманого працівника','§ 2-1(1)'],['2. Поставка товарів/послуг','Повинна бути транзакція — поставка за винагороду (платіж)','§ 1-3(1)a'],['3. Поріг обороту','Оборот, що перевищує 50 000 kr протягом 12 місяців','§ 2-1(1)'],['— ХТО ПОВИНЕН ЗАРЕЄСТРУВАТИСЯ? —',''],['Комерційні підприємства понад 50 000 kr','Повинні зареєструватися в Реєстрі ПДВ','§ 2-1(1)'],['Благодійні організації','Вищий поріг: 140 000 kr','§ 2-1(1)'],['Спортивні заходи','Окремий поріг: 3 000 000 kr','§ 2-1(1)'],['— КЛЮЧОВІ ПОНЯТТЯ —',''],['Що таке « комерційна діяльність »?','Самостійна, постійна діяльність економічного характеру та здатна генерувати прибуток. Хобі та разові завдання — звичайно не комерційна діяльність.'],['Що таке « оборот »?','Поставка товарів або послуг за винагороду. Подарунки, компенсація та гранти — звичайно не оборот.','§ 1-3(1)a'],['Що таке « платник податків »?','Суб\'єкт, зареєстрований (або зобов\'язаний зареєструватися) в Реєстрі ПДВ, зобов\'язаний розраховувати та сплачувати ПДВ.','§ 1-3(1)d'],['Добровільна реєстрація?','Власники комерційної нерухомості можуть добровільно зареєструватися, щоб отримати право на вирахування вхідного ПДВ.','§ 2-3']],
    vatSubjTitle:'Хто є платником ПДВ?', vatSubjDesc:'Комерційна діяльність · Поріг обороту · Обов\'язок реєстрації',
    vatRates: [['25','25% Стандартна — товари та послуги (§ 5-1)'],['15','15% Харчові продукти (§ 5-2)'],['12','12% Транспорт, готелі, кіно (§ 5-3/5-5/5-6)'],['0','0% Звільнено — газети, книги, експорт (розд. 6)']],
    vatInfoRows: [['— СТАВКИ —',''],['Загальна ставка (§ 5-1)','25%'],['Харчові продукти (§ 5-2)','15%'],['Пасажирський транспорт (§ 5-3)','12%'],['Оренда готельних номерів (§ 5-5)','12%'],['Кіно (§ 5-6)','12%'],['Музеї/галереї (§ 5-9)','12%'],['Парки розваг (§ 5-10)','12%'],['Спортивні заходи (§ 5-11)','12%'],['Водопостачання/каналізація (§ 5-12)','12%'],['Громадське харчування (§ 5-2)','25% (не 15%)'],['— РЕЄСТРАЦІЯ —',''],['Підприємці (§ 2-1)','50 000 kr / 12 міс.'],['Благодійні організації (§ 2-1)','140 000 kr / 12 міс.'],['Спортивні заходи (§ 2-1)','3 000 000 kr'],['— ТЕРИТОРІЯ —',''],['Географічна (§ 1-2)','Материкова Норвегія + територіальні води'],['Не зона ПДВ','Шпіцберген, Ян-Маєн, залежні території']],
    vatLawRows: [['— ВИНЯТОК (розд. 3) —','Поза законом, без права на вирахування'],['Медичні послуги (§ 3-2)','Виняток','Лікар, стоматолог, фізіотерапевт тощо — без ПДВ і без права на вирахування'],['Соціальні послуги (§ 3-4)','Виняток','Захист дітей, догляд за літніми, лікування залежностей тощо'],['Освіта (§ 3-5)','Виняток','Школа, курси, навчання — як державні, так і приватні'],['Фінансові послуги (§ 3-6)','Виняток','Банк, страхування, торгівля цінними паперами — без ПДВ'],['Мистецтво/культура — виступи (§ 3-7)','Виняток','Концерт, театр, танці — квитки без ПДВ'],['Спорт — право на заняття (§ 3-8)','Виняток','Тренажерний зал, футбольне поле, басейн тощо'],['Державна влада (§ 3-9)','Виняток'],['Нерухомість/оренда (§ 3-11)','Виняток (виняток у (2))','Оренда житла та комерційної нерухомості — виняток, але можлива добровільна реєстрація для комерційної'],['Благодійні організації (§ 3-12)','Виняток (деякі продажі)','Блошині ринки, базари тощо від благодійних організацій'],['Ідейні організації — внесок (§ 3-13)','Виняток'],['Азартні ігри (§ 3-14)','Виняток'],['Поховання — церемонія (§ 3-15)','Виняток'],['Винагорода правління (§ 3-17)','Виняток (з ЄСВ)','Винагорода правління звільнена від ПДВ, але роботодавець сплачує внесок'],['Вживані приватні товари (§ 3-19)','Виняток','Приватні особи, що продають вживані речі, не нараховують ПДВ'],['— ЗВІЛЬНЕННЯ (розд. 6) —','Підпадає під закон, 0% вихідного ПДВ, право на вирахування'],['Газети (§ 6-1)','Звільнено'],['Журнали (§ 6-3)','Звільнено (останній пункт)'],['Книги (§ 6-4)','Звільнено (останній пункт)'],['Електроенергія домогосп. Півн. Норвегія (§ 6-6)','Звільнено'],['Електромобіль ≤300 000 kr (§ 6-8)','Звільнено','Стосується лише суми покупки до 300 000 kr — понад це нараховується 25% ПДВ'],['Судна ≥15 м (§ 6-9)','Звільнено'],['Повітряні судна для бізнесу (§ 6-10)','Звільнено'],['Передача бізнесу (§ 6-14)','Звільнено','При продажу цілого бізнесу історія ПДВ передається — без ПДВ на продаж'],['Експорт товарів (§ 6-21)','Звільнено','Експорт за кордон — 0% ПДВ, але повне право на вирахування вхідного'],['Експорт послуг (§ 6-22)','Звільнено'],['Транспорт до/з-за кордону (§ 6-28)','Звільнено'],['— ВИЛУЧЕННЯ (розд. 3 ч. II) —',''],['Вилучення товарів (§ 3-21)','Обкладається ПДВ','Якщо берете товари з бізнесу для себе, потрібно нарахувати ПДВ'],['Вилучення послуг приватно (§ 3-22)','Обкладається ПДВ'],['Харчування/натуральне госп./представн. (§ 3-23)','Обкладається ПДВ'],['— ІМПОРТ (розд. 3 ч. III) —',''],['Імпорт товарів (§ 3-29)','Обкладається ПДВ','Імпорт товарів — ПДВ нараховується при розмитненні'],['Дистанційні послуги (§ 3-30)','Зворотне нарахування','При купівлі цифрових послуг з-за кордону ви нараховуєте ПДВ самостійно']],
    vatDefRows: [['Оборот (a)','Постачання товарів/послуг за винагороду','Обмінюєте щось на гроші — це оборот'],['Товари (b)','Фізичні предмети, нерухомість, електроенергія, вода, газ, тепло, холод'],['Послуги (c)','Все, що може продаватися і не є товарами','Консультації, перукар, транспорт, ремонт тощо'],['Суб\'єкт оподаткування (d)','Зареєстрований/зобов\'язаний до реєстрації в реєстрі ПДВ','Підприємства з оборотом понад 50 000 kr за 12 місяців'],['Вихідний ПДВ (e)','Нараховується при обороті та вилученні','ПДВ, який ви додаєте до ціни та стягуєте з клієнта'],['Вхідний ПДВ (f)','Нараховано при купівлі або імпорті','ПДВ, який ви сплачуєте при купівлі товарів/послуг для бізнесу'],['Виняток із закону (g)','Оборот не охоплений законом → без права на вирахування','Бізнес не може вирахувати ПДВ на покупки, пов\'язані з виключеним оборотом'],['Звільнення від ПДВ (h)','Охоплено законом, але 0% вихідного ПДВ → повне право на вирахування','Експорт звільнений — ви не додаєте ПДВ, але можете вирахувати вхідний'],['Дистанційні послуги (i)','Не прив\'язані до конкретного фізичного місця','IT-послуги, онлайн-консультації, стримінг тощо'],['Електронні послуги (j)','Дистанційні, через інтернет, автоматизовані','Додатки, електронні книги, стримінг, онлайн-курси']],
    vatDedRows: [['Основне правило (§ 8-1)','Вирахування вхідного ПДВ для зареєстрованого бізнесу','Повертається ПДВ на все, що купуєте для бізнесу'],['Подвійне використання (§ 8-2)','Пропорційне вирахування за очікуваним використанням','Якщо щось використовується 60% для бізнесу і 40% приватно — 60% вирахування'],['Без вирахування: харчування (§ 8-3 a)','','Їжа та напої для працівників, клієнтів тощо'],['Без вирахування: представництво (§ 8-3 e)','','Обіди з клієнтами, заходи для ділових партнерів'],['Без вирахування: подарунки (§ 8-3 f)','Не мізерної вартості','Подарунки понад мізерну суму не дають вирахування'],['Без вирахування: житло/добробут (§ 8-3 g)','Виняток: їдальні підприємства'],['Легковий транспорт (§ 8-4)','Без вирахування (виняток: оренда, таксі, продаж)','Службове авто не дає вирахування ПДВ, якщо не використовується для оренди або перевезення'],['Оплата через банк (§ 8-8)','Вимога при ≥10 000 kr','Готівкові платежі понад 10 000 kr не дають вирахування ПДВ']],
    vatAdjRows: [['Капітальний актив — обладнання (§ 9-1 a)','Вхідний ПДВ ≥50 000 kr','Машини, транспорт тощо з ПДВ понад 50 000 kr'],['Капітальний актив — нерухомість (§ 9-1 b)','Вхідний ПДВ ≥100 000 kr','Будівлі, споруди тощо з ПДВ понад 100 000 kr'],['Період коригування — обладнання (§ 9-4)','5 років','Якщо змінюється використання протягом 5 років, вирахування ПДВ коригується'],['Період коригування — нерухомість (§ 9-4)','10 років','Якщо змінюється використання протягом 10 років, вирахування ПДВ коригується']],
    vatCalcRows: [['Основне правило (§ 4-1)','Винагорода без ПДВ'],['Бартер (§ 4-3)','Звичайна ринкова вартість','При бартері ринкова ціна використовується як база для ПДВ'],['Пов\'язані сторони (§ 4-4)','Не нижче звичайної ринкової вартості','Якщо продаєте дешево власній компанії, ПДВ нараховується від ринкової ціни'],['Збиток за вимогами (§ 4-7)','Можна скоригувати остаточно втрачену вимогу','Клієнт не платить — тоді можна повернути сплачений ПДВ']],
    vatRegRows: [['Спільна реєстрація (§ 2-2)','≥85% власності, солідарна відповідальність','Компанії концерну можуть бути зареєстровані як один суб\'єкт ПДВ'],['Добровільна реєстрація оренди (§ 2-3)','Будівлі/споруди для зареєстрованого орендаря','Орендодавець отримує вирахування ПДВ на ремонт/будівництво, коли орендар зареєстрований'],['Попередня реєстрація (§ 2-4)','Значні придбання до початку обороту','Нове підприємство може зареєструватися до досягнення обороту 50 000 kr']],
