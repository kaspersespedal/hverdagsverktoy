          <div class="card-hdr" style="cursor:pointer" onclick="toggleCard(this.parentElement)"><div class="card-ico gold">📋</div><div><div class="card-title" id="vat-info-title">Tax Rates Reference <span style="font-size:11px;opacity:.5">▼</span></div><div class="card-desc" id="vat-info-desc">Official rates for selected region</div></div></div>
