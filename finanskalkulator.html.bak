    salInfoRows: [['Personfradrag','114 540 kr'],['Minstefradrag (maks)','95 700 kr'],['Trinnskatt 1 (226k+)','1.7%'],['Trinnskatt 2 (318k+)','4.0%'],['Trinnskatt 3 (725k+)','13.7%'],['Trinnskatt 4 (980k+)','16.8%'],['Trinnskatt 5 (1 467k+)','17.8%'],['Trygdeavgift','7.6%'],['Alminnelig skatt','22%']],
    salLawRows: [['— HVA ER SKATTEPLIKTIG INNTEKT? —','Hovedregelen i § 5-1'],['Tjener du penger?','Enhver fordel vunnet ved arbeid, kapital eller virksomhet er skattepliktig','§ 5-1'],['Pensjon, føderåd, livrente?','Også skattepliktig','§ 5-1'],['Solgte du noe med fortjeneste?','Gevinsten er skattepliktig','§ 5-1(2), kap. 9'],['Tar du varer fra bedriften til privat bruk?','Regnes som inntekt til omsetningsverdi','§ 5-2'],['— HVA BESKATTES FRA JOBBEN? —','§ 5-10 til 5-14'],['Lønn, honorar, feriepenger','Skattepliktig','§ 5-10'],['Styrehonorar, tantieme, tips','Skattepliktig','§ 5-10'],['Dagpenger, sykepenger, foreldrepenger?','Beskattes som lønn — offentlige ytelser som erstatter lønn','§ 5-10'],['Sluttvederlag ved oppsigelse?','Skattepliktig','§ 5-10 d'],['Goder fra arbeidsgiver (telefon, forsikring)?','Skattepliktig til omsetningsverdi','§ 5-12 — naturalytelser'],['Lån fra arbeidsgiver under markedsrente?','Du skattes av differansen mellom normrente og faktisk rente','§ 5-12(4)'],['Har du firmabil?','30 % av listepris beskattes (20 % over terskel, 75 % for bil over 3 år)','§ 5-13'],['Aksjeopsjoner fra jobben?','Beskattes når du bruker eller selger opsjonen — ikke når du får den','§ 5-14'],['Opsjoner i oppstartsselskap?','Gunstigere regler for ansatte i selskaper under 6 år','§ 5-14(2)'],['— HVA MED KAPITALINNTEKTER? —','§ 5-20 til 5-22'],['Leieinntekter?','Skattepliktig — gjelder bolig, hytte og løsøre','§ 5-20'],['Renter, utbytte, aksjegevinst?','Skattepliktig','§ 5-20'],['Bruker du andres ting gratis?','Regnes som skattepliktig inntekt','§ 5-20'],['Låner du penger fra eget AS?','Behandles som utbytte og oppjusteres ×1,72','§ 5-22'],['— HVA ER SKATTEFRITT? —','§ 5-15, § 5-43'],['Barnetrygd, kontantstøtte, sosialhjelp','Skattefri','§ 5-43'],['Grunnstønad, hjelpestønad, gravferdsstønad','Skattefri','§ 5-43'],['Menerstatning og oppreisning','Skattefri','§ 5-43'],['Barnebidrag','Skattefri','§ 5-43'],['Gevinst fra Norsk Tipping, Rikstoto?','Skattefri','§ 5-15'],['Andre gevinster (private lotterier o.l.)?','Skattepliktig over 10 000 kr','§ 5-50'],['Selger du brukte private ting?','Skattefritt — møbler, klær, bil o.l.','§ 5-21']],
    salDedRows: [['— HVA KAN DU TREKKE FRA? —','Hovedregelen i § 6-1'],['Kostnader for å tjene penger?','Fradragsberettiget — gjelder alt som trengs for å erverve, vedlikeholde eller sikre inntekt','§ 6-1'],['Private utgifter (bolig, mat)?','Aldri fradrag','§ 6-1'],['Solgte du noe med tap?','Fradrag etter reglene i kap. 9','§ 6-2'],['Kunder som ikke betaler?','Fradrag ved endelig konstatert tap på fordring i virksomhet','§ 6-2(2)'],['Gikk bedriften i minus?','Underskuddet motregnes mot annen inntekt, eller fremføres til senere år','§ 6-3, § 14-6'],['— MINSTEFRADRAG —','Automatisk fradrag du slipper å dokumentere'],['Lønnsinntekt','46 % av lønn, maks 95 700 kr','§ 6-30/32'],['Pensjonsinntekt','40 % av pensjon','§ 6-30/32'],['Hva dekker det?','Erstatter de fleste fradrag for arbeidskostnader — du trenger ikke kvitteringer','§ 6-30'],['Hva kommer i tillegg?','Fagforeningskontingent og pendlerkostnader kan trekkes fra utover minstefradrag'],['— VANLIGE FRADRAG —',''],['Fagforeningskontingent?','Maks 8 700 kr','§ 6-20'],['Lang reisevei til jobb?','Fradrag over 12 000 kr, maks 120 000 kr (over 37 km én vei)','§ 6-44'],['Barnehage, SFO, dagmamma?','Foreldrefradrag for barn under 12 år','§ 6-48'],['Gir du til veldedige organisasjoner?','Fradrag 500–25 000 kr til godkjente org.','§ 6-50'],['Barnepensjon?','Fradrag inntil 32 600 kr','§ 6-49'],['— GJELDSRENTER —','Renter du betaler gir 22 % tilbake på skatten'],['Boliglån, studielån, billån?','Fullt fradrag — 22 % skatteeffekt','§ 6-40'],['Lån mellom selskaper i konsern?','Begrenset til 25 % av EBITDA (terskel 25M / 5M)','§ 6-41'],['Avskåret rente?','Kan fremføres i 10 år','§ 6-41'],['— FRADRAG I VIRKSOMHET —',''],['Maskiner, kjøretøy, utstyr?','Avskrives over flere år etter saldometoden','§ 6-10'],['Vedlikehold og forsikring?','Fradrag for driftsmidler','§ 6-11'],['Forskning og utvikling?','Kan aktiveres og avskrives over tid','§ 6-25'],['Investerer du i oppstartsselskap?','Fradrag inntil 1M kr (selskap ≤ 6 år, ≥ 3 års eiertid)','§ 6-53'],['— HVA GIR ALDRI FRADRAG? —',''],['Kundemiddager og representasjon','Aldri fradrag','§ 6-21'],['Bestikkelse','Aldri fradrag','§ 6-22'],['Foreningskontingent (generelt)','Ikke fradrag — unntak for bransje- og yrkesforeninger','§ 6-18/19/20'],['— BETALING VIA BANK —',''],['Betaling over 10 000 kr?','Må gå via bank for å få fradrag — kontant gir ikke fradragsrett','§ 6-51'],['— YRKESFRADRAG —',''],['Fisker?','30 %, maks 160 000 kr (minst 130 dager)','§ 6-60'],['Sjømann?','30 %, maks 86 300 kr (minst 130 dager)','§ 6-61']],
    salRealRows: [['— NÅR HAR DU REALISERT? —','Hovedregelen i § 9-1 og § 9-2'],['Hva utløser gevinstbeskatning?','Salg, bytte, innløsning av aksjer, ekspropriasjon, ødeleggelse — enhver overføring mot vederlag','§ 9-2(1)'],['Gir du bort noe?','Gave er ikke realisasjon — ingen skatt for giver','§ 9-2(3)'],['Arv?','Ikke realisasjon — ingen gevinstskatt ved arv','§ 9-2(3)'],['Skifte mellom ektefeller?','Ikke realisasjon — heller ikke ved separasjon/skilsmisse','§ 9-2(3)'],['Hva med tvangsinnløsning?','Regnes som realisasjon — skatteplikt utløses','§ 9-2(1)'],['— SKATTEFRITAK PÅ BOLIG —','§ 9-3: Når slipper du gevinstskatt?'],['Solgt egen bolig?','Skattefritt hvis du har eid i minst 1 år og bodd der i minst 1 av de 2 siste årene','§ 9-3(2)'],['Solgt fritidsbolig?','Skattefritt hvis du har eid i minst 5 år og brukt den i minst 5 av de siste 8 årene','§ 9-3(4)'],['Solgt innbo og løsøre?','Skattefritt — personlige eiendeler','§ 9-3(1)a'],['Tomtegevinst?','Skattefritt bare hvis tomten er ubetydelig — ellers beskattes det som tomtesalg selv om huset er fritatt','§ 9-3(8): Tomteunntaket'],['Tap på bolig som ville vært fritatt?','Ingen fradrag — symmetriprinsippet: fritatt gevinst = ikke fradrag for tap','§ 9-4'],['— TAP GIR FRADRAG —','§ 9-4: Symmetriprinsippet'],['Solgt noe med tap?','Fradrag i samme utstrekning som tilsvarende gevinst ville vært skattepliktig','§ 9-4(1)'],['Solgt aksjer med tap?','Fullt fradrag — oppjusteres ×1,72 som gevinst','§ 9-4, § 10-31'],['— INNGANGSVERDI VED ARV OG GAVE —','§ 9-7: Kontinuitetsprinsippet'],['Arvet du noe?','Du trer inn i arvelaters inngangsverdi — ikke markedsverdi på arvstidspunktet','§ 9-7(1)'],['Fikk du gave?','Samme prinsipp — givers inngangsverdi overtas','§ 9-7(1)'],['Unntak ved arvelaters skattefritak?','Hvis arvelater selv kunne solgt skattefritt (bolig), settes inngangsverdi til markedsverdi','§ 9-7(2)'],['— UTTAK FRA NORSK BESKATNINGSOMRÅDE —','§ 9-14: Exit-skatt på eiendeler'],['Flytter du eiendeler ut av Norge?','Latent gevinst beskattes som om eiendelen var solgt til markedsverdi','§ 9-14(1)'],['Gjelder det også immaterielle rettigheter?','Ja — patenter, lisenser, varemerker o.l.','§ 9-14(2)'],['Kan skatten utsettes?','Ja, innen EØS — men krav om sikkerhetsstillelse kan gjelde','§ 9-14(4)']],
    salCorpRows: [['— KONSERNBIDRAG —','Hvordan jevne ut resultater i et konsern?'],['Hva er konsernbidrag?','Overføring mellom konsernselskaper — fradrag for giver, skattepliktig for mottaker','§ 10-2'],['Krav til eierskap?','Morselskap må eie over 90 % av aksjene og stemmene','§ 10-4'],['— UTBYTTE OG SKJERMING —','Hvordan beskattes utbytte til personlige aksjonærer?'],['Mottar du utbytte?','Oppjusteres ×1,72 før beskatning med 22 %','§ 10-11'],['Hva er skjermingsfradrag?','Du skatter ikke på den delen av utbyttet som tilsvarer risikofri rente','§ 10-12'],['Hvordan fastsettes skjermingsrenten?','Basert på statskasseveksler etter skatt — fastsettes årlig','§ 10-12'],['Utbytte mellom selskaper?','Skattefritt etter fritaksmetoden','§ 2-38'],['3 %-regelen?','Selskapet inntektsfører likevel 3 % — effektiv skatt 0,66 %','§ 2-38(6)'],['— AKSJEGEVINST OG -TAP —','Hva skjer når du selger aksjer?'],['Solgte du aksjer med gevinst?','Oppjusteres ×1,72 — effektiv skatt ca. 37,84 %','§ 10-31'],['Solgte du med tap?','Fradragsberettiget — oppjusteres tilsvarende ×1,72','§ 10-31(2)'],['Hva er inngangsverdien?','Det du betalte + eventuelt ubenyttet skjermingsfradrag','§ 10-32'],['Hvilke aksjer anses solgt først?','FIFO — først kjøpt, først solgt','§ 10-36'],['— VERDIPAPIRFOND OG ASK —','Sparing i fond og aksjesparekonto'],['Hvordan beskattes fond?','Aksjedel følger aksjonærmodellen, rentedel beskattes som alminnelig inntekt','§ 10-20'],['Aksjesparekonto (ASK)?','Du kan kjøpe og selge innenfor kontoen uten å utløse skatt','§ 10-21'],['Når skatter du på ASK?','Først når du tar ut mer enn du har satt inn','§ 10-21(4)'],['— ANS, KS OG DELTAKERFASTSETTING —','Slik beskattes deltakere i ansvarlige selskaper'],['Hvem skatter av overskuddet?','Hver deltaker skatter for sin andel (nettometoden)','§ 10-41'],['Utdeling til personlig deltaker?','Skattepliktig — oppjusteres ×1,72 som utbytte','§ 10-42'],['Salg av andel?','Skattepliktig — beregnes ut fra inngangsverdi med justeringer','§ 10-44'],['— SAMVIRKEFORETAK —',''],['Etterbetalinger til medlemmer?','Fradrag for foretaket — basert på omsetning med medlemmene','§ 10-50'],['— NOKUS OG LAVSKATTLAND —','Norske eiere i utenlandske selskaper'],['Eier du selskap i lavskattland?','Du skattlegges løpende i Norge (NOKUS-reglene)','§ 10-60'],['Hva er et lavskattland?','Land med effektiv skatt under ca. 14,67 % (2/3 av norsk skatt)','§ 10-63'],['Kontrollkrav?','Norske eiere må ha minst 50 % samlet','§ 10-62'],['Betalt skatt i utlandet?','Kreditfradrag — unngår dobbeltbeskatning','§ 10-65'],['— UTFLYTTINGSSKATT —','Flytter du eller selskapet fra Norge?'],['Latente gevinster på aksjer?','Skattepliktig ved utflytting','§ 10-70'],['Kan skatten utsettes?','Ja, innen EØS — men sikkerhetsstillelse kan kreves','§ 10-70(7)'],['Faller skatten bort?','Etter 5 år uten realisasjon','§ 10-70(9)'],['— KILDESKATT —','Skatt for utenlandske aksjonærer og mottakere'],['Utbytte til utenlandsk aksjonær?','15–25 % kildeskatt — avhenger av skatteavtale','§ 10-80 til 10-82'],['Renter/royalty til lavskattland?','Kildeskatt etter egne regler','§ 10-80']],
    salReorgRows: [['— FUSJON —','Slå sammen selskaper uten skatt'],['Fusjon av AS?','Skattefri når fusjonen følger aksjeloven kap. 13','§ 11-2'],['Samvirkeforetak?','Skattefri etter samvirkeloven kap. 8','§ 11-2(2)'],['ANS, KS og lignende?','Skattefri ved samme selskaps- og ansvarsform (maks 20 % kontantvederlag)','§ 11-3'],['— FISJON —','Dele opp et selskap uten skatt'],['Fisjon av AS?','Skattefri når fisjonen følger aksjeloven kap. 14','§ 11-4'],['ANS, KS og lignende?','Skattefri ved samme selskaps- og ansvarsform (maks 20 % i annet vederlag)','§ 11-5'],['— VILKÅR OG PRINSIPPER —','Hva gjelder ved fusjon og fisjon?'],['Får aksjonærene kontanter?','Kontantvederlag er skattepliktig — kun aksjer/andeler er skattefrie','§ 11-6'],['Hva skjer med skatteposisjonene?','Videreføres uendret til overtakende selskap (kontinuitet)','§ 11-7'],['Hvordan fordeles posisjoner ved fisjon?','Etter nettoverdier','§ 11-8'],['Hva skjer med overdragende selskap?','Må oppløses etter overdragelsen','§ 11-9'],['Når får det virkning?','Fra selskapsrettslig ikrafttredelse','§ 11-10'],['— OVER LANDEGRENSENE —','Fusjon, fisjon og aksjebytte innen EØS'],['Fusjon/fisjon med utenlandsk selskap?','Skattefri innen EØS med kontinuitet','§ 11-11'],['Aksjebytte?','Skattefri ved overføring av minst 90 % av aksjene (maks 20 % kontant)','§ 11-11(4)'],['Mot lavskattland?','Skattefritaket gjelder ikke — unntak hvis reelt etablert i EØS','§ 11-11(7)'],['— OMDANNING —','Endre selskapsform skattefritt'],['ENK, ANS eller DA til AS?','Kan omdannes skattefritt — verdier og posisjoner videreføres','§ 11-20'],['Overføring innen konsern?','Skattefri når morselskap eier over 90 %','§ 11-21'],['Rasjonalisering?','Departementet kan gi skattefritak ved salg av eiendom, virksomhet eller aksjer','§ 11-22']],
    salAntiRows: [['— INTERESSEFELLESSKAP —','Armlengdeprinsippet (§ 13-1)'],['Hva er interessefellesskap?','Når to parter har felles eierinteresser eller kontroll som påvirker transaksjoner mellom dem','§ 13-1(1)'],['Hva skjer hvis prisen er feil?','Skatteetaten kan fastsette inntekt/formue ved skjønn — som om interessefellesskapet ikke fantes','§ 13-1(3)'],['Part utenfor EØS?','Omvendt bevisbyrde — du må bevise at prisen er riktig','§ 13-1(2)'],['Hva er armlengdeprinsippet?','Transaksjoner mellom nærstående skal prises som mellom uavhengige parter','§ 13-1(4)'],['Hvilke retningslinjer gjelder?','OECDs retningslinjer for internprising legges til grunn','§ 13-1(4)'],['— OMGÅELSESNORMEN —','Den lovfestede gjennomskjæringsregelen (§ 13-2)'],['Hva er omgåelse?','Når en disposisjon primært er motivert av skattefordeler og ikke tåler en totalvurdering','§ 13-2(2)'],['Vilkår 1: Hovedformål?','Skattefordel må ha vært det overveiende formålet med disposisjonen','§ 13-2(2)a'],['Vilkår 2: Totalvurdering?','Disposisjonen vurderes helhetlig — forretningsmessig egenverdi, skattefordelens størrelse, om det var en uhensiktsmessig vei, og om regler er utnyttet i strid med formålet','§ 13-2(3) a–f'],['Hva skjer ved omgåelse?','Skattlegging gjennomføres etter disposisjonens økonomiske innhold — ikke formen','§ 13-2(4)'],['Gjelder det bare inntektsskatt?','Nei — også trygdeavgift, arbeidsgiveravgift og finansskatt','§ 13-2(7)'],['— SKATTEPOSISJONER UTEN TILKNYTNING —','Underskudd, tom positiv saldo o.l. (§ 13-3)'],['Hva er en generell skatteposisjon?','Underskudd til fremføring, tom positiv saldo, saldo på gevinst- og tapskonto — posisjoner uten tilknytning til konkret eiendel','§ 13-3'],['Når faller posisjonen bort?','Ved omorganisering (kap. 11) eller eierbytte der utnyttelse av posisjonen er det overveiende motivet','§ 13-3 a'],['Hva med skatteforpliktelser?','Inntektsføres uten rett til avregning mot underskudd — og kan ikke danne grunnlag for konsernbidrag','§ 13-3 b'],['Hvem gjelder dette for?','Selskaper etter § 2-2 (AS, ASA mv.) som er part i omorganisering eller får endret eierforhold','§ 13-3']],
    salKeyRows: [['— ARBEID, KAPITAL ELLER VIRKSOMHET? —','§ 5-1: Hvorfor grensen mellom disse tre avgjør hvor mye skatt du betaler'],['Arbeidsinntekt','Personlig innsats for andre. Lønn, honorar, styrehonorar, naturalytelser. Gir personinntekt → trinnskatt + trygdeavgift (7,6 %).','§ 5-10'],['Kapitalinntekt','Avkastning på noe du eier — renter, utbytte, leieinntekt, aksjegevinst. Kun 22 % alminnelig skatt. Ingen trygdeavgift, ingen trinnskatt.','§ 5-20'],['Virksomhetsinntekt','Skatteloven definerer ikke «virksomhet» direkte. Det vurderes konkret ut fra fire vilkår:'],['1. Varighet','Aktiviteten må ha en viss varighet — ikke bare et enkeltstående salg.'],['2. Omfang','Det må være et visst omfang. Én utleiebolig er normalt kapital. Ti utleieboliger med aktiv drift kan bli virksomhet.'],['3. Egnet til overskudd','Aktiviteten må objektivt sett kunne gå i pluss over tid. Ren hobby er ikke virksomhet.'],['4. Egen regning og risiko','Du bærer selv den økonomiske risikoen. Skiller virksomhet fra ansettelsesforhold.'],['Hvorfor spiller grensen rolle?','Virksomhet i ENK gir personinntekt → trinnskatt + trygdeavgift (7,6 %). Kapitalinntekt gir kun 22 %. Forskjellen kan være hundretusener på samme beløp.'],['Typisk gråsone?','Utleie av eiendom. Få enheter med lite arbeid = kapital. Mange enheter med aktiv drift = virksomhet. Omfanget av din personlige innsats avgjør.'],['— REALISASJONSBEGREPET —','§ 9-2: Hva utløser gevinstskatt — og hva gjør det ikke?'],['Hva er realisasjon?','Overføring av eiendomsrett mot vederlag: salg, bytte, innløsning, ekspropriasjon, ødeleggelse. Gjelder alle typer formuesobjekter.','§ 9-2(1)'],['Hva er IKKE realisasjon?','Gave, arv, skifte ved samlivsbrudd, overføring mellom ektefeller. Ingen av disse utløser gevinstskatt.','§ 9-2(3)'],['Boligregelen?','Gevinst ved salg av egen bolig er skattefri hvis du har eid i minst 1 år og bodd der minst 1 av de siste 2 årene. Fritidsbolig: eid 5 år, brukt 5 av 8.','§ 9-3(2)/(4)'],['Symmetriprinsippet?','Tap gir fradrag i nøyaktig samme utstrekning som tilsvarende gevinst ville vært skattepliktig. Skattefri bolig = ingen fradrag for tap.','§ 9-4'],['Arv og gave — kontinuitet?','Mottaker overtar arvelaters/givers inngangsverdi. Du skatter ikke ved mottak, men gevinsten måles fra den opprinnelige kjøpesummen ved fremtidig salg.','§ 9-7'],['Unntak: arvelater kunne solgt skattefritt?','Da settes inngangsverdien til markedsverdi på dødstidspunktet — gunstigere for arvingen.','§ 9-7(2)'],['— INNGANGSVERDI —','Hva du «kjøpte for» i skattemessig forstand'],['Hva er inngangsverdi?','Beløpet gevinst eller tap måles fra ved salg. Normalt: det du betalte (kjøpesum + omkostninger). For aksjer: også ubrukt skjermingsfradrag.','§ 9-7, § 10-32'],['Hvorfor er det viktig?','Gevinst = salgssum minus inngangsverdi. Feil inngangsverdi = feil skatt. Det er forskjellen mellom tusenvis og hundretusenvis i skatt.'],['Arv/gave?','Du overtar arvelaters/givers inngangsverdi (kontinuitet). Du får ikke «nullstilt» til markedsverdi. Unntaket: arvelater kunne selv solgt skattefritt — da brukes markedsverdi.','§ 9-7'],['Aksjer?','Kjøpesum + transaksjonskostnader + ubrukt skjermingsfradrag. FIFO bestemmer hvilke aksjer som anses solgt først.','§ 10-32, § 10-36'],['Bolig?','Kjøpesum + dokumentavgift + påkostninger (ikke vedlikehold). Relevant hvis botidskravet ikke er oppfylt.','§ 9-3'],['Hva med avskrivninger?','For driftsmidler i virksomhet reduseres inngangsverdien med skattemessige avskrivninger.','§ 6-10, § 14-40'],['— AKSJONÆRMODELLEN —','§ 10-11 til 10-12'],['Hvordan beskattes utbytte?','Utbytte ganges med 1,72 og beskattes med 22 %. Effektiv skatt: ca. 37,84 %.','§ 10-11'],['Hva er skjermingsfradrag?','Den delen av utbyttet som tilsvarer risikofri rente er skattefri. Renten fastsettes årlig.','§ 10-12'],['Hvorfor 1,72?','For at samlet skatt (selskap + aksjonær) skal ligge på nivå med skatt på lønn. Ellers ville alle tatt ut utbytte i stedet.'],['— FRITAKSMETODEN —','§ 2-38'],['Hva er det?','Selskaper slipper skatt på utbytte og gevinst fra andre selskaper. Hindrer at samme overskudd beskattes i hvert ledd.','§ 2-38'],['3 %-regelen?','Selskapet må likevel inntektsføre 3 % av fritatt utbytte. Effektiv skatt: 0,66 %.','§ 2-38(6)'],['Unntak?','Gjelder ikke i lavskattland, eller ved eierandel under 10 % utenfor EØS.','§ 2-38(3)'],['— KONSERNBIDRAG —','§ 10-2 til 10-5'],['Hva er det?','Overføring av penger mellom selskaper i samme konsern. Giver får fradrag, mottaker skatter.','§ 10-2'],['Hva er poenget?','Jevne ut overskudd og underskudd i konsernet, slik at total skatt blir riktig.'],['Krav?','Morselskapet må eie over 90 % av aksjene og stemmene.','§ 10-4'],['— SKATTEFRI FUSJON OG FISJON —','§ 11-2, § 11-4, § 11-7'],['Når er det skattefritt?','Når det gjøres etter aksjelovens regler og med skattemessig kontinuitet — altså at alle verdier og posisjoner videreføres.','§ 11-2/11-4'],['Hva er kontinuitet?','Overtakende selskap arver alle skattemessige verdier uendret. Ingen gevinst realiseres.','§ 11-7'],['Hva kan gå galt?','Kontantvederlag utløser skatt. Underskudd kan falle bort (§ 13-3). Omgåelsesnormen (§ 13-2) kan ramme transaksjoner uten reelt forretningsmessig formål.'],['— OMGÅELSESNORMEN —','§ 13-2'],['Når slår den inn?','Når hovedformålet er skattefordel, og transaksjonen ikke tåler en helhetsvurdering.','§ 13-2(2)'],['Hva vurderes?','Forretningsmessig egenverdi, skattefordelens størrelse, om veien var uhensiktsmessig, og om reglene brukes i strid med formålet.','§ 13-2(3)'],['Konsekvens?','Transaksjonen beskattes etter sitt reelle innhold — ikke etter formen.','§ 13-2(4)'],['Eksempel?','Kjøp av tomt selskap for å utnytte underskudd. Underskuddet faller bort etter § 13-3.','§ 13-3'],['— LOVLIGHETSKRAVET —','§ 11-1(2)'],['Hva er det?','Fusjon og fisjon må gjennomføres lovlig på tre nivåer for å være skattefri. Feil på ett nivå kan utløse konsekvenser på alle.','§ 11-1(2)'],['Selskapsrett (aksjeloven)','Må følge aksjeloven kap. 13 (fusjon) eller kap. 14 (fisjon): fusjonsplan, kreditorvarsel, generalforsamlingsvedtak, registrering i Foretaksregisteret. Brudd = ugyldig transaksjon.','Aksjeloven kap. 13/14'],['Skatterett (skatteloven kap. 11)','Skattemessig kontinuitet, maks 20 % kontantvederlag, oppløsning av overdragende selskap. Brudd = gevinsten beskattes som vanlig salg.','§ 11-7, § 11-6, § 11-9'],['Avgiftsrett (merverdiavgiftsloven)','Fusjon/fisjon er fritatt (§ 6-14, 0 % mva). Men justeringsforpliktelser på kapitalvarer overtas av ny eier (kap. 9). Feil her = tilbakeføring av fradrag.','Mval. § 6-14, kap. 9'],['Hva betyr det i praksis?','Alle tre nivåer må stemme. Selskapsrettslig feil smitter til skatt og avgift. Vurder alltid samlet.']],
    salSubjRows: [['— HVEM SKATTER I NORGE? —',''],['Bor du i Norge?','Du skatter av all inntekt og formue — også det du tjener i utlandet','§ 2-1(1)'],['Når blir du skattemessig bosatt?','Opphold over 183 dager i løpet av 12 mnd, eller over 270 dager i 36 mnd','§ 2-1(2)'],['Hvordan opphører bostedet?','Du må bo fast i utlandet og ha gitt opp boligen din i Norge','§ 2-1(3)'],['Hva med ferie i utlandet?','Korte opphold ute avbryter ikke skattemessig bosted','§ 2-1(4)'],['Svalbard?','Egne regler etter svalbardskatteloven','§ 2-1(5)'],['— HVA SKJER NÅR NOEN DØR? —',''],['Dødsbo','Skatter som eget subjekt i dødsåret og videre til boet er gjort opp','§ 2-2'],['Skifte i dødsåret','Arvingene overtar skatteforpliktelsene fra 1. januar','§ 2-15'],['— HVILKE SELSKAPER SKATTER? —',''],['AS, ASA og øvrige selskaper','Egne skattesubjekter — skatter 22 % av overskuddet','§ 2-2(1) a–i: AS, ASA, sparebank, forsikring, samvirke, stiftelser, stats-/helseforetak, kommunalt foretak'],['— BEGRENSET SKATTEPLIKT —','Gjelder deg som ikke bor i Norge, men har tilknytning hit'],['Eier du eiendom i Norge?','Inntekten er skattepliktig','§ 2-3(1)a'],['Driver du virksomhet herfra?','Skattepliktig i Norge','§ 2-3(1)b'],['Jobber du i Norge?','Lønnen er skattepliktig — uansett statsborgerskap','§ 2-3(1)d'],['Får du utbytte fra norsk selskap?','Kildeskatt for utenlandske aksjonærer','§ 2-3(1)c'],['Styrehonorar i norsk selskap?','Skattepliktig her','§ 2-3(1)e'],['Pensjon fra Norge?','Kildeskatt — også for deg som bor i utlandet','§ 2-3(4)'],['Utenlandsk artist som opptrer i Norge?','Skattepliktig etter egne regler','§ 2-3(1)h'],['— FRITAKSMETODEN —','Slik unngår selskaper dobbeltbeskatning av aksjeinntekter'],['Utbytte og gevinst mellom selskaper','Skattefritt — AS som eier aksjer i andre AS slipper normalt skatt','§ 2-38(1)'],['3 %-regelen','Selskapet inntektsfører likevel 3 %, som gir en effektiv skatt på 0,66 %','§ 2-38(6)'],['Selskap i lavskattland?','Fritaket gjelder ikke','§ 2-38(3)'],['Under 10 % eierandel utenfor EØS?','Fritaket gjelder ikke','§ 2-38(3)b'],['— EKTEFELLER —','Hvordan fordeles skatten mellom dere?'],['Felles eller særskilt ligning?','Dere velger selv om inntekten slås sammen eller beskattes hver for seg','§ 2-10'],['Hvem tilordnes inntekten?','Den ektefellen inntekten eller fradraget tilhører','§ 2-11'],['Forsørger du ektefellen din?','Klasse 2 gir lavere skatt når den ene har liten eller ingen inntekt','§ 2-14'],['Felles bolig?','Delt beskatning','§ 2-12'],['— BARN —','Hvem skatter for barnas inntekter?'],['Kapitalinntekt (barn under 17)','Beskattes hos foreldrene','§ 2-14(1)'],['Arbeidsinntekt','Beskattes hos barnet selv','§ 2-14(3)'],['Barns formue','Fordeles likt mellom foreldrene','§ 2-14(5)'],['— SKATTEFRIE INSTITUSJONER —','Hvem slipper skatt?'],['Staten, kommuner, kirkesamfunn','Skattefrie','§ 2-30(1) a–d'],['Foreninger og stiftelser uten erverv','Skattefrie så lenge de ikke driver med fortjeneste','§ 2-32'],['Men: ervervsaktivitet over terskel','Skattepliktig over 140 000 kr (eller 70 000 kr)','§ 2-32(2)'],['— HVOR HØRER SELSKAPET HJEMME? —',''],['Registrert eller stiftet i Norge?','Alltid norsk skattesubjekt','§ 2-2(6)/(7)'],['Reelt styrt fra Norge?','Kan bli norsk skattesubjekt selv om det er utenlandsk','§ 2-2(6)'],['— SELSKAP SOM FLYTTER —',''],['Inn til Norge','Full skatteplikt fra etablering','§ 2-2(8)'],['Ut av Norge','Må gjøre opp latente gevinster','§ 2-2(8)'],['— INTERNASJONALT —','Dobbeltbeskatning og skatteavtaler'],['Betalt skatt i utlandet?','Du kan trekke det fra på norsk selvangivelse (kreditfradrag)','§ 2-37'],['Skatteavtaler','Norge har avtaler med mange land som fordeler beskatningsretten']],
    morReqRows: [['Maks lån','Samlet gjeld maks 5× årsinntekt','All gjeld teller — boliglån, studielån, billån, kredittkort'],['Egenkapital','Minst 10%','Du må ha spart opp minst 10% av boligprisen selv'],['Stresstest','Høyeste av 7% og rente + 3 pp','Banken sjekker at du har råd selv om renta går opp'],['Avdrag','Min. 2,5% per år over 60% belåning','Har du lånt mer enn 60% av boligverdien må du betale avdrag'],['Fleksibilitetskvote','Banken kan avvike i 10% av lån','I Oslo: maks 8% — betyr at banken kan si ja selv om du ikke oppfyller alle krav']],
    morCostRows: [['Rente nå','Ca. 5,1% flytende (jan 2026)'],['Skattefradrag','22% av rentekostnadene','Du får igjen 22% av rentene du betaler på skatten'],['Dokumentavgift','2,5% av markedsverdi','Betales ved kjøp av fast eiendom — unntak for nybygg og borettslagsleiligheter']],
    morBsuRows: [['Maks sparing per år','27 500 kr'],['Maks totalbeløp','300 000 kr'],['Skattefradrag','10% av innbetalt — opptil 2 750 kr/år'],['Aldersgrense','T.o.m. det året du fyller 33'],['Krav for skattefradrag','Du må ha skattepliktig arbeidsinntekt og ikke eie bolig'],['Hva kan pengene brukes til?','Kjøp, nedbetaling, påkostning eller vedlikehold av egen bolig'],['Brudd på vilkår?','Bruker du pengene til annet enn bolig må du tilbakebetale alt skattefradrag']],
    morBsuTitle:'BSU — Boligsparing for ungdom', morBsuDesc:'Skattefradrag, sparebeløp, aldersgrense, bruksvilkår',
    morReqTitle:'Krav til boliglån', morReqDesc:'Egenkapital, gjeldsgrad, stresstest, avdrag',
    morCostTitle:'Kostnader ved boligkjøp', morCostDesc:'Renter, skattefradrag, dokumentavgift',
    npvInfoRows: [['— ORDFORKLARING —',''],['NPV (Net Present Value)','Nåverdien av fremtidige kontantstrømmer minus investering'],['IRR (Internal Rate of Return)','Renten som gir NPV = 0'],['WACC','Vektet gjennomsnittlig kapitalkostnad'],['— TOLKNING —',''],['NPV > 0','Lønnsom – aksepter investering'],['NPV < 0','Ulønnsom – forkast'],['IRR > WACC','Verdiskapende prosjekt'],['IRR < WACC','Verdiødeleggende prosjekt'],['— REFERANSE —',''],['Diskonteringsrente','Vanligvis WACC (før skatt)'],['Typisk WACC','8–12%'],['Tilbakebetalingstid','Kortere er bedre']],
    vatSubjRows: [['— GRUNNVILKÅR —','Tre ting må være oppfylt for mva-plikt'],['1. Næringsdrivende','Du må drive næringsvirksomhet — ikke hobby eller lønnstakerforhold','§ 2-1(1)'],['2. Omsetning av varer/tjenester','Det må skje en transaksjon — levering mot vederlag (betaling)','§ 1-3(1)a'],['3. Omsetningsgrense','Omsetning over 50 000 kr i løpet av 12 måneder','§ 2-1(1)'],['— HVEM MÅ REGISTRERE SEG? —',''],['Næringsdrivende over 50 000 kr','Registreringsplikt i Merverdiavgiftsregisteret','§ 2-1(1)'],['Veldedige organisasjoner','Høyere grense: 140 000 kr','§ 2-1(1)'],['Idrettsarrangementer','Egen grense: 3 000 000 kr','§ 2-1(1)'],['— BEGREPER FORKLART —',''],['Hva er «næring»?','Selvstendig, varig aktivitet med økonomisk karakter og egnet til overskudd. Hobby og enkeltoppdrag er normalt ikke næring.'],['Hva er «omsetning»?','Levering av varer eller tjenester mot vederlag. Gave, erstatning og tilskudd er normalt ikke omsetning.','§ 1-3(1)a'],['Hva er «avgiftssubjekt»?','Den som er registrert (eller skulle vært registrert) i Merverdiavgiftsregisteret og plikter å beregne og betale mva.','§ 1-3(1)d'],['Frivillig registrering?','Utleier av næringseiendom kan registrere seg frivillig for å få fradragsrett på inngående mva.','§ 2-3']],
    vatSubjTitle:'Hvem er avgiftspliktig?', vatSubjDesc:'Næring, omsetningsgrense, registreringsplikt',
    vatRates: [['25','25% Standard – varer og tjenester (§ 5-1)'],['15','15% Næringsmidler (§ 5-2)'],['12','12% Transport, hotell, kino (§ 5-3/5-5/5-6)'],['0','0% Fritatt – aviser, bøker, utførsel (kap. 6)']],
    vatInfoRows: [['— SATSER —',''],['Alminnelig sats (§ 5-1)','25%'],['Næringsmidler (§ 5-2)','15%'],['Persontransport (§ 5-3)','12%'],['Romutleie hotell (§ 5-5)','12%'],['Kino (§ 5-6)','12%'],['Museer/gallerier (§ 5-9)','12%'],['Fornøyelsesparker (§ 5-10)','12%'],['Idrettsarrangement (§ 5-11)','12%'],['Vann/avløp (§ 5-12)','12%'],['Servering (§ 5-2)','25% (ikke 15%)'],['— REGISTRERING —',''],['Næringsdrivende (§ 2-1)','50 000 kr / 12 mnd'],['Veldedige org. (§ 2-1)','140 000 kr / 12 mnd'],['Idrettsarrangement (§ 2-1)','3 000 000 kr'],['— OMRÅDE —',''],['Geografisk (§ 1-2)','Norsk fastland + territorialgrense'],['Ikke MVA-område','Svalbard, Jan Mayen, biland']],
    vatLawRows: [['— HVA ER UNNTATT MVA? —','Utenfor loven — ingen mva og ingen fradragsrett'],['Helsetjenester?','Unntatt — lege, tannlege, fysioterapi o.l.','§ 3-2'],['Sosiale tjenester?','Unntatt — barnevern, eldreomsorg, rusomsorg','§ 3-4'],['Undervisning?','Unntatt — skole, kurs, opplæring (offentlig og privat)','§ 3-5'],['Bank, forsikring, verdipapir?','Unntatt — finansielle tjenester','§ 3-6'],['Konsert, teater, dans?','Unntatt — framføring av kunst og kultur','§ 3-7'],['Treningssenter, svømmehall?','Unntatt — rett til å utøve idrett','§ 3-8'],['Offentlig myndighetsutøvelse?','Unntatt','§ 3-9'],['Utleie av eiendom?','Unntatt — men frivillig registrering er mulig for næringseiendom','§ 3-11'],['Veldedige salg (loppemarked o.l.)?','Unntatt','§ 3-12'],['Kontingent i ideelle org.?','Unntatt','§ 3-13'],['Pengespill?','Unntatt','§ 3-14'],['Begravelsesseremoni?','Unntatt','§ 3-15'],['Styrehonorar?','Unntatt mva, men AGA skal betales','§ 3-17'],['Selger du brukte private ting?','Unntatt — privatpersoner beregner ikke mva','§ 3-19'],['— HVA ER FRITATT (0 % MVA)? —','Omfattet av loven, 0 % utg. mva, full fradragsrett'],['Aviser, tidsskrift, bøker?','Fritatt','§ 6-1/6-3/6-4'],['El-kraft til husholdning i Nord-Norge?','Fritatt','§ 6-6'],['Elbil under 300 000 kr?','Fritatt — over dette beregnes 25 % mva','§ 6-8'],['Fartøy over 15 m, luftfartøy i yrke?','Fritatt','§ 6-9/6-10'],['Virksomhetsoverdragelse?','Fritatt — ingen mva når hele virksomheten selges samlet','§ 6-14'],['Eksport av varer og tjenester?','Fritatt — 0 % mva, full fradragsrett på inngående','§ 6-21/6-22'],['Transport til/fra utlandet?','Fritatt','§ 6-28'],['— UTTAK —','Bruker du bedriftens varer eller tjenester privat?'],['Uttak av varer til eget bruk?','Mva-pliktig','§ 3-21'],['Uttak av tjenester privat?','Mva-pliktig','§ 3-22'],['Kost, naturalavlønning, representasjon?','Mva-pliktig','§ 3-23'],['— INNFØRSEL —','Importerer du varer eller tjenester?'],['Varer fra utlandet?','Mva beregnes ved fortolling','§ 3-29'],['Digitale tjenester fra utlandet?','Snudd avregning — du beregner mva selv','§ 3-30']],
    vatDefRows: [['Hva er omsetning?','Levering av varer eller tjenester mot vederlag','§ 1-3 a'],['Hva er varer?','Fysiske gjenstander, fast eiendom, el-kraft, vann, gass, varme, kulde','§ 1-3 b'],['Hva er tjenester?','Alt som kan omsettes og ikke er varer — rådgivning, frisør, transport o.l.','§ 1-3 c'],['Hvem er avgiftssubjekt?','Bedrifter registrert i Mva-registeret (omsetning over 50 000 kr i 12 mnd)','§ 1-3 d'],['Hva er utgående mva?','Mva du legger på prisen og krever inn fra kunden','§ 1-3 e'],['Hva er inngående mva?','Mva du betaler når du kjøper varer/tjenester til bedriften','§ 1-3 f'],['Hva betyr «unntatt»?','Omsetning utenfor loven — ingen mva, men heller ingen fradragsrett','§ 1-3 g'],['Hva betyr «fritatt»?','Omfattet av loven, men 0 % utg. mva — full fradragsrett','§ 1-3 h'],['Fjernleverbare tjenester?','Tjenester ikke knyttet til fysisk sted — IT, rådgivning over nett, streaming','§ 1-3 i'],['Elektroniske tjenester?','Fjernleverbare og automatiserte — apper, e-bøker, strømmetjenester','§ 1-3 j']],
    vatDedRows: [['Kjøper du noe til bedriften?','Du får tilbake inngående mva på alt til bruk i registrert virksomhet','§ 8-1'],['Brukes noe både privat og i bedrift?','Forholdsmessig fradrag etter antatt bruk','§ 8-2'],['Servering til ansatte/kunder?','Aldri fradrag','§ 8-3 a'],['Kundemiddager og representasjon?','Aldri fradrag','§ 8-3 e'],['Gaver over bagatellgrensen?','Aldri fradrag','§ 8-3 f'],['Bolig og velferdstiltak?','Aldri fradrag — unntak for bedriftskantiner','§ 8-3 g'],['Firmabil?','Ingen mva-fradrag — unntak for utleie, taxi og videresalg','§ 8-4'],['Betaling over 10 000 kr?','Må gå via bank for å få mva-fradrag','§ 8-8']],
    vatAdjRows: [['Hva er en kapitalvare (driftsmidler)?','Maskiner, kjøretøy o.l. med inngående mva over 50 000 kr','§ 9-1 a'],['Hva er en kapitalvare (fast eiendom)?','Bygg, anlegg o.l. med inngående mva over 100 000 kr','§ 9-1 b'],['Hvor lenge justeres driftsmidler?','5 år — endrer du bruken må fradraget justeres','§ 9-4'],['Hvor lenge justeres fast eiendom?','10 år — endrer du bruken må fradraget justeres','§ 9-4']],
    vatCalcRows: [['Hva beregnes mva av?','Vederlaget eksklusive mva','§ 4-1'],['Byttehandel?','Markedspris brukes som beregningsgrunnlag','§ 4-3'],['Selger du billig til eget selskap?','Mva beregnes av markedspris ved interessefellesskap','§ 4-4'],['Kunden betaler aldri?','Du kan tilbakeføre mva ved endelig konstatert tap på fordring','§ 4-7']],
    vatRegRows: [['Konsernselskaper som én enhet?','Fellesregistrering ved minst 85 % eierskap — solidaransvar','§ 2-2'],['Leier du ut næringseiendom?','Frivillig registrering gir mva-fradrag på oppussing/bygging','§ 2-3'],['Nyoppstartet med store innkjøp?','Forhåndsregistrering mulig før du har nådd 50 000 kr i omsetning','§ 2-4']],
