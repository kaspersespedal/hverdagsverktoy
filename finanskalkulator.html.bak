    vatLawRows: [['— المستثنى (الفصل 3) —','خارج القانون، لا حق في الخصم'],['الخدمات الصحية (§ 3-2)','مستثنى','الطبيب، طبيب الأسنان، العلاج الطبيعي وغيرها — لا ضريبة ولا حق في الخصم'],['الخدمات الاجتماعية (§ 3-4)','مستثنى','حماية الطفولة، رعاية المسنين، علاج الإدمان وغيرها'],['التعليم (§ 3-5)','مستثنى','المدرسة، الدورات، التدريب — عام وخاص'],['الخدمات المالية (§ 3-6)','مستثنى','البنوك، التأمين، تداول الأوراق المالية — لا ضريبة'],['الفنون/الثقافة – العروض (§ 3-7)','مستثنى','الحفلات، المسرح، الرقص — التذاكر بدون ضريبة'],['الرياضة – حق الممارسة (§ 3-8)','مستثنى','مراكز اللياقة، ملاعب كرة القدم، حمامات السباحة وغيرها'],['ممارسة السلطة العامة (§ 3-9)','مستثنى'],['العقارات/الإيجار (§ 3-11)','مستثنى (استثناء في (2))','إيجار المساكن والعقارات التجارية مستثنى — لكن التسجيل الطوعي ممكن للتجاري'],['المنظمات الخيرية (§ 3-12)','مستثنى (مبيعات معينة)','أسواق البرغوث والبازارات وغيرها من المنظمات الخيرية'],['اشتراكات المنظمات المثالية (§ 3-13)','مستثنى'],['المقامرة (§ 3-14)','مستثنى'],['الجنازة – المراسم (§ 3-15)','مستثنى'],['أتعاب مجلس الإدارة (§ 3-17)','مستثنى (مع رسوم صاحب العمل)','أتعاب مجلس الإدارة مستثناة من الضريبة لكن يجب دفع رسوم صاحب العمل'],['السلع المستعملة الخاصة (§ 3-19)','مستثنى','الأفراد الذين يبيعون أغراضاً مستعملة لا يحتاجون لحساب الضريبة'],['— المعفى (الفصل 6) —','مشمول بالقانون، 0% ضريبة صادرة، حق في الخصم'],['الصحف (§ 6-1)','معفى'],['المجلات (§ 6-3)','معفى (الفقرة الأخيرة)'],['الكتب (§ 6-4)','معفى (الفقرة الأخيرة)'],['الكهرباء المنزلية شمال النرويج (§ 6-6)','معفى'],['السيارة الكهربائية ≤300 000 kr (§ 6-8)','معفى','ينطبق فقط على مبلغ الشراء حتى 300 000 kr — فوق ذلك تُحسب 25% ضريبة'],['السفن ≥15 م (§ 6-9)','معفى'],['الطائرات المهنية (§ 6-10)','معفى'],['نقل ملكية النشاط التجاري (§ 6-14)','معفى','عند بيع نشاط تجاري كامل يُنقل تاريخ الضريبة — لا ضريبة على البيع'],['تصدير السلع (§ 6-21)','معفى','التصدير للخارج — 0% ضريبة لكن حق كامل في خصم الضريبة الواردة'],['تصدير الخدمات (§ 6-22)','معفى'],['النقل من/إلى الخارج (§ 6-28)','معفى'],['— السحب (الفصل 3 الجزء الثاني) —',