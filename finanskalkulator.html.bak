    npvInfoRows: [['— FALANQAYNTA EREYADA —',''],['NPV (Qiimaha Saafiga Hadda)','Qiimaha hadda ee socodka lacageed mustaqbalka laga jaray maalgelinta'],['IRR (Heerka Soo-celinta Gudaha)','Ribada ka dhigaysa NPV = 0'],['WACC','Celceliska miisaanka leh kharashka hantida'],['— FASIRAADDA —',''],['NPV > 0','Faa\'iido leh – aqbal maalgelinta'],['NPV < 0','Faa\'iido la\'aan – diid'],['IRR > WACC','Mashruuc qiime-abuurka ah'],['IRR < WACC','Mashruuc qiime-burburka ah'],['— TIXRAACA —',''],['Heerka qiime-dhimista','Caadi ahaan WACC (ka hor cashuurta)'],['WACC caadiga ah','8–12%'],['Wakhtiga lacag-celinta','Ka gaaban waa ka wanaagsan']],
    vatSubjRows: [['— SHURUUDAHA AASAASIGA —','Saddex waxyaabo ayaa looga baahan yahay awood MVA-ka'],['1. Ganacsi','Waa inaad ganacsiga qabto — maaha camal yar ama shaqo-xiriir','§ 2-1(1)'],['2. Bixinta alaab/adeegyo','Waa in ay jiraan ganacsiga — deeq lacag-ku-beddelasho (lacag)','§ 1-3(1)a'],['3. Xadka iibinta','Iibinta 50 000 kr ka badan 12 bilood gudahood','§ 2-1(1)'],['— KOO DIIWAANGELINAYA WAJIB? —',''],['Ganacsiyada 50 000 kr ka badan','Waa in ay diiwaangeliyaan diiwaanka MVA-ka','§ 2-1(1)'],['Ururrada khayriyadda','Xad gaar: 140 000 kr','§ 2-1(1)'],['Tartamada isboortiga','Xad gooni: 3 000 000 kr','§ 2-1(1)'],['— EREYADA AASAASIGA —',''],['Waxaa maxaa « ganacsi »?','Ganacsi gooni ah, joogto ah oo ganacsigo ah oo awoodda leh in ay faa\'iido geysato. Camalo yar iyo hawlgullo hal-mar ma aha ganacsi inta badan.'],['Waxaa maxaa « iibinta »?','Bixinta alaab ama adeegyo lacag ku beddelasho. Hadiyada, lacag-badal iyo kaalmada dawladdu ma aha inta badan iibinta.','§ 1-3(1)a'],['Waxaa maxaa « qofka MVA-ka »?','Qofka diiwaangashan (ama wajib ah diiwaangelinta) diiwaanka MVA-ka iyo hadhaag xisaabinta iyo bixinta MVA-ka.','§ 1-3(1)d'],['Diiwaangelinta ikhtiyaari ah?','Iyada maliks hantida ganacsiga waxay diiwaangelinta karaan oo iska goynayaan jaritaanka MVA-ka soo-galka.','§ 2-3']],
    vatSubjTitle:'Yaa awoodda MVA-ka?', vatSubjDesc:'Ganacsi · Xadka iibinta · Awood diiwaangelinta',
    vatRates: [['25','25% Caadiga ah – alaab iyo adeegyo (§ 5-1)'],['15','15% Cuntada (§ 5-2)'],['12','12% Gaadiid, huteello, sinimaha (§ 5-3/5-5/5-6)'],['0','0% La cafiyay – wargeyso, buugaag, dhoofinta (qayb. 6)']],
    vatInfoRows: [['— HEERARKA —',''],['Heerka caadiga ah (§ 5-1)','25%'],['Cuntada (§ 5-2)','15%'],['Gaadiidka dadka (§ 5-3)','12%'],['Kirada qolalka huteelka (§ 5-5)','12%'],['Sinimaha (§ 5-6)','12%'],['Matxafyada/galeriyadaha (§ 5-9)','12%'],['Beerta madadaalada (§ 5-10)','12%'],['Tartamada isboortiga (§ 5-11)','12%'],['Biyaha/qashin-qaadasho (§ 5-12)','12%'],['Cuntada diyaarsan (§ 5-2)','25% (ma aha 15%)'],['— DIIWAANGELINTA —',''],['Ganacsatada (§ 2-1)','50 000 kr / 12 bilood'],['Ururrada khayriyadda (§ 2-1)','140 000 kr / 12 bilood'],['Tartamada isboortiga (§ 2-1)','3 000 000 kr'],['— AAGGA —',''],['Juquraafiyeed (§ 1-2)','Dhulka Noorway + xuduudda xuquuqda badda'],['Aagga MVA ka baxsan','Svalbard, Jan Mayen, dhulalka ku tiirsanaha']],
    vatLawRows: [['— KA REEBAN (qayb. 3) —','Sharciga ka baxsan, xuquuq jaritaan la\'aan'],['Adeegyada caafimaadka (§ 3-2)','Ka reeban','Dhakhtar, ilka-daawo, fiisiko-therapi iwm. — MVA la\'aan jaritaan la\'aanna'],['Adeegyada bulshada (§ 3-4)','Ka reeban','Ilaalinta caruurta, daryeelka waayeelka, daaweynta maandooriyaha iwm.'],['Waxbarashada (§ 3-5)','Ka reeban','Dugsiga, koorsooyin, tababar — dawladda iyo gaarka midba'],['Adeegyada maaliyadda (§ 3-6)','Ka reeban','Bangiga, caymiska, ganacsiga waraaqaha qiimaha — MVA la\'aan'],['Farshaxanka/dhaqanka – bandhigga (§ 3-7)','Ka reeban','Xaflad, masrax, cayaar — tigidhadu waa MVA la\'aan'],['Isboortiga – xuquuqda ku ciyaarista (§ 3-8)','Ka reeban','Jimicsiga, garoonka kubadda cagta, dabaasha iwm.'],['Awoodda dawladnimada (§ 3-9)','Ka reeban'],['Hantida/kirada (§ 3-11)','Ka reeban (ka reeban (2))','Kirada guryaha iyo hantida ganacsiga waa ka reeban — laakiin diiwaangelin ikhtiyaari ah ayaa suurtogal ganacsiga'],['Ururrada khayriyadda (§ 3-12)','Ka reeban (iibinta qaarkood)','Suuqyada alaabta duugoobay, basaarrada iwm. ururrada khayriyadda'],['Ururrada fikradda lacagta (§ 3-13)','Ka reeban'],['Khamaarta (§ 3-14)','Ka reeban'],['Aaska – xaflada (§ 3-15)','Ka reeban'],['Abaalmarinta gudidda (§ 3-17)','Ka reeban (AGA leh)','Abaalmarinta gudidda waa ka reeban MVA laakiin cashuurta loo-shaqeeyaha waa la bixiyaa'],['Alaabta gaarka ah ee la isticmaalay (§ 3-19)','Ka reeban','Shakhsiyaadka iibinaya alaab la isticmaalay uma baahna inay xisaabiyaan MVA'],['— LA CAFIYAY (qayb. 6) —','Sharciga ku jira, 0% MVA bixinta, xuquuqda jaritaanka'],['Wargeyska (§ 6-1)','La cafiyay'],['Joornaalka (§ 6-3)','La cafiyay (qaybta ugu dambeysa)'],['Buugaagta (§ 6-4)','La cafiyay (qaybta ugu dambeysa)'],['Koronto guryaha Waqooyiga Noorway (§ 6-6)','La cafiyay'],['Gaari korontada ≤300 000 kr (§ 6-8)','La cafiyay','Waxay khusaysaa kaliya qaddarka iibsashada ilaa 300 000 kr — ka badan waxaa la xisaabiyaa 25% MVA'],['Doonyaha ≥15m (§ 6-9)','La cafiyay'],['Diyaaradaha xirfadda (§ 6-10)','La cafiyay'],['Wareejinta ganacsiga (§ 6-14)','La cafiyay','Marka ganacsi dhan la iibiyo wada-jir taariikhda MVA waa la wareejiyaa — MVA la\'aan iibinta'],['Dhoofinta alaabta (§ 6-21)','La cafiyay','Dhoofinta dibadda — 0% MVA laakiin xuquuq buuxa jaritaanka soo-galka'],['Dhoofinta adeegyada (§ 6-22)','La cafiyay'],['Gaadiidka ugu/ka dibadda (§ 6-28)','La cafiyay'],['— BIXINTA (qayb. 3 qaybta II) —',''],['Bixinta alaabta (§ 3-21)','MVA la leeyahay','Haddii aad alaab ka qaadato ganacsiga si gaarka ah waa inaad xisaabiso MVA'],['Bixinta adeegyada gaarka ah (§ 3-22)','MVA la leeyahay'],['Cuntada/dabiiciga/matalaadda (§ 3-23)','MVA la leeyahay'],['— SOO-GALINTA (qayb. 3 qaybta III) —',''],['Alaabta la soo galiyay (§ 3-29)','MVA la leeyahay','Soo-galinta alaabta — MVA waxaa la xisaabiyaa kastamka'],['Adeegyada fog ee la gudbin karo (§ 3-30)','Xisaabinta rogrogsan','Haddii aad iibsato adeegyo dhijitaal ah dibadda waxaad MVA-da iskaaga xisaabisaa']],
    vatDefRows: [['Iibinta (a)','Bixinta alaab/adeegyo lacag ku beddelasho','Haddii aad wax u beddesho lacag waa iibinta'],['Alaabta (b)','Waxyaabaha jirka ah, hantida, koronto, biyo, gaas, kulaylka, qaboobaha'],['Adeegyada (c)','Wax kasta oo la iibin karo oo aan alaab ahayn','La-talinta, timo-jarista, gaadiidka, hagaajinta iwm.'],['Qofka cashuurta lagu leeyahay (d)','Diiwaangashan/waajibka diiwaangelinta diiwaanka MVA','Ganacsiyada iibinta ka badan 50 000 kr 12 bilood gudahood'],['MVA bixinta (e)','Waxaa la xisaabiyaa oo la bixiyaa iibinta iyo bixinta','MVA-da aad ku darto qiimaha oo aad ka qaadato macmiilka'],['MVA soo-galka (f)','La kulmay marka la iibsanayo ama la soo galinayo','MVA-da aad bixiso markaad iibsanayso alaab/adeegyo ganacsigaaga'],['Ka reebida sharciga (g)','Iibinta aan sharciga ku jirin → xuquuq jaritaan la\'aan','Ganacsiga kama jaridi karo MVA iibsashada la xiriirta iibinta ka reeban'],['Cafinta MVA (h)','Sharciga ku jira, laakiin 0% MVA bixinta → xuquuq jaritaan buuxa','Dhoofinta waa la cafiyay — MVA kuma darto, laakiin waxaad jaridi kartaa soo-galka'],['Adeegyada fog ee la gudbin karo (i)','Aan ku xidhayn meel jir ah gaar ah','Adeegyada IT, la-talinta onlaynka, daawo-daawashada iwm.'],['Adeegyada elektarooniga (j)','Fog oo la gudbin karo, internetka laga gudbiyo, awtomaatig ah','Aab-aabayaasha, buugaagta elektarooniga ah, adeegyada daawo-daawashada, koorsoyinka onlaynka']],
    vatDedRows: [['Xeerka guud (§ 8-1)','Jaritaanka MVA soo-galka isticmaalka ganacsiga diiwaangashan','MVA ayaad ka helaysaa wax kasta oo aad u iibsato ganacsiga'],['Isticmaalka wadaaga ah (§ 8-2)','Jaritaan saamiya sida isticmaalka qiyaasta ah','Haddii wax loo isticmaalo 60% ganacsi 40% gaari waxaad helaysaa 60% jaritaan'],['Jaritaan la\'aan: cuntada diyaarsan (§ 8-3 a)','','Cuntada iyo cabbitaanada shaqaalaha, macaamiisha iwm.'],['Jaritaan la\'aan: matalaadda (§ 8-3 e)','','Cashadaha macaamiisha, xaflado xiriirrada ganacsiga'],['Jaritaan la\'aan: hadiyado (§ 8-3 f)','Aan qiimo yar ahayn','Haddiyadaha ka badan xadka yar jaritaan kama siiyaan'],['Jaritaan la\'aan: guri/danbe (§ 8-3 g)','Ka reeban: qolka cuntada shirkadda'],['Gaadiidka dadka (§ 8-4)','Jaritaan la\'aan (ka reeban: kireysi, tagsi, iibinta)','Gaariga shirkadda jaritaan MVA kama siiyo haddii aan loo isticmaalin kireysi ama gaadiidka dadka'],['Lacag-bixinta bangiga (§ 8-8)','Waa loo baahan yahay ≥10 000 kr','Lacag-bixinnada lacagta caddaanka ah ee ka badan 10 000 kr jaritaan MVA kama siiyaan']],
    vatAdjRows: [['Hantida rasiisamaalka shaqada (§ 9-1 a)','MVA soo-galka ≥50 000 kr','Mashiinnada, gaadiidka iwm. leh MVA ka badan 50 000 kr'],['Hantida rasiisamaalka guryaha (§ 9-1 b)','MVA soo-galka ≥100 000 kr','Dhismayaasha, qalabka iwm. leh MVA ka badan 100 000 kr'],['Wakhtiga hagaajinta shaqada (§ 9-4)','5 sano','Haddii isticmaalku isbeddelo 5 sano gudahood jaritaanka MVA waa in la hagaajiyaa'],['Wakhtiga hagaajinta guryaha (§ 9-4)','10 sano','Haddii isticmaalku isbeddelo 10 sano gudahood jaritaanka MVA waa in la hagaajiyaa']],
    vatCalcRows: [['Xeerka guud (§ 4-1)','Lacag-bixinta MVA la\'aanta ah'],['Beddelka (§ 4-3)','Qiimaha suuqa caadiga ah','Marka la beddelayo qiimaha suuqa ayaa loo isticmaalaa saldhiga MVA'],['Xidhiidhka danaha (§ 4-4)','Ka yar maaha qiimaha suuqa caadiga ah','Haddii aad jaban u iibiso shirkaddaada MVA waxaa laga xisaabiyaa qiimaha suuqa'],['Khasaaraha sheegashada (§ 4-7)','Waa la saxin karaa sheegashada la waayay ugu dambeyntii','Macmiilku ma bixiyo weligii — markaas waxaad soo celin kartaa MVA-da aad bixisay']],
    vatRegRows: [['Diiwaangelinta wadajirka (§ 2-2)','≥85% lahaansho, mas\'uuliyad wadaag','Shirkadaha kooxda waxaa loo diiwangelin karaa hal qof MVA ah'],['Diiwaangelinta ikhtiyaariga kirada (§ 2-3)','Dhismaha kireenaha MVA diiwaangashan','Kireeyaha ayaa helaya jaritaan MVA dayactirka/dhismaha marka kireenaha uu diiwaangashan yahay'],['Diiwaangelinta hordhac (§ 2-4)','Iibsashooyin waaweyn ka hor iibinta','Ganacsiga cusub wuxuu isdiiwaangelin karaa ka hor inta uusan gaadhin 50 000 kr iibinta']],
