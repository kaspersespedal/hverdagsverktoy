    vatDefRows: [['البيع (a)','تسليم سلع/خدمات مقابل عوض','تبادل شيء مقابل المال يُعتبر بيعاً'],['السلع (b)','أشياء مادية، عقارات، كهرباء، ماء، غاز، حرارة، برودة'],['الخدمات (c)','كل ما يمكن بيعه وليس سلعاً','الاستشارات، الحلاقة، النقل، الإصلاح وغيرها'],['الخاضع للضريبة (d)','مسجل/ملزم بالتسجيل في سجل الضريبة','الشركات بمبيعات تزيد عن 50 000 kr خلال 12 شهراً'],['الضريبة الصادرة (e)','تُحسب وتُدفع عند البيع والسحب','الضريبة التي تضيفها على السعر وتجمعها من العميل'],['الضريبة الواردة (f)','تُتكبد عند الشراء أو الاستيراد','الضريبة التي تدفعها عند شراء سلع/خدمات للشركة'],['الاستثناء من القانون (g)','بيع غير مشمول بالقانون → لا حق في الخصم','لا يمكن للشركة خصم الضريبة على المشتريات المتعلقة بالبيع المستثنى'],['الإعفاء من الضريبة (h)','مشمول بالقانون، لكن 0% ضريبة صادرة → حق كامل في الخصم','التصدير معفى — لا تضيف ضريبة لكن يمكنك خصم الضريبة الواردة'],['الخدمات عن بُعد (i)','غير مرتبطة بمكان مادي محدد','خدمات تكنولوجيا المعلومات، الاستشارات عبر الإنترنت، البث وغيرها'],['الخدمات الإلكترونية (j)','عن بُعد، تُسلم عبر الإنترنت، آلية','التطبيقات، الكتب الإلكترونية، خدمات البث، الدورات عبر الإنترنت']],
