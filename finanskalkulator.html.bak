    <div id="calc-mortgage" class="calc-grid hidden">
      <div class="card">
        <div class="card-hdr"><div class="card-ico">🏠</div><div><div class="card-title" id="mor-title">Mortgage Calculator</div><div class="card-desc" id="mor-desc">Monthly payments and total loan costs.</div></div></div>
        <div class="card-body">
          <div class="fg"><label class="flbl" id="mor-l-type">Lånetype</label>
            <select class="fc" id="m-type"></select>
          </div>
          <div class="fg"><label class="flbl" id="mor-l-amount">Loan Amount</label><input class="fc" type="text" id="m-a" value="300,000" inputmode="numeric"></div>
          <div class="form-row">
            <div class="fg"><label class="flbl" id="mor-l-rate">Interest Rate (%)</label><input class="fc" type="number" id="m-r" value="5.5" step="0.1"></div>
            <div class="fg"><label class="flbl" id="mor-l-years">Term (years)</label><input class="fc" type="number" id="m-y" value="25"></div>
          </div>
          <button class="btn-calc" onclick="calcMor()"><span id="btn-calc-m">Calculate →</span></button>
          <div id="m-res" class="result-sec hidden">
            <div class="rh"><div class="rh-lbl" id="mor-r-mth">Monthly Payment</div><div class="rh-val" id="m-mth">–</div><div class="rh-sub" id="m-sub">–</div></div>
            <div id="m-serial-range" class="hidden" style="margin-bottom:12px;">
              <div class="rgrid">
                <div class="rt"><div class="rt-lbl" id="mor-r-first">Første måned</div><div class="rt-val" id="m-first">–</div></div>
                <div class="rt"><div class="rt-lbl" id="mor-r-last">Siste måned</div><div class="rt-val" id="m-last">–</div></div>
              </div>
            </div>
            <div class="rgrid">
              <div class="rt"><div class="rt-lbl" id="mor-r-tot">Total Repayment</div><div class="rt-val" id="m-tot">–</div></div>
              <div class="rt"><div class="rt-lbl" id="mor-r-int">Total Interest</div><div class="rt-val" id="m-int">–</div></div>
              <div class="rt"><div class="rt-lbl" id="mor-r-y1i">Year 1 Interest</div><div class="rt-val" id="m-y1i">–</div></div>
              <div class="rt"><div class="rt-lbl" id="mor-r-y1p">Year 1 Principal</div><div class="rt-val" id="m-y1p">–</div></div>
            </div>
          </div>
        </div>
      </div>
      <div class="right-col">
        <div class="info-card collapsed" id="mor-req-card">
          <div class="card-hdr" style="cursor:pointer" onclick="toggleCard(this.parentElement)"><div class="card-ico gold">🏦</div><div><div class="card-title" id="mor-req-title">Krav til boliglån <span style="font-size:11px;opacity:.5">▼</span></div><div class="card-desc" id="mor-req-desc">Egenkapital, gjeldsgrad, stresstest, avdrag</div></div></div>
          <div id="mor-req-rows" class="law-body"></div>
        </div>
        <div class="info-card collapsed" id="mor-cost-card" style="margin-top:16px;">
          <div class="card-hdr" style="cursor:pointer" onclick="toggleCard(this.parentElement)"><div class="card-ico gold">💸</div><div><div class="card-title" id="mor-cost-title">Kostnader ved boligkjøp <span style="font-size:11px;opacity:.5">▼</span></div><div class="card-desc" id="mor-cost-desc">Renter, skattefradrag, dokumentavgift</div></div></div>
          <div id="mor-cost-rows" class="law-body"></div>
