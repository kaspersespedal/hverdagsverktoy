    pensjonAgeLabel:'Поточний вік', pensjonRetireLabel:'Вік виходу на пенсію', pensjonSalaryLabel:'Річна зарплата', pensjonOtpLabel:'Ставка OTP', pensjonReturnLabel:'Повернення (%)', pensjonBtn:'Розрахувати →', pensjonPotLabel:'Загальна пенсійна касса у 67 років', pensjonAnnualLabel:'Розрахункова річна пенсія', pensjonMonthlyLabel:'Місячна пенсія', pensjonRealLabel:'Купівельна спроможність сьогодні (інфляція 2%)', pensjonDisclaimer:'Це орієнтовна оцінка для планування. Реальна пенсія може відрізнятися залежно від фактичних доходів, внесків та змін у законодавстві.',
    salKeyRows: [['— ПРАЦЯ, КАПІТАЛ ЧИ ПІДПРИЄМНИЦТВО? —','§ 5-1: Чому межа між ними визначає ваш податок'],['Дохід від праці','Особисте надання послуг іншим. Зарплата, гонорари, натуральні виплати. Дає особистий дохід → прогресивний податок + внески (7,6%).','§ 5-10'],['Дохід від капіталу','Прибуток від того, чим володієте — відсотки, дивіденди, оренда, приріст акцій. Лише 22%.','§ 5-20'],['Дохід від підприємництва','Податковий закон не визначає «підприємництво» прямо. Чотири критерії:'],['1. Тривалість','Діяльність повинна мати певну тривалість — не лише одноразовий продаж.'],['2. Обсяг','Повинен бути певний обсяг. Одна орендна квартира = капітал. Десять з активним управлінням = підприємництво.'],['3. Здатність до прибутку','Діяльність повинна об\'єктивно мати можливість бути прибутковою.'],['4. На власний ризик','Ви самі несете фінансовий ризик. Відрізняє підприємництво від найму.'],['Чому це важливо?','ФОП дає особистий дохід → прогресивний податок + внески. Капітал дає лише 22%.'],['Типова сіра зона?','Оренда нерухомості. Мало об\'єктів = капітал. Багато з активним управлінням = підприємництво.'],['— ПОНЯТТЯ РЕАЛІЗАЦІЇ —','§ 9-2: Що спричиняє податок — а що ні?'],['Що таке реалізація?','Передання права власності за винагороду: продаж, обмін, викуп, експропріація, знищення.','§ 9-2(1)'],['Що НЕ є реалізацією?','Подарунок, спадщина, поділ при розлученні, передача між подружжям.','§ 9-2(3)'],['Правило щодо житла?','Продаж власного житла звільнений: володіння мін. 1 рік і проживання 1 з 2 років. Дача: 5 років, використання 5/8.','§ 9-3(2)/(4)'],['Принцип симетрії?','Збиток відраховується рівно в тій мірі, що й відповідний прибуток оподатковувався б.','§ 9-4'],['Спадщина і дарунок — безперервність?','Отримувач приймає початкову вартість спадкодавця/дарувальника. Немає податку при отриманні, але майбутній прибуток рахується від початкової ціни.','§ 9-7'],['Виняток: спадкодавець міг продати без податку?','Початкова вартість = ринкова вартість на дату смерті — вигідніше для спадкоємця.','§ 9-7(2)'],['— ПОЧАТКОВА ВАРТІСТЬ —','Що ви «заплатили» в податковому сенсі'],['Що таке початкова вартість?','Сума від якої вимірюється прибуток або збиток при продажу. Зазвичай: ціна покупки + витрати. Для акцій: також невикористана пільга.','§ 9-7, § 10-32'],['Чому це важливо?','Прибуток = ціна продажу мінус початкова вартість. Неправильна вартість = неправильний податок.'],['Спадщина/дарунок?','Приймаєте початкову вартість (безперервність). Немає «обнулення» до ринкової вартості. Виняток: спадкодавець міг продати без податку.','§ 9-7'],['Акції?','Ціна покупки + витрати на операцію + невикористана пільга. FIFO визначає порядок продажу.','§ 10-32, § 10-36'],['Житло?','Ціна покупки + гербовий збір + покращення (не обслуговування).','§ 9-3'],['Амортизація?','Для бізнес-активів початкова вартість зменшується на податкову амортизацію.','§ 6-10, § 14-40'],['— МОДЕЛЬ АКЦІОНЕРА —','§ 10-11 до 10-12'],['Як оподатковуються дивіденди?','Дивіденди множаться на 1,72 і оподатковуються 22%. Ефективний податок: ~37,84%.','§ 10-11'],['Що таке пільга скjermінг?','Частина дивідендів, що відповідає безризиковій ставці, звільнена.','§ 10-12'],['Чому 1,72?','Щоб загальний податок (компанія + акціонер) був на рівні податку на зарплату.'],['— МЕТОД ЗВІЛЬНЕННЯ —','§ 2-38'],['Що це?','Компанії не платять податок на дивіденди та прибутки від інших компаній.','§ 2-38'],['Правило 3%?','Компанія все ж визнає 3% звільнених дивідендів. Ефективний податок: 0,66%.','§ 2-38(6)'],['Винятки?','Не застосовується до країн з низьким оподаткуванням або часток менше 10% поза ЄЕП.','§ 2-38(3)'],['— ГРУПОВІ ВНЕСКИ —','§ 10-2 до 10-5'],['Що це?','Переказ коштів між компаніями групи. Відрахування для платника, оподаткування для отримувача.','§ 10-2'],['Яка мета?','Вирівняти прибутки та збитки в групі для правильного загального податку.'],['Вимога?','Материнська компанія повинна володіти понад 90% акцій і голосів.','§ 10-4'],['— ЗВІЛЬНЕНЕ ЗЛИТТЯ ТА ПОДІЛ —','§ 11-2, § 11-4, § 11-7'],['Коли звільнено?','Коли проведено відповідно до закону про компанії з податковою безперервністю.','§ 11-2/11-4'],['Що таке безперервність?','Компанія-правонаступник успадковує всі податкові вартості без змін.','§ 11-7'],['Що може піти не так?','Грошова компенсація = оподаткування. Збитки можуть зникнути (§ 13-3).'],['— АНТИУНИКНЕННЯ —','§ 13-2'],['Коли застосовується?','Коли основна мета — податкова вигода і операція не витримує загальної оцінки.','§ 13-2(2)'],['Що оцінюється?','Ділова сутність, розмір податкової вигоди, невідповідний шлях, використання всупереч меті правил.','§ 13-2(3)'],['Наслідок?','Операція оподатковується за реальним змістом — не за формою.','§ 13-2(4)'],['Приклад?','Купівля порожньої компанії для використання збитку. Збиток зникає за § 13-3.','§ 13-3'],['— ВИМОГА ЗАКОННОСТІ —','§ 11-1(2)'],['Що це?','Злиття і поділ повинні бути законними на трьох рівнях для звільнення.','§ 11-1(2)'],['Корпоративне право','Повинно відповідати закону про компанії: план злиття, повідомлення кредиторів, рішення зборів, реєстрація.','Закон про компанії розд. 13/14'],['Податкове право (розд. 11)','Податкова безперервність, макс 20% готівкою, розпуск компанії-цедента.','§ 11-7, § 11-6, § 11-9'],['Право ПДВ','Злиття/поділ звільнені (§ 6-14, 0% ПДВ). Але обов\'язки коригування переходять до нового власника.','Закон про ПДВ § 6-14, розд. 9'],['На практиці?','Всі три рівні повинні збігатися. Помилка в корпоративному праві впливає на податки та ПДВ.']],
  },
  ar: {
    flag:'🇸🇦', name:'العربية', lang:'ar', currency:'kr', currencyCode:'NOK',
    salDefaults: { gross: 800000 },
    salClasses: [['1','الفئة 1 (عادي)'],['2','الفئة 2 (متزوج بدخل منخفض)'],['self','عامل مستقل']],
    salRegions: [['0.22','قياسي (كل النرويج)'],['0.185','فينمارك / شمال ترومس (منطقة الحوافز)']],
    salInfoRows: [['الخصم الشخصي','114 540 kr'],['الحد الأدنى للخصم (الحد الأقصى)','95 700 kr'],['الضريبة التصاعدية 1 (+226 ألف)','1.7%'],['الضريبة التصاعدية 2 (+318 ألف)','4.0%'],['الضريبة التصاعدية 3 (+725 ألف)','13.7%'],['الضريبة التصاعدية 4 (+980 ألف)','16.8%'],['الضريبة التصاعدية 5 (+1 467 ألف)','17.8%'],['اشتراك التأمين الاجتماعي','7.6%'],['ضريبة الدخل العادي','22%']],
    salLawRows: [['— القاعدة العامة (§ 5-1) —',''],['الدخل الخاضع للضريبة','أي منفعة مكتسبة من العمل أو رأس المال أو النشاط التجاري','كل ما تكسبه من العمل أو الاستثمارات أو النشاط التجاري خاضع للضريبة'],['خاضع للضريبة أيضاً','المعاش التقاعدي، الإعالة، المعاش السنوي'],['الربح من البيع (§ 5-1(2))','خاضع للضريبة (انظر الفصل 9)','إذا بعت شيئاً بربح يجب دفع ضريبة على الربح'],['السحب للاستخدام الشخصي (§ 5-2)','خاضع للضريبة بالقيمة السوقية','أخذ بضائع من شركتك للاستخدام الشخصي يُعتبر دخلاً'],['— دخل العمل (§ 5-10) —',''],['الراتب، المكافآت، بدل الإجازة','خاضع للضريبة'],['أتعاب مجلس الإدارة، العمولات، الإكراميات','خاضع للضريبة'],['إعانة البطالة، مرضية، إجازة الوالدين','خاضع للضريبة','المزايا الحكومية التي تحل محل الراتب تُفرض عليها ضريبة كالراتب'],['تعويض نهاية الخدمة (§ 5-10 d)','خاضع للضريبة'],['المزايا العينية (§ 5-12)','خاضعة للضريبة بالقيمة السوقية','المزايا التي تحصل عليها من صاحب العمل بدلاً من المال — مثل الهاتف، التأمين'],['قرض مخفض من العمل (§ 5-12(4))','الفرق = سعر الفائدة المعياري − الفائدة الفعلية','إذا حصلت على قرض من صاحب العمل بفائدة أقل من السوق يُفرض ضريبة على الفرق'],['سيارة الشركة (§ 5-13)','30% من سعر القائمة (20% فوق الحد)','إذا كان لديك سيارة شركة تُفرض ضريبة على نسبة من سعرها الجديد'],['سيارة أكثر من 3 سنوات','75% من سعر القائمة'],['خيارات الأسهم الوظيفية (§ 5-14)','خاضعة للضريبة عند الممارسة/البيع','تُفرض الضريبة عند استخدام أو بيع الخيار وليس عند الحصول عليه'],['خيارات الشركات الناشئة (§ 5-14(2))','ليست دخل عمل (شروط خاصة)','قواعد أكثر تفضيلاً لموظفي الشركات الصغيرة التي عمرها أقل من 6 سنوات'],['— دخل رأس المال (§ 5-20) —',''],['عوائد العقارات/الممتلكات','خاضعة للضريبة','دخل الإيجار من تأجير المساكن أو المنازل الريفية أو الممتلكات'],['عوائد الأصول المالية','خاضعة للضريبة','الفوائد والأرباح والمكاسب من الأسهم والصناديق والودائع البنكية'],['استخدام مجاني لممتلكات الغير','خاضع للضريبة','استخدام سكن مجاني أو ما شابه يُعتبر دخلاً'],['قرض للشركة (§ 5-22)','ضريبة إضافية، يُضرب في ×1.72','القرض من شركتك الخاصة يُعامل كتوزيعات أرباح ويُفرض عليه ضريبة'],['— المعفى من الضريبة (§ 5-15/5-43) —',''],['إعانة الطفل','معفاة من الضريبة'],['الدعم النقدي','معفى من الضريبة'],['المساعدة الاجتماعية','معفاة من الضريبة'],['المنحة الأساسية/منحة المساعدة','معفاة من الضريبة'],['منحة الجنازة','معفاة من الضريبة'],['تعويض الإعاقة/الأذى المعنوي','معفى من الضريبة'],['نفقة الأطفال','معفاة من الضريبة'],['اليانصيب الحكومي (Norsk Tipping وغيره)','معفاة من الضريبة','أرباح Norsk Tipping و Rikstoto وما شابهها معفاة من الضريبة'],['الأرباح العرضية (§ 5-50)','خاضعة للضريبة فوق 10 000 kr','أرباح المسابقات الخاصة واليانصيب وغيرها'],['السلع الاستهلاكية (§ 5-21)','معفاة عند الاستخدام الشخصي','بيع الأغراض الشخصية المستعملة (أثاث، ملابس، سيارة) معفى من الضريبة']],
    salDedRows: [['— القاعدة العامة (§ 6-1) —',''],['حق الخصم','التكاليف المتكبدة لاكتساب أو صيانة أو تأمين الدخل الخاضع للضريبة','يمكنك خصم المصاريف الضرورية لكسب المال'],['لا خصم','التكاليف الشخصية (السكن، الطعام، الإعالة)','مصاريف المعيشة الشخصية لا يمكن خصمها أبداً'],['الخسارة من البيع (§ 6-2)','خصم وفق قواعد الفصل 9','إذا بعت شيئاً بخسارة يمكنك خصمها من الضريبة'],['خسارة الديون (§ 6-2(2))','خصم عند التأكد النهائي من الخسارة في النشاط التجاري','شخص ما مدين لشركتك ولا يستطيع الدفع'],['العجز (§ 6-3)','يُقاصّ مع دخل آخر، يُرحّل (§ 14-6)','إذا كانت الشركة في خسارة يمكنك استخدامها ضد دخل آخر — أو ترحيلها لسنوات لاحقة'],['— الحد الأدنى للخصم (§ 6-30/32) —',''],['دخل الراتب','46% من الراتب، حد أقصى 95 700 kr','جميع الموظفين يحصلون عليه تلقائياً — يغطي السفر والملابس والأدوات وغيرها'],['دخل التقاعد','40% من التقاعد'],['يحل محل','معظم خصومات تكاليف العمل','لا تحتاج لتوثيق المصاريف الفردية عند استخدام الحد الأدنى للخصم'],['غير مشمول','اشتراك النقابة، تكاليف التنقل','هذه يمكن خصمها بالإضافة إلى الحد الأدنى للخصم'],['— الخصومات القياسية —',''],['اشتراك النقابة (§ 6-20)','حد أقصى 8 700 kr','عضوية نقابة مثل LO، YS، Unio، Akademikerne'],['السفر بين المنزل والعمل (§ 6-44)','فوق 12 000 kr، حد أقصى 120 000 kr','خصم لمسافة السفر أكثر من 37 كم في اتجاه واحد (بعد الحد الأدنى)'],['خصم الأطفال (§ 6-48)','أطفال أقل من 12 سنة، حد يحدده البرلمان','يغطي مصاريف الحضانة ورعاية ما بعد المدرسة'],['التبرعات للمنظمات (§ 6-50)','الحد الأدنى 500 kr، الحد الأقصى 25 000 kr','تبرعات لمنظمات معتمدة مثل الصليب الأحمر، أطباء بلا حدود'],['خصم معاش الأطفال (§ 6-49)','حتى 32 600 kr'],['— فوائد الديون (§ 6-40) —',''],['فوائد الديون','خصم كامل (تأثير ضريبي 22%)','جميع الفوائد التي تدفعها — قرض السكن، قرض الدراسة، قرض السيارة — تسترد 22% على الضريبة'],['تقييد الفائدة للمجموعات (§ 6-41)','25% من EBITDA، حد 25 مليون (مجموعة) / 5 مليون (خارجها)','يقيد خصم الفائدة على القروض بين الشركات في نفس المجموعة'],['ترحيل الفائدة المرفوضة','10 سنوات','الفوائد التي لم تُقبل هذا العام يمكن استخدامها في السنوات العشر القادمة'],['— خصومات النشاط التجاري —',''],['الاستهلاك (§ 6-10)','تآكل/تقادم الأصول التشغيلية، الشهرة عند الشراء','توزيع تكلفة الآلات والمركبات وغيرها على عدة سنوات'],['الصيانة/التأمين (§ 6-11)','خصم للأصول التشغيلية'],['البحث والتطوير (§ 6-25)','جزء من سعر التكلفة للأصل التشغيلي','يمكن رسملة تكاليف التطوير واستهلاكها على مدار الوقت'],['الشركات الناشئة (§ 6-53)','حتى 1 مليون kr، شركة عمرها ≤6 سنوات، فترة ملكية ≥3 سنوات','الأفراد الذين يستثمرون في شركات ناشئة صغيرة يحصلون على خصم'],['— لا خصم —',''],['التمثيل (§ 6-21)','لا خصم أبداً','عشاء العملاء، الهدايا لشركاء الأعمال وما شابه'],['الرشوة (§ 6-22)','لا خصم أبداً'],['اشتراك الجمعيات (§ 6-18)','لا خصم بشكل عام (استثناء § 6-19/20)','استثناء لجمعيات القطاع والمهنة'],['— الدفع عبر البنك (§ 6-51) —',''],['الشرط','الدفع ≥10 000 kr يجب أن يتم عبر البنك للحصول على حق الخصم','المدفوعات النقدية فوق 10 000 kr لا تمنح حق الخصم'],['— خصومات مهنية —',''],['خصم الصيادين (§ 6-60)','30%، حد أقصى 160 000 kr، ≥130 يوماً','يتطلب 130 يوماً على الأقل من الصيد في سنة الدخل'],['خصم البحارة (§ 6-61)','30%، حد أقصى 86 300 kr، ≥130 يوماً','يتطلب 130 يوماً على الأقل في البحر في سنة الدخل']],
    salCorpRows: [['— مساهمات المجموعة (§ 10-2 إلى 10-5) —',''],['مساهمات المجموعة (§ 10-2)','خصم للمانح، خاضعة للضريبة للمستلم','تحويل بين شركات في نفس المجموعة — يُستخدم لموازنة النتائج'],['شرط الملكية (§ 10-4)','الشركة الأم تملك >90% من الأسهم والأصوات','ينطبق على شركات المساهمة والشركات الأجنبية المماثلة في المنطقة الاقتصادية الأوروبية'],['— توزيعات الأرباح والحماية (§ 10-10 إلى 10-13) —',''],['توزيعات الأرباح (§ 10-11)','خاضعة للضريبة للمساهمين الأفراد','تُضرب بمعامل 1.72 قبل فرض ضريبة 22%'],['خصم الحماية (§ 10-12)','يُخصم من التوزيعات قبل الضريبة','لا تدفع ضريبة على الجزء من التوزيعات الذي يعادل العائد الخالي من المخاطر'],['سعر فائدة الحماية','سندات الخزينة بعد الضريبة','تُحدد من قبل مديرية الضرائب سنوياً'],['طريقة الإعفاء (§ 2-38)','معفاة للشركات','الشركات المساهمة التي تملك أسهماً في شركات أخرى تُعفى من ضريبة التوزيعات والأرباح'],['قاعدة 3% (§ 2-38(6))','3% من الدخل تُحتسب كإيراد','الشركات تدفع 0.66% (3% × 22%) على التوزيعات المعفاة'],['— أرباح وخسائر الأسهم (§ 10-30 إلى 10-37) —',''],['الربح من البيع (§ 10-31)','خاضع للضريبة للمساهمين الأفراد','يُضرب بمعامل 1.72، أي ضريبة فعلية حوالي 37.84%'],['الخسارة من البيع (§ 10-31(2))','قابلة للخصم','تُضرب بمعامل 1.72 بالمثل'],['القيمة الأولية (§ 10-32)','سعر التكلفة + حماية غير مستخدمة','ما دفعته مقابل السهم مضافاً إليه خصم الحماية المتراكم'],['مبدأ FIFO (§ 10-36)','أول شراء = أول بيع','عند بيع جزء من حصة أسهم تُعتبر الأسهم الأقدم مباعة أولاً'],['— صناديق الأوراق المالية و ASK (§ 10-20/10-21) —',''],['صناديق الأوراق المالية (§ 10-20)','جزء الأسهم وجزء الفائدة يُفرض عليهما ضريبة مختلفة','جزء الأسهم = نموذج المساهم، جزء الفائدة = دخل عادي'],['حساب توفير الأسهم (§ 10-21)','تُؤجل الضريبة حتى السحب','يمكنك شراء وبيع الأسهم/الصناديق داخل الحساب دون تحفيز ضريبة'],['السحب الخاضع للضريبة (§ 10-21(4))','السحب فوق الإيداع خاضع للضريبة','تدفع ضريبة فقط عندما تسحب أكثر مما أودعت'],['— التقييم الضريبي للشركاء ANS/KS (§ 10-40 إلى 10-49) —',''],['طريقة الصافي (§ 10-41)','الأرباح تُفرض ضريبتها على الشركاء','كل شريك يدفع ضريبة على حصته من نتيجة الشركة'],['التوزيع (§ 10-42)','خاضع للضريبة للشريك الفرد','يُضرب بمعامل 1.72 كتوزيعات الأرباح'],['الربح من بيع الحصة (§ 10-44)','خاضع للضريبة','يُحسب بناءً على القيمة الأولية مع تعديلات الزيادة/النقصان'],['— التعاونيات (§ 10-50) —',''],['المدفوعات اللاحقة (§ 10-50)','خصم للتعاونية','إعادة الدفع للأعضاء بناءً على حجم التعامل مع التعاونية'],['— NOKUS / الدول منخفضة الضرائب (§ 10-60 إلى 10-68) —',''],['قواعد NOKUS (§ 10-60)','المالك النرويجي يُفرض عليه ضريبة مستمرة','تنطبق على شركات في دول منخفضة الضرائب يسيطر عليها ملاك نرويجيون'],['دولة منخفضة الضرائب (§ 10-63)','ضريبة أقل من 2/3 من الضريبة النرويجية','تُعتبر الدولة منخفضة الضرائب إذا كانت الضريبة الفعلية أقل من حوالي 14.67%'],['شرط السيطرة (§ 10-62)','الملاك النرويجيون يملكون 50% على الأقل','تُقيّم السيطرة إجمالياً لجميع دافعي الضرائب النرويجيين'],['خصم الائتمان (§ 10-65)','خصم للضريبة الأجنبية المدفوعة','تجنب الازدواج الضريبي بخصم الضريبة المدفوعة في الخارج'],['— ضريبة الهجرة (§ 10-70/10-71) —',''],['الأرباح الكامنة (§ 10-70)','خاضعة للضريبة عند مغادرة النرويج','تنطبق على الأسهم والحصص وبعض الأصول الأخرى'],['التأجيل (§ 10-70(7))','يمكن التأجيل داخل المنطقة الاقتصادية الأوروبية','يُؤجل الدفع لكن قد يُطلب تقديم ضمان'],['السقوط (§ 10-70(9))','تسقط الضريبة بعد 5 سنوات','إذا لم تبع خلال 5 سنوات تسقط الضريبة'],['— الضريبة المقتطعة عند المصدر (§ 10-80 إلى 10-82) —',''],['ضريبة مقتطعة على التوزيعات','15–25% للمساهمين الأجانب','يعتمد السعر على اتفاقية الضرائب مع بلد المساهم'],['ضريبة مقتطعة على الفوائد/الإتاوات (§ 10-80)','وفق القواعد المحددة في القانون','تنطبق على المدفوعات لأطراف ذات صلة في دول منخفضة الضرائب']],
        salRealRows: [['— متى يتم التحقق؟ —','القاعدة الرئيسية §§ 9-1 و 9-2'],['ما الذي يؤدي لضريبة الأرباح الرأسمالية؟','البيع، المبادلة، استرداد الأسهم، نزع الملكية، التدمير — أي نقل ملكية مقابل عوض','§ 9-2(1)'],['الهبة؟','الهبة ليست تحققاً — لا ضريبة على الواهب','§ 9-2(3)'],['الإرث؟','ليس تحققاً — لا ضريبة أرباح رأسمالية عند الإرث','§ 9-2(3)'],['التقسيم بين الزوجين؟','ليس تحققاً — حتى عند الانفصال/الطلاق','§ 9-2(3)'],['الاسترداد الإجباري؟','يُعتبر تحققاً — ينشأ الالتزام الضريبي','§ 9-2(1)'],['— إعفاء السكن —','§ 9-3: متى تُعفى من ضريبة الأرباح؟'],['بيع مسكنك الخاص؟','معفى إذا امتلكته سنة على الأقل وسكنت فيه سنة من آخر سنتين','§ 9-3(2)'],['بيع بيت العطلات؟','معفى إذا امتلكته 5 سنوات واستخدمته 5 من آخر 8 سنوات','§ 9-3(4)'],['بيع متعلقات شخصية؟','معفى — ممتلكات شخصية','§ 9-3(1)a'],['ربح من الأرض؟','معفى فقط إذا كانت الأرض ضئيلة — وإلا تُفرض الضريبة كبيع أرض','§ 9-3(8)'],['خسارة على سكن معفى؟','لا خصم — مبدأ التماثل: ربح معفى = خسارة غير قابلة للخصم','§ 9-4'],['— الخسائر قابلة للخصم —','§ 9-4: مبدأ التماثل'],['بيع بخسارة؟','خصم بنفس القدر الذي يكون فيه الربح المقابل خاضعاً للضريبة','§ 9-4(1)'],['خسارة في الأسهم؟','خصم كامل — تُضاعف ×1.72 كالأرباح','§ 9-4, § 10-31'],['— القيمة الأساسية عند الإرث/الهبة —','§ 9-7: مبدأ الاستمرارية'],['ورثت شيئاً؟','تأخذ القيمة الأساسية للمورّث — وليس القيمة السوقية','§ 9-7(1)'],['تلقيت هبة؟','نفس المبدأ — تأخذ القيمة الأساسية للواهب','§ 9-7(1)'],['استثناء — المورّث كان يمكنه البيع معفىً؟','القيمة الأساسية تُحدد بالقيمة السوقية عند الوفاة','§ 9-7(2)'],['— الخروج من الولاية الضريبية النرويجية —','§ 9-14: ضريبة الخروج'],['نقل أصول خارج النرويج؟','الربح الكامن يُفرض عليه ضريبة كأن الأصل بيع بالقيمة السوقية','§ 9-14(1)'],['تشمل الأصول غير الملموسة؟','نعم — براءات الاختراع والتراخيص والعلامات التجارية','§ 9-14(2)'],['يمكن التأجيل؟','نعم، داخل المنطقة الاقتصادية الأوروبية — لكن قد يُطلب ضمان','§ 9-14(4)']],

    salReorgRows: [['— الاندماج (§ 11-2/11-3) —',''],['شركات المساهمة (§ 11-2)','معفى من الضريبة عندما يتبع الاندماج قانون الشركات المساهمة الفصل 13','يتم دمج شركتين أو أكثر دون أن يدفع أحد ضريبة'],['التعاونيات (§ 11-2(2))','معفى من الضريبة وفق قانون التعاونيات الفصل 8'],['شركات بتقييم ضريبي للشركاء (§ 11-3)','معفى من الضريبة بنفس الشكل القانوني والمسؤولية','يجب أن يحصل الشركاء على حصص كمقابل (حد أقصى 20% إضافي نقداً)'],['— الانقسام (§ 11-4/11-5) —',''],['شركات المساهمة (§ 11-4)','معفى من الضريبة عندما يتبع الانقسام قانون الشركات المساهمة الفصل 14','يتم تقسيم شركة إلى شركتين أو أكثر دون ضريبة'],['شركات بتقييم ضريبي للشركاء (§ 11-5)','معفى من الضريبة بنفس الشكل القانوني والمسؤولية','حد أقصى 20% من المقابل يمكن أن يكون غير حصص'],['— الشروط والمبادئ —',''],['مقابل آخر (§ 11-6)','المقابل النقدي للمساهم خاضع للضريبة','فقط الأسهم/الحصص في الشركات المندمجة تكون معفاة'],['الاستمرارية (§ 11-7)','تُنقل القيم الضريبية وتاريخ الاكتساب','الشركة المستلمة تتولى جميع المراكز الضريبية دون تغيير'],['التوزيع عند الانقسام (§ 11-8)','توزع المراكز الضريبية وفق صافي القيم'],['التصفية (§ 11-9)','يجب حل الشركة المنقولة بعد النقل'],['تاريخ السريان (§ 11-10)','من تاريخ النفاذ في قانون الشركات'],['— عبر الحدود (§ 11-11) —',''],['اندماج/انقسام عبر الحدود','معفى من الضريبة داخل المنطقة الاقتصادية الأوروبية مع استمرارية','يمكن لشركة نرويجية الاندماج مع شركة في دولة أخرى في المنطقة'],['تبادل الأسهم (§ 11-11(4))','معفى من الضريبة عند نقل 90% على الأقل من الأسهم','حد أقصى 20% مقابل نقدي'],['الدول منخفضة الضرائب (§ 11-11(7))','الإعفاء لا ينطبق على الدول منخفضة الضرائب','استثناء إذا كانت الشركة مؤسسة فعلياً في دولة أوروبية'],['— التحويل (§ 11-20) —',''],['إلى شركة مساهمة','يمكن تحويل المؤسسة الفردية و ANS و DA وغيرها معفاة من الضريبة','تُنقل القيم والمراكز الضريبية'],['نقل داخل المجموعة (§ 11-21)','نقل معفى من الضريبة بين شركات في نفس المجموعة','يجب أن تملك الشركة الأم أكثر من 90% من الأسهم'],['إعادة الهيكلة (§ 11-22)','يمكن للوزارة منح إعفاء ضريبي عند إعادة التنظيم','ينطبق على بيع العقارات أو النشاط التجاري أو الأسهم']],
    salKeyRows: [['— عمل أم رأسمال أم نشاط تجاري؟ —','§ 5-1: لماذا الحد بينها يحدد ضريبتك'],['دخل العمل','أداء شخصي للآخرين. الراتب والمكافآت والمزايا العينية. يعطي دخلاً شخصياً → ضريبة تصاعدية + اشتراكات (7.6%).','§ 5-10'],['دخل رأس المال','عائد مما تملكه — فوائد، أرباح أسهم، إيجار، مكاسب أسهم. فقط 22%.','§ 5-20'],['دخل النشاط التجاري','قانون الضرائب لا يعرّف «النشاط التجاري» مباشرة. أربعة معايير:'],['1. المدة','يجب أن يكون للنشاط مدة معينة — وليس بيعاً واحداً فقط.'],['2. النطاق','يجب أن يكون بنطاق معين. شقة إيجار واحدة = رأسمال. عشر مع إدارة نشطة = نشاط تجاري.'],['3. القدرة على الربح','يجب أن يكون النشاط قادراً موضوعياً على تحقيق ربح.'],['4. على حسابك ومخاطرتك','أنت تتحمل المخاطر المالية بنفسك.'],['لماذا هذا مهم؟','النشاط الفردي يعطي دخلاً شخصياً → ضريبة تصاعدية + اشتراكات. رأس المال يعطي فقط 22%.'],['منطقة رمادية نموذجية؟','تأجير العقارات. قليل من العقارات = رأسمال. كثير مع إدارة نشطة = نشاط تجاري.'],['— مفهوم التحقق —','§ 9-2: ما الذي يؤدي للضريبة — وما الذي لا يؤدي؟'],['ما هو التحقق؟','نقل ملكية مقابل عوض: بيع، مبادلة، استرداد، نزع ملكية، تدمير.','§ 9-2(1)'],['ما ليس تحققاً؟','الهبة، الإرث، التقسيم عند الانفصال، النقل بين الزوجين.','§ 9-2(3)'],['قاعدة السكن؟','بيع المسكن الخاص معفى: ملكية سنة وسكن 1 من 2 سنة. بيت العطلات: 5 سنوات، استخدام 5/8.','§ 9-3(2)/(4)'],['مبدأ التماثل؟','الخسارة تُخصم بنفس القدر الذي يكون فيه الربح المقابل خاضعاً للضريبة.','§ 9-4'],['الإرث والهبة — الاستمرارية؟','المستلم يأخذ القيمة الأساسية للمورّث/الواهب. لا ضريبة عند الاستلام لكن الربح المستقبلي يُحسب من سعر الشراء الأصلي.','§ 9-7'],['استثناء: المورّث كان يمكنه البيع معفىً؟','القيمة الأساسية تُحدد بالقيمة السوقية عند الوفاة — أفضل للوارث.','§ 9-7(2)'],['— القيمة الأساسية —','ما «دفعته» بالمعنى الضريبي'],['ما هي القيمة الأساسية؟','المبلغ الذي يُقاس منه الربح أو الخسارة عند البيع. عادة: سعر الشراء + التكاليف. للأسهم: أيضاً الإعفاء غير المستخدم.','§ 9-7, § 10-32'],['لماذا مهمة؟','الربح = سعر البيع ناقص القيمة الأساسية. قيمة خاطئة = ضريبة خاطئة.'],['الإرث/الهبة؟','تأخذ القيمة الأساسية (استمرارية). لا «إعادة تعيين» للقيمة السوقية. الاستثناء: المورّث كان يمكنه البيع معفىً.','§ 9-7'],['الأسهم؟','سعر الشراء + تكاليف المعاملة + الإعفاء غير المستخدم. FIFO يحدد ترتيب البيع.','§ 10-32, § 10-36'],['السكن؟','سعر الشراء + رسوم التوثيق + التحسينات (ليس الصيانة).','§ 9-3'],['الاستهلاك؟','للأصول التجارية تُخفض القيمة الأساسية بالاستهلاك الضريبي.','§ 6-10, § 14-40'],['— نموذج المساهم —','§ 10-11 إلى 10-12'],['كيف تُفرض الضريبة على الأرباح؟','الأرباح تُضرب في 1.72 وتُفرض عليها ضريبة 22%. الضريبة الفعلية: ~37.84%.','§ 10-11'],['ما هو إعفاء التدريع؟','جزء الأرباح المقابل لمعدل العائد الخالي من المخاطر معفى.','§ 10-12'],['لماذا 1.72؟','لكي يكون إجمالي الضريبة (شركة + مساهم) على مستوى ضريبة الرواتب.'],['— طريقة الإعفاء —','§ 2-38'],['ما هي؟','الشركات لا تدفع ضريبة على أرباح الأسهم والمكاسب من شركات أخرى.','§ 2-38'],['قاعدة 3%؟','الشركة يجب أن تعترف بـ 3% من الأرباح المعفاة. الضريبة الفعلية: 0.66%.','§ 2-38(6)'],['استثناءات؟','لا تنطبق على بلدان الضرائب المنخفضة أو حصص أقل من 10% خارج المنطقة الاقتصادية.','§ 2-38(3)'],['— المساهمات الجماعية —','§ 10-2 إلى 10-5'],['ما هي؟','تحويل أموال بين شركات المجموعة. خصم للمعطي، ضريبة على المستلم.','§ 10-2'],['ما الهدف؟','موازنة الأرباح والخسائر في المجموعة للضريبة الإجمالية الصحيحة.'],['الشرط؟','الشركة الأم يجب أن تملك أكثر من 90% من الأسهم والأصوات.','§ 10-4'],['— الاندماج والتقسيم المعفى —','§ 11-2، § 11-4، § 11-7'],['متى يكون معفى؟','عند التنفيذ وفقاً لقانون الشركات مع الاستمرارية الضريبية.','§ 11-2/11-4'],['ما هي الاستمرارية؟','الشركة المستحوذة ترث جميع القيم الضريبية دون تغيير.','§ 11-7'],['ما الذي قد يسوء؟','العوض النقدي = ضريبة. الخسائر قد تختفي (§ 13-3).'],['— معيار مكافحة التجنب —','§ 13-2'],['متى يُطبق؟','عندما يكون الهدف الرئيسي ميزة ضريبية والعملية لا تصمد أمام تقييم شامل.','§ 13-2(2)'],['ما الذي يُقيّم؟','الجوهر التجاري، حجم الميزة الضريبية، المسار غير الملائم، الاستخدام المخالف لغرض القواعس.','§ 13-2(3)'],['النتيجة؟','العملية تُفرض عليها ضريبة وفقاً لمحتواها الحقيقي — وليس شكلها.','§ 13-2(4)'],['مثال؟','شراء شركة فارغة لاستغلال خسارة. الخسارة تختفي وفقاً لـ § 13-3.','§ 13-3'],['— شرط المشروعية —','§ 11-1(2)'],['ما هو؟','الاندماج والتقسيم يجب أن يكونا قانونيين على ثلاثة مستويات ليكونا معفيين.','§ 11-1(2)'],['قانون الشركات','يجب اتباع قانون الشركات: خطة الاندماج، إخطار الدائنين، قرار الجمعية العمومية، التسجيل.','قانون الشركات فصل 13/14'],['القانون الضريبي (فصل 11)','الاستمرارية الضريبية، حد أقصى 20% نقداً، حل الشركة المحيلة.','§ 11-7، § 11-6، § 11-9'],['قانون ضريبة القيمة المضافة','الاندماج/التقسيم معفى (§ 6-14، 0% ض.ق.م). لكن التزامات التعديل تنتقل للمالك الجديد.','قانون ض.ق.م § 6-14، فصل 9'],['عملياً؟','المستويات الثلاثة يجب أن تتوافق. خطأ في قانون الشركات يؤثر على الضرائب وض.ق.م.']],

    salSubjRows: [['— دافع الضرائب الشخصي (§ 2-1) —',''],['مقيم في النرويج (§ 2-1(1))','خاضع للضريبة على جميع الدخل/الثروة في النرويج وخارجها','إذا كنت تعيش في النرويج تدفع ضريبة على كل شيء — بغض النظر عن مصدر الدخل في العالم'],['بدء الإقامة (§ 2-1(2))','إقامة >183 يوماً في 12 شهراً، أو >270 يوماً في 36 شهراً','إذا مكثت في النرويج فترة كافية تصبح مقيماً ضريبياً'],['انتهاء الإقامة (§ 2-1(3))','يتطلب إقامة دائمة في الخارج + التخلي عن السكن في النرويج','يجب أن تعيش بشكل دائم في الخارج ولا تملك سكناً في النرويج'],['الغياب المؤقت (§ 2-1(4))','لا يقطع الإقامة الضريبية','الإجازة أو الإقامة القصيرة في الخارج لا تغير إقامتك'],['سفالبارد (§ 2-1(5))','نظام خاص (قانون ضريبة سفالبارد)'],['— التركة (§ 2-2) —',''],['التركة (§ 2-2)','كيان ضريبي مستقل في سنة الوفاة وما بعدها','التركة تدفع الضريبة ككيان مستقل حتى يتم تسويتها'],['التسوية في سنة الوفاة (§ 2-15)','الورثة يتحملون من 1 يناير','إذا تم توزيع الإرث في سنة الوفاة يدفع الورثة الضريبة عن السنة كاملة'],['— الشركات (§ 2-2) —',''],['شركة مساهمة (§ 2-2(1)a)','كيان ضريبي مستقل','الشركة المساهمة دافع ضرائب مستقل — تدفع 22% من الأرباح'],['شركة مساهمة عامة (§ 2-2(1)b)','كيان ضريبي مستقل'],['بنك ادخار، تأمين تبادلي (§ 2-2(1)c-d)','كيان ضريبي مستقل'],['جمعية تعاونية (§ 2-2(1)e)','كيان ضريبي مستقل'],['مؤسسة حكومية، مؤسسة صحية (§ 2-2(1)g-h)','كيان ضريبي مستقل'],['مؤسسات (§ 2-2(1)f)','كيان ضريبي مستقل'],['مؤسسة بلدية (§ 2-2(1)i)','كيان ضريبي مستقل'],['— الالتزام الضريبي المحدود (§ 2-3) —',''],['دخل العقارات في النرويج (§ 2-3(1)a)','خاضع للضريبة','الأجانب الذين يملكون عقارات في النرويج يدفعون ضريبة على الدخل'],['نشاط تجاري في النرويج (§ 2-3(1)b)','خاضع للضريبة','إذا كنت تمارس نشاطاً تجارياً من النرويج تدفع الضريبة هنا'],['العمل في النرويج (§ 2-3(1)d)','خاضع للضريبة','إذا عملت في النرويج تدفع ضريبة على الراتب هنا — حتى الأجانب'],['توزيعات أرباح من شركة نرويجية (§ 2-3(1)c)','ضريبة مقتطعة عند المصدر','المساهمون الأجانب يدفعون ضريبة مقتطعة على التوزيعات من الشركات النرويجية'],['أتعاب مجلس الإدارة (§ 2-3(1)e)','خاضعة للضريبة','إذا كنت عضواً في مجلس إدارة شركة نرويجية تدفع ضريبة على الأتعاب'],['معاش من النرويج (§ 2-3(4))','خاضع للضريبة (ضريبة مقتطعة)','حتى للأشخاص المقيمين في الخارج'],['ضريبة الفنانين (§ 2-3(1)h)','خاضعة للضريبة للفنانين الأجانب','قواعد خاصة لضريبة الحفلات والعروض وما شابه'],['— طريقة الإعفاء (§ 2-38) —',''],['معفاة للشركات (§ 2-38(1))','التوزيعات والأرباح بين الشركات معفاة من الضريبة','الشركة المساهمة التي تملك أسهماً في شركات أخرى تُعفى عادة من ضريبة التوزيعات والأرباح'],['قاعدة 3% (§ 2-38(6))','3% من الدخل تُحتسب كإيراد','الشركة تدفع فعلياً 0.66% (3% × 22%) من التوزيعات المعفاة'],['استثناء الدول منخفضة الضرائب (§ 2-38(3))','الإعفاء لا يشمل الشركات في الدول منخفضة الضرائب','الشركات في دول ذات ضرائب منخفضة جداً لا تشملها طريقة الإعفاء'],['استثناء المحفظة في المنطقة الاقتصادية الأوروبية (§ 2-38(3)b)','الإعفاء لا يشمل أقل من 10% ملكية خارج المنطقة','إذا كنت تملك أقل من 10% من شركة خارج المنطقة الاقتصادية الأوروبية لا تنطبق طريقة الإعفاء'],['— الأزواج (§ 2-10 إلى 2-16) —',''],['مشترك أو منفصل (§ 2-10)','يمكن للأزواج أن يُقيّموا ضريبياً معاً أو كل على حدة','يمكنكم اختيار دمج الدخل أو فرض ضريبة على كل منكما بشكل منفصل'],['التوزيع (§ 2-11)','الدخل/الخصم يُنسب للزوج المعني'],['الفئة 2 (§ 2-14)','إعالة زوج بدخل منخفض','يعطي ضريبة أقل إذا كان أحد الزوجين بدخل قليل أو بدون دخل'],['السكن المشترك (§ 2-12)','ضريبة مشتركة على السكن المشترك'],['— الأطفال (§ 2-14) —',''],['أطفال أقل من 17 سنة (§ 2-14(1))','دخل الأطفال يُفرض ضريبته على الوالدين','دخل رأس المال للأطفال أقل من 17 سنة يُفرض ضريبته على الوالدين'],['دخل عمل الأطفال (§ 2-14(3))','يُفرض ضريبته على الطفل نفسه','الراتب الذي يكسبه الطفل بنفسه يُفرض عليه ضريبة منفصلة'],['ثروة الأطفال (§ 2-14(5))','تُوزع بالتساوي بين الوالدين'],['— المؤسسات المعفاة من الضريبة (§ 2-30 إلى 2-32) —',''],['الدولة (§ 2-30(1)a)','معفاة من الضريبة'],['المحافظات/البلديات (§ 2-30(1)b-c)','معفاة من الضريبة'],['الكنائس (§ 2-30(1)d)','معفاة من الضريبة'],['المؤسسات غير التجارية (§ 2-32)','معفاة ما دام الدخل غير تجاري','الجمعيات والمنظمات والمؤسسات التي لا تسعى للربح تُعفى من الضريبة'],['النشاط التجاري (§ 2-32(2))','خاضع للضريبة فوق 140 000 kr / 70 000 kr','إذا تجاوز الدخل من المبيعات والتأجير وغيرها الحد الأدنى يجب دفع الضريبة'],['— قواعد إقامة الشركات (§ 2-2(6)) —',''],['مسجلة في النرويج','دائماً كيان ضريبي نرويجي','الشركات المسجلة في سجل الشركات النرويجي ملزمة بالضريبة في النرويج'],['تأسست في النرويج (§ 2-2(7))','دائماً كيان ضريبي نرويجي'],['الإدارة في النرويج (§ 2-2(6))','قد تصبح كياناً ضريبياً نرويجياً','شركة أجنبية تُدار فعلياً من النرويج قد تصبح ملزمة بالضريبة هنا'],['— دخول/خروج الشركة (§ 2-2(8)) —',''],['الدخول (§ 2-2(8))','التزام ضريبي كامل من التأسيس في النرويج'],['الخروج (§ 2-2(8))','تسوية الأرباح الكامنة','يجب على الشركة تسوية المراكز الضريبية عند مغادرة النرويج'],['— دولي (§ 2-37/2-38) —',''],['خصم الائتمان (§ 2-37)','خصم للضريبة المدفوعة في الخارج','تجنب الازدواج الضريبي — خصم الضريبة الأجنبية من الإقرار الضريبي النرويجي'],['الاتفاقيات الضريبية','قد تحد من حق النرويج في فرض الضريبة','النرويج لديها اتفاقيات مع دول كثيرة تحدد من يدفع الضريبة على ماذا']],
    morReqRows: [['الحد الأقصى للقرض','إجمالي الديون حد أقصى 5× الدخل السنوي','جميع الديون تُحتسب — قرض السكن، قرض الدراسة، قرض السيارة، بطاقة الائتمان'],['رأس المال الذاتي','10% على الأقل','يجب أن تكون قد وفرت 10% من سعر المسكن على الأقل'],['اختبار الضغط','أعلى من 7% أو الفائدة + 3 نقاط مئوية','يتحقق البنك من قدرتك على الدفع حتى لو ارتفعت الفائدة'],['الأقساط','مطلوبة فوق 60% نسبة القرض','إذا اقترضت أكثر من 60% من قيمة المسكن يجب دفع أقساط'],['حصة المرونة','قد يحيد البنك عن 10% من القروض','في القاهرة: بحد أقصى 8% — يعني أن البنك قد يقول نعم حتى لو لم تستوفِ جميع المتطلبات']],
    morCostRows: [['الفائدة الحالية','حوالي 5.1% متغيرة (يناير 2026)'],['الخصم الضريبي','22% من تكاليف الفائدة','تسترد 22% من الفوائد التي تدفعها على الضريبة'],['رسوم التوثيق','عادة 2.5% من القيمة السوقية','تُدفع عند شراء العقار — قد تنطبق استثناءات']],
