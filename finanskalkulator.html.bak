<!DOCTYPE html>
<html lang="no">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hverdagsverktøy – Kalkulator, boliglån, investering, skatt og MVA</title>

<!-- SEO -->
<meta name="description" content="Gratis norsk finanskalkulator — beregn skatt, boliglån, MVA, uttaksbeskatning, lønn og mer. 10 språk. Kjører helt lokalt i nettleseren.">
<meta name="keywords" content="finanskalkulator, skattekalkulator, boliglånskalkulator, MVA-kalkulator, lønn etter skatt, Norge">
<meta name="author" content="Kasper Espedal">
<meta name="robots" content="index, follow">
<link rel="canonical" href="https://hverdagsverktoy.com/">

<!-- Open Graph (sosiale medier) -->
<meta property="og:title" content="Hverdagsverktøy – Gratis finanskalkulator">
<meta property="og:description" content="Beregn skatt, boliglån, MVA, uttaksbeskatning og mer. Kjører lokalt — ingen data samles inn.">
<meta property="og:type" content="website">
<meta property="og:url" content="https://hverdagsverktoy.com/">
