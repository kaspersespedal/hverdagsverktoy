    uttakExF2:'ENK: Canshuur = Faaidada × (22% + caymiska bulshada + canshuurta jarjarka)',
    uttakExF3:'AS: Canshuurta faaida = Faaidada × 22% · Canshuurta rabitka = (Faaidada − ilaalinta) × 1.72 × 22%',
