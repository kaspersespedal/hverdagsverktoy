  lt: {
    flag:'🇱🇹', name:'Lietuvių', lang:'lt', currency:'kr', currencyCode:'NOK',
    salDefaults: { gross: 800000 },
    salClasses: [['1','1 klasė (Standartinė)'],['2','2 klasė (Sutuoktinis su mažomis pajamomis)'],['self','Savarankiškai dirbantis']],
