    salInfoRows: [['ውልቃዊ ቅነሳ (Personfradrag)','114 540 kr'],['ዝተሓተ ቅነሳ (Minstefradrag, ዝለዓለ)','95 700 kr'],['ደረጃዊ ግብሪ 1 (226k+)','1.7%'],['ደረጃዊ ግብሪ 2 (318k+)','4.0%'],['ደረጃዊ ግብሪ 3 (725k+)','13.7%'],['ደረጃዊ ግብሪ 4 (980k+)','16.8%'],['ደረጃዊ ግብሪ 5 (1 467k+)','17.8%'],['ክፍሊት ማሕበራዊ ውሕስነት (Trygdeavgift)','7.6%'],['ልሙድ ግብሪ (Alminnelig skatt)','22%']],
    salLawRows: [['— ቀንዲ ሕጊ (§ 5-1) —',''],['ግብሪ ዝኽፈሎ ኣታዊ','ዝኾነ ጥቕሚ ካብ ስራሕ፣ ካፒታል ወይ ንግዲ ዝተረኽበ','ኩሉ ካብ ስራሕ፣ ወፍሪ ወይ ንግዲ ዝረኽቦ ኣታዊ ግብሪ ይኽፈሎ'],['ከምኡ ውን ግብሪ ዝኽፈሎ','ጡረታ፣ ምግቢ፣ ዓመታዊ ኣበል'],['ረብሓ ኣብ ሽያጥ (§ 5-1(2))','ግብሪ ዝኽፈሎ (ምዕ. 9 ርአ)','ገለ ነገር ብረብሓ እንተ ሸጥካ ኣብቲ ረብሓ ግብሪ ክትከፍል ኣለካ'],['ምውጻእ ንውልቃዊ ጥቕሚ (§ 5-2)','ግብሪ ዝኽፈሎ ብዋጋ ዕዳጋ','ካብ ትካልካ ንውልቃዊ ጥቕሚ ኣቕሑ እንተ ወሲድካ ከም ኣታዊ ይቑጸር'],['— ኣታዊ ስራሕ (§ 5-10) —',''],['ደሞዝ፣ ክፍሊት፣ ናይ ዕረፍቲ ገንዘብ','ግብሪ ዝኽፈሎ'],['ክፍሊት ቦርድ፣ ቦነስ፣ ቲፕ','ግብሪ ዝኽፈሎ'],['ናይ ስራሕ ኣልቦነት ሓገዝ፣ ናይ ሕማም ክፍሊት፣ ናይ ወላዲ ሓገዝ','ግብሪ ዝኽፈሎ','ደሞዝ ዝትክኡ መንግስታዊ ሓገዛት ከም ደሞዝ ግብሪ ይኽፈሎም'],['ናይ ምፍላይ ክፍሊት (§ 5-10 d)','ግብሪ ዝኽፈሎ'],['ተፈጥሮኣዊ ጥቕምታት (§ 5-12)','ግብሪ ዝኽፈሎ ብዋጋ ዕዳጋ','ኣብ ክንዲ ገንዘብ ካብ ወሃብ ስራሕ ዝረኽቦ ጥቕምታት — ንኣብነት ተለፎን፣ ጋዜጣ፣ ውሕስነት'],['ሕሱር ልቓሕ ኣብ ስራሕ (§ 5-12(4))','ጥቕሚ = ስታንዳርድ ወለድ − ሓቂ ወለድ','ካብ ወሃብ ስራሕ ትሕቲ ዋጋ ዕዳጋ ልቓሕ እንተ ረኺብካ እቲ ፍልልይ ግብሪ ይኽፈሎ'],['ነጻ መኪና (§ 5-13)','30% ናይ ዝርዝር ዋጋ (20% ልዕሊ ደረት)','ናይ ትካል መኪና እንተ ኣለካ ካብ ሓዳስ ዋጋ መኪና ክፋል ግብሪ ይኽፈለካ'],['መኪና >3 ዓመት','75% ናይ ዝርዝር ዋጋ'],['ኣማራጺ ኣብ ስራሕ (§ 5-14)','ግብሪ ዝኽፈሎ ኣብ ምጥቃም/ሽያጥ','ኣማራጺ ምስ ተጠቀምካዮ ወይ ሸጥካዮ ግብሪ ይኽፈለካ፣ ምስ ተቐበልካዮ ኣይኮነን'],['ናይ ጅማሮ ኣማራጺ (§ 5-14(2))','ናይ ስራሕ ኣታዊ ኣይኮነን (ፍሉይ ሕግታት)','ዝያዳ ምቹእ ሕግታት ንሰራሕተኛታት ናይ ንኣሽቱ ትካላት ትሕቲ 6 ዓመት'],['— ኣታዊ ካፒታል (§ 5-20) —',''],['ኣታዊ ካብ ንብረት/ንዋት','ግብሪ ዝኽፈሎ','ካብ ምክራይ ገዛ፣ ጎጆ ወይ ንዋት ዝርከብ ኣታዊ ኽራይ'],['ኣታዊ ካብ ፋይናንሳዊ ንብረት','ግብሪ ዝኽፈሎ','ወለድ፣ ምቕባል ረብሓ ከምኡ ውን ረብሓ ካብ ኣክሲዮን፣ ፈንድ፣ ባንክ ዝተቐመጠ'],['ነጻ ኣጠቓቕማ ንብረት ካልኦት','ግብሪ ዝኽፈሎ','ነጻ ገዛ ወይ ተመሳሳሊ ምጥቃም ከም ኣታዊ ይቑጸር'],['ልቓሕ ናብ ትካል (§ 5-22)','ተወሳኺ ግብሪ፣ ×1.72 ይዓቢ','ካብ ናትካ ኣ.ሽ. ዝተወስደ ልቓሕ ከም ምቕባል ረብሓ ይረአን ብኡ መሰረት ግብሪ ይኽፈሎን'],['— ግብሪ ዘይኽፈሎ (§ 5-15/5-43) —',''],['ሓገዝ ህጻናት (Barnetrygd)','ግብሪ ነጻ'],['ናይ ጥረ ገንዘብ ደገፍ (Kontantstøtte)','ግብሪ ነጻ'],['ማሕበራዊ ሓገዝ','ግብሪ ነጻ'],['መሰረታዊ/ናይ ሓገዝ ኣበል','ግብሪ ነጻ'],['ናይ ቀብሪ ሓገዝ','ግብሪ ነጻ'],['ክሳራ ካሕሳ/ዕርቂ','ግብሪ ነጻ'],['ናይ ቆልዓ ሓገዝ (Barnebidrag)','ግብሪ ነጻ'],['ናይ ቁማር ዓወት (Norsk Tipping ወዘተ.)','ግብሪ ነጻ','ካብ Norsk Tipping፣ Rikstoto ን ተመሳሰልትን ዝተረኽበ ዓወት ግብሪ ነጻ እዩ'],['ኣጋጣሚያዊ ዓወት (§ 5-50)','ልዕሊ 10 000 kr ግብሪ ዝኽፈሎ','ካብ ብሕታዊ ውድድራት፣ ሎተሪ ወዘተ.'],['ናይ ተጠቃሚ ኣቑሑ (§ 5-21)','ግብሪ ነጻ ኣብ ውልቃዊ ሽያጥ','ዝተጠቐምካሎም ውልቃዊ ነገራት (ኣቑሑ ገዛ፣ ክዳውንቲ፣ መኪና) ምሻጥ ግብሪ ነጻ እዩ']],
    salDedRows: [['— ቀንዲ ሕጊ (§ 6-1) —',''],['መሰል ቅነሳ','ግብሪ ዝኽፈሎ ኣታዊ ንምርካብ፣ ንምዕቃብ ወይ ንምውሓስ ዝተኸፍለ ወጻኢታት','ገንዘብ ንኽትረክብ ኣድላዪ ዝኾኑ ወጻኢታት ክትቅንስ ትኽእል'],['ቅነሳ የብሉን','ውልቃዊ ወጻኢታት (ገዛ፣ መግቢ፣ ውልቃዊ ወጻኢ)','ውልቃዊ ናይ መነባብሮ ወጻኢታት ፈጺሙ ክቕነስ ኣይከኣልን'],['ክሳራ ኣብ ሽያጥ (§ 6-2)','ቅነሳ ብሕግታት ምዕ. 9','ገለ ነገር ብኽሳራ እንተ ሸጥካ ካብ ግብሪኻ ክትቅንሶ ትኽእል'],['ክሳራ ኣብ ዕዳ (§ 6-2(2))','ቅነሳ ኣብ ንግዲ ናይ መወዳእታ ክሳራ ምስ ተረጋገጸ','ሓደ ሰብ ንትካልካ ገንዘብ ክኸፍል ዘይክእል ኮይኑ'],['ጉድለት (§ 6-3)','ምስ ካልእ ኣታዊ ይቕነስ፣ ይቕጽል (§ 14-6)','ትካል ብኻሳራ እንተ ከይዱ ነቲ ክሳራ ኣብ ካልእ ኣታዊ ክትጥቀመሉ ትኽእል — ወይ ንዝቕጽሉ ዓመታት ክትዕቅቦ'],['— ዝተሓተ ቅነሳ (§ 6-30/32) —',''],['ናይ ደሞዝ ኣታዊ','46% ናይ ደሞዝ፣ ዝለዓለ 95 700 kr','ኩሎም ሰራሕተኛታት ኣውቶማቲክ ይረኽቡዎ — ጉዕዞ፣ ክዳውንቲ፣ መሳርሒ ወዘተ. ይሽፍን'],['ናይ ጡረታ ኣታዊ','40% ናይ ጡረታ'],['ዝትክኦ','መብዛሕትአን ናይ ስራሕ ወጻኢ ቅነሳታት','ዝተሓተ ቅነሳ ምስ ተጠቐምካ ንውልቂ ወጻኢታት ሰነድ ምቕራብ ኣየድልየካን'],['ዘይጥርናፈ','ናይ ማሕበር ክፍሊት፣ ናይ ተመላለስቲ ወጻኢ','እዚኣቶም ብተወሳኺ ናይ ዝተሓተ ቅነሳ ክቕነሱ ይኽእሉ'],['— ስታንዳርድ ቅነሳታት —',''],['ናይ ማሕበር ክፍሊት (§ 6-20)','ዝለዓለ 8 700 kr','ኣባልነት ኣብ ማሕበራት ከም LO፣ YS፣ Unio፣ Akademikerne'],['ጉዕዞ ገዛ–ስራሕ (§ 6-44)','ልዕሊ 12 000 kr፣ ዝለዓለ 120 000 kr','ልዕሊ 37 ኪ.ሜ. ንሓደ ኣንፈት ጉዕዞ ቅነሳ (ድሕሪ ታሕተዋይ ደረት)'],['ናይ ወላዲ ቅነሳ (§ 6-48)','ትሕቲ 12 ዓመት ቆልዑ፣ ብፓርላማ ዝተወሰነ ዓቐን','ንመዋዕለ ህጻናት፣ ድሕሪ ትምህርቲ ክንክን ወጻኢታት ይሽፍን'],['ውህብቶ ንውድባት (§ 6-50)','ዝውሓደ 500 kr፣ ዝለዓለ 25 000 kr','ንጹር መስቀል፣ ሓካይም ብዘይ ዶብ ዝኣመሰሉ ፍቓድ ዝተዋህቦም ውድባት ውህብቶ'],['ናይ ቆልዓ ጡረታ ቅነሳ (§ 6-49)','ክሳብ 32 600 kr'],['— ናይ ዕዳ ወለድ (§ 6-40) —',''],['ናይ ዕዳ ወለድ','ምሉእ ቅነሳ (22% ናይ ግብሪ ጽልዋ)','ኩሉ ዝኸፈልካዮ ወለድ — ናይ ገዛ ልቓሕ፣ ናይ ትምህርቲ ልቓሕ፣ ናይ መኪና ልቓሕ — 22% ኣብ ግብሪ ይመልሰልካ'],['ናይ ወለድ ደረት ኮንሰርን (§ 6-41)','25% ናይ EBITDA፣ ደረት 25M (ኮንሰርን) / 5M (ደገ)','ኣብ ሓደ ኮንሰርን ዘሎ ትካላት መንጎ ናይ ልቓሕ ወለድ ቅነሳ ይድርት'],['ዝቐጸለ ዝተኸልከለ ወለድ','10 ዓመት','ሎሚ ዘይተፈቕደ ወለድ ኣብ ዝቕጽሉ 10 ዓመታት ክጥቀመሉ ይከኣል'],['— ናይ ንግዲ ቅነሳታት —',''],['ምህላቕ (§ 6-10)','ናይ ንግዲ ንብረት ምብላይ/ምንቕናቕ፣ ጉድዊል ኣብ ግዝኢ','ናይ ማሽን፣ ተሽከርከርቲ ወዘተ. ወጻኢ ኣብ ብዙሕ ዓመታት ይዝርጋሕ'],['ጽገና/ውሕስነት (§ 6-11)','ንናይ ንግዲ ንብረት ቅነሳ'],['ምርምርን ምዕባለን (§ 6-25)','ናይ ንግዲ ንብረት ዋጋ ክፋል','ናይ ምዕባለ ወጻኢታት ክትሕዘሎምን ብግዜ ከተህልቖምን ይከኣል'],['ናይ ጅማሮ ትካል ወፍሪ (§ 6-53)','ክሳብ 1M kr፣ ትካል ≤6 ዓመት፣ ≥3 ዓመት ዋንነት','ኣብ ንኣሽቱ ሓደስቲ ትካላት ዝወፍሩ ውልቀ ሰባት ቅነሳ ይረኽቡ'],['— ቅነሳ የብሉን —',''],['ውክልና (§ 6-21)','ፈጺሙ ቅነሳ የብሉን','ናይ ዓሚል ድራር፣ ንናይ ንግዲ መሻርኽቲ ህያባት ወዘተ.'],['ምብልሻው (§ 6-22)','ፈጺሙ ቅነሳ የብሉን'],['ናይ ማሕበር ክፍሊት (§ 6-18)','ብሓፈሻ ቅነሳ የብሉን (ፍሉይ § 6-19/20)','ንናይ ኢንዱስትሪን ሞያን ማሕበራት ፍሉይ ኣሎ'],['— ብባንክ ምኽፋል (§ 6-51) —',''],['ጠለብ','ክፍሊት ≥10 000 kr ብባንክ ክኸውን ኣለዎ ንቅነሳ','ልዕሊ 10 000 kr ጥረ ገንዘብ ክፍሊት ቅነሳ ኣይህብን'],['— ናይ ሞያ ቅነሳታት —',''],['ናይ ዓሳ ሓራሲ ቅነሳ (§ 6-60)','30%፣ ዝለዓለ 160 000 kr፣ ≥130 መዓልቲ','ኣብ ዓመተ ኣታዊ ብውሑዱ 130 መዓልቲ ዓሳ ምሓዝ የድሊ'],['ናይ ባሕረኛ ቅነሳ (§ 6-61)','30%፣ ዝለዓለ 86 300 kr፣ ≥130 መዓልቲ','ኣብ ዓመተ ኣታዊ ብውሑዱ 130 መዓልቲ ኣብ ባሕሪ የድሊ']],
    salRealRows: [['— መዓስ እዩ ምግባር ዝፍጸም? —','ቀንዲ ሕጊ §§ 9-1ን 9-2ን'],['እንታይ እዩ ናይ ረብሓ ቀረጽ ዘስዕብ?','ምሻጥ፣ ምቅያር፣ ናይ ኣክስዮን ምምላስ፣ ምውሳድ፣ ምዕናው — ዝኾነ ናይ ዋንነት ምስግጋር ብዋጋ','§ 9-2(1)'],['ህያብ?','ህያብ ምግባር ኣይኮነን — ንህያብ ዝህብ ቀረጽ የብሉን','§ 9-2(3)'],['ውርሻ?','ምግባር ኣይኮነን — ኣብ ውርሻ ናይ ረብሓ ቀረጽ የብሉን','§ 9-2(3)'],['ምክፍፋል ኣብ መንጎ ሰብ ሓዳር?','ምግባር ኣይኮነን — ኣብ ፍትሕ/ምፍልላይ እውን','§ 9-2(3)'],['ግዱድ ምምላስ?','ከም ምግባር ይቑጸር — ናይ ቀረጽ ግዴታ ይለዓል','§ 9-2(1)'],['— ናይ ገዛ ምሕዳግ —','§ 9-3: መዓስ ቀረጽ ዘይትኸፍል?'],['ገዛኻ ሸጥካ?','ሕዳግ ብውሑዱ 1 ዓመት ተዋኒንካ ብውሑዱ 1 ካብ ናይ መወዳእታ 2 ዓመት ተቐሚጥካ','§ 9-3(2)'],['ናይ ዕረፍቲ ገዛ ሸጥካ?','ሕዳግ ብውሑዱ 5 ዓመት ተዋኒንካ ብውሑዱ 5 ካብ ናይ መወዳእታ 8 ዓመት ተጠቒምካ','§ 9-3(4)'],['ውልቃዊ ነገራት ሸጥካ?','ሕዳግ — ውልቃዊ ንብረት','§ 9-3(1)a'],['ናይ መሬት ረብሓ?','ሕዳግ እቲ መሬት ኣዝዩ ንእሽቶ ክኸውን ኣለዎ — ኣንተዘይኮይኑ ገዛ ሕዳግ ኮይኑ ከም ምሻጥ መሬት ይቕረጽ','§ 9-3(8)'],['ክሳራ ኣብ ሕዳግ ገዛ?','ቅነሳ የብሉን — ናይ ተመዓራረይነት መትከል','§ 9-4'],['— ክሳራታት ይቕነስ —','§ 9-4: ናይ ተመዓራረይነት መትከል'],['ብክሳራ ሸጥካ?','ቅነሳ ከምቲ ረብሓ ቀረጽ ዝኾነሉ ዝነበረ ደረጃ','§ 9-4(1)'],['ናይ ኣክስዮን ክሳራ?','ምሉእ ቅነሳ — ×1.72 ከም ረብሓ ይውስኽ','§ 9-4, § 10-31'],['— መሰረታዊ ዋጋ ኣብ ውርሻ/ህያብ —','§ 9-7: ናይ ቀጻልነት መትከል'],['ገለ ወሪስካ?','ናይ ሞያስኻ መሰረታዊ ዋጋ ትወስድ — ናይ ሕጂ ዋጋ ሹቕ ኣይኮነን','§ 9-7(1)'],['ህያብ ረኺብካ?','ተመሳሳሊ መትከል — ናይ ህያብ ዝሃበ መሰረታዊ ዋጋ ትወስድ','§ 9-7(1)'],['ፍሉይ — ሞያስኻ ብሕዳግ ክሸይጥ ዝኽእል ኔሩ?','መሰረታዊ ዋጋ ናይ ሕጂ ዋጋ ሹቕ ይኸውን ኣብ መዓልቲ ሞት','§ 9-7(2)'],['— ካብ ናይ ኖርወይ ቀረጽ ምውጻእ —','§ 9-14: ናይ ምውጻእ ቀረጽ'],['ንብረት ካብ ኖርወይ ተወጽእ?','ዝተሓብአ ረብሓ ከም ብዋጋ ሹቕ ዝተሸጠ ይቕረጽ','§ 9-14(1)'],['ዘይጭበጥ ንብረት ይሓውስ?','እወ — ፓተንት፣ ፍቓድ፣ ናይ ንግዲ ምልክት ወዘተ','§ 9-14(2)'],['ምድንጓይ ይከኣል?','እወ፣ ኣብ ኤኤኤ — ግን ዋሕስ ክሕተት ይኽእል','§ 9-14(4)']],
    salCorpRows: [['— ናይ ኮንሰርን ወፍሪ (§ 10-2 ክሳብ 10-5) —',''],['ናይ ኮንሰርን ወፍሪ (§ 10-2)','ንወሃቢ ቅነሳ፣ ንተቐባሊ ግብሪ ዝኽፈሎ','ኣብ ሓደ ኮንሰርን ዘሎ ትካላት መንጎ ምስግጋር — ውጽኢት ንምምዕርራይ ይጥቀሙ'],['ናይ ዋንነት ጠለብ (§ 10-4)','ኣደ ትካል >90% ናይ ኣክሲዮንን ድምጽን ዋንነት','ንኣክሲዮን ትካላትን ኣብ ኢ.ኤ.ኤ. ተመሳሳሊ ናይ ወጻኢ ትካላትን ይምልከት'],['— ምቕባል ረብሓን ምኽልኻልን (§ 10-10 ክሳብ 10-13) —',''],['ምቕባል ረብሓ (§ 10-11)','ንውልቃዊ ባለ ኣክሲዮን ግብሪ ዝኽፈሎ','ብረቛሒ 1.72 ቅድሚ ብ22% ግብሪ ምኽፋል ይዓቢ'],['ናይ ምኽልኻል ቅነሳ (§ 10-12)','ቅድሚ ግብሪ ካብ ምቕባል ረብሓ ይቕነስ','ንሓደጋ-ነጻ ወለድ ዝኸውን ክፋል ናይ ምቕባል ረብሓ ግብሪ ኣይትኸፍልን'],['ናይ ምኽልኻል ወለድ','ናይ መንግስቲ ሸቐጣ-ሸቐጥ ድሕሪ ግብሪ','ኣብ ነፍሲ ወከፍ ዓመት ብናይ ግብሪ ምምሕዳር ይውሰን'],['ናይ ምሕረት ኣገባብ (§ 2-38)','ንትካላት ግብሪ ነጻ','ኣ.ሽ. ኣብ ካልእ ኣ.ሽ. ኣክሲዮን ዝውንን ኣብ ምቕባል ረብሓን ረብሓን ግብሪ ኣይከፍልን'],['3% ሕጊ (§ 2-38(6))','3% ናይ ኣታዊ ይእመን','ትካላት ግን 0.66% (3% × 22%) ናይ ዝተሓድገ ምቕባል ረብሓ ይኸፍሉ'],['— ናይ ኣክሲዮን ረብሓን ክሳራን (§ 10-30 ክሳብ 10-37) —',''],['ረብሓ ኣብ ሽያጥ (§ 10-31)','ንውልቃዊ ባለ ኣክሲዮን ግብሪ ዝኽፈሎ','ብረቛሒ 1.72 ይዓቢ፣ ማለት ውጽኢታዊ ግብሪ ኣስታት 37.84%'],['ክሳራ ኣብ ሽያጥ (§ 10-31(2))','ቅነሳ ዝግበረሉ','ተመሳሳሊ ብረቛሒ 1.72 ይዓቢ'],['ናይ ኣታዊ ዋጋ (§ 10-32)','ዋጋ ግዝኢ + ዘይተጠቐምካሉ ምኽልኻል','ንኣክሲዮን ዝኸፈልካዮ ዋጋ ከምኡ ውን ዝተኣኻኸበ ናይ ምኽልኻል ቅነሳ'],['FIFO ኣርእስቲ (§ 10-36)','ቅድም ዝተገዝአ = ቅድም ዝሽየጥ','ካብ ኣክሲዮን ክፋል ምስ ሸጥካ እተን ዝቐደማ ዝተገዝአ ኣክሲዮን ቅድም ተሸይጠን ይቑጸራ'],['— ናይ ወረቐት ዋጋ ፈንድን ኣ.ስ.ክ.ን (§ 10-20/10-21) —',''],['ናይ ወረቐት ዋጋ ፈንድ (§ 10-20)','ናይ ኣክሲዮንን ወለድን ክፋል ብፍልልይ ግብሪ ይኽፈሎ','ናይ ኣክሲዮን ክፋል = ናይ ባለ ኣክሲዮን ሞዴል፣ ናይ ወለድ ክፋል = ልሙድ ኣታዊ'],['ናይ ኣክሲዮን ቁጠባ ሕሳብ (§ 10-21)','ግብሪ ክሳብ ምውጻእ ይደናጎ','ብዘይ ግብሪ ምፍናው ኣብ ውሽጢ ሕሳብ ኣክሲዮን/ፈንድ ክትገዝእን ክትሸጥን ትኽእል'],['ግብሪ ዝኽፈሎ ምውጻእ (§ 10-21(4))','ልዕሊ ዝኣተወ ዝወጸ ግብሪ ዝኽፈሎ','ካብ ዘእተኻዮ ንላዕሊ ምስ ወጻእካ ጥራይ ግብሪ ትኸፍል'],['— ናይ ተሳተፍቲ ግብሪ ዊንታ ANS/KS (§ 10-40 ክሳብ 10-49) —',''],['ናይ ኔቶ ኣገባብ (§ 10-41)','ትርፊ ኣብ ደረጃ ተሳተፍቲ ግብሪ ይኽፈሎ','ነፍሲ ወከፍ ተሳታፊ ንናቱ ኣታዊ ካብ ትካል ግብሪ ይኸፍል'],['ምዕዳል (§ 10-42)','ንውልቃዊ ተሳታፊ ግብሪ ዝኽፈሎ','ከም ምቕባል ረብሓ ብረቛሒ 1.72 ይዓቢ'],['ረብሓ ኣብ ሽያጥ ኣክሲዮን (§ 10-44)','ግብሪ ዝኽፈሎ','ካብ ናይ ኣታዊ ዋጋ ብናይ ልዕሊ-/ትሕቲ-ዋጋ ምትዕርራይ ይሕሰብ'],['— ናይ ሓባር ትካል (§ 10-50) —',''],['ድሕረ-ክፍሊት (§ 10-50)','ንናይ ሓባር ትካል ቅነሳ','ምስ ትካል ብዝገበሩዎ ንግዲ ዝተመርኮሰ ንኣባላት ምምላስ'],['— NOKUS / ትሑት ግብሪ ሃገር (§ 10-60 ክሳብ 10-68) —',''],['NOKUS ሕግታት (§ 10-60)','ኖርወጃዊ ዋናታት ብቐጻሊ ግብሪ ይኽፈሎም','ብኖርወጃዊ ዋናታት ዝቆጻጸርዎ ኣብ ትሑት ግብሪ ሃገራት ዘሎ ትካላት ይምልከት'],['ትሑት ግብሪ ሃገር (§ 10-63)','ግብሪ ትሕቲ 2/3 ናይ ኖርወይ ግብሪ','ውጽኢታዊ ግብሪ ትሕቲ ኣስታት 14.67% እንተ ኾይኑ ትሑት ግብሪ ሃገር ይብሃል'],['ናይ ቁጽጽር ጠለብ (§ 10-62)','ኖርወጃውያን ዋናታት ብውሑዱ 50%','ቁጽጽር ንኹሎም ኖርወጃውያን ግብሪ ከፈልቲ ብሓባር ይግምገም'],['ናይ ክረዲት ቅነሳ (§ 10-65)','ንዝተኸፍለ ናይ ወጻኢ ግብሪ ቅነሳ','ኣብ ወጻኢ ዝተኸፍለ ግብሪ ብምቕናስ ድርብ ግብሪ ይከላኸል'],['— ናይ ምግዓዝ ግብሪ (§ 10-70/10-71) —',''],['ዘይተረጋገጸ ረብሓ (§ 10-70)','ካብ ኖርወይ ምስ ትወጽእ ግብሪ ዝኽፈሎ','ንኣክሲዮን፣ ኣክሲዮንን ገለ ካልኦት ንብረትን ይምልከት'],['ምድንጓይ (§ 10-70(7))','ኣብ ውሽጢ ኢ.ኤ.ኤ. ክደናጎ ይኽእል','ክፍሊት ይደናጎ፣ ግን ውሕስነት ክሕተት ይኽእል'],['ምብዃር (§ 10-70(9))','ድሕሪ 5 ዓመት ግብሪ ይብኩር','ንብረትካ ኣብ ውሽጢ 5 ዓመት ዘይሸጥካዮ ግብሪ ይስረዝ'],['— ምንጪ ግብሪ (§ 10-80 ክሳብ 10-82) —',''],['ምንጪ ግብሪ ኣብ ምቕባል ረብሓ','15–25% ንናይ ወጻኢ ባለ ኣክሲዮን','ዋጋ ምስ ናይ ባለ ኣክሲዮን ሃገር ናይ ግብሪ ስምምዕ ይምርኮስ'],['ምንጪ ግብሪ ኣብ ወለድ/ሮያልቲ (§ 10-80)','ብሕጊ ዝተወሰነ ሕግታት','ኣብ ትሑት ግብሪ ሃገር ንዘሎ ቀረባ ሰብ ዝግበር ክፍሊት ይምልከት']],
    salReorgRows: [['— ምውህሃድ (§ 11-2/11-3) —',''],['ኣክሲዮን ትካላት (§ 11-2)','ምውህሃድ ናይ ኣክሲዮን ሕጊ ምዕ. 13 ምስ ዝስዕብ ግብሪ ነጻ','ክልተ ወይ ልዕሊኡ ኣ.ሽ. ብዘይ ግብሪ ይጽንበሩ'],['ናይ ሓባር ትካላት (§ 11-2(2))','ብናይ ሓባር ትካል ሕጊ ምዕ. 8 ግብሪ ነጻ'],['ናይ ተሳተፍቲ ትካል (§ 11-3)','ተመሳሳሊ ናይ ትካልን ሓላፍነትን ቅርጺ ምስ ዝኸውን ግብሪ ነጻ','ተሳተፍቲ ከም ክፍሊት ኣክሲዮን ክረኽቡ ኣለዎም (ዝለዓለ 20% ተወሳኺ ጥረ ገንዘብ)'],['— ምፍላይ (§ 11-4/11-5) —',''],['ኣክሲዮን ትካላት (§ 11-4)','ምፍላይ ናይ ኣክሲዮን ሕጊ ምዕ. 14 ምስ ዝስዕብ ግብሪ ነጻ','ሓደ ትካል ብዘይ ግብሪ ናብ ክልተ ወይ ልዕሊኡ ይፍለ'],['ናይ ተሳተፍቲ ትካል (§ 11-5)','ተመሳሳሊ ናይ ትካልን ሓላፍነትን ቅርጺ ምስ ዝኸውን ግብሪ ነጻ','ዝለዓለ 20% ናይ ክፍሊት ካብ ኣክሲዮን ወጻኢ ክኸውን ይኽእል'],['— ኩነታትን ኣርእስቲታትን —',''],['ካልእ ክፍሊት (§ 11-6)','ናብ ባለ ኣክሲዮን ናይ ጥረ ገንዘብ ክፍሊት ግብሪ ዝኽፈሎ','ኣክሲዮን/ኣክሲዮን ኣብ ዝጽንበሩ ትካላት ጥራይ ግብሪ ነጻ'],['ቀጻልነት (§ 11-7)','ናይ ግብሪ ዋጋታትን ናይ ግዝኢ ዕለታትን ይቕጽሉ','ተቐባሊ ትካል ኩሎም ናይ ግብሪ ኣቋም ብዘይ ለውጢ ይወስድ'],['ምምቕራሕ ኣብ ምፍላይ (§ 11-8)','ናይ ግብሪ ኣቋም ብናይ ኔቶ ዋጋ ይምቐል'],['ምፍራስ (§ 11-9)','ዘመሓላለፈ ትካል ድሕሪ ምስግጋር ክፈርስ ኣለዎ'],['ናይ ጽልዋ ዕለት (§ 11-10)','ካብ ናይ ትካል ሕጊ ጅማሮ'],['— ዶብ ሰጋሪ (§ 11-11) —',''],['ምውህሃድ/ምፍላይ ሃገራት ሰጊሩ','ኣብ ውሽጢ ኢ.ኤ.ኤ. ብቐጻልነት ግብሪ ነጻ','ኖርወጃዊ ኣ.ሽ. ምስ ኣብ ካልእ ኢ.ኤ.ኤ. ሃገር ዘሎ ትካል ክጽንበር ይኽእል'],['ናይ ኣክሲዮን ምልውዋጥ (§ 11-11(4))','ብውሑዱ 90% ናይ ኣክሲዮን ምስ ዝስግገር ግብሪ ነጻ','ዝለዓለ 20% ጥረ ገንዘብ ክፍሊት'],['ትሑት ግብሪ ሃገር (§ 11-11(7))','ናይ ግብሪ ምሕረት ንትሑት ግብሪ ሃገር ኣይምልከትን','ፍሉይ ኣብ ኢ.ኤ.ኤ. ሃገር ብሓቂ ዝተመስረተ ምስ ዝኸውን'],['— ምቕያር (§ 11-20) —',''],['ናብ ኣክሲዮን ትካል','ውልቃዊ ትካል፣ ANS፣ DA ወዘተ. ብዘይ ግብሪ ክቕየሩ ይኽእሉ','ናይ ግብሪ ዋጋታትን ኣቋምን ይቕጽሉ'],['ናይ ኮንሰርን ምስግጋር (§ 11-21)','ኣብ ሓደ ኮንሰርን ዘሎ ትካላት መንጎ ግብሪ ነጻ ምስግጋር','ኣደ ትካል ልዕሊ 90% ናይ ኣክሲዮን ክውንን ኣለዎ'],['ምምዕባል (§ 11-22)','ሚኒስትሪ ኣብ ምትዕርራይ ናይ ግብሪ ምሕረት ክህብ ይኽእል','ንሽያጥ ንብረት፣ ንግዲ ወይ ኣክሲዮን ይምልከት']],
    salKeyRows: [['— ስራሕ፣ ማልን ወይ ንግዲ? —','§ 5-1: ስለምንታይ እቲ ዶብ ናይ ቀረጽካ ይውስን'],['ናይ ስራሕ ኣታዊ','ውልቃዊ ኣገልግሎት ንኻልኦት። ደሞዝ፣ ናይ ቦርድ ክፍሊት፣ ናይ ዓይነት ጥቕሚ። ውልቃዊ ኣታዊ ይህብ → ደረጃዊ ቀረጽ + ኣበርክቶ (7.6%)።','§ 5-10'],['ናይ ማል ኣታዊ','ካብ ዋንነትካ ዝመጽእ — ወለድ፣ ዲቪደንድ፣ ክራይ፣ ናይ ኣክስዮን ረብሓ። 22% ጥራይ።','§ 5-20'],['ናይ ንግዲ ኣታዊ','ናይ ቀረጽ ሕጊ «ንግዲ» ቀጥታ ኣይገልጽን። ኣርባዕተ ረቛሒታት:'],['1. ግዜ','ንጥፈት ገለ ግዜ ክህልዎ ኣለዎ — ሓደ ሻቐጥ ጥራይ ኣይኮነን።'],['2. ስፍሓት','ገለ ስፍሓት ክህልዎ ኣለዎ። ሓደ ናይ ክራይ ገዛ = ማል። ዓሰርተ ብንቑሕ ኣመሓድራ = ንግዲ።'],['3. ናይ ረብሓ ዓቕሚ','ንጥፈት ብቕንዕና ረብሓ ክረክብ ዝኽእል ክኸውን ኣለዎ።'],['4. ናይ ገዛእ ርእስኻ ሓደጋ','ንስኻ ባዕልኻ ናይ ገንዘብ ሓደጋ ትሰከም። ንግዲ ካብ ምስራሕ ይፈልዮ።'],['ስለምንታይ ኣገዳሲ?','ውልቃዊ ንግዲ ውልቃዊ ኣታዊ ይህብ → ደረጃዊ ቀረጽ + ኣበርክቶ። ማል 22% ጥራይ ይህብ።'],['ልሙድ ግራጫ ቦታ?','ናይ ንብረት ክራይ። ቁሩብ ንብረት = ማል። ብዙሕ ብንቑሕ ኣመሓድራ = ንግዲ።'],['— ናይ ምግባር ሓሳብ —','§ 9-2: እንታይ እዩ ቀረጽ ዘስዕብ — እንታይ ከ ኣየስዕብን?'],['እንታይ እዩ ምግባር?','ናይ ዋንነት ምስግጋር ብዋጋ: ምሻጥ፣ ምቅያር፣ ምምላስ፣ ምውሳድ፣ ምዕናው።','§ 9-2(1)'],['እንታይ ኣይኮነን ምግባር?','ህያብ፣ ውርሻ፣ ኣብ ፍትሕ ምክፍፋል፣ ኣብ መንጎ ሰብ ሓዳር ምስግጋር።','§ 9-2(3)'],['ናይ ገዛ ሕጊ?','ገዛኻ ምሻጥ ሕዳግ: ዋንነት 1 ዓመት ምቕማጥ 1 ካብ 2 ዓመት። ናይ ዕረፍቲ: 5 ዓመት፣ ተጠቒምካ 5/8።','§ 9-3(2)/(4)'],['ናይ ተመዓራረይነት መትከል?','ክሳራ ቀረጽ ይቕነስ ከምቲ ረብሓ ቀረጽ ዝኾነሉ ዝነበረ ደረጃ።','§ 9-4'],['ውርሳን ህያብን — ቀጻልነት?','ተቐባሊ ናይ ሞያስኻ/ህያብ ዝሃበ መሰረታዊ ዋጋ ይወስድ። ኣብ ምቕባል ቀረጽ የብሉን ግን መጻኢ ረብሓ ካብ መበቆል ዋጋ ይቑጸር።','§ 9-7'],['ፍሉይ: ሞያስኻ ብሕዳግ ክሸይጥ ዝኽእል ኔሩ?','መሰረታዊ ዋጋ = ናይ ሹቕ ዋጋ ኣብ ዕለት ሞት — ንወራሲ ዝሓይሽ።','§ 9-7(2)'],['— መሰረታዊ ዋጋ —','ብናይ ቀረጽ ትርጉም ዝኸፈልካዮ'],['እንታይ እዩ መሰረታዊ ዋጋ?','ናይ ረብሓ ወይ ክሳራ ዝዕቀነሉ ቁጽሪ ኣብ ምሻጥ። ልሙድ: ናይ ግዝኢ ዋጋ + ወጻኢታት።','§ 9-7, § 10-32'],['ስለምንታይ ኣገዳሲ?','ረብሓ = ናይ ሻቐጥ ዋጋ ድህሪ መሰረታዊ ዋጋ። ጌጋ ዋጋ = ጌጋ ቀረጽ።'],['ውርሳ/ህያብ?','መሰረታዊ ዋጋ ትወስድ (ቀጻልነት)። ናብ ናይ ሹቕ ዋጋ \'ምቕያር\' የብሉን።','§ 9-7'],['ኣክስዮን?','ናይ ግዝኢ ዋጋ + ናይ ስምምዕ ወጻኢ + ዘይተጠቐምካሉ ሕዳግ። FIFO ቅደም ተኸተል ይውስን።','§ 10-32, § 10-36'],['ገዛ?','ናይ ግዝኢ ዋጋ + ናይ ሰነድ ቀረጽ + ምምሕያሽ (ኣይኮነን ጽገና)።','§ 9-3'],['ምህዳም ዋጋ?','ናይ ንግዲ ንብረት መሰረታዊ ዋጋ ብናይ ቀረጽ ምህዳም ይንኪ።','§ 6-10, § 14-40'],['— ናይ ኣክስዮን ሞዴል —','§ 10-11 ክሳብ 10-12'],['ዲቪደንድ ከመይ ይቕረጽ?','ዲቪደንድ ×1.72 ተባዚሑ 22% ይቕረጽ። ናይ ሓቂ ቀረጽ: ~37.84%።','§ 10-11'],['ናይ ምሕዳግ ቅነሳ እንታይ እዩ?','ናይ ዲቪደንድ ክፋል ናይ ሓደጋ-ኣልቦ ዋጋ ዝመዓራረ ሕዳግ እዩ።','§ 10-12'],['ስለምንታይ 1.72?','ጠቕላላ ቀረጽ (ትካል + ኣክስዮን) ናይ ደሞዝ ቀረጽ ደረጃ ክኸውን።'],['— ናይ ምሕዳግ ኣገባብ —','§ 2-38'],['እንታይ እዩ?','ትካላት ኣብ ዲቪደንድን ረብሓን ናይ ካልኦት ትካላት ቀረጽ ኣይከፍሉን።','§ 2-38'],['ናይ 3% ሕጊ?','ትካል 3% ናይ ሕዳግ ዲቪደንድ ክፈልጥ ኣለዎ። ናይ ሓቂ ቀረጽ: 0.66%።','§ 2-38(6)'],['ፍሉይ?','ንትሑት ቀረጽ ዘለዎም ሃገራት ወይ ኣብ ኤኤኤ ወጻኢ 10% ትሕቲ ዋንነት ኣይምልከትን።','§ 2-38(3)'],['— ናይ ጉጅለ ኣበርክቶ —','§ 10-2 ክሳብ 10-5'],['እንታይ እዩ?','ኣብ መንጎ ናይ ጉጅለ ትካላት ናይ ገንዘብ ምስግጋር። ንዝህብ ቅነሳ፣ ንዝቕበል ቀረጽ።','§ 10-2'],['እንታይ እዩ ዕላማ?','ረብሓን ክሳራን ኣብ ጉጅለ ንቕኑዕ ጠቕላላ ቀረጽ ምስምማዕ።'],['ቅድመ-ኩነት?','ኣደ ትካል 90% ልዕሊ ኣክስዮንን ድምጽን ክህልዎ ኣለዎ።','§ 10-4'],['— ናይ ቀረጽ-ኣልቦ ምጥርናፍን ምፍልላይን —','§ 11-2, § 11-4, § 11-7'],['መዓስ ቀረጽ-ኣልቦ?','ብሕጊ ትካላት ምስ ናይ ቀረጽ ቀጾልነት ምስ ዝፍጸም።','§ 11-2/11-4'],['ቀጾልነት እንታይ እዩ?','ተቐባሊ ትካል ኩሉ ናይ ቀረጽ ዋጋ ብዘይ ለውጢ ይወርስ።','§ 11-7'],['እንታይ ጌጋ ክኸውን ይኽእል?','ናይ ገንዘብ ክፍሊት = ቀረጽ። ክሳራታት ክጠፉ ይኽእሉ (§ 13-3)።'],['— ጸረ-ምህዳም —','§ 13-2'],['መዓስ ይምልከት?','ቀንዲ ዕላማ ናይ ቀረጽ ጥቕሚ ኮይኑ ስምምዕ ንጠቕላላ ገምጋም ዘይጻወር ምስ ዝኸውን።','§ 13-2(2)'],['እንታይ ይገምገም?','ናይ ንግዲ ትሕዝቶ፣ ናይ ቀረጽ ጥቕሚ ዓቐን፣ ዘይግቡእ መንገዲ፣ ዕላማ ሕግታት ዝጻረር ኣጠቓቕማ።','§ 13-2(3)'],['ውጽኢት?','ስምምዕ ብሓቀኛ ትሕዝቶኡ ይቕረጽ — ብቕርጽኡ ኣይኮነን።','§ 13-2(4)'],['ኣብነት?','ክሳራ ንምጥቃም ጥራሕ ትካል ምግዛእ። ክሳራ ብ § 13-3 ይጠፍእ።','§ 13-3'],['— ናይ ሕጋውነት ቅድመ-ኩነት —','§ 11-1(2)'],['እንታይ እዩ?','ምጥርናፍን ምፍልላይን ኣብ ሰለስተ ደረጃ ሕጋዊ ክኸውን ኣለዎ ንቀረጽ-ኣልቦ።','§ 11-1(2)'],['ናይ ትካላት ሕጊ','ናይ ትካላት ሕጊ ክኽተል ኣለዎ: ናይ ምጥርናፍ ውጥን፣ ናይ ኣለቃሒ ምልክታ፣ ናይ ጠቕላላ ኣኼባ ውሳኔ።','ናይ ትካላት ሕጊ ምዕ. 13/14'],['ናይ ቀረጽ ሕጊ (ምዕ. 11)','ናይ ቀረጽ ቀጾልነት፣ ዝበዝሐ 20% ገንዘብ፣ ናይ ዘረከበ ትካል ምፍራስ።','§ 11-7, § 11-6, § 11-9'],['ናይ ቀረጽ ዋጋ ወሰኽ ሕጊ','ምጥርናፍ/ምፍልላይ ሕዳግ (§ 6-14, 0% ቀ.ዋ.ወ.)። ግን ናይ ምትዕርራይ ግዴታ ናብ ሓድሽ ዋናን ይሓልፍ።','ናይ ቀ.ዋ.ወ. ሕጊ § 6-14, ምዕ. 9'],['ብግብሪ?','ሰለስቲኦም ደረጃታት ክሰማምዑ ኣለዎም። ጌጋ ኣብ ናይ ትካላት ሕጊ ኣብ ቀረጽን ቀ.ዋ.ወ.ን ይጸልው።']],
    salSubjRows: [['— ውልቃዊ ግብሪ ከፋሊ (§ 2-1) —',''],['ኣብ ኖርወይ ዝቕመጥ (§ 2-1(1))','ኣብ ኖርወይን ወጻኢን ዘሎ ኩሉ ኣታዊ/ንብረት ግብሪ ዝኽፈሎ','ኣብ ኖርወይ እንተ ትቕመጥ ኩሉ ግብሪ ትኸፍል — ኣታዊ ኣብ ዝኾነ ቦታ ዓለም ይምጻእ'],['መንበሪ ዝጅመር (§ 2-1(2))','ልዕሊ 183 መዓልቲ ኣብ 12 ወርሒ፣ ወይ ልዕሊ 270 መዓልቲ ኣብ 36 ወርሒ','ኣብ ኖርወይ ዝኣክል ግዜ እንተ ተቐሚጥካ ናይ ግብሪ ነባሪ ትኸውን'],['መንበሪ ዝቋረጽ (§ 2-1(3))','ኣብ ወጻኢ ቀዋሚ መንበሪ + ኣብ ኖርወይ ገዛ ምሕዳግ የድሊ','ኣብ ወጻኢ ብቐዋሚ ክትነብርን ኣብ ኖርወይ ገዛ ከይህልወካን ኣለዎ'],['ግዝያዊ ምርሓቕ (§ 2-1(4))','ናይ ግብሪ መንበሪ ኣይቋርጽን','ዕረፍቲ ወይ ሓጺር ምቕማጥ ኣብ ወጻኢ መንበሪኻ ኣይቅይሮን'],['ስቫልባርድ (§ 2-1(5))','ፍሉይ ስርዓት (ናይ ስቫልባርድ ግብሪ ሕጊ)'],['— ናይ ሞት ንብረት (§ 2-2) —',''],['ናይ ሞት ንብረት (§ 2-2)','ኣብ ዓመተ ሞትን ድሕሪኡን ፍሉይ ናይ ግብሪ ኣካል','ናይ ሞት ንብረት ክሳብ ዝጠናቐቕ ከም ፍሉይ ኣካል ግብሪ ይኸፍል'],['ኣብ ዓመተ ሞት ምክፍፋል (§ 2-15)','ወረስቲ ካብ ጥሪ 1 ይወስዱ','ውርሻ ኣብ ዓመተ ሞት እንተ ተመቓቒሉ ወረስቲ ንምሉእ ዓመት ግብሪ ይኸፍሉ'],['— ትካላት (§ 2-2) —',''],['ኣክሲዮን ትካል (§ 2-2(1)a)','ፍሉይ ናይ ግብሪ ኣካል','ኣ.ሽ. ርእሰ-ነጻ ግብሪ ከፋሊ — 22% ካብ ትርፊ ይኸፍል'],['ህዝባዊ ኣክሲዮን ትካል (§ 2-2(1)b)','ፍሉይ ናይ ግብሪ ኣካል'],['ባንክ ቁጠባ፣ ናይ ሓድሕድ ውሕስነት (§ 2-2(1)c-d)','ፍሉይ ናይ ግብሪ ኣካል'],['ናይ ሓባር ትካል (§ 2-2(1)e)','ፍሉይ ናይ ግብሪ ኣካል'],['መንግስታዊ ትካል፣ ጥዕናዊ ትካል (§ 2-2(1)g-h)','ፍሉይ ናይ ግብሪ ኣካል'],['ፋውንደሽን (§ 2-2(1)f)','ፍሉይ ናይ ግብሪ ኣካል'],['ናይ ኮሙን ትካል (§ 2-2(1)i)','ፍሉይ ናይ ግብሪ ኣካል'],['— ውሱን ናይ ግብሪ ግቡእ (§ 2-3) —',''],['ኣታዊ ካብ ንብረት ኣብ ኖርወይ (§ 2-3(1)a)','ግብሪ ዝኽፈሎ','ኣብ ኖርወይ ንብረት ዝውንኑ ናይ ወጻኢ ሰባት ካብ ኣታዊ ግብሪ ይኸፍሉ'],['ንግዲ ኣብ ኖርወይ (§ 2-3(1)b)','ግብሪ ዝኽፈሎ','ካብ ኖርወይ ንግዲ እንተ ትዓዪ ኣብዚ ግብሪ ትኸፍል'],['ስራሕ ኣብ ኖርወይ (§ 2-3(1)d)','ግብሪ ዝኽፈሎ','ኣብ ኖርወይ እንተ ትሰርሕ ካብ ደሞዝ ኣብዚ ግብሪ ትኸፍል — ናይ ወጻኢ ሰባት ውን'],['ምቕባል ረብሓ ካብ ኖርወጃዊ ትካል (§ 2-3(1)c)','ምንጪ ግብሪ','ናይ ወጻኢ ባለ ኣክሲዮን ካብ ኖርወጃዊ ትካላት ምንጪ ግብሪ ይኸፍሉ'],['ክፍሊት ቦርድ (§ 2-3(1)e)','ግብሪ ዝኽፈሎ','ኣብ ኖርወጃዊ ትካል ቦርድ ኣባል እንተ ኾንካ ካብ ክፍሊት ግብሪ ትኸፍል'],['ጡረታ ካብ ኖርወይ (§ 2-3(4))','ግብሪ ዝኽፈሎ (ምንጪ ግብሪ)','ኣብ ወጻኢ ንዝቕመጡ ሰባት ውን'],['ናይ ስነ-ጥበብ ግብሪ (§ 2-3(1)h)','ንናይ ወጻኢ ፈጸምቲ ግብሪ ዝኽፈሎ','ንኮንሰርት፣ ኣቃርጾ ወዘተ. ፍሉይ ሕግታት'],['— ናይ ምሕረት ኣገባብ (§ 2-38) —',''],['ንትካላት ግብሪ ነጻ (§ 2-38(1))','ኣብ መንጎ ትካላት ምቕባል ረብሓን ረብሓን ግብሪ ነጻ','ኣ.ሽ. ኣብ ካልእ ኣ.ሽ. ኣክሲዮን ዝውንን ልሙድ ኣብ ምቕባል ረብሓን ረብሓን ግብሪ ኣይከፍልን'],['3% ሕጊ (§ 2-38(6))','3% ናይ ኣታዊ ይእመን','ትካል ብሓቂ 0.66% (3% × 22%) ናይ ዝተሓድገ ምቕባል ረብሓ ይኸፍል'],['ፍሉይ ትሑት ግብሪ ሃገር (§ 2-38(3))','ምሕረት ኣብ ትሑት ግብሪ ሃገር ዘሎ ትካላት ኣይምልከትን','ኣብ ኣዝዩ ትሑት ግብሪ ሃገራት ዘሎ ትካላት ናይ ምሕረት ኣገባብ ኣይምልከቶምን'],['ፍሉይ ፖርትፎሊዮ ኢ.ኤ.ኤ. (§ 2-38(3)b)','ምሕረት ትሕቲ 10% ዋንነት ደገ ኢ.ኤ.ኤ. ኣይምልከትን','ትሕቲ 10% ናይ ደገ ኢ.ኤ.ኤ. ትካል እንተ ተውንን ናይ ምሕረት ኣገባብ ኣይምልከትን'],['— ሰብ ሓዳር (§ 2-10 ክሳብ 2-16) —',''],['ሓባራዊ ወይ ፍሉይ (§ 2-10)','ሰብ ሓዳር ብሓባር ወይ ብፍሉይ ግብሪ ክግምገሙ ይኽእሉ','ኣታዊ ክጽንበር ወይ ነፍሲ ወከፍ ብፍሉይ ግብሪ ክኸፍል ክመርጹ ይኽእሉ'],['ምክፍፋል (§ 2-11)','ኣታዊ/ቅነሳ ንዝምልከቶ ሰብ ሓዳር ይምደብ'],['ክፍሊ 2 (§ 2-14)','ትሑት ኣታዊ ዘለዎ ሰብ ሓዳር ምህላው','ሓደ ሰብ ሓዳር ውሑድ ወይ ዜሮ ኣታዊ እንተ ኣለዎ ትሑት ግብሪ ይህብ'],['ሓባራዊ ገዛ (§ 2-12)','ኣብ ሓባራዊ ገዛ ሓባራዊ ግብሪ'],['— ቆልዑ (§ 2-14) —',''],['ትሕቲ 17 ዓመት ቆልዑ (§ 2-14(1))','ናይ ቆልዑ ኣታዊ ኣብ ወለዲ ግብሪ ይኽፈሎ','ትሕቲ 17 ዓመት ቆልዑ ናይ ካፒታል ኣታዊ ኣብ ወለዲ ግብሪ ይኽፈሎ'],['ናይ ቆልዑ ናይ ስራሕ ኣታዊ (§ 2-14(3))','ኣብ ቆልዓ ባዕሉ ግብሪ ይኽፈሎ','ቆልዓ ባዕሉ ዝሰርሓሉ ደሞዝ ብፍሉይ ግብሪ ይኽፈሎ'],['ናይ ቆልዑ ንብረት (§ 2-14(5))','ብማዕረ ኣብ መንጎ ወለዲ ይምቐል'],['— ግብሪ ነጻ ትካላት (§ 2-30 ክሳብ 2-32) —',''],['መንግስቲ (§ 2-30(1)a)','ግብሪ ነጻ'],['ክፍለ ሃገር/ኮሙን (§ 2-30(1)b-c)','ግብሪ ነጻ'],['ቤተ ክርስትያን (§ 2-30(1)d)','ግብሪ ነጻ'],['ንግዳዊ ዘይኮነ ትካላት (§ 2-32)','ኣታዊ ንግዲ ዘይኮነ ክሳብ ዝኾነ ግብሪ ነጻ','ማሕበራት፣ ጉጅለታትን ፋውንደሽንን ንረብሓ ዘይሰርሑ ግብሪ ኣይከፍሉን'],['ንግዳዊ ንጥፈት (§ 2-32(2))','ልዕሊ 140 000 kr / 70 000 kr ግብሪ ዝኽፈሎ','ካብ ሽያጥ፣ ኽራይ ወዘተ. ዝርከብ ኣታዊ ደረት ምስ ሓለፈ ግብሪ ክኽፈል ኣለዎ'],['— ናይ ትካል መንበሪ ሕግታት (§ 2-2(6)) —',''],['ኣብ ኖርወይ ዝተመዝገበ','ኩሉ ግዜ ኖርወጃዊ ናይ ግብሪ ኣካል','ኣብ ኖርወይ ናይ ትካል መዝገብ ዝተመዝገቡ ትካላት ኣብ ኖርወይ ግብሪ ግዱዳት'],['ኣብ ኖርወይ ዝተመስረተ (§ 2-2(7))','ኩሉ ግዜ ኖርወጃዊ ናይ ግብሪ ኣካል'],['ኣብ ኖርወይ ዝመሓደር (§ 2-2(6))','ኖርወጃዊ ናይ ግብሪ ኣካል ክኸውን ይኽእል','ናይ ወጻኢ ትካል ብሓቂ ካብ ኖርወይ ዝመሓደር ኣብዚ ግብሪ ግዱድ ክኸውን ይኽእል'],['— ምእታው/ምውጻእ ትካል (§ 2-2(8)) —',''],['ምእታው (§ 2-2(8))','ኣብ ኖርወይ ካብ ዝምስረት ምሉእ ናይ ግብሪ ግቡእ'],['ምውጻእ (§ 2-2(8))','ዘይተረጋገጸ ረብሓ ምዕራፍ','ትካል ካብ ኖርወይ ምስ ዝወጽእ ናይ ግብሪ ኣቋም ክዓርፍ ኣለዎ'],['— ዓለምለኻዊ (§ 2-37/2-38) —',''],['ናይ ክረዲት ቅነሳ (§ 2-37)','ኣብ ወጻኢ ንዝተኸፍለ ግብሪ ቅነሳ','ድርብ ግብሪ ምክልኻል — ናይ ወጻኢ ግብሪ ካብ ኖርወይ ናይ ግብሪ ጸብጻብ ቅነሳ'],['ናይ ግብሪ ስምምዓት','ናይ ኖርወይ ናይ ግብሪ መሰል ክድርት ይኽእል','ኖርወይ ምስ ብዙሕ ሃገራት ስምምዓት ኣለዋ መን እንታይ ግብሪ ይኸፍል ዝውስን']],
    morReqRows: [['ዝለዓለ ልቓሕ','ጠቕላላ ዕዳ ዝለዓለ 5× ዓመታዊ ኣታዊ','ኩሉ ዕዳ ይቑጸር — ናይ ገዛ ልቓሕ፣ ናይ ትምህርቲ ልቓሕ፣ ናይ መኪና ልቓሕ፣ ክረዲት ካርድ'],['ናይ ገዛእ ርእስኻ ገንዘብ','ብውሑዱ 10%','ካብ ዋጋ ገዛ ብውሑዱ 10% ባዕልኻ ዝቖጠብካዮ ክህልወካ ኣለዎ'],['ናይ ጸቕጢ ፈተነ','ዝለዓለ ናይ 7% ከምኡ ውን ወለድ + 3 pp','ባንክ ወለድ እንተ ደይቡ ውን ክትኸፍል ከም ዝኽእል ይምርምር'],['ኣቡይ','ልዕሊ 60% ናይ ልቓሕ ሬሾ ጠለብ','ልዕሊ 60% ናይ ገዛ ዋጋ ተለቂሕካ እንተ ኣለካ ኣቡይ ክትከፍል ኣለካ'],['— ክንደይ ይኽፈል —',''],['ወለድ ሕጂ','ኣስታት 5.1% ተለዋዋጢ (ጥሪ 2026)'],['ናይ ግብሪ ቅነሳ ኣብ ወለድ','22% ናይ ወለድ ወጻኢ','ዝኸፈልካዮ ወለድ 22% ኣብ ግብሪ ይምለሰልካ'],['ናይ ሰነድ ቀረጽ','ልሙድ 2.5% ናይ ዋጋ ዕዳጋ','ቀወምቲ ንብረት ምስ ገዛእካ ይኽፈል — ፍሉይ ክምልከት ይኽእል'],['ናይ ምዝገባ ክፍሊት','545 kr ንነፍሲ ወከፍ ሰነድ (2026)'],['— ኣታዊ —',''],['ተወሳኺ ኣታዊ','ኣብ ናይ ልቓሕ ሕቶ ክሕሰብ ይኽእል','ንኣብነት ቀዋሚ ናይ ኽራይ ኣታዊ፣ ሓገዝ ህጻናት፣ ናይ ቆልዓ ሓገዝ']],
