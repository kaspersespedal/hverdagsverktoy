  so: {
    flag:'🇸🇴', name:'Soomaali', lang:'so', currency:'kr', currencyCode:'NOK',
    salDefaults: { gross: 800000 },
    salClasses: [['1','Fasalka 1 (Caadiga ah)'],['2','Fasalka 2 (Qof guursaday oo dakhli yar)'],['self','Shaqo-iska-qabso']],
    salRegions: [['0.22','Caadiga ah (wadanka oo dhan)'],['0.185','Finnmark / Waqooyiga Troms (aagga tallaabooyinka)']],
    salInfoRows: [['Qadka shakhsiga','114 540 kr'],['Jaritaanka ugu yar (ugu badnaan)','95 700 kr'],['Cashuurta darajo 1 (226k+)','1.7%'],['Cashuurta darajo 2 (318k+)','4.0%'],['Cashuurta darajo 3 (725k+)','13.7%'],['Cashuurta darajo 4 (980k+)','16.8%'],['Cashuurta darajo 5 (1 467k+)','17.8%'],['Caymiska bulshada','7.6%'],['Cashuurta caadiga ah','22%']],
    salLawRows: [['— XEERKA GUUD (§ 5-1) —',''],['Dakhliga cashuurta lagu leeyahay','Faa\'iido kasta oo laga helo shaqo, hanti ama ganacsi','Wax kasta oo aad ka hesho shaqo, maalgelin ama ganacsiga waa la cashuuraa'],['Sidoo kale waa la cashuuraa','Howlgab, nafaqo, lacag-xiliyeed'],['Faa\'iidada iibinta (§ 5-1(2))','Waa la cashuuraa (eeg qayb. 9)','Haddii aad wax iibiso oo aad faa\'iido hesho waa inaad cashuur bixiso'],['Bixinta isticmaalka gaarka ah (§ 5-2)','Waa la cashuuraa qiimaha suuqa','Haddii aad alaab ka qaadato ganacsigaaga si gaarka ah waxaa loo tiriyaa dakhli'],['— DAKHLIGA SHAQADA (§ 5-10) —',''],['Mushahaar, sharaf, lacagta fasaxa','Waa la cashuuraa'],['Abaalmarinta gudidda, tansiyame, bacshiish','Waa la cashuuraa'],['Kaalmada shaqo la\'aanta, jirrada, waalidnimada','Waa la cashuuraa','Lacagaha dawladda ee bedelka mushaharka waxaa loo cashuuraa sida mushaharka'],['Magdhowga shaqo-joojinta (§ 5-10 d)','Waa la cashuuraa'],['Faa\'iidooyinka dabiiciga ah (§ 5-12)','Waa la cashuuraa qiimaha suuqa','Faa\'iidooyinka aad ka hesho shaqo-bixiyaha halkii lacag — tusaale taleefan, caymis'],['Amaahda jaban shaqada (§ 5-12(4))','Faa\'iidada = ribada caadiga ah − ribada dhabta ah','Haddii aad amaah ka hesho shaqo-bixiyaha oo ka hooseysa suuqa, farqiga waa la cashuuraa'],['Gaari shirkadeed (§ 5-13)','30% qiimaha liiska (20% ka badan xadka)','Haddii aad leedahay gaari shirkadeed waxaa lagu cashuuraa qayb ka mid ah qiimaha gaariga cusub'],['Gaari >3 sano','75% qiimaha liiska'],['Ikhtiyaarada shaqada (§ 5-14)','Waa la cashuuraa marka la isticmaalo/iibiyo','Waxaa lagu cashuuraa markaad isticmaasho ama iibiso ikhtiyaarka, maaha markaad hesho'],['Ikhtiyaarada shirkadaha bilowga (§ 5-14(2))','Ma aha dakhliga shaqada (shuruudo gaar ah)','Xeerar ka wanaagsan shaqaalaha shirkadaha yaryar ee ka yar 6 sano'],['— DAKHLIGA HANTIDA (§ 5-20) —',''],['Soo-celinta hantida/alaabta','Waa la cashuuraa','Dakhliga kirada guryaha, aqalka fasaxa ama alaabta kale'],['Soo-celinta maalgalinta','Waa la cashuuraa','Ribada, qaybsiga faa\'iidada iyo faa\'iidada sahaamadaha, sanduuqyada, kaydka bangiga'],['Isticmaalka bilaashka ah ee hantida dadka kale','Waa la cashuuraa','Haddii aad isticmaasho guri bilaash ah waxaa loo tiriyaa dakhli'],['Amaahda shirkadda (§ 5-22)','Cashuur dheeraad ah, la buuxiyo ×1.72','Amaahda AS-gaaga waxaa loo dhigaa qaybsiga faa\'iidada oo sidaas loo cashuuraa'],['— CASHUUR LA\'AAN (§ 5-15/5-43) —',''],['Kaalmada caruurta','Cashuur la\'aan'],['Kaalmada lacageed','Cashuur la\'aan'],['Kaalmada bulshada','Cashuur la\'aan'],['Kaalmada aasaasiga/caawinta','Cashuur la\'aan'],['Kaalmada aaska','Cashuur la\'aan'],['Magdhowga dhaawaca/sharafta','Cashuur la\'aan'],['Nafaqada caruurta','Cashuur la\'aan'],['Khamaarada (Norsk Tipping iwm.)','Cashuur la\'aan','Guulaha Norsk Tipping, Rikstoto iyo kuwa la midka ah waa cashuur la\'aan'],['Guulaha lama filaanka ah (§ 5-50)','Waa la cashuuraa ee ka badan 10 000 kr','Guulaha tartamada gaarka ah, bakhtiga iwm.'],['Alaabta isticmaalka (§ 5-21)','Cashuur la\'aan marka isticmaalka gaarka ah','Iibinta alaabta gaarka ah ee la isticmaalay (alaab guri, dhar, gaari) waa cashuur la\'aan']],
    salDedRows: [['— XEERKA GUUD (§ 6-1) —',''],['Xuquuqda jaritaanka','Kharashka loo bixiyay inuu helo, ilaaliyo ama sugo dakhliga cashuurta lagu leeyahay','Waxaad jaridi kartaa kharashaadka lagama maarmaanka ah si aad lacag u hesho'],['Jaritaan la\'aan','Kharashka gaarka ah (guri, cunto, masruuf)','Kharashka nolosha gaarka ah weligaa lama jaridi karo'],['Khasaaraha iibinta (§ 6-2)','Jaritaan sida xeerarka qayb. 9','Haddii aad wax iibiso oo aad khasaaro ku hesho waxaad cashuurta ka jaridi kartaa'],['Khasaaraha sheegashada (§ 6-2(2))','Jaritaan marka ugu dambeeyey la xaqiijiyo khasaaraha ganacsiga','Qof ayaa ganacsigaaga u deyn ah oo aan bixin karin'],['Khasaaraha guud (§ 6-3)','Lagu jaraa dakhli kale, la sii qaado (§ 14-6)','Haddii ganacsigu khasaaro galo waxaad isticmaali kartaa dakhli kale — ama u kaydi sanado dambe'],['— JARITAANKA UGU YAR (§ 6-30/32) —',''],['Dakhliga mushaharka','46% mushaharka, ugu badnaan 95 700 kr','Shaqaale kasta ayaa si toos ah u helaa — waxay daboolaan safar, dhar, qalab iwm.'],['Dakhliga howlgabka','40% howlgabka'],['Waxay bedeshaa','Jaritaannada badanaa ee kharashka shaqada','Uma baahnid inaad dukumeenti u sameyso kharash kasta marka aad isticmaasho jaritaanka ugu yar'],['Kuma jirto','Lacagta ururka shaqaalaha, kharashka socdaalka','Kuwan waxaad jaridi kartaa oo ka sii ah jaritaanka ugu yar'],['— JARITAANNADA CAADIGA AH —',''],['Lacagta ururka shaqaalaha (§ 6-20)','Ugu badnaan 8 700 kr','Xubinnimada urur shaqaale sida LO, YS, Unio, Akademikerne'],['Safarka guri-shaqo (§ 6-44)','Ka badan 12 000 kr, ugu badnaan 120 000 kr','Jaritaanka safarka ee ka badan 37 km hal dhinac (ka dib jaritaanka aasaasiga)'],['Jaritaanka waalidka (§ 6-48)','Carruur ka yar 12 sano, qadarka uu go\'aamiyo Stortinget','Waxay daboolaan kharashka xanaanada, SFO iyo daryeelka maalinlaha ah'],['Deeqaha ururrada (§ 6-50)','Ugu yaraan 500 kr, ugu badnaan 25 000 kr','Deeqaha ururrada la ansixiyay sida Laanta Cas, Dhakhaatiirta aan Xuduudda Lahayn'],['Jaritaanka howlgabka caruurta (§ 6-49)','Ilaa 32 600 kr'],['— RIBADA DEYNTA (§ 6-40) —',''],['Ribada deynta','Jaritaan buuxa (22% saamaynta cashuurta)','Dhammaan ribada aad bixiso — amaahda guriga, amaahda waxbarashada, amaahda gaariga — 22% ayaad cashuurta ka hesho'],['Xaddidaadda ribada kooxda (§ 6-41)','25% EBITDA, xadka 25M (koox) / 5M (dibadda)','Waxay xaddidaa jaritaanka ribada amaahaha u dhexeeya shirkadaha isku koox'],['Sii qaadista ribada la diidday','10 sano','Ribada aan la aqbalin sannadkan waxaa la isticmaali karaa 10 sano ee soo socota'],['— JARITAANNADA GANACSIGA —',''],['Qiime-dhimista (§ 6-10)','Daalidda alaabta shaqada, goodwill marka la iibsado','Waxay u qaybisaa kharashka mashinadka, gaadiidka iwm. sannado badan'],['Dayactirka/caymiska (§ 6-11)','Jaritaanka alaabta shaqada'],['Cilmi-baadhista iyo horumarinta (§ 6-25)','Qayb kharashka alaab shaqeed','Kharashka horumarinta waa la kaydin karaa oo wakhti ahaan la qiime-dhimin karaa'],['Shirkadaha bilaabista (§ 6-53)','Ilaa 1M kr, shirkad ≤6 sano, ≥3 sano lahaansho','Shakhsiyaadka maalgeliya shirkadaha yaryar cusub waxay helaan jaritaan'],['— JARITAAN LA\'AAN —',''],['Matalaad (§ 6-21)','Weligaa lama jaridi karo','Cashadaha macaamiisha, hadiyado xiriirrada ganacsiga iwm.'],['Musuq-maasuq (§ 6-22)','Weligaa lama jaridi karo'],['Lacagta ururrada (§ 6-18)','Guud ahaan jaritaan la\'aan (ka reeban § 6-19/20)','Ka reeban ururrada xirfadda iyo warshadaha'],['— LACAG-BIXINTA BANGIGA (§ 6-51) —',''],['Shuruudda','Lacag-bixin ≥10 000 kr waa inay noqotaa bangi si loo helo jaritaan','Lacag-bixinnada lacagta caddaanka ah ee ka badan 10 000 kr jaritaan kama siiyaan'],['— JARITAANNADA XIRFADDA —',''],['Jaritaanka kalluumeysatada (§ 6-60)','30%, ugu badnaan 160 000 kr, ≥130 maalmood','Waxay u baahan tahay ugu yaraan 130 maalmood kalluumeeysi sannadka dakhliga'],['Jaritaanka badmaaxiinta (§ 6-61)','30%, ugu badnaan 86 300 kr, ≥130 maalmood','Waxay u baahan tahay ugu yaraan 130 maalmood badda sannadka dakhliga']],
    salRealRows: [['— GOORMA AYAA IIBINTA DHACDAY? —','Xeerka aasaasiga ah §§ 9-1 iyo 9-2'],['Maxaa keena canshuurta faa\'iidada?','Iibinta, beddelka, soo celinta saamiyada, la wareegista, burburka — wareejin kasta oo lacag leh','§ 9-2(1)'],['Hadiyad?','Hadiyadu maaha iibinta — canshuur ma jirto hadiyadbixiyaha','§ 9-2(3)'],['Dhaxal?','Maaha iibinta — canshuur faa\'iido ma jirto dhaxalka','§ 9-2(3)'],['Qaybinta lammaaneyaasha?','Maaha iibinta — xataa furitaanka/kala tagista','§ 9-2(3)'],['Soo celinta khasabka ah?','Waxaa loo tiriyaa iibinta — waajibaadka canshuurtu wuu yimaadaa','§ 9-2(1)'],['— CAFINTA GURIGA —','§ 9-3: Goorma aadan bixin canshuurta?'],['Iibisay gurigaaga?','Cafin haddii aad lahaysay ugu yaraan 1 sano oo aad ku nooleyd ugu yaraan 1 labadii sano ee u dambeeysay','§ 9-3(2)'],['Iibisay guriga fasaxa?','Cafin haddii aad lahaysay ugu yaraan 5 sano oo aad isticmaashay ugu yaraan 5 sideedii sano ee u dambeeysay','§ 9-3(4)'],['Iibisay alaabta shakhsiga?','Cafin — hanti shakhsi ah','§ 9-3(1)a'],['Faa\'iido dhulka?','Cafin kaliya haddii dhulku yahay mid yar — hadii kale waa canshuur xataa haddii gurigu cafinaado','§ 9-3(8)'],['Khasaare guri cafin ah?','Dhimis ma jirto — mabda\'a isla mid ahaanshaha','§ 9-4'],['— KHASAARAHA WAA LA DHIMI KARAA —','§ 9-4: Mabda\'a isla mid ahaanshaha'],['Iibinta oo khasaare ah?','Dhimis isla heerka faa\'iidada u dhiganta ay canshuur noqon lahayd','§ 9-4(1)'],['Khasaare saamiyada?','Dhimis buuxa — kor u qaaday ×1,72 sida faa\'iidada','§ 9-4, § 10-31'],['— QIIMAHA AASAASIGA DHAXALKA/HADIYADA —','§ 9-7: Mabda\'a joogteynta'],['Wax baad dhaxashay?','Waxaad qaadanaysaa qiimaha aasaasiga ee kan kaa tegay — maaha qiimaha suuqa','§ 9-7(1)'],['Hadiyad baad heshay?','Isla mabda\'a — waxaad qaadanaysaa qiimaha aasaasiga ee hadiyadbixiyaha','§ 9-7(1)'],['Markii kan kaa tegay uu iibsan kari lahaa canshuur la\'aan?','Qiimaha aasaasiga wuxuu noqdaa qiimaha suuqa maalinta dhimashada','§ 9-7(2)'],['— KA BIXITAANKA AWOODDA CANSHUUREED —','§ 9-14: Canshuurta bixitaanka'],['Hantida ka wareejinaysa Noorway?','Faa\'iidada qarsoon waxaa lagu canshuuraa sida hantida loo iibiyay qiimaha suuqa','§ 9-14(1)'],['Waxay ku jiraan hantida aan la taaban karin?','Haa — batentigga, laysinnada, calaamadaha ganacsi iwm.','§ 9-14(2)'],['Ma dib loo dhigi karaa?','Haa, EEE gudaheeda — laakiin damaanad qaad laga yaabo in la weydiiyo','§ 9-14(4)']],
    salCorpRows: [['— TABARUCA KOOXDA (§ 10-2 ilaa 10-5) —',''],['Tabaruca kooxda (§ 10-2)','Jaritaan bixiyaha, cashuurta qaataha','Wareejin u dhexeeya shirkadaha isku koox — loo isticmaalo in la simo natiijada'],['Shuruudda lahaanshaha (§ 10-4)','Shirkadda hooyada waxay lahayd >90% sahaamadaha iyo codadka','Waxay khusaysaa shirkadaha sahaamadaha iyo kuwa shisheeye ee u dhigma EØS'],['— QAYBSIGA FAA\'IIDADA IYO ILAALINTA (§ 10-10 ilaa 10-13) —',''],['Qaybsiga faa\'iidada (§ 10-11)','Waa la cashuuraa milkiilayaasha shakhsi ah','Waxaa lagu buuxiyaa caamil 1.72 ka hor cashuurta 22%'],['Jaritaanka ilaalinta (§ 10-12)','Waxaa laga jaridaa qaybsiga ka hor cashuurta','Laguma cashuurayo qeybta qaybsiga faa\'iidada ee u dhiganta ribada halista la\'aanta ah'],['Heerka ilaalinta','Sanadaadka khasnada dawladda kadib cashuurta','Waxaa go\'aaminaya Maamulka Cashuuraha sannad kasta'],['Habka cafinta (§ 2-38)','Cashuur la\'aan shirkadaha','AS-yada leh sahaamad AS-yad kale cashuurta qaybsiga faa\'iidada iyo faa\'iidada kama baxdo'],['Xeerka 3% (§ 2-38(6))','3% dakhliga waa la tiriyaa','Shirkadaha weli waxay bixiyaan 0.66% (3% × 22%) qaybsiga faa\'iidada la cafiyay'],['— FAA\'IIDADA IYO KHASAARAHA SAHAAMADAHA (§ 10-30 ilaa 10-37) —',''],['Faa\'iidada iibinta (§ 10-31)','Waa la cashuuraa milkiilayaasha shakhsi ah','Waxaa lagu buuxiyaa caamil 1.72, cashuur dhabta ah qiyaas ahaan 37.84%'],['Khasaaraha iibinta (§ 10-31(2))','Waa la jaridi karaa','Waxaa sidoo kale lagu buuxiyaa caamil 1.72'],['Qiimaha bilowga (§ 10-32)','Qiimaha iibsashada + ilaalinta aan la isticmaalin','Waxaad ku bixisay sahaamada oo lagu daray jaritaanka ilaalinta la uruursaday'],['Mabda\'a FIFO (§ 10-36)','Kan hore la iibsaday = kan hore la iibiyay','Marka aad iibiso qayb sahaamadaada, sahaamadaha ugu da\'da weyn ayaa hore loo iibiyaa'],['— SANDUUQYADA MAALGELINTA IYO ASK (§ 10-20/10-21) —',''],['Sanduuqyada maalgelinta (§ 10-20)','Qaybta sahaamadaha iyo qaybta ribada si kala duwan ayaa loo cashuuraa','Qaybta sahaamadaha = habka milkiilaha, qaybta ribada = dakhliga caadiga ah'],['Akoonka kaydinta sahaamadaha (§ 10-21)','Cashuurta waxaa la dib u dhigaa ilaa bixinta','Waxaad iibsan kartaa oo iibsan kartaa sahaamad/sanduuq akoonka gudihiisa adiga oo aan cashuur bixin'],['Bixinta cashuurta lagu leeyahay (§ 10-21(4))','Bixinta ka badan lacagta la geliyay waa la cashuuraa','Waxaad cashuur bixisaa marka aad ka badan ka bixiso intii aad gelisay'],['— CASHUURTA KA-QEYBGALAYAASHA ANS/KS (§ 10-40 ilaa 10-49) —',''],['Habka saafiga ah (§ 10-41)','Faa\'iidada waxaa lagu cashuuraa ka-qeybgalayaasha','Ka-qeybgale kasta wuxuu cashuur ka bixiyaa qeybtiisa natiijada shirkadda'],['Bixinta (§ 10-42)','Waa la cashuuraa ka-qeybgalaha shakhsiga ah','Waxaa lagu buuxiyaa caamil 1.72 sida qaybsiga faa\'iidada'],['Faa\'iidada iibinta qaybta (§ 10-44)','Waa la cashuuraa','Waxaa lagu xisaabiyaa qiimaha bilowga oo leh hagaajin kor/hoos'],['— ISKAASHIGA (§ 10-50) —',''],['Lacag-celinta (§ 10-50)','Jaritaan iskaashiga','Lacag-celinta xubnaha ku salaysan ganacsiga iskaashiga'],['— NOKUS / WADAMADA CASHUURTA HOOSE (§ 10-60 ilaa 10-68) —',''],['Xeerarka NOKUS (§ 10-60)','Milkiilaha Noorwiijiga ah waa la cashuuraa joogto ahaan','Waxay khusaysaa shirkadaha wadamada cashuurta hoose ee ay maamulaan milkiilayaasha Noorwiijiga ah'],['Wadanka cashuurta hoose (§ 10-63)','Cashuurta ka yar 2/3 cashuurta Noorwiijiga','Wadanka waxaa loo tiriyaa cashuur hoose haddii cashuurta dhabta ah ka hooseyso qiyaas ahaan 14.67%'],['Shuruudda maamulka (§ 10-62)','Milkiilayaasha Noorwiijiga ah waxay leeyihiin ugu yaraan 50%','Maamulka waxaa loo qiimeeyaa wadajir dhammaan cashuur-bixiyayaasha Noorwiijiga'],['Jaritaanka deynta (§ 10-65)','Jaritaanka cashuurta shisheeye ee la bixiyay','Ka fogaanshaha laba-cashuurta adigoo jaridaya cashuurta la bixiyay dibadda'],['— CASHUURTA DALKA KA BIXITAANKA (§ 10-70/10-71) —',''],['Faa\'iidooyinka qarsoon (§ 10-70)','Waa la cashuuraa markaad ka tagto Noorway','Waxay khusaysaa sahaamadaha, qaybaha iyo hantida kale'],['Dib u dhigista (§ 10-70(7))','Waa la dib u dhigi karaa gudaha EØS','Lacag-bixintu waa la dib u dhigaa, laakiin damaanad ayaa la codsan karaa'],['Dhicitaanka (§ 10-70(9))','Cashuurtu way dhacaysaa 5 sano kadib','Haddii aadan iibin 5 sano gudahood cashuurtu way baabi\'i doontaa'],['— CASHUURTA ISHA (§ 10-80 ilaa 10-82) —',''],['Cashuurta isha qaybsiga faa\'iidada','15–25% milkiilayaasha shisheeye','Heerku wuxuu ku xidhan yahay heshiiska cashuurta wadanka milkiilaha'],['Cashuurta isha ribada/royaaltiiga (§ 10-80)','Sida xeerarka sharciga','Waxay khusaysaa lacag-bixinnada xiriirka dhow wadamada cashuurta hoose']],
    salReorgRows: [['— ISKU-DARKA (§ 11-2/11-3) —',''],['Shirkadaha sahaamadaha (§ 11-2)','Cashuur la\'aan marka isku-darku raaco sharciga shirkadaha qayb. 13','Laba ama ka badan AS ayaa la isku daraa iyada oo aan qof cashuur bixin'],['Iskaashiyada (§ 11-2(2))','Cashuur la\'aan sida sharciga iskaashiga qayb. 8'],['Shirkadaha leh cashuurta ka-qeybgalayaasha (§ 11-3)','Cashuur la\'aan isku qaab shirkad iyo mas\'uuliyad','Ka-qeybgalayaashu waa inay helaan qaybaha abaalmarinta ahaan (ugu badnaan 20% lacag cad)'],['— KALA-QAYBINTA (§ 11-4/11-5) —',''],['Shirkadaha sahaamadaha (§ 11-4)','Cashuur la\'aan marka kala-qaybintu raacdo sharciga shirkadaha qayb. 14','Shirkad ayaa loo qaybiyaa laba ama ka badan iyada oo aan cashuur la bixin'],['Shirkadaha leh cashuurta ka-qeybgalayaasha (§ 11-5)','Cashuur la\'aan isku qaab shirkad iyo mas\'uuliyad','Ugu badnaan 20% abaalmarinta waxay noqon kartaa wax aan qaybaha ahayn'],['— SHURUUDAHA IYO MABAADI\'DA —',''],['Abaalmarinta kale (§ 11-6)','Lacagta caddaanka ah ee milkiilaha waa la cashuuraa','Kaliya sahaamadaha/qaybaha shirkadaha isku-darka waa cashuur la\'aan'],['Joogteynta (§ 11-7)','Qiimayaasha cashuurta iyo taariikhda lahaanshaha waa la sii wadaa','Shirkadda qaadanaysu waxay wareejisaa dhammaan booska cashuurta iyada oo aan isbeddel lahayn'],['Qaybinta kala-qaybinta (§ 11-8)','Boosaska cashuurta waxaa loo qaybiyaa qiimaha saafiga ah'],['Xallinta (§ 11-9)','Shirkadda wareejinaysu waa in la xalliyaa kadib wareejinta'],['Taariikhda dhaqan-galka (§ 11-10)','Laga bilaabo taariikhda dhaqan-galka sharciga shirkadaha'],['— DALALKA KALA GUDBA (§ 11-11) —',''],['Isku-darka/kala-qaybinta caalamiga','Cashuur la\'aan gudaha EØS oo leh joogteyn','AS Noorwiijiga ah waxay isku-dari kartaa shirkad dal kale oo EØS ah'],['Beddelashada sahaamadaha (§ 11-11(4))','Cashuur la\'aan marka la wareejiyo ugu yaraan 90% sahaamadaha','Ugu badnaan 20% abaalmarinta lacagta caddaanka ah'],['Wadanka cashuurta hoose (§ 11-11(7))','Cafinta kama shaqeyso wadamada cashuurta hoose','Ka reeban haddii si dhab ah loogu aasaasay dal EØS ah'],['— BEDDELIDA (§ 11-20) —',''],['Shirkad sahaamad ah','Ganacsi-iska-qabso, ANS, DA iwm. waxaa loo beddeli karaa cashuur la\'aan','Qiimayaasha cashuurta iyo boosaska waa la sii wadaa'],['Wareejinta kooxda (§ 11-21)','Wareejin cashuur la\'aan u dhexeeya shirkadaha isku koox','Shirkadda hooyadu waa inay lahayd ka badan 90% sahaamadaha'],['Habsami-yeelka (§ 11-22)','Wasaaraddu waxay siin kartaa cafis cashuur dib-u-habeynta','Waxay khusaysaa iibinta hantida, ganacsiga ama sahaamadaha']],
    salKeyRows: [['— SHAQO, MAALGELIN MISE GANACSI? —','§ 5-1: Sababta xadku u go\'aamiyay canshuurta'],['Dakhliga shaqada','Adeeg shakhsi ah oo dad kale. Mushahar, gunno, dheefaha nooca ah. Wuxuu siiyaa dakhli shakhsi ah → canshuur kor u kacda + saamileyda (7.6%).','§ 5-10'],['Dakhliga maalgalinta','Soo celinta waxa aad leedahay — ribada, dividendka, kirada, faa\'iidada saamiyada. Kaliya 22%.','§ 5-20'],['Dakhliga ganacsiga','Sharciga canshuurtu kama qeexo «ganacsi» si toos ah. Afar shuruud:'],['1. Muddo','Hawshu waa in ay muddo leedahay — maaha iibinta hal mar.'],['2. Baaxad','Waa in ay baaxad leedahay. Hal guri kireysi = maalgelin. Toban oo guri oo maareyn firfircoon = ganacsi.'],['3. Awoodda faa\'iidada','Hawshu waa in ay si macquul ah ugu awood badnaan lahayd inay faa\'iido gasho.'],['4. Khatartaada','Adiga ayaa khatarta maaliyadeed qaadanaya. Ganacsiga ayaa ka duwan shaqaalanimada.'],['Maxuu muhiim u yahay?','Ganacsiga shakhsiga wuxuu siiyaa dakhli shakhsi → canshuur kor u kacda + saamileyda. Maalgalintu kaliya 22%.'],['Aagga cawlan ee caadiga ah?','Kireysta hantida dhaqdhaqaaqa ah. Guri yar = maalgelin. Guri badan oo maareyn firfircoon = ganacsi.'],['— FIKRADA IIBINTA —','§ 9-2: Maxaa keena canshuurta — maxaana aanay keenin?'],['Waa maxay iibinta?','Wareejinta lahaanshaha lacag: iibinta, beddelka, soo celinta, la wareegista, burburka.','§ 9-2(1)'],['Maxaa AANAN ahayn iibinta?','Hadiyad, dhaxal, qaybinta furitaanka, wareejinta lammaaneyaasha.','§ 9-2(3)'],['Xeerka guriga?','Iibinta gurigaaga waa cafin: lahaansho 1 sano iyo degan 1 ka mid ah 2 sano. Fasax: 5 sano, isticmaal 5/8.','§ 9-3(2)/(4)'],['Mabda\'a isla mid ahaanshaha?','Khasaaraha waa la dhimaa isla heerka faa\'iidada u dhiganta ay canshuur noqon lahayd.','§ 9-4'],['Dhaxalka iyo hadiyada — joogteynta?','Qaabiluhu wuxuu qaadanayaa qiimaha aasaasiga. Canshuur ma jirto qaabilitaanka, laakiin faa\'iidada mustaqbalka waxaa laga xisaabiyaa qiimaha asalka ah.','§ 9-7'],['Markii kan kaa tegay uu iibsan kari lahaa canshuur la\'aan?','Qiimaha aasaasiga = qiimaha suuqa maalinta dhimashada — waa ka fiican dhaxalqaataha.','§ 9-7(2)'],['— QIIMAHA AASAASIGA —','Waxa aad «bixisay» macnaha canshuureed'],['Waa maxay qiimaha aasaasiga?','Qaddarka faa\'iidada ama khasaaraha laga cabbirayo iibinta. Caadi ahaan: qiimaha iibsashada + kharashka.','§ 9-7, § 10-32'],['Maxuu muhiim u yahay?','Faa\'iido = qiimaha iibinta ka jar qiimaha aasaasiga. Qiime khaldan = canshuur khaldan.'],['Dhaxalka/hadiyada?','Waxaad qaadanaysaa qiimaha aasaasiga (joogteynta). Ma jirto \'dib u dejin\' qiimaha suuqa.','§ 9-7'],['Saamiyada?','Qiimaha iibsashada + kharashka macaamiilka + cafinta la isticmaalin. FIFO ayaa go\'aamiya tartiibbka iibinta.','§ 10-32, § 10-36'],['Guriga?','Qiimaha iibsashada + canshuurta diiwaanka + hagaajinta (maaha dayactirka).','§ 9-3'],['Qiimadhaca?','Hantida ganacsiga qiimaha aasaasiga waxaa lagu yareyaa qiimadhaca canshuureed.','§ 6-10, § 14-40'],['— QAABKA SAAMIDOONAHA —','§ 10-11 ilaa 10-12'],['Sidee ayaa dividendka loo canshuuraa?','Dividendka waxaa lagu dhufaa 1.72 oo lagu canshuuraa 22%. Canshuur dhab ah: ~37.84%.','§ 10-11'],['Waa maxay cafinta ilaalinta?','Qaybta dividendka u dhiganta soo celinta khatarta la\'aanta ah waa cafin.','§ 10-12'],['Maxaa 1.72?','Si uu canshuurta wadarta (shirkadda + saamidoonaha) u noqdo heerka canshuurta mushahar.'],['— HABKA CAFINTA —','§ 2-38'],['Waa maxay?','Shirkadahu kama bixiyaan canshuur dividendka iyo faa\'iidada shirkado kale.','§ 2-38'],['Xeerka 3%?','Shirkaddu wali waa inay aqoonsataa 3% dividendka la cafiyay. Canshuur dhab ah: 0.66%.','§ 2-38(6)'],['Ka reebban?','Laguma dabaqo wadamada canshuurta hooseeya ama saamiyada ka yar 10% meel ka baxsan EEE.','§ 2-38(3)'],['— WAX KU BIIRINTA KOOXDA —','§ 10-2 ilaa 10-5'],['Waa maxay?','U wareejinta lacagta shirkadaha kooxda. Dhimis bixiyaha, canshuur qaabiluha.','§ 10-2'],['Waa maxay ujeedada?','Sinaynta faa\'iidooyinka iyo khasaaraha kooxda canshuurta saxda ah.'],['Shuruud?','Shirkadda hooyo waa in ay leedahay in ka badan 90% saamiyada iyo codadka.','§ 10-4'],['— ISKU MIDNAAN IYO QAYBINTA CANSHUUR LA\'AANTA —','§ 11-2, § 11-4, § 11-7'],['Goorma ayay canshuur la\'aan tahay?','Marka loo sameeyo sida sharciga shirkadaha oo joogteyn canshuureed la yeesho.','§ 11-2/11-4'],['Waa maxay joogteynta?','Shirkadda qaadaneysa waxay dhaxashaa dhammaan qiimayaasha canshuureed iyagoo aan isbeddelin.','§ 11-7'],['Maxaa qaldami kara?','Lacag caddaan ah = canshuur. Khasaaraha way dhammaadaan (§ 13-3).'],['— KA FOGAANSHAHA —','§ 13-2'],['Goorma ayay dabaqday?','Marka ujeedada ugu weyn ay tahay faa\'iido canshuureed oo macaamiilku aanu u adkeysan qiimeyn dhammeystiran.','§ 13-2(2)'],['Maxaa la qiimeeyaa?','Nuxurka ganacsiga, cabbirka faa\'iidada canshuureed, wadada habboonayn, isticmaalka ka soo horjeeda ujeeddada xeerarka.','§ 13-2(3)'],['Natiijada?','Macaamiilka waxaa lagu canshuuraa nuxurkiisa dhabta ah — maaha qaabkiisa.','§ 13-2(4)'],['Tusaale?','Iibsashada shirkad faaruq ah si loo isticmaalo khasaaraha. Khasaarahu wuu baxaa sida § 13-3.','§ 13-3'],['— SHURUUDDA SHARCI AHAANSHAHA —','§ 11-1(2)'],['Waa maxay?','Isku midnaantu iyo qaybintu waa inay sharci ahaadaan saddex heer si ay canshuur la\'aan u noqdaan.','§ 11-1(2)'],['Sharciga shirkadaha','Waa inuu raacaa sharciga shirkadaha: qorshaha isku midnaanta, ogeysiinta deynleyaasha, go\'aanka kulan guud, diiwaangelinta.','Sharciga shirkadaha qaybta 13/14'],['Sharciga canshuurta (qaybta 11)','Joogteyn canshuureed, ugu badnaan 20% lacag, kala dirista shirkadda wareejinaysa.','§ 11-7, § 11-6, § 11-9'],['Sharciga CBM','Isku midnaanta/qaybintu waa cafin (§ 6-14, 0% CBM). Laakiin waajibaadyada hagaajinta ayaa u wareegaya mulkiilaha cusub.','Sharciga CBM § 6-14, qaybta 9'],['Arrin ahaan?','Saddexda heer waa inay isku raacaan. Qalad sharciga shirkadaha ayaa saameynaya canshuurta iyo CBM.']],
    salSubjRows: [['— CASHUUR-BIXIYAHA SHAKHSIGA AH (§ 2-1) —',''],['Deggan Noorway (§ 2-1(1))','Cashuur lagu leeyahay dhammaan dakhliga/hantida, Noorway iyo dibadda','Haddii aad Noorway ku nooshahay wax kasta ayaad cashuur ka bixisaa — meel kasta oo aduunka dakhligu ka yimaado'],['Deganaansho bilaabma (§ 2-1(2))','Joogitaan >183 maalmood 12 bilood, ama >270 maalmood 36 bilood','Haddii aad Noorway ku joogto wakhti ku filan waxaad noqotaa deggane cashuur'],['Deganaansho joojin (§ 2-1(3))','Waxay u baahan tahay joogitaan dibadda + ka tagis guriga Noorway','Waa inaad si joogto ah dibadda u degtaa oo aanad guri ku lahayn Noorway'],['Maqnaansho ku meel gaar ah (§ 2-1(4))','Jabin maayo deganaanshaha cashuurta','Fasaxa ama joogitaanka gaaban ee dibadda ma beddelayo deganaanshadaada'],['Svalbard (§ 2-1(5))','Nidaam gaar ah (sharciga cashuurta Svalbard)'],['— DHAXALKA (§ 2-2) —',''],['Dhaxalka (§ 2-2)','Qof cashuur gaar ah sanadka dhimashada iyo ka dib','Dhaxalku wuxuu cashuur bixiyaa sidii hay\'ad madax bannaan ilaa la xalliyo'],['Qaybinta sanadka dhimashada (§ 2-15)','Dhaxlayaashu waxay la wareegaan janaayo 1-aad','Haddii dhaxalka la qaybiyay sanadka dhimashada, dhaxlayaashu waxay cashuur bixiyaan sanadka oo dhan'],['— SHIRKADAHA (§ 2-2) —',''],['Shirkadda sahaamadaha (§ 2-2(1)a)','Qof cashuur gaar ah','AS waa cashuur-bixiye madax bannaan — wuxuu bixiyaa 22% faa\'iidada'],['Shirkadda sahaamadaha dadweynaha (§ 2-2(1)b)','Qof cashuur gaar ah'],['Bangiga kaydinta, caymiska iskaashiga (§ 2-2(1)c-d)','Qof cashuur gaar ah'],['Iskaashiga (§ 2-2(1)e)','Qof cashuur gaar ah'],['Shirkadda dawladda, caafimaadka (§ 2-2(1)g-h)','Qof cashuur gaar ah'],['Aasaasaha (§ 2-2(1)f)','Qof cashuur gaar ah'],['Shirkadda degmada (§ 2-2(1)i)','Qof cashuur gaar ah'],['— CASHUUR XADDIDAN (§ 2-3) —',''],['Dakhliga hantida Noorway (§ 2-3(1)a)','Cashuur lagu leeyahay','Ajnabiga leh hanti Noorway waxay cashuur ka bixiyaan dakhliga'],['Ganacsi Noorway (§ 2-3(1)b)','Cashuur lagu leeyahay','Haddii aad ganacsi ka waddo Noorway halkan ayaad cashuur ku bixisaa'],['Shaqo Noorway (§ 2-3(1)d)','Cashuur lagu leeyahay','Haddii aad Noorway ka shaqeyso mushaharka halkan ayaad cashuur ku bixisaa — xataa ajnabiga'],['Qaybsiga faa\'iidada shirkad Noorwiijiyeed (§ 2-3(1)c)','Cashuurta isha','Sahaamadleyda shisheeye waxay bixiyaan cashuurta isha qaybsiga faa\'iidada shirkadaha Noorwiijiga'],['Abaalmarinta gudidda (§ 2-3(1)e)','Cashuur lagu leeyahay','Haddii aad ku jirto gudidda shirkad Noorwiijiyeed waxaad cashuur ka bixisaa abaalmarinta'],['Howlgabka Noorway (§ 2-3(4))','Cashuur lagu leeyahay (cashuurta isha)','Xataa dadka dibadda deggan'],['Cashuurta fannaaniinta (§ 2-3(1)h)','Cashuur lagu leeyahay fannaaniinta shisheeye','Xeerar gaar ah cashuurta riwaayada, bandhigga iwm.'],['— HABKA CAFINTA (§ 2-38) —',''],['Cashuur la\'aan shirkadaha (§ 2-38(1))','Qaybsiga faa\'iidada iyo faa\'iidada shirkadaha u dhexeeya cashuur la\'aan','AS leh sahaamad AS-yad kale cashuurta qaybsiga faa\'iidada iyo faa\'iidada caadi ahaan kama baxdo'],['Xeerka 3% (§ 2-38(6))','3% dakhliga waa la tiriyaa','Shirkaddu dhab ahaan 0.66% (3% × 22%) ayay ka bixisaa qaybsiga la cafiyay'],['Ka reeban wadamada cashuurta hoose (§ 2-38(3))','Cafinta kama shaqeyso shirkadaha wadamada cashuurta hoose','Shirkadaha wadamada cashuurta aad u hoose kuma jiraan habka cafinta'],['Ka reeban portfolio EØS (§ 2-38(3)b)','Cafinta kama shaqeyso lahaansho <10% EØS ka baxsan','Haddii aad ka yar 10% shirkad EØS ka baxsan leedahay habka cafinta kama shaqeyso'],['— XAASASKA (§ 2-10 ilaa 2-16) —',''],['Wadajir ama gaar (§ 2-10)','Xaasasku waxay noqon karaan cashuur wadajir ama gaar','Waxaad dooranaysaan in dakhliga la isku daro ama cashuurta si gaar ah loo bixiyo'],['Qaybinta (§ 2-11)','Dakhliga/jaritaanka waxaa loo tiriyaa xaaska ay ku habboontahay'],['Fasalka 2 (§ 2-14)','Masruufka xaas dakhli yar','Waxay siisaa cashuur yar haddii xaasaska mid uu dakhli yar leeyahay ama aanu wax lahayn'],['Guri wadajir (§ 2-12)','Cashuur wadajir guriga wadajirka ah'],['— CARRUURTA (§ 2-14) —',''],['Carruurta ka yar 17 sano (§ 2-14(1))','Dakhliga carruurta waa lagu cashuuraa waalidiinta','Dakhliga hantida carruurta ka yar 17 sano waa lagu cashuuraa waalidiinta'],['Dakhliga shaqada carruurta (§ 2-14(3))','Waa lagu cashuuraa ilmaha qudhiisa','Mushaharka ilmuhu qudhiisu u shaqeeyo si gaar ah ayaa loo cashuuraa'],['Hantida carruurta (§ 2-14(5))','Si siman loo qaybiyaa waalidiinta'],['— HAY\'ADAHA CASHUURTA LA\'AANTA AH (§ 2-30 ilaa 2-32) —',''],['Dawladda (§ 2-30(1)a)','Cashuur la\'aan'],['Gobolka/degmada (§ 2-30(1)b-c)','Cashuur la\'aan'],['Kiniisadaha (§ 2-30(1)d)','Cashuur la\'aan'],['Hay\'adaha aan ganacsiga ahayn (§ 2-32)','Cashuur la\'aan ilaa dakhligu aanu ganacsi ahayn','Ururrada, kooxaha iyo aasaasaha aan faa\'iido doonka ahayn cashuur kama baxdo'],['Howlaha ganacsiga (§ 2-32(2))','Cashuur lagu leeyahay ee ka badan 140 000 kr / 70 000 kr','Haddii dakhliga iibinta, kirada iwm. ka badan xadka waa in la cashuuraa'],['— XEERARKA DEGANAANSHAHA SHIRKADAHA (§ 2-2(6)) —',''],['Ka diiwaangashan Noorway','Had iyo jeer qof cashuur Noorwiijiyeed ah','Shirkadaha diiwaanka shirkadaha Noorway ku qoran waa kuwa cashuurta lagu leeyahay Noorway'],['Lagu aasaasay Noorway (§ 2-2(7))','Had iyo jeer qof cashuur Noorwiijiyeed ah'],['Maamulka Noorway (§ 2-2(6))','Waxay noqon kartaa qof cashuur Noorwiijiyeed ah','Shirkad shisheeye oo dhab ahaan laga maamulay Noorway waxay noqon kartaa mid cashuurta lagu leeyahay halkan'],['— SOO GALITAANKA/KA BIXITAANKA SHIRKADDA (§ 2-2(8)) —',''],['Soo galitaanka (§ 2-2(8))','Cashuur buuxda laga bilaabo aasaasida Noorway'],['Ka bixitaanka (§ 2-2(8))','Xisaabinta faa\'iidooyinka qarsoon','Shirkaddu waa inay xalliso boosaska cashuurta markey ka tageyso Noorway'],['— CAALAMIGA (§ 2-37/2-38) —',''],['Jaritaanka deynta (§ 2-37)','Jaritaanka cashuurta la bixiyay dibadda','Ka fogaanshaha laba-cashuurta — jaritaanka cashuurta shisheeye warqadda cashuurta Noorway'],['Heshiisyada cashuurta','Waxay xaddidi karaan xuquuqda Noorway ee cashuurta','Noorway waxay heshiisyo la leedahay wadamo badan oo go\'aamiya cidda cashuurta bixisa']],
    morReqRows: [['Amaahda ugu badan','Deynta guud ugu badnaan 5× dakhliga sannadlaha ah','Deynta oo dhan ayaa lagu tiriyaa — amaahda guriga, waxbarashada, gaariga, kaarka'],['Hantida gaarka ah','Ugu yaraan 10%','Waa inaad keydsatay ugu yaraan 10% qiimaha guriga adigaa iska leh'],['Tijaabinta cadaadiska','Kan ugu sarreeya 7% iyo ribada + 3 dhibcood','Bangiga ayaa hubinaya inaad awoodo xataa haddii ribadu kor u kacdo'],['Lacag-celinta','Waa loo baahan yahay ka badan 60% heerka amaahda','Haddii aad amaahdo ka badan 60% qiimaha guriga waa inaad lacag-celisaa'],['— INTAY KUGU KACAYSO —',''],['Ribada hadda','Qiyaas ahaan 5.1% isbeddeli kara (jan 2026)'],['Jaritaanka cashuurta','22% kharashka ribada','22% ribada aad bixiso ayaad cashuurta ka helaysaa'],['Cashuurta dukumeentiga','Caadi ahaan 2.5% qiimaha suuqa','Waxaa la bixiyaa marka la iibsanayo hanti — ka reeban ayaa jiri kara'],['Kharashka diiwaangelinta','545 kr dukumeenti kasta (2026)'],['— DAKHLIGA —',''],['Dakhliga dheeraadka ah','Waxaa lagu dari karaa codsiga amaahda','Tusaale dakhli kirada oo taagan, kaalmada caruurta, nafaqada']],
    morCostRows: [['Ribada hadda','Qiyaas ahaan 5.1% isbeddeli kara (jan 2026)'],['Jaritaanka cashuurta','22% kharashka ribada','22% ribada aad bixiso ayaad cashuurta ka helaysaa'],['Cashuurta dukumeentiga','Caadi ahaan 2.5% qiimaha suuqa','Waxaa la bixiyaa marka la iibsanayo hanti — ka reeban ayaa jiri kara']],
    morBsuRows: [['Boos intaan sano kahor','27 500 kr'],['Guud ahaan wax badnaan','300 000 kr'],['Jaritaanka cashuurta','10% kahor la samuustay — ilaa 2 750 kr/sano'],['Xadi-badda umurka','Ilaa iyo oo lagu jiro sanada aad dhamaad tahay 33 jir'],['Sharti jaritaanka cashuurta','Waa inaad leedahay dakhli shaqo la cashuuray oo aydna guriga lahayn'],['Lacagta maxaa loo isticmaali kara?','Iibsiga, celinta, sittaanbarka ama saldhiga gurigaaga'],['Jebiga sharcigu?','Hadii aad lacagta isticmaasho wax kale oo mooyee guriga, waa inaad soo celisaa cashuuraha kahor ah oo dhan']],
