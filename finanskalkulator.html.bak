    salInfoRows: [['Abattement personnel','114 540 kr'],['Déduction minimum (max)','95 700 kr'],['Impôt progressif 1 (226k+)','1,7%'],['Impôt progressif 2 (318k+)','4,0%'],['Impôt progressif 3 (725k+)','13,7%'],['Impôt progressif 4 (980k+)','16,8%'],['Impôt progressif 5 (1 467k+)','17,8%'],['Cotisation sociale','7,6%'],['Impôt ordinaire','22%']],
    salLawRows: [['— RÈGLE PRINCIPALE (§ 5-1) —',''],['Revenu imposable','Tout avantage obtenu par le travail, le capital ou l\'activité commerciale','Tout ce que vous gagnez par le travail, les investissements ou l\'activité commerciale est imposable'],['Également imposable','Pensions, rentes viagères, prestations à vie'],['Gain lors de réalisation (§ 5-1(2))','Imposable (voir chap. 9)','Si vous vendez quelque chose avec un bénéfice, vous devez payer l\'impôt sur le gain'],['Prélèvement pour usage personnel (§ 5-2)','Imposable à la valeur de marché','Si vous prenez des marchandises de votre entreprise pour un usage privé, cela compte comme un revenu'],['— REVENU DU TRAVAIL (§ 5-10) —',''],['Salaire, honoraires, indemnités de vacances','Imposable'],['Jetons de présence, tantièmes, pourboires','Imposable'],['Allocations chômage, indemnités maladie, allocations parentales','Imposable','Les prestations publiques remplaçant le salaire sont imposées comme un salaire'],['Indemnité de départ/licenciement (§ 5-10 d)','Imposable'],['Avantages en nature (§ 5-12)','Imposable à la valeur de marché','Avantages reçus de l\'employeur au lieu d\'argent — par ex. téléphone, journal, assurance'],['Prêt avantageux en emploi (§ 5-12(4))','Avantage = taux de référence − taux réel','Si vous obtenez un prêt de votre employeur en dessous du taux du marché, la différence est imposée'],['Voiture de fonction (§ 5-13)','30% du prix catalogue (20% au-dessus du seuil)','Si vous avez une voiture de fonction, vous êtes imposé sur une part du prix neuf du véhicule'],['Voiture >3 ans','75% du prix catalogue'],['Options en emploi (§ 5-14)','Imposable lors de l\'exercice/vente','Imposé lorsque vous exercez ou vendez l\'option, pas lorsque vous la recevez'],['Options de startup (§ 5-14(2))','Pas un revenu du travail (conditions spéciales)','Règles plus avantageuses pour les employés de petites entreprises de moins de 6 ans'],['— REVENU DU CAPITAL (§ 5-20) —',''],['Rendement des biens immobiliers/mobiliers','Imposable','Revenus locatifs de la location de logement, chalet ou biens mobiliers'],['Rendement des instruments financiers','Imposable','Intérêts, dividendes et gains provenant d\'actions, fonds, dépôts bancaires'],['Usage gratuit des biens d\'autrui','Imposable','Si vous utilisez un logement gratuit ou similaire, cela compte comme un revenu'],['Prêt à la société (§ 5-22)','Impôt supplémentaire, majoré ×1,72','Un prêt de votre propre AS est traité comme un dividende et imposé en conséquence'],['— EXONÉRÉ D\'IMPÔT (§ 5-15/5-43) —',''],['Allocations familiales','Exonérées'],['Allocation de garde','Exonérée'],['Aide sociale','Exonérée'],['Allocation de base/aide personnelle','Exonérée'],['Allocation funéraire','Exonérée'],['Indemnité pour préjudice/réparation','Exonérée'],['Pension alimentaire pour enfant','Exonérée'],['Jeux de hasard (Norsk Tipping etc.)','Exonérés','Les gains de Norsk Tipping, Rikstoto et similaires sont exonérés d\'impôt'],['Gains occasionnels (§ 5-50)','Imposable au-dessus de 10 000 kr','Gains de concours privés, loteries etc.'],['Biens de consommation (§ 5-21)','Exonérés en cas d\'usage personnel','La vente d\'objets personnels usagés (meubles, vêtements, voiture) est exonérée d\'impôt']],
    salDedRows: [['— RÈGLE PRINCIPALE (§ 6-1) —',''],['Droit à déduction','Coûts engagés pour acquérir, maintenir ou sécuriser un revenu imposable','Vous pouvez déduire les dépenses nécessaires pour gagner de l\'argent'],['Pas de déduction','Coûts privés (logement, nourriture, entretien)','Les frais de subsistance personnels ne peuvent jamais être déduits'],['Perte lors de réalisation (§ 6-2)','Déduction selon les règles du chap. 9','Si vous vendez quelque chose à perte, vous pouvez la déduire de vos impôts'],['Perte sur créance (§ 6-2(2))','Déduction en cas de perte définitivement constatée en activité','Quelqu\'un doit de l\'argent à votre entreprise et ne peut pas payer'],['Déficit (§ 6-3)','Compensation avec d\'autres revenus, report (§ 14-6)','Si l\'entreprise est en déficit, vous pouvez utiliser la perte contre d\'autres revenus — ou la reporter aux années suivantes'],['— DÉDUCTION MINIMUM (§ 6-30/32) —',''],['Revenu salarial','46% du salaire, max 95 700 kr','Tous les salariés reçoivent cela automatiquement — couvre les déplacements, vêtements, outils etc.'],['Revenu de pension','40% de la pension'],['Remplace','La plupart des déductions pour frais professionnels','Vous n\'avez pas besoin de justifier les dépenses individuelles en utilisant la déduction minimum'],['Non inclus','Cotisation syndicale, frais de navette','Ceux-ci peuvent être déduits en plus de la déduction minimum'],['— DÉDUCTIONS STANDARD —',''],['Cotisation syndicale (§ 6-20)','Max 8 700 kr','Adhésion à un syndicat comme LO, YS, Unio, Akademikerne'],['Trajet domicile–travail (§ 6-44)','Au-dessus de 12 000 kr, max 120 000 kr','Déduction pour trajet supérieur à 37 km aller simple (après abattement de base)'],['Déduction parentale (§ 6-48)','Enfant de moins de 12 ans, montant fixé par le Storting','Couvre les frais de garderie, activités périscolaires et assistante maternelle'],['Dons aux organisations (§ 6-50)','Min 500 kr, max 25 000 kr','Dons à des organisations agréées comme la Croix-Rouge, Médecins Sans Frontières'],['Déduction pension orphelin (§ 6-49)','Jusqu\'à 32 600 kr'],['— INTÉRÊTS D\'EMPRUNT (§ 6-40) —',''],['Intérêts d\'emprunt','Déduction intégrale (22% d\'effet fiscal)','Tous les intérêts que vous payez — prêt immobilier, étudiant, auto — vous donnent 22% de remboursement fiscal'],['Limitation d\'intérêts groupe (§ 6-41)','25% de l\'EBITDA, seuil 25M (groupe) / 5M (hors groupe)','Limite la déduction d\'intérêts sur les prêts entre sociétés du même groupe'],['Report des intérêts refusés','10 ans','Les intérêts non acceptés cette année peuvent être utilisés dans les 10 années suivantes'],['— DÉDUCTIONS D\'ACTIVITÉ —',''],['Amortissement (§ 6-10)','Usure des actifs d\'exploitation, goodwill lors d\'un achat','Répartit le coût des machines, véhicules etc. sur plusieurs années'],['Entretien/assurance (§ 6-11)','Déduction pour les actifs d\'exploitation'],['Recherche et développement (§ 6-25)','Partie du coût de production d\'un actif','Les coûts de développement peuvent être activés et amortis dans le temps'],['Startup (§ 6-53)','Jusqu\'à 1M kr, société ≤6 ans, ≥3 ans de détention','Les particuliers investissant dans de petites entreprises nouvellement créées obtiennent une déduction'],['— PAS DE DÉDUCTION —',''],['Représentation (§ 6-21)','Jamais déductible','Dîners avec les clients, cadeaux aux relations d\'affaires etc.'],['Corruption (§ 6-22)','Jamais déductible'],['Cotisation d\'association (§ 6-18)','Généralement non déductible (exception § 6-19/20)','Exception pour les associations professionnelles et sectorielles'],['— PAIEMENT PAR BANQUE (§ 6-51) —',''],['Exigence','Paiement ≥10 000 kr doit passer par la banque pour ouvrir droit à déduction','Les paiements en espèces supérieurs à 10 000 kr ne donnent pas droit à déduction'],['— DÉDUCTIONS PROFESSIONNELLES —',''],['Déduction pêcheur (§ 6-60)','30%, max 160 000 kr, ≥130 jours','Nécessite au moins 130 jours de pêche dans l\'année fiscale'],['Déduction marin (§ 6-61)','30%, max 86 300 kr, ≥130 jours','Nécessite au moins 130 jours en mer dans l\'année fiscale']],
    salCorpRows: [['— CONTRIBUTION DE GROUPE (§ 10-2 à 10-5) —',''],['Contribution de groupe (§ 10-2)','Déduction pour le donneur, imposable pour le receveur','Transfert entre sociétés du même groupe — utilisé pour lisser les résultats'],['Exigence de propriété (§ 10-4)','La société mère détient >90% des actions et des voix','Concerne les sociétés par actions et les sociétés étrangères équivalentes dans l\'EEE'],['— DIVIDENDE ET ABATTEMENT (§ 10-10 à 10-13) —',''],['Dividende (§ 10-11)','Imposable pour les actionnaires personnes physiques','Majoré d\'un facteur 1,72 avant imposition à 22%'],['Abattement pour risque (§ 10-12)','Déduit du dividende avant impôt','Vous n\'êtes pas imposé sur la partie du dividende correspondant au taux sans risque'],['Taux d\'abattement','Bons du Trésor après impôt','Fixé chaque année par la Direction des impôts'],['Méthode d\'exemption (§ 2-38)','Exonéré pour les sociétés','Les AS détenant des actions dans d\'autres AS sont exonérés d\'impôt sur les dividendes et gains'],['Règle des 3% (§ 2-38(6))','3% du revenu est comptabilisé','Les sociétés paient néanmoins 0,66% (3% × 22%) du dividende exonéré'],['— GAIN ET PERTE SUR ACTIONS (§ 10-30 à 10-37) —',''],['Gain à la vente (§ 10-31)','Imposable pour les actionnaires personnes physiques','Majoré d\'un facteur 1,72, soit un impôt effectif d\'env. 37,84%'],['Perte à la vente (§ 10-31(2))','Déductible','Majorée de la même manière avec le facteur 1,72'],['Valeur d\'entrée (§ 10-32)','Prix d\'achat + abattement non utilisé','Ce que vous avez payé pour l\'action plus l\'abattement éventuellement accumulé'],['Principe FIFO (§ 10-36)','Premier acheté = premier vendu','Lors de la vente d\'une partie d\'un portefeuille d\'actions, les plus anciennes sont considérées comme vendues en premier'],['— FONDS D\'INVESTISSEMENT ET ASK (§ 10-20/10-21) —',''],['Fonds d\'investissement (§ 10-20)','Parts actions et parts intérêts imposées différemment','Part actions = modèle actionnaire, part intérêts = revenu ordinaire'],['Compte d\'épargne en actions (§ 10-21)','Impôt reporté jusqu\'au retrait','Vous pouvez acheter et vendre des actions/fonds au sein du compte sans déclencher d\'impôt'],['Retrait imposable (§ 10-21(4))','Retrait supérieur au dépôt est imposable','Vous payez l\'impôt uniquement lorsque vous retirez plus que ce que vous avez déposé'],['— IMPOSITION DES PARTICIPANTS ANS/KS (§ 10-40 à 10-49) —',''],['Méthode nette (§ 10-41)','Le bénéfice est imposé chez les participants','Chaque participant paie l\'impôt sur sa part du résultat de la société'],['Distribution (§ 10-42)','Imposable pour le participant personne physique','Majorée d\'un facteur 1,72 comme un dividende'],['Gain à la vente de parts (§ 10-44)','Imposable','Calculé sur la base de la valeur d\'entrée avec ajustements pour sur-/sous-prix'],['— COOPÉRATIVE (§ 10-50) —',''],['Ristournes (§ 10-50)','Déduction pour la coopérative','Remboursement aux membres basé sur le chiffre d\'affaires avec la coopérative'],['— NOKUS / PAYS À FAIBLE FISCALITÉ (§ 10-60 à 10-68) —',''],['Règles NOKUS (§ 10-60)','Le propriétaire norvégien est imposé en continu','Concerne les sociétés dans des pays à faible fiscalité contrôlées par des propriétaires norvégiens'],['Pays à faible fiscalité (§ 10-63)','Impôt inférieur à 2/3 de l\'impôt norvégien','Le pays est considéré comme à faible fiscalité si l\'impôt effectif est inférieur à env. 14,67%'],['Exigence de contrôle (§ 10-62)','Les propriétaires norvégiens détiennent au moins 50%','Le contrôle est évalué globalement pour tous les contribuables norvégiens'],['Crédit d\'impôt (§ 10-65)','Déduction pour l\'impôt étranger payé','Évite la double imposition en déduisant l\'impôt payé à l\'étranger'],['— IMPÔT DE SORTIE (§ 10-70/10-71) —',''],['Gains latents (§ 10-70)','Imposable lors du départ de Norvège','Concerne les actions, parts et certains autres actifs'],['Report (§ 10-70(7))','Possible au sein de l\'EEE','Le paiement est reporté, mais une garantie peut être exigée'],['Extinction (§ 10-70(9))','L\'impôt s\'éteint après 5 ans','Si vous n\'avez pas réalisé dans les 5 ans, l\'impôt disparaît'],['— RETENUE À LA SOURCE (§ 10-80 à 10-82) —',''],['Retenue à la source sur dividendes','15–25% pour les actionnaires étrangers','Le taux dépend de la convention fiscale avec le pays de l\'actionnaire'],['Retenue à la source sur intérêts/redevances (§ 10-80)','Selon les règles fixées par la loi','Concerne les paiements aux parties liées dans des pays à faible fiscalité']],
    salRealRows: [['— QUAND Y A-T-IL RÉALISATION ? —','Règle principale §§ 9-1 et 9-2'],['Qu\'est-ce qui déclenche l\'impôt sur les plus-values ?','Vente, échange, rachat d\'actions, expropriation, destruction — tout transfert contre contrepartie','§ 9-2(1)'],['Don ?','Le don n\'est pas une réalisation — pas d\'impôt pour le donateur','§ 9-2(3)'],['Héritage ?','Pas de réalisation — pas d\'impôt sur les plus-values à la succession','§ 9-2(3)'],['Partage entre époux ?','Pas de réalisation — y compris en cas de séparation/divorce','§ 9-2(3)'],['Rachat forcé ?','Considéré comme réalisation — obligation fiscale déclenchée','§ 9-2(1)'],['— EXONÉRATION RÉSIDENCE —','§ 9-3 : Quand êtes-vous exonéré ?'],['Vente de résidence principale ?','Exonéré si détenue au moins 1 an et habitée au moins 1 des 2 dernières années','§ 9-3(2)'],['Vente de résidence secondaire ?','Exonéré si détenue au moins 5 ans et utilisée au moins 5 des 8 dernières années','§ 9-3(4)'],['Vente de biens personnels ?','Exonéré — effets personnels','§ 9-3(1)a'],['Plus-value foncière ?','Exonéré uniquement si le terrain est insignifiant — sinon imposé comme vente de terrain même si la maison est exonérée','§ 9-3(8)'],['Perte sur résidence exonérée ?','Pas de déduction — principe de symétrie : plus-value exonérée = perte non déductible','§ 9-4'],['— PERTES DÉDUCTIBLES —','§ 9-4 : Principe de symétrie'],['Vente à perte ?','Déduction dans la même mesure que la plus-value correspondante serait imposable','§ 9-4(1)'],['Perte sur actions ?','Entièrement déductible — majorée ×1,72 comme les gains','§ 9-4, § 10-31'],['— BASE FISCALE HÉRITAGE/DON —','§ 9-7 : Principe de continuité'],['Hérité quelque chose ?','Vous reprenez la base fiscale du défunt — pas la valeur marchande au moment de la succession','§ 9-7(1)'],['Reçu un don ?','Même principe — la base fiscale du donateur est reprise','§ 9-7(1)'],['Exception si le défunt aurait pu vendre en franchise ?','La base fiscale est fixée à la valeur marchande au décès','§ 9-7(2)'],['— SORTIE DU TERRITOIRE FISCAL —','§ 9-14 : Impôt de sortie sur les actifs'],['Transfert d\'actifs hors de Norvège ?','La plus-value latente est imposée comme si l\'actif avait été vendu à la valeur marchande','§ 9-14(1)'],['Y compris les actifs incorporels ?','Oui — brevets, licences, marques, etc.','§ 9-14(2)'],['Report possible ?','Oui, dans l\'EEE — mais une garantie peut être exigée','§ 9-14(4)']],
    salReorgRows: [['— FUSION (§ 11-2/11-3) —',''],['Sociétés par actions (§ 11-2)','Exonérée d\'impôt lorsque la fusion suit la loi sur les sociétés par actions chap. 13','Deux ou plusieurs AS fusionnent sans payer d\'impôt'],['Coopératives (§ 11-2(2))','Exonérée d\'impôt selon la loi sur les coopératives chap. 8'],['Sociétés à imposition des participants (§ 11-3)','Exonérée d\'impôt si même forme de société et de responsabilité','Les participants doivent recevoir des parts en contrepartie (max 20% de complément en espèces)'],['— SCISSION (§ 11-4/11-5) —',''],['Sociétés par actions (§ 11-4)','Exonérée d\'impôt lorsque la scission suit la loi sur les sociétés par actions chap. 14','Une société est divisée en deux ou plusieurs sans impôt'],['Sociétés à imposition des participants (§ 11-5)','Exonérée d\'impôt si même forme de société et de responsabilité','Max 20% de la contrepartie peut être autre chose que des parts'],['— CONDITIONS ET PRINCIPES —',''],['Autre contrepartie (§ 11-6)','La contrepartie en espèces pour l\'actionnaire est imposable','Seules les actions/parts dans les sociétés fusionnantes sont exonérées d\'impôt'],['Continuité (§ 11-7)','Les valeurs fiscales et les dates d\'acquisition sont maintenues','La société absorbante reprend toutes les positions fiscales sans changement'],['Répartition lors de scission (§ 11-8)','Les positions fiscales sont réparties selon les valeurs nettes'],['Dissolution (§ 11-9)','La société cédante doit être dissoute après le transfert'],['Date d\'effet (§ 11-10)','À compter de l\'entrée en vigueur en droit des sociétés'],['— TRANSFRONTALIER (§ 11-11) —',''],['Fusion/scission transfrontalière','Exonérée d\'impôt au sein de l\'EEE avec continuité','Une AS norvégienne peut fusionner avec une société d\'un autre État de l\'EEE'],['Échange d\'actions (§ 11-11(4))','Exonéré d\'impôt lors du transfert d\'au moins 90% des actions','Max 20% de contrepartie en espèces'],['Pays à faible fiscalité (§ 11-11(7))','L\'exonération ne s\'applique pas aux pays à faible fiscalité','Exception si réellement établi dans un État de l\'EEE'],['— TRANSFORMATION (§ 11-20) —',''],['En société par actions','Entreprise individuelle, ANS, DA etc. peuvent être transformées en franchise d\'impôt','Les valeurs et positions fiscales sont maintenues'],['Transfert intra-groupe (§ 11-21)','Transfert exonéré d\'impôt entre sociétés du même groupe','La société mère doit détenir plus de 90% des actions'],['Rationalisation (§ 11-22)','Le ministère peut accorder une exonération fiscale lors d\'une réorganisation','Concerne la vente de biens immobiliers, d\'activités ou d\'actions']],
    salKeyRows: [['— TRAVAIL, CAPITAL OU ENTREPRISE ? —','§ 5-1 : Pourquoi la frontière entre ces trois détermine votre impôt'],['Revenus du travail','Prestation personnelle pour autrui. Salaire, honoraires, avantages en nature. Donne un revenu personnel → impôt progressif + cotisations sociales (7,6 %).','§ 5-10'],['Revenus du capital','Rendement de ce que vous possédez — intérêts, dividendes, loyers, plus-values. Uniquement 22 % d\'impôt ordinaire.','§ 5-20'],['Revenus d\'entreprise','La loi fiscale ne définit pas « entreprise » directement. Quatre critères :'],['1. Durée','L\'activité doit avoir une certaine durée — pas une vente isolée.'],['2. Ampleur','Il faut une certaine ampleur. Un bien locatif = capital. Dix biens avec gestion active = entreprise.'],['3. Aptitude au bénéfice','L\'activité doit objectivement pouvoir être rentable. Un hobby n\'est pas une entreprise.'],['4. À ses propres risques','Vous supportez le risque financier. Distingue l\'entreprise du salariat.'],['Pourquoi c\'est important ?','L\'entreprise individuelle donne un revenu personnel → impôt progressif + cotisations. Le capital donne seulement 22 %.'],['Zone grise typique ?','Location immobilière. Peu de biens, peu de travail = capital. Beaucoup de biens, gestion active = entreprise.'],['— CONCEPT DE RÉALISATION —','§ 9-2 : Qu\'est-ce qui déclenche l\'impôt — et qu\'est-ce qui ne le fait pas ?'],['Qu\'est-ce que la réalisation ?','Transfert de propriété contre contrepartie : vente, échange, rachat, expropriation, destruction. S\'applique à tous les types de biens.','§ 9-2(1)'],['Qu\'est-ce qui n\'est PAS une réalisation ?','Don, héritage, partage lors d\'une séparation, transfert entre époux. Aucun ne déclenche d\'impôt.','§ 9-2(3)'],['Règle résidence ?','Vente de résidence principale exonérée si détenue 1 an min et habitée 1 des 2 dernières années. Secondaire : 5 ans, utilisée 5/8.','§ 9-3(2)/(4)'],['Principe de symétrie ?','La perte est déductible dans exactement la même mesure que le gain correspondant serait imposable. Résidence exonérée = pas de déduction pour perte.','§ 9-4'],['Héritage et don — continuité ?','Le bénéficiaire reprend la base fiscale du défunt/donateur. Pas d\'impôt à la réception, mais le gain futur se calcule depuis le prix d\'achat initial.','§ 9-7'],['Exception : défunt aurait pu vendre en franchise ?','La base fiscale est fixée à la valeur marchande au décès — plus avantageux pour l\'héritier.','§ 9-7(2)'],['— BASE FISCALE —','Ce que vous avez « payé » au sens fiscal'],['Qu\'est-ce que la base fiscale ?','Le montant à partir duquel on mesure le gain ou la perte à la vente. Normalement : prix d\'achat + frais. Pour les actions : aussi le crédit d\'abattement non utilisé.','§ 9-7, § 10-32'],['Pourquoi est-ce important ?','Gain = prix de vente moins base fiscale. Mauvaise base = mauvais impôt. La différence peut être de centaines de milliers.'],['Héritage/don ?','Vous reprenez la base fiscale du défunt/donateur (continuité). Pas de « remise à zéro » à la valeur marchande. Exception : si le défunt aurait pu vendre en franchise.','§ 9-7'],['Actions ?','Prix d\'achat + frais de transaction + crédit d\'abattement non utilisé. FIFO détermine les actions vendues en premier.','§ 10-32, § 10-36'],['Résidence ?','Prix d\'achat + droits de mutation + améliorations (pas l\'entretien). Pertinent si le critère de résidence n\'est pas rempli.','§ 9-3'],['Amortissements ?','Pour les actifs professionnels, la base fiscale est réduite par les amortissements fiscaux.','§ 6-10, § 14-40'],['— MODÈLE ACTIONNAIRE —','§ 10-11 à 10-12'],['Comment sont imposés les dividendes ?','Dividendes multipliés par 1,72 et imposés à 22 %. Impôt effectif : env. 37,84 %.','§ 10-11'],['Qu\'est-ce que le crédit d\'abattement ?','La partie du dividende correspondant au rendement sans risque est exonérée.','§ 10-12'],['Pourquoi 1,72 ?','Pour que l\'impôt total (société + actionnaire) soit au niveau de l\'impôt sur les salaires.'],['— MÉTHODE D\'EXEMPTION —','§ 2-38'],['Qu\'est-ce que c\'est ?','Les sociétés ne paient pas d\'impôt sur les dividendes et plus-values d\'autres sociétés.','§ 2-38'],['Règle des 3 % ?','La société doit quand même comptabiliser 3 % du dividende exonéré. Impôt effectif : 0,66 %.','§ 2-38(6)'],['Exceptions ?','Ne s\'applique pas aux pays à fiscalité privilégiée ni aux participations inférieures à 10 % hors EEE.','§ 2-38(3)'],['— CONTRIBUTIONS DE GROUPE —','§ 10-2 à 10-5'],['Qu\'est-ce que c\'est ?','Transfert d\'argent entre sociétés du même groupe. Déductible pour le donneur, imposable pour le receveur.','§ 10-2'],['Quel est l\'intérêt ?','Égaliser les bénéfices et pertes dans le groupe pour un impôt total correct.'],['Condition ?','La société mère doit détenir plus de 90 % des actions et des droits de vote.','§ 10-4'],['— FUSION ET SCISSION EXONÉRÉES —','§ 11-2, § 11-4, § 11-7'],['Quand est-ce exonéré ?','Lorsque réalisé selon le droit des sociétés avec continuité fiscale.','§ 11-2/11-4'],['Qu\'est-ce que la continuité ?','La société repreneuse hérite de toutes les valeurs fiscales inchangées.','§ 11-7'],['Qu\'est-ce qui peut mal tourner ?','Contrepartie en espèces = imposition. Les déficits peuvent disparaître (§ 13-3). La norme anti-évasion (§ 13-2) peut frapper.'],['— NORME ANTI-ÉVASION —','§ 13-2'],['Quand s\'applique-t-elle ?','Lorsque l\'objectif principal est un avantage fiscal et que l\'opération ne résiste pas à une évaluation globale.','§ 13-2(2)'],['Que considère-t-on ?','Substance commerciale, ampleur de l\'avantage fiscal, voie inappropriée, utilisation contraire à l\'esprit des règles.','§ 13-2(3)'],['Conséquence ?','L\'opération est imposée selon son contenu réel — pas selon sa forme.','§ 13-2(4)'],['Exemple ?','Achat d\'une société vide pour exploiter un déficit. Le déficit disparaît selon § 13-3.','§ 13-3'],['— EXIGENCE DE LÉGALITÉ —','§ 11-1(2)'],['Qu\'est-ce que c\'est ?','Fusion et scission doivent être légales à trois niveaux pour être exonérées.','§ 11-1(2)'],['Droit des sociétés','Doit suivre la loi sur les sociétés : plan de fusion, avis aux créanciers, vote en AG, enregistrement.','Loi sur les sociétés chap. 13/14'],['Droit fiscal (chap. 11)','Continuité fiscale, max 20 % en espèces, dissolution de la société cédante.','§ 11-7, § 11-6, § 11-9'],['Droit de la TVA','Fusion/scission exonérée (§ 6-14, 0 % TVA). Mais obligations d\'ajustement reprises par le nouveau propriétaire.','Loi TVA § 6-14, chap. 9'],['En pratique ?','Les trois niveaux doivent être respectés. Une erreur en droit des sociétés contamine le fiscal et la TVA.']],
    salSubjRows: [['— CONTRIBUABLE PERSONNE PHYSIQUE (§ 2-1) —',''],['Résident en Norvège (§ 2-1(1))','Imposable sur tous les revenus/patrimoine, en Norvège et à l\'étranger','Si vous résidez en Norvège, vous êtes imposé sur tout — quelle que soit l\'origine du revenu'],['Établissement de la résidence (§ 2-1(2))','Séjour >183 jours sur 12 mois ou >270 jours sur 36 mois','Si vous restez assez longtemps en Norvège, vous devenez résident fiscal'],['Cessation de la résidence (§ 2-1(3))','Exige un séjour permanent à l\'étranger + abandon du logement en Norvège','Vous devez résider en permanence à l\'étranger et ne plus disposer de logement en Norvège'],['Absence temporaire (§ 2-1(4))','N\'interrompt pas la résidence fiscale','Les vacances ou courts séjours à l\'étranger ne changent pas votre résidence'],['Svalbard (§ 2-1(5))','Réglementation propre (loi fiscale du Svalbard)'],['— SUCCESSION (§ 2-2) —',''],['Succession (§ 2-2)','Sujet fiscal distinct l\'année du décès et au-delà','La succession est imposée comme une entité distincte jusqu\'à sa liquidation'],['Partage dans l\'année du décès (§ 2-15)','Les héritiers prennent le relais au 1er janvier','Si la succession est partagée dans l\'année du décès, les héritiers sont imposés pour toute l\'année'],['— SOCIÉTÉS (§ 2-2) —',''],['Société à responsabilité limitée (§ 2-2(1)a)','Sujet fiscal distinct','La SARL est un contribuable indépendant — imposée à 22% sur le bénéfice'],['Société anonyme (§ 2-2(1)b)','Sujet fiscal distinct'],['Caisse d\'épargne, assurance mutuelle (§ 2-2(1)c-d)','Sujet fiscal distinct'],['Société coopérative (§ 2-2(1)e)','Sujet fiscal distinct'],['Entreprise publique, établissement de santé (§ 2-2(1)g-h)','Sujet fiscal distinct'],['Fondations (§ 2-2(1)f)','Sujet fiscal distinct'],['Entreprise communale (§ 2-2(1)i)','Sujet fiscal distinct'],['— OBLIGATION FISCALE LIMITÉE (§ 2-3) —',''],['Revenu de bien immobilier en Norvège (§ 2-3(1)a)','Imposable','Les étrangers propriétaires de biens en Norvège sont imposés sur le revenu qui en découle'],['Activité en Norvège (§ 2-3(1)b)','Imposable','Si vous exercez une activité depuis la Norvège, vous y êtes imposé'],['Travail en Norvège (§ 2-3(1)d)','Imposable','Si vous travaillez en Norvège, vous êtes imposé sur votre salaire — y compris les étrangers'],['Dividendes d\'une société norvégienne (§ 2-3(1)c)','Retenue à la source','Les actionnaires étrangers paient une retenue à la source sur les dividendes de sociétés norvégiennes'],['Jetons de présence (§ 2-3(1)e)','Imposables','Si vous siégez au conseil d\'une société norvégienne, vous êtes imposé sur les jetons'],['Pension de Norvège (§ 2-3(4))','Imposable (retenue à la source)','Également pour les personnes résidant à l\'étranger'],['Impôt sur les artistes (§ 2-3(1)h)','Imposable pour les artistes étrangers','Règles spécifiques pour l\'imposition des concerts, représentations, etc.'],['— MÉTHODE D\'EXONÉRATION (§ 2-38) —',''],['Exonération pour les sociétés (§ 2-38(1))','Dividendes et plus-values entre sociétés sont exonérés','Une société détenant des actions dans une autre échappe normalement à l\'impôt sur les dividendes et plus-values'],['Règle des 3% (§ 2-38(6))','3% du revenu est néanmoins imposé','La société paie en pratique 0,66% (3% × 22%) des dividendes exonérés'],['Exception pays à faible fiscalité (§ 2-38(3))','L\'exonération ne s\'applique pas aux sociétés dans les pays à faible fiscalité','Les sociétés dans des pays à fiscalité très basse ne bénéficient pas de la méthode d\'exonération'],['Exception portefeuille EEE (§ 2-38(3)b)','L\'exonération ne s\'applique pas sous 10% de participation hors EEE','Si vous détenez moins de 10% d\'une société hors EEE, la méthode d\'exonération ne s\'applique pas'],['— CONJOINTS (§ 2-10 à 2-16) —',''],['Imposition commune ou séparée (§ 2-10)','Les conjoints peuvent être imposés ensemble ou séparément','Vous pouvez choisir de cumuler ou de séparer vos revenus'],['Répartition (§ 2-11)','Revenus/déductions attribués au conjoint concerné'],['Classe 2 (§ 2-14)','Conjoint à charge avec faible revenu','Donne un impôt plus bas si l\'un des conjoints a peu ou pas de revenu'],['Logement commun (§ 2-12)','Imposition partagée du logement commun'],['— ENFANTS (§ 2-14) —',''],['Enfants de moins de 17 ans (§ 2-14(1))','Les revenus des enfants sont imposés chez les parents','Les revenus du capital des enfants de moins de 17 ans sont imposés chez les parents'],['Revenus du travail des enfants (§ 2-14(3))','Imposés chez l\'enfant lui-même','Le salaire gagné par l\'enfant est imposé séparément'],['Patrimoine des enfants (§ 2-14(5))','Réparti à parts égales entre les parents'],['— INSTITUTIONS EXONÉRÉES (§ 2-30 à 2-32) —',''],['L\'État (§ 2-30(1)a)','Exonéré d\'impôt'],['Départements/communes (§ 2-30(1)b-c)','Exonérés d\'impôt'],['Communautés religieuses (§ 2-30(1)d)','Exonérées d\'impôt'],['Institutions non commerciales (§ 2-32)','Exonérées tant que le revenu n\'est pas commercial','Associations, clubs et fondations à but non lucratif sont exonérés d\'impôt'],['Activité commerciale (§ 2-32(2))','Imposable au-delà de 140 000 kr / 70 000 kr','Si le revenu de vente, location, etc. dépasse le seuil, il faut payer l\'impôt'],['— RÈGLES DE RÉSIDENCE DES SOCIÉTÉS (§ 2-2(6)) —',''],['Enregistrée en Norvège','Toujours sujet fiscal norvégien','Les sociétés inscrites au registre norvégien sont imposables en Norvège'],['Constituée en Norvège (§ 2-2(7))','Toujours sujet fiscal norvégien'],['Direction en Norvège (§ 2-2(6))','Peut devenir sujet fiscal norvégien','Une société étrangère effectivement dirigée depuis la Norvège peut y être imposée'],['— TRANSFERT DE SIÈGE D\'UNE SOCIÉTÉ (§ 2-2(8)) —',''],['Transfert en Norvège (§ 2-2(8))','Obligation fiscale complète dès l\'établissement en Norvège'],['Transfert hors de Norvège (§ 2-2(8))','Règlement des plus-values latentes','La société doit régler ses positions fiscales lors du transfert hors de Norvège'],['— INTERNATIONAL (§ 2-37/2-38) —',''],['Crédit d\'impôt (§ 2-37)','Déduction pour impôt payé à l\'étranger','Évite la double imposition — l\'impôt étranger est déduit de la déclaration norvégienne'],['Conventions fiscales','Peuvent limiter le droit d\'imposition de la Norvège','La Norvège a des conventions avec de nombreux pays répartissant le droit d\'imposer']],
    morReqRows: [['Prêt maximum','Endettement total max 5× revenu annuel','Toutes les dettes comptent — prêt immobilier, étudiant, auto, cartes de crédit'],['Apport personnel','Minimum 10%','Vous devez avoir épargné au moins 10% du prix du logement'],['Test de résistance','Le plus élevé entre 7% et taux + 3 pp','La banque vérifie que vous pouvez vous permettre le prêt même si le taux augmente'],['Amortissement','Obligatoire au-dessus de 60% de ratio prêt-valeur','Si vous avez emprunté plus de 60% de la valeur du bien, vous devez rembourser le capital'],['Quota de flexibilité','La banque peut dévier pour 10% des prêts','À Paris : max 8% — signifie que la banque peut dire oui même si vous ne remplissez pas tous les critères']],
    morCostRows: [['Taux actuel','Env. 5,1% variable (jan 2026)'],['Déduction fiscale','22% des coûts d\'intérêts','Vous récupérez 22% des intérêts que vous payez sur vos impôts'],['Droit de mutation','Normalement 2,5% de la valeur de marché','Payé lors de l\'achat d\'un bien immobilier — des exceptions peuvent s\'appliquer']],
    morBsuRows: [['Épargne annuelle maximale','27 500 kr'],['Montant total maximal','300 000 kr'],['Déduction fiscale','10% du montant versé — jusqu\'à 2 750 kr/an'],['Limite d\'âge','Jusqu\'à et y compris l\'année où vous atteignez 33 ans'],['Condition pour la déduction fiscale','Vous devez avoir un revenu d\'emploi imposable et ne pas être propriétaire d\'une maison'],['À quoi l\'argent peut-il servir ?','Achat, remboursement, amélioration ou entretien de votre propre logement'],['Rupture de contrat ?','Si vous utilisez l\'argent à une autre fin que le logement, vous devez rembourser toutes les déductions fiscales']],
    morBsuTitle:'BSU — Épargne pour l\'accession à la propriété', morBsuDesc:'Déduction fiscale, limites d\'épargne, limite d\'âge, conditions d\'utilisation',
    morReqTitle:'Conditions de prêt immobilier', morReqDesc:'Apport personnel, ratio d\'endettement, test de résistance, amortissement',
    morCostTitle:'Coûts d\'achat d\'une propriété', morCostDesc:'Intérêts, déduction fiscale, droit de mutation',
    npvInfoRows: [['— GLOSSAIRE —',''],['VAN (Valeur Actuelle Nette)','La valeur actuelle des flux de trésorerie futurs moins l\'investissement'],['TRI (Taux de Rendement Interne)','Le taux d\'intérêt qui donne une VAN = 0'],['CMPC','Coût moyen pondéré du capital'],['— INTERPRÉTATION —',''],['VAN > 0','Rentable — accepter l\'investissement'],['VAN < 0','Non rentable — rejeter'],['TRI > CMPC','Projet créateur de valeur'],['TRI < CMPC','Projet destructeur de valeur'],['— RÉFÉRENCE —',''],['Taux d\'actualisation','Généralement le CMPC (avant impôt)'],['CMPC typique','8–12%'],['Délai de récupération','Plus court est mieux']],
    vatSubjRows: [['— CONDITIONS DE BASE —','Trois choses doivent être satisfaites pour la responsabilité TVA'],['1. Activité commerciale','Vous devez exercer une activité commerciale — pas un hobby ou un emploi','§ 2-1(1)'],['2. Fourniture de biens/services','Il doit y avoir une transaction — livraison contre contrepartie (paiement)','§ 1-3(1)a'],['3. Seuil de chiffre d\'affaires','Chiffre d\'affaires dépassant 50 000 kr sur 12 mois','§ 2-1(1)'],['— QUI DOIT S\'ENREGISTRER ? —',''],['Entreprises au-dessus de 50 000 kr','Doivent s\'enregistrer au registre de la TVA','§ 2-1(1)'],['Organismes caritatifs','Seuil plus élevé : 140 000 kr','§ 2-1(1)'],['Événements sportifs','Seuil distinct : 3 000 000 kr','§ 2-1(1)'],['— CONCEPTS CLÉS —',''],['Qu\'est-ce qu\'une « activité commerciale » ?','Une activité indépendante, durable, de caractère économique et capable de générer un profit. Les hobbies et les commandes ponctuelles ne sont normalement pas une activité commerciale.'],['Qu\'est-ce que le « chiffre d\'affaires » ?','Fourniture de biens ou services contre contrepartie. Les dons, l\'indemnisation et les subventions ne sont normalement pas du chiffre d\'affaires.','§ 1-3(1)a'],['Qu\'est-ce qu\'un « assujetti » ?','Une entité enregistrée (ou tenue de s\'enregistrer) au registre de la TVA, tenue de calculer et de payer la TVA.','§ 1-3(1)d'],['Enregistrement volontaire ?','Les bailleurs de propriétés commerciales peuvent s\'enregistrer volontairement pour obtenir des déductions sur la TVA en amont.','§ 2-3']],
    vatSubjTitle:'Qui est assujetti à la TVA ?', vatSubjDesc:'Activité commerciale · Seuil de chiffre d\'affaires · Obligation d\'enregistrement',
