    npvInfoRows: [['— 术语解释 —',''],['NPV（净现值）','未来现金流的现值减去投资'],['IRR（内部收益率）','使NPV = 0的利率'],['WACC','加权平均资本成本'],['— 解读 —',''],['NPV > 0','有利可图——接受投资'],['NPV < 0','无利可图——拒绝'],['IRR > WACC','创造价值的项目'],['IRR < WACC','毁灭价值的项目'],['— 参考 —',''],['贴现率','通常为WACC（税前）'],['典型WACC','8–12%'],['回收期','越短越好']],
    vatRates: [['25','25% 标准——商品和服务（§ 5-1）'],['15','15% 食品（§ 5-2）'],['12','12% 交通、酒店、电影院（§ 5-3/5-5/5-6）'],['0','0% 免征——报纸、书籍、出口（第6章）']],
    vatInfoRows: [['— 税率 —',''],['一般税率（§ 5-1）','25%'],['食品（§ 5-2）','15%'],['客运（§ 5-3）','12%'],['酒店客房（§ 5-5）','12%'],['电影院（§ 5-6）','12%'],['博物馆/画廊（§ 5-9）','12%'],['游乐园（§ 5-10）','12%'],['体育赛事（§ 5-11）','12%'],['供水/排水（§ 5-12）','12%'],['餐饮服务（§ 5-2）','25%（非15%）'],['— 登记 —',''],['经营者（§ 2-1）','50 000 kr / 12个月'],['慈善组织（§ 2-1）','140 000 kr / 12个月'],['体育赛事（§ 2-1）','3 000 000 kr'],['— 地域范围 —',''],['地理范围（§ 1-2）','挪威大陆 + 领海'],['非增值税区域','斯瓦尔巴群岛、扬马延岛、属地']],
    vatLawRows: [['— 豁免（第3章） —','不在法律范围内，无抵扣权'],['医疗服务（§ 3-2）','豁免','医生、牙医、理疗师等——无增值税且无抵扣权'],['社会服务（§ 3-4）','豁免','儿童保护、养老护理、戒瘾护理等'],['教育（§ 3-5）','豁免','学校、课程、培训——公立和私立均适用'],['金融服务（§ 3-6）','豁免','银行、保险、证券交易——无增值税'],['艺术/文化——表演（§ 3-7）','豁免','音乐会、戏剧、舞蹈——门票不含增值税'],['体育——使用权（§ 3-8）','豁免','健身中心、足球场、游泳馆等'],['公权力行使（§ 3-9）','豁免'],['不动产/租赁（§ 3-11）','豁免（第(2)款有例外）','住宅和商业不动产的租赁豁免——但商业用途可自愿登记'],['慈善组织（§ 3-12）','豁免（部分销售）','慈善组织的跳蚤市场、义卖会等'],['公益组织会费（§ 3-13）','豁免'],['博彩（§ 3-14）','豁免'],['葬礼——仪式（§ 3-15）','豁免'],['董事酬金（§ 3-17）','豁免（含雇主社保费）','董事酬金免征增值税但须缴纳雇主社保费'],['私人二手物品（§ 3-19）','豁免','私人出售二手物品无需计算增值税'],['— 零税率（第6章） —','适用法律，0%销项税，有抵扣权'],['报纸（§ 6-1）','零税率'],['期刊（§ 6-3）','零税率（最后一款）'],['书籍（§ 6-4）','零税率（最后一款）'],['北挪威家庭用电（§ 6-6）','零税率'],['电动汽车≤300 000 kr（§ 6-8）','零税率','仅适用于购买金额不超过300 000 kr的部分——超出部分按25%计征增值税'],['船舶≥15米（§ 6-9）','零税率'],['职业用航空器（§ 6-10）','零税率'],['业务整体转让（§ 6-14）','零税率','整体出售企业时增值税历史记录转移——销售不征增值税'],['出口货物（§ 6-21）','零税率','出口到国外——0%增值税但进项税全额抵扣'],['出口服务（§ 6-22）','零税率'],['往返国外运输（§ 6-28）','零税率'],['— 自用提取（第3章第II部分） —',''],['提取商品（§ 3-21）','应征增值税','从企业中取出商品供自用须计算增值税'],['私人提取服务（§ 3-22）','应征增值税'],['餐饮/实物/招待（§ 3-23）','应征增值税'],['— 进口（第3章第III部分） —',''],['进口商品（§ 3-29）','应征增值税','进口商品——通关时计算增值税'],['远程可交付服务（§ 3-30）','反向征收','从国外购买数字服务由你自行计算增值税']],
    vatDefRows: [['营业额（a）','以对价交付商品/服务','以金钱交换某物即为营业额'],['商品（b）','实物、不动产、电力、水、天然气、热能、冷能'],['服务（c）','一切可交易且非商品的项目','咨询、美发、运输、维修等'],['纳税主体（d）','已在增值税登记册登记/应当登记','12个月内营业额超过50 000 kr的企业'],['销项税（e）','在营业和自用提取时计算并缴纳','你加在价格上并向客户收取的增值税'],['进项税（f）','在购买或进口时产生','你在为企业购买商品/服务时支付的增值税'],['法律豁免（g）','不适用法律的营业额→无抵扣权','企业不能抵扣与豁免营业额相关的进项税'],['增值税免征（h）','适用法律但0%销项税→完全抵扣权','出口是免征的——你不加增值税但可以抵扣进项税'],['远程可交付服务（i）','不与特定物理地点关联','IT服务、在线咨询、流媒体等'],['电子服务（j）','远程可交付、通过互联网、自动化','应用程序、电子书、流媒体服务、在线课程']],
    vatDedRows: [['基本规则（§ 8-1）','在登记经营中使用的进项税可抵扣','你可以收回为企业购买的一切的增值税'],['混合使用（§ 8-2）','按估计使用比例进行比例抵扣','60%用于企业、40%用于私人，则可获60%抵扣'],['不可抵扣：餐饮（§ 8-3 a）','','为员工、客户等提供的餐饮'],['不可抵扣：招待（§ 8-3 e）','','客户宴请、商业伙伴活动'],['不可抵扣：礼品（§ 8-3 f）','非微量价值','超过微量门槛的礼品不可抵扣'],['不可抵扣：住房/福利（§ 8-3 g）','例外：企业食堂'],['私人用车（§ 8-4）','不可抵扣（例外：出租、出租车、销售）','公司车不可抵扣增值税，除非用于出租或客运'],['银行支付（§ 8-8）','≥10 000 kr时要求','超过10 000 kr的现金支付不可抵扣增值税']],
    vatAdjRows: [['资本货物——动产（§ 9-1 a）','进项税≥50 000 kr','增值税超过50 000 kr的机器、车辆等'],['资本货物——不动产（§ 9-1 b）','进项税≥100 000 kr','增值税超过100 000 kr的建筑物、设施等'],['动产调整期（§ 9-4）','5年','如果在接下来5年内改变用途，增值税抵扣须调整'],['不动产调整期（§ 9-4）','10年','如果在接下来10年内改变用途，增值税抵扣须调整']],
    vatCalcRows: [['基本规则（§ 4-1）','不含增值税的对价'],['以物易物（§ 4-3）','按市场价值','以物易物时按市场价格作为增值税计算基础'],['关联交易（§ 4-4）','不低于市场价值','低价卖给自己的公司时按市场价格计算增值税'],['坏账损失（§ 4-7）','可对最终确认的坏账进行更正','客户永远不会付款——那么你可以收回已缴纳的增值税']],
    vatRegRows: [['联合登记（§ 2-2）','≥85%所有权，连带责任','集团公司可作为一个增值税主体登记'],['自愿登记——出租（§ 2-3）','向增值税登记租户出租的建筑/设施','当租户已登记增值税时，出租人可获得装修/建设的增值税抵扣'],['预先登记（§ 2-4）','在营业前有重大采购','新成立的企业可在营业额达到50 000 kr之前登记']],
    vatSubjRows: [['— 基本条件 —','增值税义务需满足三个条件'],['1. 经营者','必须从事商业活动——不是爱好或雇佣关系','§ 2-1(1)'],['2. 销售商品/服务','必须存在交易——交付并收取对价（付款）','§ 1-3(1)a'],['3. 营业额门槛','12个月内营业额超过50 000 kr','§ 2-1(1)'],['— 谁必须登记？ —',''],['营业额超过50 000 kr的经营者','必须在增值税登记册中登记','§ 2-1(1)'],['慈善组织','较高门槛：140 000 kr','§ 2-1(1)'],['体育赛事','特殊门槛：3 000 000 kr','§ 2-1(1)'],['— 概念解释 —',''],['什么是"经营"？','独立、持续、具有经济性质且有盈利能力的活动。爱好和单次任务通常不是经营。'],['什么是"销售"？','交付商品或服务并收取对价。赠与、赔偿和补贴通常不是销售。','§ 1-3(1)a'],['什么是"增值税主体"？','已登记（或应登记）在增值税登记册中，有义务计算和缴纳增值税的人。','§ 1-3(1)d'],['自愿登记？','商业房产出租人可自愿登记以获得进项增值税抵扣权。','§ 2-3']],
