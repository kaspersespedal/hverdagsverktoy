        <div class="info-card hidden" id="sal-corp-card" style="margin-top:16px;">
          <div class="card-hdr" style="cursor:pointer" onclick="toggleCard(this.parentElement)"><div class="card-ico gold">🏢</div><div><div class="card-title" id="sal-corp-title">Særregler selskaper (kap. 10) <span style="font-size:11px;opacity:.5">▼</span></div><div class="card-desc" id="sal-corp-desc">Utbytte · Aksjegevinst · Konsernbidrag · NOKUS</div></div></div>
          <div id="sal-corp-rows" class="law-body"></div>
        </div>
        <div class="info-card hidden" id="sal-reorg-card" style="margin-top:16px;">
