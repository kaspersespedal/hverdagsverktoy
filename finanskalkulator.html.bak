function updateDashStats() {
  const el = (id) => document.getElementById(id);
  if(_sal) {
    el('dash-sal-val').textContent = fmt(_sal.net);
  } else {
    el('dash-sal-val').textContent = '–';
  }
  if(_mor) {
    el('dash-mor-val').textContent = fmt(_mor.mnd) + R().mo;
  } else {
    el('dash-mor-val').textContent = '–';
  }
  if(_npv) {
    el('dash-npv-val').textContent = fmt(_npv.npv);
    el('dash-npv-val').style.color = _npv.npv >= 0 ? 'var(--green)' : 'var(--red)';
  } else {
    el('dash-npv-val').textContent = '–';
    el('dash-npv-val').style.color = '';
  }
}

