    salInfoRows: [['Asmeninis atskaitymas','114 540 kr'],['Minimalus atskaitymas (maks.)','95 700 kr'],['Pakopinis mokestis 1 (226 tūkst.+)','1.7%'],['Pakopinis mokestis 2 (318 tūkst.+)','4.0%'],['Pakopinis mokestis 3 (725 tūkst.+)','13.7%'],['Pakopinis mokestis 4 (980 tūkst.+)','16.8%'],['Pakopinis mokestis 5 (1 467 tūkst.+)','17.8%'],['Socialinio draudimo įmoka','7.6%'],['Įprastinis mokestis','22%']],
    salLawRows: [['— PAGRINDINĖ TAISYKLĖ (§ 5-1) —',''],['Apmokestinamos pajamos','Bet kokia nauda, gauta iš darbo, kapitalo ar verslo veiklos','Viskas, ką uždirbate iš darbo, investicijų ar verslo, yra apmokestinama'],['Taip pat apmokestinama','Pensijos, rentų išmokos, rentos'],['Pelnas pardavus (§ 5-1(2))','Apmokestinamas (žr. 9 sk.)','Jei parduodate ką nors su pelnu, turite sumokėti mokestį nuo pelno'],['Paėmimas asmeniniam naudojimui (§ 5-2)','Apmokestinamas rinkos verte','Jei imate prekes iš savo įmonės asmeniniam naudojimui, tai laikoma pajamomis'],['— DARBO PAJAMOS (§ 5-10) —',''],['Atlyginimas, honorarai, atostoginiai','Apmokestinama'],['Valdybos atlyginimai, tantjemos, arbatpinigiai','Apmokestinama'],['Bedarbio pašalpa, ligos išmokos, tėvystės/motinystės išmokos','Apmokestinama','Viešosios išmokos, pakeičiančios atlyginimą, apmokestinamos kaip atlyginimas'],['Išeitinė kompensacija/atleidimas (§ 5-10 d)','Apmokestinama'],['Natūrinės išmokos (§ 5-12)','Apmokestinamos rinkos verte','Nepiniginės naudos iš darbdavio — pvz., telefonas, laikraštis, draudimas'],['Lengvatinė paskola darbo santykiuose (§ 5-12(4))','Nauda = bazinė norma − faktinė norma','Jei gaunate paskolą iš darbdavio žemesne nei rinkos palūkanų norma, skirtumas apmokestinamas'],['Tarnybinis automobilis (§ 5-13)','30% nuo katalogo kainos (20% virš ribos)','Jei turite tarnybinį automobilį, apmokestinama dalis nuo naujo automobilio kainos'],['Automobilis >3 m.','75% nuo katalogo kainos'],['Darbo opcionai (§ 5-14)','Apmokestinami realizavus/pardavus','Apmokestinami, kai panaudojate arba parduodate opcioną, o ne kai jį gaunate'],['Startuolių opcionai (§ 5-14(2))','Nelaikomos darbo pajamomis (specialios sąlygos)','Palankesnės taisyklės darbuotojams mažose įmonėse iki 6 metų'],['— KAPITALO PAJAMOS (§ 5-20) —',''],['Pajamos iš nekilnojamojo turto/kilnojamojo turto','Apmokestinamos','Nuomos pajamos iš būsto, vasarnamio ar kilnojamojo turto nuomos'],['Finansinių priemonių pajamos','Apmokestinamos','Palūkanos, dividendai ir pelnas iš akcijų, fondų, banko indėlių'],['Neatlygintinas kitų turto naudojimas','Apmokestinamas','Jei naudojatės nemokamu būstu ar panašiai, tai laikoma pajamomis'],['Paskola bendrovei (§ 5-22)','Papildomas mokestis, perskaičiuojama ×1.72','Paskola iš savo UAB traktuojama kaip dividendai ir atitinkamai apmokestinama'],['— NEAPMOKESTINAMA (§ 5-15/5-43) —',''],['Vaiko išmoka','Neapmokestinama'],['Grynųjų pinigų parama','Neapmokestinama'],['Socialinė pašalpa','Neapmokestinama'],['Bazinė/slaugos pašalpa','Neapmokestinama'],['Laidojimo pašalpa','Neapmokestinama'],['Žalos atlyginimas/kompensacija','Neapmokestinama'],['Alimentai','Neapmokestinami'],['Lošimo laimėjimai (Norsk Tipping ir pan.)','Neapmokestinami','Laimėjimai iš Norsk Tipping, Rikstoto ir panašių yra neapmokestinami'],['Atsitiktiniai laimėjimai (§ 5-50)','Apmokestinami virš 10 000 kr','Laimėjimai iš privačių konkursų, loterijų ir pan.'],['Vartojimo daiktai (§ 5-21)','Neapmokestinami asmeniniame naudojime','Parduodant naudotus asmeninius daiktus (baldus, drabužius, automobilį) mokestis netaikomas']],
    salDedRows: [['— PAGRINDINĖ TAISYKLĖ (§ 6-1) —',''],['Atskaitymo teisė','Išlaidos, patirtos įgyjant, palaikant ar užtikrinant apmokestinamas pajamas','Galite atskaityti išlaidas, būtinas pajamoms uždirbti'],['Neatskaitoma','Asmeninės išlaidos (būstas, maistas, išlaikymas)','Asmeninių pragyvenimo išlaidų niekada negalima atskaityti'],['Nuostolis pardavus (§ 6-2)','Atskaitoma pagal 9 sk. taisykles','Jei parduodate ką nors su nuostoliu, galite jį atskaityti iš mokesčių'],['Nuostolis dėl reikalavimo (§ 6-2(2))','Atskaitoma galutinai patvirtinus nuostolį versle','Kai jūsų įmonei skolingas asmuo negali sumokėti'],['Deficitas (§ 6-3)','Užskaitomas su kitomis pajamomis, perkeliamas (§ 14-6)','Jei verslas nuostolingas, galite panaudoti nuostolį prieš kitas pajamas — arba išsaugoti ateinantiems metams'],['— MINIMALUS ATSKAITYMAS (§ 6-30/32) —',''],['Darbo pajamos','46% nuo atlyginimo, maks. 95 700 kr','Visi darbuotojai gauna tai automatiškai — padengia kelionę, drabužius, įrankius ir kt.'],['Pensijos pajamos','40% nuo pensijos'],['Pakeičia','Daugumą darbo išlaidų atskaitymų','Nereikia dokumentuoti atskirų išlaidų naudojant minimalų atskaitymą'],['Neįtraukta','Profesinės sąjungos mokestis, komandiruočių išlaidos','Tai galite atskaityti papildomai prie minimalaus atskaitymo'],['— STANDARTINIAI ATSKAITYMAI —',''],['Profesinės sąjungos mokestis (§ 6-20)','Maks. 8 700 kr','Narystė profesinėje sąjungoje, pvz., LO, YS, Unio, Akademikerne'],['Kelionė namo–darbas (§ 6-44)','Virš 12 000 kr, maks. 120 000 kr','Atskaitymas už kelionės atstumą virš 37 km viena kryptimi (po bazinio atskaitymo)'],['Vaiko priežiūros atskaitymas (§ 6-48)','Vaikai iki 12 metų, sumos riba nustatyta Stortingo','Padengia vaikų darželio, popamokinio klubo ir auklės išlaidas'],['Dovanos organizacijoms (§ 6-50)','Min. 500 kr, maks. 25 000 kr','Dovanos patvirtintoms organizacijoms, pvz., Raudonasis Kryžius, Gydytojai be sienų'],['Vaiko pensijos atskaitymas (§ 6-49)','Iki 32 600 kr'],['— SKOLOS PALŪKANOS (§ 6-40) —',''],['Skolos palūkanos','Pilnas atskaitymas (22% mokestinis efektas)','Visos mokamos palūkanos — būsto paskola, studijų paskola, auto paskola — grąžina 22% mokesčių'],['Palūkanų apribojimas koncerne (§ 6-41)','25% nuo EBITDA, riba 25 mln. (koncernas) / 5 mln. (ne koncernas)','Riboja palūkanų atskaitymą paskoloms tarp tos pačios grupės bendrovių'],['Neatskaitytų palūkanų perkėlimas','10 metų','Palūkanos, kurios nebuvo priimtos šiemet, gali būti panaudotos per ateinančius 10 metų'],['— VERSLO ATSKAITYMAI —',''],['Nusidėvėjimas (§ 6-10)','Ilgalaikio turto, prestižo nusidėvėjimas perkant','Paskirsto mašinų, transporto priemonių ir kt. kainą per kelerius metus'],['Priežiūra/draudimas (§ 6-11)','Atskaitymas ilgalaikiam turtui'],['Moksliniai tyrimai ir plėtra (§ 6-25)','Dalis ilgalaikio turto savikainos','Plėtros išlaidos gali būti kapitalizuotos ir nudėvimos per laiką'],['Startuolių bendrovė (§ 6-53)','Iki 1 mln. kr, bendrovė ≤6 m., ≥3 m. nuosavybės','Privatūs asmenys, investuojantys į mažas naujai įkurtas bendroves, gauna atskaitymą'],['— NEATSKAITOMA —',''],['Reprezentacija (§ 6-21)','Niekada neatskaitoma','Klientų vakarienės, dovanos verslo partneriams ir pan.'],['Kyšiai (§ 6-22)','Niekada neatskaitoma'],['Asociacijos mokestis (§ 6-18)','Paprastai neatskaitomas (išimtis § 6-19/20)','Išimtis šakinėms ir profesinėms asociacijoms'],['— MOKĖJIMAS PER BANKĄ (§ 6-51) —',''],['Reikalavimas','Mokėjimas ≥10 000 kr turi būti per banką dėl atskaitymo teisės','Grynieji mokėjimai virš 10 000 kr nesuteikia atskaitymo teisės'],['— PROFESINIAI ATSKAITYMAI —',''],['Žvejo atskaitymas (§ 6-60)','30%, maks. 160 000 kr, ≥130 dienų','Reikia mažiausiai 130 žvejybos dienų per mokestinius metus'],['Jūrininko atskaitymas (§ 6-61)','30%, maks. 86 300 kr, ≥130 dienų','Reikia mažiausiai 130 dienų jūroje per mokestinius metus']],
    salRealRows: [['— KADA ĮVYKSTA REALIZACIJA? —','Pagrindinė taisyklė §§ 9-1 ir 9-2'],['Kas sukelia kapitalo prieaugio mokestį?','Pardavimas, mainai, akcijų išpirkimas, nusavinimas, sunaikinimas — bet koks nuosavybės perleidimas už atlygį','§ 9-2(1)'],['Dovana?','Dovana nėra realizacija — dovanojas nemoka mokesčio','§ 9-2(3)'],['Paveldėjimas?','Nėra realizacija — nėra kapitalo prieaugio mokesčio paveldint','§ 9-2(3)'],['Dalijimas tarp sutuoktinių?','Nėra realizacija — taip pat ir skyrybų atveju','§ 9-2(3)'],['Priverstinis išpirkimas?','Laikomas realizacija — mokestinė prievolė atsiranda','§ 9-2(1)'],['— BŪSTO ATLEIDIMAS —','§ 9-3: Kada nemokate mokesčio?'],['Pardavėte savo būstą?','Atleista jei turėjote min. 1 metus ir gyvenote min. 1 iš paskutinių 2 metų','§ 9-3(2)'],['Pardavėte poilsio būstą?','Atleista jei turėjote min. 5 metus ir naudojote min. 5 iš paskutinių 8 metų','§ 9-3(4)'],['Pardavėte asmeninius daiktus?','Atleista — asmeninis turtas','§ 9-3(1)a'],['Pelnas iš sklypo?','Atleista tik jei sklypas nereikšmingas — kitaip apmokestinama kaip žemės pardavimas','§ 9-3(8)'],['Nuostolis nuo atleisto būsto?','Nėra atskaitymo — simetrijos principas','§ 9-4'],['— NUOSTOLIAI ATSKAITOMI —','§ 9-4: Simetrijos principas'],['Pardavimas su nuostoliu?','Atskaitymas tokiu pat mastu, kokiu atitinkamas pelnas būtų apmokestintas','§ 9-4(1)'],['Nuostolis nuo akcijų?','Visiškai atskaitomas — padidintas ×1,72 kaip pelnas','§ 9-4, § 10-31'],['— PRADINĖ VERTĖ PAVELDINT/DOVANOJANT —','§ 9-7: Tęstinumo principas'],['Paveldėjote ką nors?','Periate palikėjo pradinę vertę — ne rinkos vertę','§ 9-7(1)'],['Gavote dovaną?','Tas pats principas — periate dovanos teikėjo pradinę vertę','§ 9-7(1)'],['Išimtis — palikėjas galėjo parduoti be mokesčio?','Pradinė vertė nustatoma pagal rinkos vertę mirties dieną','§ 9-7(2)'],['— IŠVEŽIMAS IŠ NORVEGIJOS JURISDIKCIJOS —','§ 9-14: Išvykimo mokestis'],['Perkeliate turtą iš Norvegijos?','Latentinis pelnas apmokestinamas tarsi turtas parduotas rinkos verte','§ 9-14(1)'],['Apima ir nematerialų turtą?','Taip — patentus, licencijas, prekių ženklus ir kt.','§ 9-14(2)'],['Galima atidėti?','Taip, EEE viduje — bet gali būti reikalaujamas užstatas','§ 9-14(4)']],
    salCorpRows: [['— KONCERNO ĮNAŠAI (§ 10-2 iki 10-5) —',''],['Koncerno įnašas (§ 10-2)','Atskaitymas davėjui, apmokestinamas gavėjui','Perkėlimas tarp tos pačios grupės bendrovių — naudojamas rezultatams išlyginti'],['Nuosavybės reikalavimas (§ 10-4)','Patronuojanti bendrovė valdo >90% akcijų ir balsų','Taikoma akcinėms bendrovėms ir atitinkamoms užsienio bendrovėms EEE'],['— DIVIDENDAI IR APSAUGA (§ 10-10 iki 10-13) —',''],['Dividendai (§ 10-11)','Apmokestinami asmeniniams akcininkams','Perskaičiuojami koeficientu 1.72 prieš apmokestinant 22%'],['Apsaugos atskaitymas (§ 10-12)','Atimamas iš dividendų prieš mokesčius','Nemokate mokesčio nuo tos dividendų dalies, kuri atitinka nerizikingą palūkanų normą'],['Apsaugos palūkanų norma','Valstybės iždo vekseliai po mokesčių','Kasmet nustatoma Mokesčių direkcijos'],['Atleidimo metodas (§ 2-38)','Neapmokestinama bendrovėms','UAB, turinčios akcijų kitose UAB, atleidžiamos nuo mokesčio už dividendus ir pelną'],['3% taisyklė (§ 2-38(6))','3% pajamų apmokestinamos','Bendrovės vis tiek moka 0.66% (3% × 22%) nuo atleistų dividendų'],['— AKCIJŲ PELNAS IR NUOSTOLIAI (§ 10-30 iki 10-37) —',''],['Pelnas pardavus (§ 10-31)','Apmokestinamas asmeniniams akcininkams','Perskaičiuojamas koeficientu 1.72, t.y. efektyvus mokestis apie 37.84%'],['Nuostolis pardavus (§ 10-31(2))','Atskaitomas','Perskaičiuojamas analogiškai koeficientu 1.72'],['Pradinė vertė (§ 10-32)','Savikaina + nepanaudota apsauga','Tai, ką sumokėjote už akciją, plius sukauptas apsaugos atskaitymas'],['FIFO principas (§ 10-36)','Pirma nupirkta = pirma parduota','Parduodant dalį akcijų paketo, laikoma, kad seniausios akcijos parduodamos pirmiausia'],['— VERTYBINIŲ POPIERIŲ FONDAI IR ASK (§ 10-20/10-21) —',''],['Vertybinių popierių fondas (§ 10-20)','Akcijų ir palūkanų dalis apmokestinamos skirtingai','Akcijų dalis = akcininkų modelis, palūkanų dalis = įprastos pajamos'],['Akcijų taupymo sąskaita (§ 10-21)','Mokestis atidedamas iki išėmimo','Galite pirkti ir parduoti akcijas/fondus sąskaitoje neapmokestinant'],['Apmokestinamas išėmimas (§ 10-21(4))','Išėmimas viršijantis įnašą yra apmokestinamas','Mokestį mokate tik kai išimate daugiau, nei įnešėte'],['— DALYVIŲ APMOKESTINIMAS ANS/KS (§ 10-40 iki 10-49) —',''],['Neto metodas (§ 10-41)','Pelnas apmokestinamas dalyviams','Kiekvienas dalyvis moka mokesčius nuo savo bendrovės rezultato dalies'],['Paskirstymas (§ 10-42)','Apmokestinamas asmeniniam dalyviui','Perskaičiuojamas koeficientu 1.72 kaip dividendai'],['Pelnas pardavus dalį (§ 10-44)','Apmokestinamas','Skaičiuojamas pagal pradinę vertę su koregavimais dėl virškainio/nuolaidos'],['— KOOPERATYVAI (§ 10-50) —',''],['Papildomos išmokos (§ 10-50)','Atskaitymas kooperatyvui','Grąžinimas nariams pagal apyvartą su kooperatyvu'],['— NOKUS / MAŽŲ MOKESČIŲ ŠALYS (§ 10-60 iki 10-68) —',''],['NOKUS taisyklės (§ 10-60)','Norvegijos savininkas apmokestinamas nuolat','Taikoma bendrovėms mažų mokesčių šalyse, kontroliuojamoms norvegų savininkų'],['Mažų mokesčių šalis (§ 10-63)','Mokestis mažesnis nei 2/3 Norvegijos mokesčio','Šalis laikoma mažų mokesčių šalimi, jei efektyvus mokestis yra mažesnis nei apie 14.67%'],['Kontrolės reikalavimas (§ 10-62)','Norvegijos savininkai turi bent 50%','Kontrolė vertinama bendrai visiems Norvegijos mokesčių mokėtojams'],['Kredito atskaitymas (§ 10-65)','Atskaitymas už sumokėtą užsienio mokestį','Išvengiama dvigubo apmokestinimo atskaitant užsienyje sumokėtą mokestį'],['— IŠVYKIMO MOKESTIS (§ 10-70/10-71) —',''],['Latentinis pelnas (§ 10-70)','Apmokestinamas išvykstant iš Norvegijos','Taikoma akcijoms, dalims ir tam tikram kitam turtui'],['Atidėjimas (§ 10-70(7))','Galima atidėti EEE viduje','Mokėjimas atidedamas, bet gali būti reikalaujama užstato'],['Panaikinimas (§ 10-70(9))','Mokestis panaikinamas po 5 metų','Jei per 5 metus nerealizavote, mokestis panaikinamas'],['— ŠALTINIO MOKESTIS (§ 10-80 iki 10-82) —',''],['Šaltinio mokestis už dividendus','15–25% užsienio akcininkams','Tarifas priklauso nuo mokesčių sutarties su akcininko šalimi'],['Šaltinio mokestis už palūkanas/autorines (§ 10-80)','Pagal įstatyme nustatytas taisykles','Taikoma mokėjimams susijusiems asmenims mažų mokesčių šalyse']],
    salReorgRows: [['— SUSIJUNGIMAS (§ 11-2/11-3) —',''],['Akcinės bendrovės (§ 11-2)','Neapmokestinama, kai susijungimas atitinka Akcinių bendrovių įstatymo 13 sk.','Dvi ar daugiau UAB sujungiamos be mokesčių'],['Kooperatyvai (§ 11-2(2))','Neapmokestinama pagal Kooperatyvų įstatymo 8 sk.'],['Dalyvių bendrovės (§ 11-3)','Neapmokestinama esant tai pačiai bendrovės ir atsakomybės formai','Dalyviai turi gauti dalis kaip atlygį (maks. 20% papildomai grynaisiais)'],['— PADALIJIMAS (§ 11-4/11-5) —',''],['Akcinės bendrovės (§ 11-4)','Neapmokestinama, kai padalijimas atitinka Akcinių bendrovių įstatymo 14 sk.','Bendrovė padalijama į dvi ar daugiau be mokesčių'],['Dalyvių bendrovės (§ 11-5)','Neapmokestinama esant tai pačiai bendrovės ir atsakomybės formai','Maks. 20% atlygio gali būti ne dalimis'],['— SĄLYGOS IR PRINCIPAI —',''],['Kitas atlygis (§ 11-6)','Grynųjų atlygis akcininkui yra apmokestinamas','Tik besijungiančių bendrovių akcijos/dalys yra neapmokestinamos'],['Tęstinumas (§ 11-7)','Mokestinės vertės ir įsigijimo datos perkeliamos','Perėmusi bendrovė perima visas mokestines pozicijas nepakeistas'],['Paskirstymas padalijant (§ 11-8)','Mokestinės pozicijos paskirstomos pagal grynąsias vertes'],['Likvidavimas (§ 11-9)','Perleidžianti bendrovė turi būti likviduota po perleidimo'],['Įsigaliojimo data (§ 11-10)','Nuo bendrovių teisės įsigaliojimo momento'],['— TARPTAUTINIS (§ 11-11) —',''],['Susijungimas/padalijimas per sienas','Neapmokestinama EEE viduje su tęstinumu','Norvegijos UAB gali susijungti su kitos EEE valstybės bendrove'],['Akcijų mainai (§ 11-11(4))','Neapmokestinama perduodant mažiausiai 90% akcijų','Maks. 20% grynųjų atlygio'],['Mažų mokesčių šalis (§ 11-11(7))','Atleidimas netaikomas prieš mažų mokesčių šalis','Išimtis, jei realiai įsteigta EEE valstybėje'],['— PERTVARKYMAS (§ 11-20) —',''],['Į akcinę bendrovę','Individualios įmonės, ūkinės bendrijos ir kt. gali būti pertvarkytos neapmokestinamai','Mokestinės vertės ir pozicijos perkeliamos'],['Koncerno perkėlimas (§ 11-21)','Neapmokestinamas perkėlimas tarp tos pačios grupės bendrovių','Patronuojanti bendrovė turi valdyti daugiau nei 90% akcijų'],['Racionalizavimas (§ 11-22)','Ministerija gali suteikti mokestinį atleidimą reorganizuojant','Taikoma nekilnojamojo turto, verslo ar akcijų pardavimui']],
    salKeyRows: [['— DARBAS, KAPITALAS AR VERSLAS? —','§ 5-1: Kodėl riba tarp jų nulemia jūsų mokestį'],['Darbo pajamos','Asmeninis darbas kitiems. Atlyginimas, honorarai, natūrinės išmokos. Duoda asmenines pajamas → progresinį mokestį + įmokas (7,6%).','§ 5-10'],['Kapitalo pajamos','Grąža iš to, ką turite — palūkanos, dividendai, nuoma, akcijų prieaugis. Tik 22%.','§ 5-20'],['Verslo pajamos','Mokesčių įstatymas neapibrėžia «verslo» tiesiogiai. Keturi kriterijai:'],['1. Trukmė','Veikla turi turėti tam tikrą trukmę — ne tik vienkartinis pardavimas.'],['2. Apimtis','Turi būti tam tikra apimtis. Vienas nuomojamas būstas = kapitalas. Dešimt su aktyvia valdymu = verslas.'],['3. Gebėjimas pelno','Veikla turi objektyviai galėti būti pelninga.'],['4. Savo rizika','Pats prisiimate finansinę riziką. Skiria verslą nuo darbo.'],['Kodėl tai svarbu?','Individualus verslas duoda asmenines pajamas → progresinį mokestį + įmokas. Kapitalas duoda tik 22%.'],['Tipinė pilkoji zona?','Nekilnojamojo turto nuoma. Mažai objektų = kapitalas. Daug su aktyvia valdymu = verslas.'],['— REALIZACIJOS SĄVOKA —','§ 9-2: Kas sukelia mokestį — ir kas ne?'],['Kas yra realizacija?','Nuosavybės teisės perleidimas už atlygį: pardavimas, mainai, išpirkimas, nusavinimas, sunaikinimas.','§ 9-2(1)'],['Kas NĖRA realizacija?','Dovana, paveldėjimas, dalijimas skyrybose, perleidimas tarp sutuoktinių.','§ 9-2(3)'],['Būsto taisyklė?','Savo būsto pardavimas atleistas: turėjimas min. 1 metai ir gyvenimas 1 iš 2 metų. Poilsio: 5 metai, naudojimas 5/8.','§ 9-3(2)/(4)'],['Simetrijos principas?','Nuostolis atskaitomas lygiai tokiu mastu, kokiu pelnas būtų apmokestintas.','§ 9-4'],['Paveldėjimas ir dovana — tęstinumas?','Gavėjas perima palikėjo/dovanos teikėjo pradinę vertę. Mokesčio nėra gavus, bet būsimas pelnas skaičiuojamas nuo pradinės kainos.','§ 9-7'],['Išimtis: palikėjas galėjo parduoti be mokesčio?','Pradinė vertė = rinkos vertė mirties dieną — palankiau paveldėtojui.','§ 9-7(2)'],['— PRADINĖ VERTĖ —','Ką «sumokėjote» mokestine prasme'],['Kas yra pradinė vertė?','Suma, nuo kurios matuojamas pelnas ar nuostolis parduodant. Paprastai: pirkimo kaina + išlaidos. Akcijoms: taip pat nepanaudota lengvata.','§ 9-7, § 10-32'],['Kodėl svarbu?','Pelnas = pardavimo kaina minus pradinė vertė. Neteisinga vertė = neteisingas mokestis.'],['Paveldėjimas/dovana?','Periate pradinę vertę (tęstinumas). Nėra «nustatymo iš naujo» į rinkos vertę. Išimtis: palikėjas galėjo parduoti be mokesčio.','§ 9-7'],['Akcijos?','Pirkimo kaina + sandorio išlaidos + nepanaudota lengvata. FIFO nustato pardavimo tvarką.','§ 10-32, § 10-36'],['Būstas?','Pirkimo kaina + žyminis mokestis + pagerinimas (ne priežiūra).','§ 9-3'],['Nusidėvėjimas?','Verslo turto pradinė vertė mažinama mokestiniu nusidėvėjimu.','§ 6-10, § 14-40'],['— AKCININKŲ MODELIS —','§ 10-11 iki 10-12'],['Kaip apmokestinami dividendai?','Dividendai dauginami iš 1,72 ir apmokestinami 22%. Efektyvus mokestis: ~37,84%.','§ 10-11'],['Kas yra skjermingo lengvata?','Dividendų dalis, atitinkanti nerizikingą grąžą, yra atleista.','§ 10-12'],['Kodėl 1,72?','Kad bendras mokestis (įmonė + akcininkas) būtų atlyginimų mokesčio lygyje.'],['— ATLEIDIMO METODAS —','§ 2-38'],['Kas tai?','Įmonės nemoka mokesčio nuo dividendų ir pelno iš kitų įmonių.','§ 2-38'],['3% taisyklė?','Įmonė vis tiek pripažįsta 3% atleistų dividendų. Efektyvus mokestis: 0,66%.','§ 2-38(6)'],['Išimtys?','Netaikoma mažų mokesčių šalims ar dalims mažesnėms nei 10% ne EEE.','§ 2-38(3)'],['— GRUPĖS ĮNAŠAI —','§ 10-2 iki 10-5'],['Kas tai?','Pinigų pervedimas tarp grupės įmonių. Atskaitymas mokėtojui, mokestis gavėjui.','§ 10-2'],['Koks tikslas?','Sulyginti pelnus ir nuostolius grupėje teisingam bendram mokesčiui.'],['Reikalavimas?','Patronuojanti įmonė turi turėti daugiau nei 90% akcijų ir balsų.','§ 10-4'],['— NEAPMOKESTINAMAS JUNGIMAS IR SKAIDYMAS —','§ 11-2, § 11-4, § 11-7'],['Kada neapmokestinama?','Kai atliekama pagal bendrovių teisę su mokestiniu tęstinumu.','§ 11-2/11-4'],['Kas yra tęstinumas?','Perėmėja paveldi visas mokestines vertes nepakeistas.','§ 11-7'],['Kas gali nepavykti?','Piniginis atlygis = apmokestinimas. Nuostoliai gali išnykti (§ 13-3).'],['— ANTIVENGIAMAS —','§ 13-2'],['Kada taikomas?','Kai pagrindinis tikslas — mokestinė nauda ir sandoris neatlaikys bendro vertinimo.','§ 13-2(2)'],['Kas vertinama?','Verslo esmė, mokestinės naudos dydis, netinkamas kelias, naudojimas prieš taisyklių tikslą.','§ 13-2(3)'],['Pasekmė?','Sandoris apmokestinamas pagal tikrąjį turinį — ne formą.','§ 13-2(4)'],['Pavyzdys?','Tuščios įmonės pirkimas nuostoliams panaudoti. Nuostolis išnyksta pagal § 13-3.','§ 13-3'],['— TEISĖTUMO REIKALAVIMAS —','§ 11-1(2)'],['Kas tai?','Jungimas ir skaidymas turi būti teisėti trimis lygiais, kad būtų neapmokestinami.','§ 11-1(2)'],['Bendrovių teisė','Turi atitikti bendrovių įstatymą: jungimo planas, kreditorių pranešimas, visuotinio susirinkimo nutarimas, registracija.','Bendrovių įstatymas sk. 13/14'],['Mokesčių teisė (sk. 11)','Mokestinis tęstinumas, maks 20% grynaisiais, perleidžiančios bendrovės likvidavimas.','§ 11-7, § 11-6, § 11-9'],['PVM teisė','Jungimas/skaidymas atleistas (§ 6-14, 0% PVM). Bet koregavimo prievolės pereina naujam savininkui.','PVM įstatymas § 6-14, sk. 9'],['Praktikoje?','Visi trys lygiai turi sutapti. Klaida bendrovių teisėje veikia mokesčius ir PVM.']],
    salSubjRows: [['— ASMENINIS MOKESČIŲ MOKĖTOJAS (§ 2-1) —',''],['Gyvenantis Norvegijoje (§ 2-1(1))','Apmokestinamas už visas pajamas/turtą Norvegijoje ir užsienyje','Jei gyvenate Norvegijoje, mokate mokesčius nuo visko — nesvarbu, kur pasaulyje pajamos gaunamos'],['Gyvenamoji vieta nustatoma (§ 2-1(2))','Buvimas >183 dienos per 12 mėn., arba >270 dienų per 36 mėn.','Jei Norvegijoje praleidžiate pakankamai laiko, tampate mokestiniu rezidentu'],['Gyvenamoji vieta nutrūksta (§ 2-1(3))','Reikia nuolatinio gyvenimo užsienyje + atsisakyti būsto Norvegijoje','Turite nuolat gyventi užsienyje ir nebeturėti būsto Norvegijoje'],['Laikinas nebuvimas (§ 2-1(4))','Nenutraukia mokestinės rezidencijos','Atostogos ar trumpas buvimas užsienyje nekeičia jūsų rezidencijos'],['Svalbardas (§ 2-1(5))','Atskiras reglamentavimas (Svalbardo mokesčių įstatymas)'],['— PALIKIMAS (§ 2-2) —',''],['Palikimas (§ 2-2)','Atskiras mokesčių subjektas mirties metais ir toliau','Palikimas moka mokesčius kaip atskiras subjektas, kol bus atsiskaityta'],['Pasidalijimas mirties metais (§ 2-15)','Įpėdiniai perima nuo sausio 1 d.','Jei paveldėjimas paskirstytas mirties metais, įpėdiniai moka mokesčius už visus metus'],['— BENDROVĖS (§ 2-2) —',''],['Akcinė bendrovė (§ 2-2(1)a)','Atskiras mokesčių subjektas','AB yra savarankiškas mokesčių mokėtojas — moka 22% nuo pelno'],['Viešoji akcinė bendrovė (§ 2-2(1)b)','Atskiras mokesčių subjektas'],['Taupomasis bankas, savitarpio draudimas (§ 2-2(1)c-d)','Atskiras mokesčių subjektas'],['Kooperatyvas (§ 2-2(1)e)','Atskiras mokesčių subjektas'],['Valstybės įmonė, sveikatos įmonė (§ 2-2(1)g-h)','Atskiras mokesčių subjektas'],['Fondai (§ 2-2(1)f)','Atskiras mokesčių subjektas'],['Savivaldybės įmonė (§ 2-2(1)i)','Atskiras mokesčių subjektas'],['— RIBOTA MOKESTINĖ PRIEVOLĖ (§ 2-3) —',''],['Pajamos iš nekilnojamojo turto Norvegijoje (§ 2-3(1)a)','Apmokestinamos','Užsieniečiai, turintys nekilnojamojo turto Norvegijoje, moka pajamų mokestį'],['Verslo veikla Norvegijoje (§ 2-3(1)b)','Apmokestinamos','Jei vykdote verslą Norvegijoje, mokate mokesčius čia'],['Darbas Norvegijoje (§ 2-3(1)d)','Apmokestinamas','Jei dirbate Norvegijoje, mokate mokesčius nuo atlyginimo — taip pat užsieniečiai'],['Dividendai iš norvegų bendrovės (§ 2-3(1)c)','Šaltinio mokestis','Užsienio akcininkai moka šaltinio mokestį nuo dividendų iš norvegų bendrovių'],['Valdybos atlyginimai (§ 2-3(1)e)','Apmokestinami','Jei esate norvegų bendrovės valdybos narys, mokate mokesčius nuo atlyginio'],['Pensija iš Norvegijos (§ 2-3(4))','Apmokestinama (šaltinio mokestis)','Taip pat asmenims, gyvenantiems užsienyje'],['Atlikėjų mokestis (§ 2-3(1)h)','Apmokestinamas užsienio atlikėjams','Specialios taisyklės koncertams, pasirodymams ir pan.'],['— ATLEIDIMO METODAS (§ 2-38) —',''],['Neapmokestinama bendrovėms (§ 2-38(1))','Dividendai ir pelnas tarp bendrovių neapmokestinami','AB, turinti akcijų kitose AB, paprastai atleidžiama nuo dividendų ir pelno mokesčio'],['3% taisyklė (§ 2-38(6))','3% pajamų vis tiek apmokestinami','Bendrovė faktiškai moka 0.66% (3% × 22%) nuo atleistų dividendų'],['Mažų mokesčių šalių išimtis (§ 2-38(3))','Atleidimas netaikomas bendrovėms mažų mokesčių šalyse','Bendrovės labai mažų mokesčių šalyse nepatenka į atleidimo metodą'],['Portfelio išimtis EEE (§ 2-38(3)b)','Atleidimas netaikomas esant <10% nuosavybei ne EEE','Jei turite mažiau nei 10% bendrovės ne EEE, atleidimo metodas netaikomas'],['— SUTUOKTINIAI (§ 2-10 iki 2-16) —',''],['Bendras ar atskiras (§ 2-10)','Sutuoktiniai gali būti apmokestinami kartu arba atskirai','Galite rinktis, ar pajamos bus sujungtos, ar apmokestinamos atskirai'],['Paskirstymas (§ 2-11)','Pajamos/atskaitymai priskiriami atitinkamam sutuoktiniui'],['2 klasė (§ 2-14)','Išlaikantis sutuoktinį su mažomis pajamomis','Mažesnis mokestis, jei vienas sutuoktinis turi mažas arba jokias pajamas'],['Bendras būstas (§ 2-12)','Bendras apmokestinimas bendram būstui'],['— VAIKAI (§ 2-14) —',''],['Vaikai iki 17 metų (§ 2-14(1))','Vaikų pajamos apmokestinamos tėvams','Vaikų iki 17 metų kapitalo pajamos apmokestinamos tėvams'],['Vaikų darbo pajamos (§ 2-14(3))','Apmokestinamos pačiam vaikui','Vaiko paties uždirbtas atlyginimas apmokestinamas atskirai'],['Vaikų turtas (§ 2-14(5))','Padalijamas lygiomis dalimis tarp tėvų'],['— NEAPMOKESTINAMOS INSTITUCIJOS (§ 2-30 iki 2-32) —',''],['Valstybė (§ 2-30(1)a)','Neapmokestinama'],['Apskritys/savivaldybės (§ 2-30(1)b-c)','Neapmokestinamos'],['Bažnyčios (§ 2-30(1)d)','Neapmokestinamos'],['Nekomercinės institucijos (§ 2-32)','Neapmokestinamos, kol pajamos nėra komercinės','Draugijos, organizacijos ir fondai, nesiekiantys pelno, atleidžiami nuo mokesčių'],['Komercinė veikla (§ 2-32(2))','Apmokestinama viršijus 140 000 kr / 70 000 kr','Viršijus pardavimo, nuomos ir pan. pajamų ribą reikia mokėti mokesčius'],['— BENDROVIŲ REZIDENCIJOS TAISYKLĖS (§ 2-2(6)) —',''],['Registruota Norvegijoje','Visada norvegų mokesčių subjektas','Norvegijos įmonių registre registruotos bendrovės yra apmokestinamos Norvegijoje'],['Įsteigta Norvegijoje (§ 2-2(7))','Visada norvegų mokesčių subjektas'],['Valdymas Norvegijoje (§ 2-2(6))','Gali tapti norvegų mokesčių subjektu','Užsienio bendrovė, faktiškai valdoma iš Norvegijos, gali tapti apmokestinama čia'],['— BENDROVĖS IMIGRACIJA/EMIGRACIJA (§ 2-2(8)) —',''],['Imigracija (§ 2-2(8))','Pilna mokestinė prievolė nuo įsisteigimo Norvegijoje'],['Emigracija (§ 2-2(8))','Latentinių pelnų atsiskaitymas','Bendrovė turi atsiskaityti mokestines pozicijas, kai išvyksta iš Norvegijos'],['— TARPTAUTINIS (§ 2-37/2-38) —',''],['Kredito atskaitymas (§ 2-37)','Atskaitymas už užsienyje sumokėtą mokestį','Išvengiama dvigubo apmokestinimo — užsienio mokestis atskaitomas iš norvegų deklaracijos'],['Mokesčių sutartys','Gali apriboti Norvegijos apmokestinimo teisę','Norvegija turi sutartis su daugeliu šalių, nustatančias, kas moka kokį mokestį']],
    morReqRows: [['Maks. paskola','Bendra skola maks. 5× metinės pajamos','Visos skolos skaičiuojamos — būsto paskola, studijų paskola, auto paskola, kreditinė kortelė'],['Nuosavas kapitalas','Mažiausiai 10%','Turite sutaupyti mažiausiai 10% būsto kainos patys'],['Testavimas nepalankiausiomis sąlygomis','Didžiausias iš 7% ir palūkanos + 3 pp','Bankas tikrina, ar galite sau leisti net jei palūkanos pakiltų'],['Įmokos','Reikalavimas virš 60% įkeitimo','Jei skolinote daugiau nei 60% būsto vertės, turite mokėti įmokas'],['Lankstumo kvota','Bankas gali nukrypti 10% paskolų','Vilniuje: max 8% — reiškia, kad bankas gali pasakyti „taip", net jei neviskas atitinka reikalavimus']],
    morCostRows: [['Palūkanos dabar','Apie 5,1% kintamos (2026 m. sausis)'],['Mokesčių atskaitymas','22% nuo palūkanų išlaidų','Gaunate 22% grąžą nuo sumokėtų palūkanų mokesčiuose'],['Dokumentų mokestis','Paprastai 2,5% nuo rinkos vertės','Mokamas perkant nekilnojamąjį turtą — gali būti taikomos išimtys']],
    morBsuRows: [['Maks. metinė taupyba','27 500 kr'],['Maks. bendras dydis','300 000 kr'],['Mokesčių atskaitymas','10% nuo sumokėtos sumos — iki 2 750 kr/metams'],['Amžiaus riba','Iki ir įskaitant metus, kai sulauki 33 metų'],['Mokesčių atskaitymo sąlyga','Turite turėti apmokestinamų darbo pajamų ir negyventi savo namų/bute'],['Kam galima panaudoti pinigus?','Pirkti, grąžinti, pagerint arba tvarkyti savo namą/butą'],['Sąlygų pažeidimas?','Jei panaudojate pinigus kitam tikslui nei būstui, turite grąžinti visus mokesčių atskaitymus']],
    morBsuTitle:'BSU — Būsto taupyba jauniems žmonėms', morBsuDesc:'Mokesčių atskaitymas, taupymo ribos, amžiaus riba, naudojimo sąlygos',
    morReqTitle:'Būsto paskolos reikalavimai', morReqDesc:'Nuosavas kapitalas, skolos santykis, streso testas, įmokos',
    morCostTitle:'Nuosavybės pirkimo kaštai', morCostDesc:'Palūkanos, mokesčių atskaitymas, dokumentų mokestis',
    npvInfoRows: [['— TERMINŲ ŽODYNAS —',''],['NPV (grynoji dabartinė vertė)','Būsimų pinigų srautų dabartinė vertė minus investicija'],['IRR (vidinė grąžos norma)','Palūkanų norma, kuri duoda NPV = 0'],['WACC','Svertinis vidutinis kapitalo kaštai'],['— INTERPRETACIJA —',''],['NPV > 0','Pelninga – priimkite investiciją'],['NPV < 0','Nepelninga – atmeskite'],['IRR > WACC','Vertę kuriantis projektas'],['IRR < WACC','Vertę naikinantis projektas'],['— NUORODA —',''],['Diskonto norma','Paprastai WACC (prieš mokesčius)'],['Tipinis WACC','8–12%'],['Atsipirkimo laikotarpis','Trumpesnis yra geriau']],
    vatSubjRows: [['— PAGRINDINĖS SĄLYGOS —','Trys dalykai turi būti įvykdyti PVM atsakomybei'],['1. Verslo veikla','Turite vykdyti verslo veiklą — ne hobį ar darbo santykį','§ 2-1(1)'],['2. Prekių/paslaugų tiekimas','Turi būti sandoris — tiekimas už atlygį (mokėjimas)','§ 1-3(1)a'],['3. Apyvartos riba','Apyvarta viršijanti 50 000 kr per 12 mėnesių','§ 2-1(1)'],['— KAS PRIVALO REGISTRUOTIS? —',''],['Verslo subjektai virš 50 000 kr','Privalo registruotis PVM registre','§ 2-1(1)'],['Labdaros org.','Aukštesnė riba: 140 000 kr','§ 2-1(1)'],['Sporto renginiai','Atskira riba: 3 000 000 kr','§ 2-1(1)'],['— PAGRINDINĖS SĄVOKOS —',''],['Kas yra « verslo veikla »?','Savarankiška, nuolatinė ekonominio pobūdžio veikla, galinti duoti pelno. Hobiai ir vienkarinės užduotys paprastai nėra verslas.'],['Kas yra « apyvarta »?','Prekių ar paslaugų tiekimas už atlygį. Dovanos, atlyginimas ir dotacijos paprastai nėra apyvarta.','§ 1-3(1)a'],['Kas yra « PVM subjektas »?','Subjektas, užsiregistravęs (arba turėtų būti užsiregistravęs) PVM registre, privalantis skaičiuoti ir mokėti PVM.','§ 1-3(1)d'],['Savanoriška registracija?','Komercinės paskirties nekilnojamojo turto savininkai gali savanoriškai registruotis, kad gautų įvestės PVM atskaitymą.','§ 2-3']],
    vatSubjTitle:'Kas yra PVM subjektas?', vatSubjDesc:'Verslo veikla · Apyvartos riba · Registracijos pareiga',
    vatRates: [['25','25% Standartinis – prekės ir paslaugos (§ 5-1)'],['15','15% Maisto produktai (§ 5-2)'],['12','12% Transportas, viešbutis, kinas (§ 5-3/5-5/5-6)'],['0','0% Atleista – laikraščiai, knygos, eksportas (6 sk.)']],
    vatInfoRows: [['— TARIFAI —',''],['Standartinis tarifas (§ 5-1)','25%'],['Maisto produktai (§ 5-2)','15%'],['Keleivių transportas (§ 5-3)','12%'],['Viešbučio kambarių nuoma (§ 5-5)','12%'],['Kinas (§ 5-6)','12%'],['Muziejai/galerijos (§ 5-9)','12%'],['Pramogų parkai (§ 5-10)','12%'],['Sporto renginiai (§ 5-11)','12%'],['Vanduo/nuotekos (§ 5-12)','12%'],['Maitinimo paslaugos (§ 5-2)','25% (ne 15%)'],['— REGISTRACIJA —',''],['Verslo subjektai (§ 2-1)','50 000 kr / 12 mėn.'],['Labdaros org. (§ 2-1)','140 000 kr / 12 mėn.'],['Sporto renginiai (§ 2-1)','3 000 000 kr'],['— TERITORIJA —',''],['Geografinė (§ 1-2)','Norvegijos žemyninė dalis + teritorinė riba'],['Ne PVM teritorija','Svalbardas, Jan Majenas, priklausomos teritorijos']],
    vatLawRows: [['— NEAPMOKESTINAMOS (3 sk.) —','Už įstatymo ribų, be atskaitymo teisės'],['Sveikatos paslaugos (§ 3-2)','Neapmokestinamos','Gydytojas, odontologas, fizioterapija ir pan. — be PVM ir be atskaitymo teisės'],['Socialinės paslaugos (§ 3-4)','Neapmokestinamos','Vaiko teisių apsauga, vyresnio amžiaus priežiūra, priklausomybių gydymas ir pan.'],['Švietimas (§ 3-5)','Neapmokestinamas','Mokykla, kursai, mokymas — tiek viešas, tiek privatus'],['Finansinės paslaugos (§ 3-6)','Neapmokestinamos','Bankas, draudimas, vertybinių popierių prekyba — be PVM'],['Menas/kultūra – pasirodymai (§ 3-7)','Neapmokestinami','Koncertas, teatras, šokis — bilietai be PVM'],['Sportas – teisė užsiimti (§ 3-8)','Neapmokestinamas','Sporto salė, futbolo aikštė, baseinas ir pan.'],['Viešosios valdžios funkcijos (§ 3-9)','Neapmokestinamos'],['Nekilnojamasis turtas/nuoma (§ 3-11)','Neapmokestinamas (išimtis (2) d.)','Būsto ir komercinės paskirties nuoma neapmokestinama — bet galima savanoriška registracija verslui'],['Labdaros org. (§ 3-12)','Neapmokestinamos (tam tikras pardavimas)','Mugės, labdaros pardavimai ir pan. iš labdaros organizacijų'],['Ideologinių org. mokestis (§ 3-13)','Neapmokestinamas'],['Lošimai (§ 3-14)','Neapmokestinami'],['Laidotuvės – ceremonija (§ 3-15)','Neapmokestinamos'],['Valdybos atlyginimai (§ 3-17)','Neapmokestinami (su DGA)','Valdybos atlyginimai neapmokestinami PVM, bet mokamas darbdavio socialinis mokestis'],['Privačiai naudotos prekės (§ 3-19)','Neapmokestinamos','Privatūs asmenys, parduodantys naudotus daiktus, neprivalo skaičiuoti PVM'],['— ATLEISTA (6 sk.) —','Pagal įstatymą, 0% pardavimo PVM, su atskaitymo teise'],['Laikraščiai (§ 6-1)','Atleista'],['Žurnalai (§ 6-3)','Atleista (paskutinė dalis)'],['Knygos (§ 6-4)','Atleista (paskutinė dalis)'],['Elektra namų ūkiams Šiaurės Norvegijoje (§ 6-6)','Atleista'],['Elektromobilis ≤300 000 kr (§ 6-8)','Atleista','Taikoma tik pirkimo sumai iki 300 000 kr — virš šios sumos taikomas 25% PVM'],['Laivai ≥15 m (§ 6-9)','Atleista'],['Orlaiviai verslui (§ 6-10)','Atleista'],['Verslo perleidimas (§ 6-14)','Atleista','Parduodant visą verslą kartu, PVM istorija perkeliama — pardavimas be PVM'],['Prekių eksportas (§ 6-21)','Atleista','Eksportas į užsienį — 0% PVM, bet pilna pirkimo PVM atskaitymo teisė'],['Paslaugų eksportas (§ 6-22)','Atleista'],['Transportas į/iš užsienio (§ 6-28)','Atleista'],['— PAĖMIMAS (3 sk. II d.) —',''],['Prekių paėmimas (§ 3-21)','PVM privalomas','Jei imate prekes iš įmonės asmeniniam naudojimui, turite skaičiuoti PVM'],['Paslaugų paėmimas privačiam naudojimui (§ 3-22)','PVM privalomas'],['Maistas/natūrinė produkcija/repr. (§ 3-23)','PVM privalomas'],['— IMPORTAS (3 sk. III d.) —',''],['Importuotos prekės (§ 3-29)','PVM privalomas','Prekių importas — PVM skaičiuojamas muitinėje'],['Nuotolinės paslaugos (§ 3-30)','Atvirkštinis apmokestinimas','Perkant skaitmenines paslaugas iš užsienio, PVM skaičiuojate patys']],
    vatDefRows: [['Apyvarta (a)','Prekių/paslaugų tiekimas už atlygį','Mainant ką nors už pinigus, tai yra apyvarta'],['Prekės (b)','Fiziniai daiktai, nekilnojamasis turtas, elektra, vanduo, dujos, šiluma, šaltis'],['Paslaugos (c)','Viskas, kas gali būti parduodama ir nėra prekės','Konsultacijos, kirpykla, transportas, remontas ir pan.'],['PVM subjektas (d)','Registruotas/privalantis registruotis PVM registre','Įmonės su apyvarta virš 50 000 kr per 12 mėnesių'],['Pardavimo PVM (e)','Skaičiuojamas ir mokamas pardavus ir paėmus','PVM, kurį pridedate prie kainos ir surenkate iš kliento'],['Pirkimo PVM (f)','Sumokėtas perkant ar importuojant','PVM, kurį mokate pirkdami prekes/paslaugas įmonei'],['Išimtis iš įstatymo (g)','Apyvarta nepatenka į įstatymą → be atskaitymo teisės','Įmonė negali atskaityti PVM už pirkimus, susijusius su neapmokestinama apyvarta'],['Atleidimas nuo PVM (h)','Patenka į įstatymą, bet 0% pardavimo PVM → pilna atskaitymo teisė','Eksportas atleistas — nepridedate PVM, bet galite atskaityti pirkimo PVM'],['Nuotolinės paslaugos (i)','Nesusietos su konkrečia fizine vieta','IT paslaugos, konsultacijos internetu, transliavimas ir pan.'],['Elektroninės paslaugos (j)','Nuotolinės, teikiamos internetu, automatizuotos','Programėlės, e. knygos, transliavimo paslaugos, internetiniai kursai']],
    vatDedRows: [['Pagrindinė taisyklė (§ 8-1)','Pirkimo PVM atskaitymas naudojimui registruotoje veikloje','Gaunate PVM grąžą už viską, ką perkate įmonės reikmėms'],['Mišrus naudojimas (§ 8-2)','Proporcinis atskaitymas pagal numatomą naudojimą','Jei naudojama 60% verslui ir 40% asmeniškai, gaunate 60% atskaitymą'],['Be atskaitymo: maitinimas (§ 8-3 a)','','Maistas ir gėrimai darbuotojams, klientams ir pan.'],['Be atskaitymo: reprezentacija (§ 8-3 e)','','Klientų vakarienės, renginiai verslo partneriams'],['Be atskaitymo: dovanos (§ 8-3 f)','Ne mažareikšmės vertės','Dovanos virš mažareikšmės ribos nesuteikia atskaitymo'],['Be atskaitymo: būstas/socialinė gerovė (§ 8-3 g)','Išimtis: įmonės valgyklos'],['Lengvasis automobilis (§ 8-4)','Be atskaitymo (išimtis: nuoma, taksi, pardavimas)','Tarnybinis automobilis nesuteikia PVM atskaitymo, nebent naudojamas nuomai ar keleivių pervežimui'],['Mokėjimas per banką (§ 8-8)','Reikalavimas esant ≥10 000 kr','Grynieji mokėjimai virš 10 000 kr nesuteikia PVM atskaitymo']],
    vatAdjRows: [['Kapitalo prekė – ilgalaikis turtas (§ 9-1 a)','Pirkimo PVM ≥50 000 kr','Mašinos, transporto priemonės ir pan. su PVM virš 50 000 kr'],['Kapitalo prekė – nekilnojamasis turtas (§ 9-1 b)','Pirkimo PVM ≥100 000 kr','Pastatai, statiniai ir pan. su PVM virš 100 000 kr'],['Koregavimo laikotarpis ilgalaikiam turtui (§ 9-4)','5 metų','Pasikeitus naudojimui per ateinančius 5 metus, PVM atskaitymas koreguojamas'],['Koregavimo laikotarpis nekilnojamam turtui (§ 9-4)','10 metų','Pasikeitus naudojimui per ateinančius 10 metų, PVM atskaitymas koreguojamas']],
    vatCalcRows: [['Pagrindinė taisyklė (§ 4-1)','Atlygis be PVM'],['Mainai (§ 4-3)','Įprastinė rinkos vertė','Mainų atveju PVM pagrindas yra rinkos kaina'],['Susijusios šalys (§ 4-4)','Ne mažiau nei įprastinė rinkos vertė','Parduodant pigiai savo bendrovei, PVM skaičiuojamas nuo rinkos kainos'],['Nuostolis dėl reikalavimo (§ 4-7)','Galima koreguoti galutinai prarastą reikalavimą','Klientas niekada nesumokėjo — galite susigrąžinti sumokėtą PVM']],
    vatRegRows: [['Bendra registracija (§ 2-2)','≥85% nuosavybės, solidarioji atsakomybė','Koncerno bendrovės gali būti registruotos kaip vienas PVM subjektas'],['Savanoriška registracija nuomai (§ 2-3)','Pastatai/statiniai PVM registruotam nuomininkui','Nuomotojas gauna PVM atskaitymą už remontą/statybą, kai nuomininkas yra PVM registruotas'],['Išankstinė registracija (§ 2-4)','Reikšmingi pirkimai prieš apyvartą','Naujai įkurta įmonė gali registruotis dar nepasiekusi 50 000 kr apyvartos']],
